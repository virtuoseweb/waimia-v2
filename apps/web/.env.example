# Waimia · apps/web · variables d'environnement
#
# Copier en `.env` (gitignored) et remplir :
#   cp .env.example .env
#
# Astro charge automatiquement `.env` dans `import.meta.env`.
# Préfixe `PUBLIC_*` → exposé au bundle client (Cal widget, etc.).
# Sans préfixe → server-only, accessible dans `src/pages/api/*` et SSR.
#
# Prod (Vercel) : ces clés sont set via dashboard Vercel
# `https://vercel.com/<team>/waimia-v2/settings/environment-variables`
# ou via `vercel env add` (cf skill `vercel:env-vars`).

# ─── Resend · transactional email ───────────────────────────────────
# Console : https://resend.com/api-keys
# La clé `re_*` doit être Production (pas Development) sur Vercel prod.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxx"

# Audience newsletter (Resend Audiences) — créer dans le dashboard
# https://resend.com/audiences
RESEND_AUDIENCE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Adresse expéditeur · doit être un domaine vérifié dans Resend (DKIM/SPF OK)
# Format RFC 5322 : "Nom Affichage <email@domaine>"
EMAIL_FROM="Waimia <hello@waimia.com>"

# Adresse reply-to (humaine, lue par l'équipe)
EMAIL_REPLY_TO="simon@waimia.com"

# Adresse interne pour alertes lead chaud / nouveau form
EMAIL_INTERNAL_TO="team@waimia.com"

# ─── Cal.com / Cal.diy · embed widget ───────────────────────────────
# Username Cal (slug avant `/event-type`) — visible dans l'URL booking
# Phase actuelle : Cal.com SaaS (waimia.cal.com/45min)
# Phase suivante : Cal.diy self-host (cal.waimia.com/waimia/45min)
PUBLIC_CAL_USERNAME="waimia"

# Event type slug (45min = séance diagnostique standard)
PUBLIC_CAL_EVENT_TYPE="45min"

# ─── Site · URL canonique ───────────────────────────────────────────
# Utilisée pour les liens dans les emails transactionnels
# Dev  : http://localhost:4321
# Prod : https://waimia.com
PUBLIC_SITE_URL="https://waimia.com"

# ─── Notion · sync content éditorial (optionnel) ────────────────────
# Token d'intégration interne — uniquement si pipeline Notion → Astro activé
# https://www.notion.so/profile/integrations
NOTION_TOKEN=""
