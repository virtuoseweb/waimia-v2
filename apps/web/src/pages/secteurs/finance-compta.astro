---
import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Comment automatiser la réconciliation bancaire avec l'IA ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Un agent analyse les relevés bancaires et les écritures comptables, identifie les correspondances et propose les rapprochements. Les cas clairs sont traités automatiquement. Les cas ambigus sont présentés au collaborateur pour validation. Temps moyen par dossier : 20 minutes au lieu de 2 jours. Aucun changement de logiciel comptable requis."
        }
      },
      {
        "@type": "Question",
        "name": "Combien coûte Claude for Excel pour un cabinet comptable ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "L'offre Starter Waimia (1 200€/mois) inclut Excel augmenté pour 5 utilisateurs — formules à la voix, modèles financiers, pivot auto. L'offre Growth (2 800€/mois) couvre réconciliation, reporting et mémos. ROI break-even observé : 3 à 4 mois selon la taille du cabinet."
        }
      },
      {
        "@type": "Question",
        "name": "L'IA respecte-t-elle les obligations CAC et la conformité française ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Oui. Human-in-the-loop obligatoire — aucune écriture n'est passée sans validation humaine. Données hébergées sur vos serveurs ou hébergement français (HDS si besoin). Traçabilité complète des décisions IA. Conformes RGPD et recommandations de l'Autorité de contrôle prudentiel. Documentation disponible sur demande."
        }
      },
      {
        "@type": "Question",
        "name": "Comment réduire le temps de clôture mensuelle de 9 à 3 jours ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En automatisant les 3 étapes les plus chronophages : réconciliation bancaire (20 min au lieu de 2 jours), génération des mémos variance (15 min au lieu de 5h) et consolidation des données multi-entités (1h au lieu de 2 jours). Ces 3 workflows représentent 70% du temps de clôture. Déployés en 4 à 6 semaines."
        }
      },
      {
        "@type": "Question",
        "name": "Quels gains pour un DAF d'ETI sur 12 mois ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "1 200h récupérées pour une équipe de 5 personnes — l'équivalent de 0,7 ETP. Clôture mensuelle en 3 jours ouvrés. Reporting CODIR automatisé. Audit CAC en 8 jours. Marge par centre de coût visible en J+1 au lieu de J+10. ROI médian 3,8× à 12 mois hors gains qualitatifs."
        }
      },
      {
        "@type": "Question",
        "name": "Faut-il changer de logiciel comptable pour utiliser l'IA ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Non. On se branche sur votre existant — Sage, Cegid, QuickBooks, Divalto ou environnement Excel. Les connecteurs MCP permettent aux agents de lire et d'écrire dans vos outils actuels. Changer de logiciel en même temps que déployer l'IA est l'erreur qui fait échouer 80% des projets."
        }
      },
      {
        "@type": "Question",
        "name": "L'IA peut-elle remplacer un contrôleur de gestion ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Non — et c'est la mauvaise question. L'IA remplace la partie mécanique : saisie, réconciliation, consolidation, mise en forme. Elle libère le contrôleur pour l'analyse, la recommandation, l'alerte stratégique. Nos clients DAF observent que leurs contrôleurs font enfin du contrôle de gestion — pas de la comptabilité."
        }
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Finance & Compta · IA pour cabinets et DAF PME · Waimia",
    "description": "IA pour cabinets comptables 5-50 pers et DAF de PME. Clôture 9j→3j, réconciliation auto −85%, audit 3 sem→8j. ROI 3,8× sur 12 mois.",
    "keywords": "IA cabinet comptable, automatisation clôture mensuelle, réconciliation bancaire IA, Excel augmenté finance"
  }
];
---

<Base
  title="Finance & Compta · IA pour cabinets et DAF PME · Waimia"
  description="IA pour cabinets comptables 5-50 pers et DAF de PME. Clôture 9j→3j, réconciliation auto −85%, audit 3 sem→8j. ROI 3,8× sur 12 mois."
  jsonLd={jsonLd}
>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="sec-hero">
    <div class="wrap">
      <Kicker tone="muted">§ Secteur · Finance &amp; Compta</Kicker>
      <h1 class="hero-h1">Clôture en 3 jours. <i>Excel qui parle.</i></h1>
      <p class="hero-sub">
        Pour cabinets comptables 5-50 personnes et fonctions finance d'entreprise.
        Réconciliation auto, audit en 8 jours, marge live.
      </p>

      <div class="hero-metrics">
        <div class="metric">
          <span class="metric-val">1 200h</span>
          <span class="metric-lbl">récupérées/an</span>
        </div>
        <div class="metric">
          <span class="metric-val">9j → 3j</span>
          <span class="metric-lbl">clôture mensuelle</span>
        </div>
        <div class="metric">
          <span class="metric-val">3 sem → 8j</span>
          <span class="metric-lbl">préparation audit</span>
        </div>
        <div class="metric">
          <span class="metric-val">3,8×</span>
          <span class="metric-lbl">ROI 12 mois</span>
        </div>
      </div>

      <div class="hero-actions">
        <a href="/contact" class="cta-primary">Activer Excel parlant →</a>
      </div>
      <p class="hero-icp">Cabinets comptables 5-50 pers · DAF PME 20-200 pers</p>
    </div>
  </section>

  <!-- ═══════════════ PROBLEM ═══════════════ -->
  <section class="sec-problem">
    <div class="wrap">
      <h2 class="sec-h2">
        Pourquoi les cabinets comptables perdent 40&nbsp;% de leur temps sur des tâches sans valeur ajoutée&nbsp;?
      </h2>
      <p class="answer-chunk">
        La saisie manuelle, la réconciliation bancaire et la préparation d'audit représentent 35 à 45&nbsp;% du temps
        d'un collaborateur comptable selon l'Ordre des Experts-Comptables 2025. Ce temps est consacré à des tâches
        reproductibles — les mêmes formules, les mêmes copier-coller, les mêmes tableaux assemblés à la main.
        L'analyse, le conseil et la valeur ajoutée attendent.
      </p>

      <div class="pain-grid">
        <div class="pain-card">
          <span class="pain-num">01</span>
          <h3 class="pain-title">Saisie manuelle chronophage</h3>
          <p class="pain-body">
            40&nbsp;% du temps en formules, copier-coller, recopie ligne par ligne.
            Un collaborateur senior à 45&nbsp;k€/an passe 18&nbsp;000€ de son temps à copier-coller.
          </p>
        </div>
        <div class="pain-card">
          <span class="pain-num">02</span>
          <h3 class="pain-title">Réconciliation bancaire</h3>
          <p class="pain-body">
            1 à 2 jours par collaborateur, par mois, par client.
            Sur 15 clients actifs&nbsp;: 30 jours de réconciliation pure par mois.
          </p>
        </div>
        <div class="pain-card">
          <span class="pain-num">03</span>
          <h3 class="pain-title">Mémos CODIR à la main</h3>
          <p class="pain-body">
            4-8h par document. Copy-paste depuis anciens mémos, reformulation selon le contexte.
            Pendant ce temps, le client attend sa variance.
          </p>
        </div>
        <div class="pain-card">
          <span class="pain-num">04</span>
          <h3 class="pain-title">Préparation audit CAC</h3>
          <p class="pain-body">
            3 semaines pour rassembler pièces justificatives, annoter, commenter.
            Chaque exercice fiscal, exactement le même travail.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ AGITATION ═══════════════ -->
  <section class="sec-agitation">
    <div class="wrap">
      <h2 class="sec-h2 agit-h2">Sans automatisation, voici votre cabinet dans 12 mois.</h2>
      <ul class="agit-list">
        <li>
          Vos concurrents qui ont automatisé la réconciliation servent 30&nbsp;% de clients de plus
          avec la même équipe. Vous recrutez pour suivre.
        </li>
        <li>
          Turnover cabinet&nbsp;: 22&nbsp;% en moyenne selon APEC 2025. Recrutement permanent,
          formation permanente, clients mécontents des changements.
        </li>
        <li>
          Selon Gartner Finance Automation 2026&nbsp;: les fonctions finance sans automatisation IA
          verront leur temps de clôture stagner tandis que leurs concurrents passeront sous 3 jours
          ouvrés d'ici 2027.
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════ SOLUTION ═══════════════ -->
  <section class="sec-solution">
    <div class="wrap">
      <h2 class="sec-h2">
        Comment Waimia réduit le temps de clôture mensuelle de 9 jours à 3 jours&nbsp;?
      </h2>
      <p class="answer-chunk">
        On audite vos flux actuels — saisie, réconciliation, reporting. On câble 3 à 4 agents
        directement dans votre environnement&nbsp;: Excel, Sage, Cegid, logiciel bancaire.
        L'agent de réconciliation rapproche les écritures en 20 minutes, soumet les cas ambigus
        à validation humaine. L'agent de reporting génère les mémos de variance depuis les chiffres bruts.
        Résultat&nbsp;: clôture en 3 jours ouvrés, collaborateurs sur l'analyse et le conseil.
        En savoir plus sur notre approche de <a href="/solutions/productivite-ia" class="inline-link">productivité</a>
        et de <a href="/solutions/crm-relances-ia" class="inline-link">suivi clients</a>.
      </p>

      <div class="table-wrap">
        <table class="workflows-table">
          <thead>
            <tr>
              <th>Workflow</th>
              <th>Gain</th>
              <th>Comment</th>
              <th>Outils</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Excel augmenté</td>
              <td>Formules à la voix</td>
              <td>Modèles financiers, tableaux croisés depuis instructions</td>
              <td>Claude for Excel + MCP Office</td>
            </tr>
            <tr>
              <td>Réconciliation bancaire</td>
              <td>−85&nbsp;% temps</td>
              <td>Rapprochement auto, cas ambigus soumis</td>
              <td>Claude Haiku + MCP banques</td>
            </tr>
            <tr>
              <td>Génération mémos variance</td>
              <td>−80&nbsp;% rédaction</td>
              <td>Chiffres → mémo CODIR en 15 min</td>
              <td>Claude Sonnet + Word/Google Docs</td>
            </tr>
            <tr>
              <td>Audit prep automatisé</td>
              <td>3 sem → 8j</td>
              <td>Pièces justificatives, commentaires, liasses</td>
              <td>Claude Sonnet + Files API</td>
            </tr>
            <tr>
              <td>Pilotage marge live</td>
              <td>Visible J+1</td>
              <td>Par dossier, par centre de coût</td>
              <td>Claude Opus + data layer</td>
            </tr>
            <tr>
              <td>Synthèse documents</td>
              <td>−70&nbsp;% lecture</td>
              <td>Contrats, conventions, mémoires résumés</td>
              <td>Claude Sonnet + Files API</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══════════════ PROOF ═══════════════ -->
  <section class="sec-proof">
    <div class="wrap">
      <h2 class="sec-h2">Résultats observés sur cabinets et fonctions finance</h2>

      <div class="proof-metrics">
        <div class="proof-cell">
          <span class="proof-val">1 200h</span>
          <span class="proof-lbl">récupérées/an (cabinet 15 collab)</span>
        </div>
        <div class="proof-cell">
          <span class="proof-val">9j → 3j</span>
          <span class="proof-lbl">clôture mensuelle</span>
        </div>
        <div class="proof-cell">
          <span class="proof-val">3 sem → 8j</span>
          <span class="proof-lbl">préparation audit CAC</span>
        </div>
        <div class="proof-cell">
          <span class="proof-val">3,8×</span>
          <span class="proof-lbl">ROI 12 mois</span>
        </div>
      </div>

      <blockquote>
        <p>
          «&nbsp;La réconciliation bancaire prenait 2 jours par collaborateur. Maintenant c'est 20 minutes
          et une relecture. L'équipe fait de l'analyse depuis.&nbsp;»
        </p>
        <cite>Expert-comptable associé, cabinet 22 collaborateurs, Lyon</cite>
      </blockquote>

      <p class="proof-links">
        Voir nos <a href="/cas/" class="inline-link">cas clients</a> ou découvrir l'<a href="/offres/starter" class="inline-link">offre Starter</a>.
      </p>
    </div>
  </section>

  <!-- ═══════════════ FAQ ═══════════════ -->
  <section class="sec-faq">
    <div class="wrap">
      <Kicker tone="muted">§ Questions fréquentes</Kicker>
      <h2 class="sec-h2">Finance &amp; Compta — ce qu'on nous pose comme questions</h2>

      <div class="faq-list">
        <details>
          <summary>Comment automatiser la réconciliation bancaire avec l'IA&nbsp;?</summary>
          <p>
            Un agent analyse les relevés bancaires et les écritures comptables, identifie les correspondances
            et propose les rapprochements. Les cas clairs sont traités automatiquement. Les cas ambigus sont
            présentés au collaborateur pour validation. Temps moyen par dossier&nbsp;: 20 minutes au lieu de
            2 jours. Aucun changement de logiciel comptable requis.
          </p>
        </details>

        <details>
          <summary>Combien coûte Claude for Excel pour un cabinet comptable&nbsp;?</summary>
          <p>
            L'<a href="/offres/starter" class="inline-link">offre Starter</a> Waimia (1&nbsp;200€/mois)
            inclut Excel augmenté pour 5 utilisateurs — formules à la voix, modèles financiers, pivot auto.
            L'offre Growth (2&nbsp;800€/mois) couvre réconciliation, reporting et mémos. ROI break-even
            observé&nbsp;: 3 à 4 mois selon la taille du cabinet.
          </p>
        </details>

        <details>
          <summary>L'IA respecte-t-elle les obligations CAC et la conformité française&nbsp;?</summary>
          <p>
            Oui. Human-in-the-loop obligatoire — aucune écriture n'est passée sans validation humaine.
            Données hébergées sur vos serveurs ou hébergement français (HDS si besoin). Traçabilité complète
            des décisions IA. Conformes RGPD et recommandations de l'Autorité de contrôle prudentiel.
            Documentation disponible sur demande.
          </p>
        </details>

        <details>
          <summary>Comment réduire le temps de clôture mensuelle de 9 à 3 jours&nbsp;?</summary>
          <p>
            En automatisant les 3 étapes les plus chronophages&nbsp;: réconciliation bancaire (20 min au lieu
            de 2 jours), génération des mémos variance (15 min au lieu de 5h) et consolidation des données
            multi-entités (1h au lieu de 2 jours). Ces 3 workflows représentent 70&nbsp;% du temps de clôture.
            Déployés en 4 à 6 semaines.
          </p>
        </details>

        <details>
          <summary>Quels gains pour un DAF d'ETI sur 12 mois&nbsp;?</summary>
          <p>
            1&nbsp;200h récupérées pour une équipe de 5 personnes — l'équivalent de 0,7 ETP. Clôture mensuelle
            en 3 jours ouvrés. Reporting CODIR automatisé. Audit CAC en 8 jours. Marge par centre de coût
            visible en J+1 au lieu de J+10. ROI médian 3,8× à 12 mois hors gains qualitatifs.
          </p>
        </details>

        <details>
          <summary>Faut-il changer de logiciel comptable pour utiliser l'IA&nbsp;?</summary>
          <p>
            Non. On se branche sur votre existant — Sage, Cegid, QuickBooks, Divalto ou environnement Excel.
            Les connecteurs MCP permettent aux agents de lire et d'écrire dans vos outils actuels. Changer de
            logiciel en même temps que déployer l'IA est l'erreur qui fait échouer 80&nbsp;% des projets.
          </p>
        </details>

        <details>
          <summary>L'IA peut-elle remplacer un contrôleur de gestion&nbsp;?</summary>
          <p>
            Non — et c'est la mauvaise question. L'IA remplace la partie mécanique&nbsp;: saisie, réconciliation,
            consolidation, mise en forme. Elle libère le contrôleur pour l'analyse, la recommandation, l'alerte
            stratégique. Nos clients DAF observent que leurs contrôleurs font enfin du contrôle de gestion —
            pas de la comptabilité.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══════════════ CTA FINAL ═══════════════ -->
  <section class="sec-cta-final">
    <div class="wrap">
      <h2 class="cta-final-h2">Activer la clôture en 3 jours. Cette semaine.</h2>
      <p class="cta-final-sub">
        Votre prochain mois de clôture commence dans quelques semaines. L'audit Waimia prend
        1 journée et chiffre le gain avant tout engagement.
      </p>
      <div class="cta-final-actions">
        <a href="/contact" class="cta-primary">Démarrer l'audit →</a>
        <a href="/offres" class="cta-secondary">Voir les offres →</a>
      </div>
    </div>
  </section>

  <CtaBand />

</Base>

<style>
  /* ── tokens ── */
  :root {
    --paper: #F6F1E8;
    --paper-2: #EFE9DD;
    --ink: #0C0B09;
    --accent: #C94F2E;
    --muted: #6B6560;
    --font-display: "Instrument Serif", Georgia, serif;
    --font-sans: "Inter Tight", system-ui, sans-serif;
    --font-mono: "JetBrains Mono", "Courier New", monospace;
    --wrap: 1440px;
    --gut: 32px;
    --hairline: 1px solid rgba(12,11,9,.12);
    --ease: cubic-bezier(.4,0,.2,1);
  }

  /* ── layout ── */
  .wrap {
    max-width: var(--wrap);
    margin-inline: auto;
    padding-inline: var(--gut);
  }

  /* ── shared headings ── */
  .sec-h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 400;
    line-height: 1.2;
    margin-bottom: 2rem;
  }

  /* ── inline links ── */
  .inline-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .inline-link:hover { opacity: .75; }

  /* ══════════════════════════════════════
     HERO
  ══════════════════════════════════════ */
  .sec-hero {
    background: var(--paper);
    padding: 7rem 0 5rem;
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 5rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -.02em;
    margin: 1rem 0 1.5rem;
    max-width: 18ch;
  }
  .hero-h1 i { font-style: italic; color: var(--accent); }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    color: var(--muted);
    max-width: 52ch;
    line-height: 1.6;
    margin-bottom: 3rem;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--hairline);
    border: var(--hairline);
    margin-bottom: 3rem;
    max-width: 860px;
  }

  .metric {
    background: var(--paper);
    padding: 1.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }

  .metric-val {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-style: italic;
    color: var(--accent);
    line-height: 1;
  }

  .metric-lbl {
    font-family: var(--font-mono);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .hero-icp {
    font-family: var(--font-mono);
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
  }

  /* ── CTAs ── */
  .cta-primary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: var(--ink);
    color: var(--paper);
    font-family: var(--font-sans);
    font-size: .9rem;
    font-weight: 600;
    padding: .85rem 1.75rem;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity .18s var(--ease);
  }
  .cta-primary:hover { opacity: .82; }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    background: transparent;
    color: var(--ink);
    font-family: var(--font-sans);
    font-size: .9rem;
    font-weight: 600;
    padding: .85rem 1.75rem;
    border-radius: 999px;
    border: 1.5px solid var(--ink);
    text-decoration: none;
    transition: opacity .18s var(--ease);
  }
  .cta-secondary:hover { opacity: .65; }

  /* ══════════════════════════════════════
     PROBLEM
  ══════════════════════════════════════ */
  .sec-problem {
    background: var(--paper-2);
    padding: 6rem 0;
  }

  .answer-chunk {
    font-family: var(--font-sans);
    font-size: clamp(.95rem, 1.4vw, 1.1rem);
    line-height: 1.75;
    color: var(--ink);
    max-width: 72ch;
    margin-bottom: 3.5rem;
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--hairline);
    border: var(--hairline);
  }

  .pain-card {
    background: var(--paper-2);
    padding: 2.5rem 2rem;
    display: flex;
    flex-direction: column;
    gap: .75rem;
    transition: background .2s var(--ease);
  }
  .pain-card:hover { background: var(--paper); }

  .pain-num {
    font-family: var(--font-display);
    font-size: 2.8rem;
    font-style: italic;
    color: var(--accent);
    line-height: 1;
  }

  .pain-title {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
  }

  .pain-body {
    font-family: var(--font-sans);
    font-size: .9rem;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ══════════════════════════════════════
     AGITATION
  ══════════════════════════════════════ */
  .sec-agitation {
    background: var(--ink);
    color: var(--paper);
    padding: 6rem 0;
  }

  .agit-h2 { color: var(--paper); }

  .agit-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 2px solid var(--accent);
