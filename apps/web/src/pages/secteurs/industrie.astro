---
import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Industrie & PMI · IA pour PME industrielles 50-500 pers · Waimia",
  "description": "ERP connectés, maintenance prédictive et OEE amélioré pour PME industrielles 50-500 pers. 1 200h/an récupérées, ROI 3,8× sur 12 mois.",
  "url": "https://waimia.fr/secteurs/industrie",
  "mainEntity": {
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Comment connecter plusieurs ERP en industrie sans tout migrer ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Via des connecteurs MCP qui lisent vos ERP en lecture seule. Vos données restent dans SAP, Sage ou Cegid — rien ne bouge. Un orchestrateur IA unifie les flux pour créer une vue consolidée. Déploiement sans interruption de production. Aucune migration requise, aucun risque sur vos données historiques."
        }
      },
      {
        "@type": "Question",
        "name": "Combien coûte la maintenance prédictive pour une PMI ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Entre 8 000€ et 25 000€ selon le parc machines et le nombre de capteurs. Le ROI est mesurable dès le premier arrêt évité. Break-even médian : 4 à 6 mois. Une PMI de 100 personnes évite en moyenne 3 arrêts majeurs par an — soit 280 k€ économisés sur l'exercice."
        }
      },
      {
        "@type": "Question",
        "name": "Quel ROI sur l'IA en industrie sur 12 mois ?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "3,8× en médiane sur nos clients PMI. Ce chiffre combine les gains sur les arrêts évités, le temps documentaire récupéré, la réduction des retraitements qualité et la vélocité administrative. Premiers gains visibles dès 90 jours. Pleine valeur atteinte à 6-12 mois selon la complexité du déploiement."
        }
      }
    ]
  }
};
---

<Base
  title="Industrie & PMI · IA pour PME industrielles 50-500 pers · Waimia"
  description="ERP connectés, maintenance prédictive et OEE amélioré pour PME industrielles 50-500 pers. 1 200h/an récupérées, ROI 3,8× sur 12 mois."
  jsonLd={jsonLd}
>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="sec-hero">
    <div class="wrap">
      <Kicker tone="accent" class="hero-kicker">§ Secteur · Industrie & PMI</Kicker>
      <h1 class="hero-h1">Vos 3 ERP connectés.<br/><i>Vos arrêts, anticipés.</i></h1>
      <p class="hero-sub">
        Pilotage temps réel, maintenance prédictive et opérations fluidifiées
        pour PME industrielles 50-500 personnes.
      </p>

      <div class="hero-metrics">
        <div class="metric">
          <span class="metric-val">1 200h</span>
          <span class="metric-lbl">récupérées/an</span>
        </div>
        <div class="metric">
          <span class="metric-val">+12 pts</span>
          <span class="metric-lbl">OEE médian</span>
        </div>
        <div class="metric">
          <span class="metric-val">−72%</span>
          <span class="metric-lbl">temps clôture</span>
        </div>
        <div class="metric">
          <span class="metric-val">3,8×</span>
          <span class="metric-lbl">ROI 12 mois</span>
        </div>
      </div>

      <div class="hero-ctas">
        <a href="/contact" class="cta-primary">Connecter votre ERP →</a>
      </div>
      <p class="hero-icp">Pour PME industrielles 50-500 personnes — France</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROBLEM
  ═══════════════════════════════════════════ -->
  <section class="sec-problem">
    <div class="wrap">
      <Kicker>§ Diagnostic</Kicker>
      <h2 class="sec-h2">Pourquoi les PME industrielles perdent 4 à 7&nbsp;% de CA en arrêts non planifiés&nbsp;?</h2>

      <p class="answer-chunk">
        La maintenance réactive coûte 2 à 5 fois plus cher que la maintenance prédictive. Sur une PMI de 80 personnes,
        chaque heure d'arrêt non planifié représente en moyenne 4&nbsp;200€ de manque à gagner. Selon Gartner 2026,
        73&nbsp;% des PMI ont encore 3 ERP ou plus en silos — sans vue unifiée sur leurs opérations critiques.
      </p>

      <div class="pain-grid">
        <div class="pain-card">
          <div class="pain-num">01</div>
          <div class="pain-title">3-4 ERP non connectés</div>
          <p class="pain-body">
            Héritage d'acquisitions, données dispersées. Le DAF assemble des exports Excel à J+10.
            Pas de vue unifiée. Les décisions attendent.
          </p>
        </div>
        <div class="pain-card">
          <div class="pain-num">02</div>
          <div class="pain-title">Maintenance réactive</div>
          <p class="pain-body">
            Pannes = arrêts non planifiés. Médiane PMI : 4-7&nbsp;% de CA perdu
            en coûts d'arrêts directs et d'opportunité.
          </p>
        </div>
        <div class="pain-card">
          <div class="pain-num">03</div>
          <div class="pain-title">Qualité détectée trop tard</div>
          <p class="pain-body">
            Contrôle après production : rebuts, retraitements, retards clients.
            Coût moyen : 1,8&nbsp;% de CA selon INSEE 2025.
          </p>
        </div>
        <div class="pain-card">
          <div class="pain-num">04</div>
          <div class="pain-title">Documentation technique à la main</div>
          <p class="pain-body">
            Manuels, fiches process, modes opératoires rédigés ligne par ligne.
            40h par document pour un technicien senior.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       AGITATION
  ═══════════════════════════════════════════ -->
  <section class="sec-agitation">
    <div class="wrap">
      <Kicker tone="dim">§ Conséquences</Kicker>
      <h2 class="sec-h2 agit-h2">Sans IA industrielle, voici votre usine dans 12 mois.</h2>
      <ul class="agit-list">
        <li>
          Votre concurrent prédit ses pannes 14 jours à l'avance. Vous répondez à la vôtre
          avec zéro préavis. L'écart de coût de revient se creuse chaque mois.
        </li>
        <li>
          Recruter un coordinateur production pour combler les silos ERP : 55&nbsp;k€/an.
          Problème non résolu — les silos restent.
        </li>
        <li>
          Selon McKinsey AI in Manufacturing 2026 : les PMI qui n'automatisent pas le monitoring
          opérationnel avant 2027 subiront un désavantage compétitif structurel sur leurs coûts de revient.
        </li>
      </ul>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SOLUTION
  ═══════════════════════════════════════════ -->
  <section class="sec-solution">
    <div class="wrap">
      <Kicker>§ Méthode</Kicker>
      <h2 class="sec-h2">Comment Waimia connecte les ERP d'une PME industrielle sans migration&nbsp;?</h2>

      <p class="answer-chunk">
        On audite vos systèmes existants — SAP, Sage, Cegid, GPAO maison. On câble des connecteurs MCP entre
        vos sources de données et une couche d'agents. Aucune migration. Vos données restent où elles sont.
        Un agent unifie la vue opérationnelle, un autre analyse les capteurs pour prédire les pannes,
        un troisième génère la documentation technique à la demande. Opérationnel en 6 à 12 semaines.
        En savoir plus sur notre approche de <a href="/solutions/productivite-ia" class="inline-link">productivité opérationnelle</a>.
      </p>

      <div class="workflows-table-wrap">
        <table class="workflows-table">
          <thead>
            <tr>
              <th>Workflow</th>
              <th>Gain</th>
              <th>Comment</th>
              <th>Outils</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Connexion ERP unique</td>
              <td>Vue unifiée J+1</td>
              <td>Connecteurs SAP/Sage/Cegid → dashboard central</td>
              <td>Claude Opus + MCP ERP</td>
            </tr>
            <tr>
              <td>Maintenance prédictive</td>
              <td>−60% pannes</td>
              <td>Analyse capteurs IoT, alertes 7-14j avant</td>
              <td>Claude Haiku + MQTT/IoT</td>
            </tr>
            <tr>
              <td>Documentation technique auto</td>
              <td>−85% temps</td>
              <td>Specs → manuel/fiche process générés</td>
              <td>Claude Opus + Word/PDF</td>
            </tr>
            <tr>
              <td>Reporting industriel live</td>
              <td>OEE visible H+1</td>
              <td>Qualité, marges, OEE temps réel</td>
              <td>Claude Opus + data layer</td>
            </tr>
            <tr>
              <td>Triage qualité</td>
              <td>Détection continue</td>
              <td>Vision + capteurs → alerte ligne</td>
              <td>Claude Sonnet + Computer Vision</td>
            </tr>
            <tr>
              <td>Admin automatisé</td>
              <td>−70% temps devis/BL</td>
              <td>Devis, factures, BL en 1 clic</td>
              <td>Claude Haiku + Office</td>
            </tr>
          </tbody>
        </table>
      </div>

      <p class="solution-links">
        Voir aussi notre approche sur l'<a href="/solutions/acquisition-ia" class="inline-link">acquisition</a>
        et <a href="/offres/" class="inline-link">nos offres</a>.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PROOF
  ═══════════════════════════════════════════ -->
  <section class="sec-proof">
    <div class="wrap">
      <Kicker>§ Résultats</Kicker>
      <h2 class="sec-h2">Résultats observés sur PME industrielles</h2>

      <div class="proof-metrics">
        <div class="proof-cell">
          <span class="proof-val">1 200h</span>
          <span class="proof-lbl">récupérées/an (médiane)</span>
        </div>
        <div class="proof-cell">
          <span class="proof-val">+12 pts</span>
          <span class="proof-lbl">OEE (médiane 90j)</span>
        </div>
        <div class="proof-cell">
          <span class="proof-val">−72%</span>
          <span class="proof-lbl">temps clôture mensuelle</span>
        </div>
        <div class="proof-cell">
          <span class="proof-val">3,8×</span>
          <span class="proof-lbl">ROI 12 mois</span>
        </div>
      </div>

      <blockquote>
        « On avait 3 ERP qui ne se parlaient pas depuis 8 ans. En 10 semaines, la vue unifiée
        était en prod. Le DAF a arrêté ses exports Excel du dimanche. »
        <cite>— Directeur de production, ETI agroalimentaire 220 personnes, Lyon</cite>
      </blockquote>

      <p class="proof-cas">
        <a href="/cas/caserne" class="inline-link">Voir le cas client →</a>
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FAQ
  ═══════════════════════════════════════════ -->
  <section class="sec-faq">
    <div class="wrap">
      <Kicker>§ Questions fréquentes</Kicker>
      <h2 class="sec-h2">Ce qu'on nous demande.</h2>

      <div class="faq-list">
        <details>
          <summary>Comment connecter plusieurs ERP en industrie sans tout migrer&nbsp;?</summary>
          <div class="faq-body">
            Via des connecteurs MCP qui lisent vos ERP en lecture seule. Vos données restent dans SAP, Sage ou Cegid — rien ne bouge. Un orchestrateur IA unifie les flux pour créer une vue consolidée. Déploiement sans interruption de production. Aucune migration requise, aucun risque sur vos données historiques.
          </div>
        </details>

        <details>
          <summary>Combien coûte la maintenance prédictive pour une PMI&nbsp;?</summary>
          <div class="faq-body">
            Entre 8&nbsp;000€ et 25&nbsp;000€ selon le parc machines et le nombre de capteurs. Le ROI est mesurable dès le premier arrêt évité. Break-even médian : 4 à 6 mois. Une PMI de 100 personnes évite en moyenne 3 arrêts majeurs par an — soit 280&nbsp;k€ économisés sur l'exercice.
          </div>
        </details>

        <details>
          <summary>Quel ROI sur l'IA en industrie sur 12 mois&nbsp;?</summary>
          <div class="faq-body">
            3,8× en médiane sur nos clients PMI. Ce chiffre combine les gains sur les arrêts évités, le temps documentaire récupéré, la réduction des retraitements qualité et la vélocité administrative. Premiers gains visibles dès 90 jours. Pleine valeur atteinte à 6-12 mois selon la complexité du déploiement.
          </div>
        </details>

        <details>
          <summary>Faut-il une équipe data science pour déployer l'IA en industrie&nbsp;?</summary>
          <div class="faq-body">
            Non. Waimia livre des systèmes clés en main, documentés et transférables. Votre équipe n'a pas besoin de compétences IA. On forme 1 ou 2 référents internes en 2 jours. La maintenance courante s'effectue via interface — pas de code. Data scientist requis uniquement si vous développez en interne ensuite.
          </div>
        </details>

        <details>
          <summary>Comment l'IA peut-elle améliorer l'OEE d'une ligne de production&nbsp;?</summary>
          <div class="faq-body">
            En détectant les micro-arrêts et les dérives qualité avant qu'ils impactent la production. L'IA analyse les capteurs en temps réel, identifie les patterns annonciateurs de panne et déclenche des alertes 7 à 14 jours à l'avance. Sur nos clients PMI, l'OEE progresse de 8 à 15 points sur 12 mois.
          </div>
        </details>

        <details>
          <summary>Que se passe-t-il en cas de panne IT pendant la production&nbsp;?</summary>
          <div class="faq-body">
            Les systèmes Waimia fonctionnent en mode dégradé automatique. En cas de coupure réseau, l'agent bascule sur les dernières données locales et alerte l'opérateur humain. Aucun process de production n'est piloté automatiquement sans validation humaine. La couche IA est additive — vos ERP continuent de fonctionner indépendamment.
          </div>
        </details>

        <details>
          <summary>Quelle conformité IA Act pour l'industrie manufacturière&nbsp;?</summary>
          <div class="faq-body">
            Nos systèmes sont conçus avec human-in-the-loop — aucune décision critique (arrêt de ligne, modification process) sans validation humaine. Traçabilité complète de chaque décision IA documentée. Selon l'IA Act européen applicable en 2026, nos déploiements industriels tombent en catégorie risque faible à limité.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════════════ -->
  <section class="sec-cta-final">
    <div class="wrap">
      <Kicker>§ Démarrer</Kicker>
      <h2 class="sec-h2 cta-final-h2">Connecter votre parc. Récupérer les heures perdues.</h2>
      <p class="cta-final-sub">
        Votre prochain arrêt non planifié coûte en moyenne 4&nbsp;200€/heure.
        L'audit Waimia prend 2 jours et chiffre l'économie avant engagement.
      </p>
      <div class="cta-final-btns">
        <a href="/contact" class="cta-primary">Demander un audit ERP →</a>
        <a href="/cas/caserne" class="cta-secondary">Voir le cas Caserne →</a>
      </div>
    </div>
  </section>

  <CtaBand />

</Base>

<style>
  /* ─── Wrap ─── */
  .wrap {
    max-width: var(--wrap);
    margin-inline: auto;
    padding-inline: var(--gut);
  }

  /* ─── Typography helpers ─── */
  .sec-h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 5vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 400;
    text-wrap: balance;
    margin: 20px 0 clamp(32px, 4vw, 52px);
  }

  .answer-chunk {
    font-size: clamp(16px, 1.6vw, 19px);
    line-height: 1.65;
    color: var(--muted);
    max-width: 820px;
    margin-bottom: clamp(36px, 5vw, 64px);
  }

  .inline-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ─── CTAs ─── */
  .cta-primary {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 16px 36px;
    border-radius: 999px;
    border: 1px solid var(--ink);
    text-decoration: none;
    transition: background 220ms var(--ease), border-color 220ms var(--ease);
  }
  .cta-primary:hover { background: var(--accent); border-color: var(--accent); }

  .cta-secondary {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink);
    background: transparent;
    padding: 16px 36px;
    border-radius: 999px;
    border: 1px solid var(--ink);
    text-decoration: none;
    transition: background 220ms var(--ease), color 220ms var(--ease);
  }
  .cta-secondary:hover { background: var(--ink); color: var(--paper); }

  /* ─── Kicker global override ─── */
  :global(.hero-kicker),
  :global(.sec-hero .kicker),
  :global(.sec-hero [class*="kicker"]) {
    display: block;
    margin-bottom: 20px;
  }

  /* ═══════════════════════
     HERO
  ═══════════════════════ */
  .sec-hero {
    padding: 140px var(--gut) clamp(60px, 8vw, 100px);
    border-bottom: 1px solid var(--hairline);
  }

  .hero-h1 {
    font-family: var(--font-display);
    font-size: clamp(52px, 10vw, 140px);
    line-height: 0.94;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0 0 28px;
  }
  .hero-h1 i { font-style: italic; color: var(--accent); }

  .hero-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(18px, 2vw, 26px);
    color: var(--muted);
    max-width: 680px;
    line-height: 1.45;
    margin: 0 0 clamp(40px, 5vw, 64px);
    text-wrap: pretty;
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    margin-bottom: clamp(40px, 5vw, 64px);
    max-width: 860px;
  }

  .metric {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: clamp(20px, 2.5vw, 32px) clamp(16px, 2vw, 28px);
    background: var(--paper);
  }

  .metric-val {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 52px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--accent);
    font-style: italic;
  }

  .metric-lbl {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 20px;
  }

  .hero-icp {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
  }

  /* ═══════════════════════
     PROBLEM
  ═══════════════════════ */
  .sec-problem {
    background: var(--paper-2);
    padding: clamp(80px, 10vw, 128px) var(--gut);
    border-bottom: 1px solid var(--hairline);
  }

  .pain-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
  }

  .pain-card {
    background: var(--paper);
    padding: clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .pain-num {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 60px);
    line-height: 0.9;
    color: var(--accent);
    font-style: italic;
  }

  .pain-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 30px);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 4px 0 0;
  }

  .pain-body {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.65;
    margin: 0;
  }

  /* ═══════════════════════
     AGITATION
  ═══════════════════════ */
  .sec-agitation {
    background: var(--ink);
    color: var(--paper);
    padding: clamp(80px, 10vw, 128px) var(--gut);
    border-bottom: 1px solid var(--hairline);
  }

  .agit-h2 { color: var(--paper); }

  .agit-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 860px;
  }

  .agit-list li {
    padding: 28px 28px 28px 32px;
    border-left: 2px solid var(--accent);
    font-size: clamp(16px, 1.8vw, 19px);
    line-height: 1.65;
    color: color-mix(in srgb, var(--paper) 80%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--paper) 12%, transparent);
  }
  .agit-list li:last-child { border-bottom: none; }

  /* ═══════════════════════
     SOLUTION
  ═══════════════════════ */
  .sec-solution {
    padding: clamp(80px, 10vw, 128px) var(--gut);
    border-bottom: 1px solid var(--hairline);
  }

  .workflows-table-wrap {
    overflow-x: auto;
    margin-bottom: 24px;
    border: 1px solid var(--hairline);
  }

  .workflows-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14px;
  }

  .workflows-table th {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    padding: 14px 20px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--hairline);
    white-space: nowrap;
  }

  .workflows-table td {
    padding: 16px 20px;
    border-bottom: 1px solid var(--hairline);
    line-height: 1.5;
    vertical-align: top;
  }
  .workflows-table tr:last-child td { border-bottom: none; }
  .workflows-table tr:hover td { background: var(--paper-2); }

  .workflows-table td:nth-child(2) {
    color: var(--accent);
    font-style: italic;
    font-family: var(--font-display);
