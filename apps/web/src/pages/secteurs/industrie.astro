---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';
---
<Base
  title="Industrie & PME Industrielles · IA sur mesure · Waimia"
  description="Waimia déploie l'IA dans les PME industrielles : ERP connecté, maintenance prédictive, contrôle qualité automatisé."
>
  <section class="mast">
    <div class="wrap-wide">
      <Kicker>SECTEUR · 02 / Industrial SMEs</Kicker>
      <h1 class="mast-h1 reveal">Données <i>connectées</i>.<br>Production <i>fluide</i>.</h1>
      <p class="mast-lede">
        ERP connecté, maintenance prédictive et contrôle qualité en amont.
        L'IA unifie vos données dispersées et anticipe les pannes avant l'arrêt.
      </p>
      <svg class="sector-svg-sig" viewBox="0 0 200 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <rect x="15" y="45" width="36" height="30" stroke="currentColor" stroke-width="1.5"/>
        <line x1="51" y1="60" x2="82" y2="60" stroke="currentColor" stroke-width="1.5"/>
        <rect x="82" y="35" width="40" height="50" stroke="currentColor" stroke-width="1.5"/>
        <line x1="122" y1="60" x2="152" y2="60" stroke="currentColor" stroke-width="1.5"/>
        <rect x="152" y="45" width="32" height="30" stroke="currentColor" stroke-width="1.5"/>
        <path d="M30 100 L170 100" stroke="currentColor" stroke-width="1" stroke-dasharray="4 3"/>
        <polyline points="166,96 170,100 166,104" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="60" cy="100" r="3" stroke="currentColor" stroke-width="1"/>
        <circle cx="100" cy="100" r="3" stroke="currentColor" stroke-width="1"/>
        <circle cx="140" cy="100" r="3" stroke="currentColor" stroke-width="1"/>
      </svg>
      <a href="/secteurs" class="back-link">← Tous les secteurs</a>
    </div>
  </section>

  <section class="problems-section">
    <div class="wrap-wide">
      <div class="section-header">
        <Kicker>PROBLÈMES SECTORIELS / Pain Points</Kicker>
        <h2 class="section-h2">Ce qui freine <i>concrètement</i>.</h2>
      </div>
      <div class="problems-grid">
        <div class="problem-item">
          <p class="problem-num">01</p>
          <span class="problem-en">Data silos</span>
          <h3 class="problem-title">Données dispersées</h3>
          <p class="problem-desc">3 ERPs, tableurs locaux, aucun flux unifié en temps réel. La direction pilote à l'aveugle.</p>
        </div>
        <div class="problem-item">
          <p class="problem-num">02</p>
          <span class="problem-en">Reactive maintenance</span>
          <h3 class="problem-title">Maintenance réactive</h3>
          <p class="problem-desc">Pannes non anticipées, coûts d'arrêt ×4, équipes en mode pompier. La production subit.</p>
        </div>
        <div class="problem-item">
          <p class="problem-num">03</p>
          <span class="problem-en">Late quality control</span>
          <h3 class="problem-title">Qualité tardive</h3>
          <p class="problem-desc">Défauts détectés en bout de chaîne, retours coûteux, certifications sous pression permanente.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="solutions-section">
    <div class="wrap-wide">
      <div class="section-header">
        <Kicker>MODULES WAIMIA / AI Solutions</Kicker>
        <h2 class="section-h2">L'IA qui <i>anticipe</i> et unifie.</h2>
      </div>
      <div class="solutions-grid">
        <div class="solution-item">
          <h3 class="solution-name">Agent ERP Unifié</h3>
          <p class="solution-desc">Agrège données SAP, Sage et Dynamics en flux unique. Tableaux de bord temps réel. Décisions fondées sur les faits.</p>
        </div>
        <div class="solution-item">
          <h3 class="solution-name">Agent Maintenance Prédictive</h3>
          <p class="solution-desc">Modèles vibratoires, alertes préventives J−7. ROI moyen ×3.8. Fin des arrêts surprise.</p>
        </div>
        <div class="solution-item">
          <h3 class="solution-name">Agent Qualité</h3>
          <p class="solution-desc">Contrôle automatique à chaque étape, traçabilité lot, export ISO. Audit certif sans stress.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="metrics-section">
    <div class="wrap-wide">
      <div class="section-header">
        <Kicker>RÉSULTATS / Outcomes</Kicker>
        <h2 class="section-h2">Chiffres <i>réels</i>. Clients réels.</h2>
      </div>
      <div class="metrics-grid">
        <div class="metric-item">
          <span class="metric-val reveal-zoom">−68%</span>
          <span class="metric-unit">Arrêts non planifiés</span>
          <p class="metric-desc">Réduction des pannes non planifiées sur clients actifs en maintenance prédictive.</p>
        </div>
        <div class="metric-item">
          <span class="metric-val reveal-zoom">×3.8</span>
          <span class="metric-unit">ROI maintenance</span>
          <p class="metric-desc">Retour sur investissement médian des clients déployés sur 12 mois.</p>
        </div>
        <div class="metric-item">
          <span class="metric-val reveal-zoom">&lt; 2h</span>
          <span class="metric-unit">Consolidation ERP</span>
          <p class="metric-desc">Contre 2 jours en consolidation manuelle multi-sources.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="citation-section">
    <div class="wrap-wide">
      <blockquote class="citation-text">
        « On avait 3 ERPs qui ne se parlaient pas. Maintenant une seule vue. La maintenance est passée de réactive à préventive. »
      </blockquote>
      <span class="citation-attr">DSI · PMI agroalimentaire, 340 pers.</span>
    </div>
  </section>

  <section class="sector-cta-section">
    <div class="wrap-wide">
      <span class="sector-cta-eyebrow">Industrial SMEs · Démarrer</span>
      <h2 class="sector-cta-h2">Vos données unifiées. <i>Cette semaine.</i></h2>
      <a href="/contact" class="cta-btn" data-mag="0.15">Planifier une démo →</a>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .mast {
    padding: 140px 32px clamp(44px, 6vw, 84px);
    border-bottom: 1px solid var(--hairline);
  }
  .mast-h1 {
    font-family: var(--font-display);
    font-size: clamp(52px, 10vw, 160px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .mast-h1 i { font-style: italic; color: var(--accent); }
  .mast-lede {
    font-family: var(--font-sans);
    font-size: clamp(18px, 2vw, 24px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 720px;
    line-height: 1.6;
    text-wrap: pretty;
  }
  .sector-svg-sig {
    width: 200px;
    height: auto;
    margin-top: 48px;
    color: var(--hairline-strong);
    opacity: 0.7;
    display: block;
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 40px;
    text-decoration: none;
  }
  .back-link:hover { color: var(--ink); }
  .section-header { margin-bottom: clamp(32px, 4vw, 48px); }
  .section-h2 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.5vw, 52px);
    font-weight: 400;
    letter-spacing: -0.022em;
    margin: 16px 0 0;
    max-width: 640px;
    text-wrap: balance;
  }
  .section-h2 i { font-style: italic; }
  .problems-section {
    padding: clamp(80px, 10vw, 128px) 32px;
    border-bottom: 1px solid var(--hairline);
  }
  .problems-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    margin-top: clamp(40px, 5vw, 56px);
  }
  .problem-item {
    padding: clamp(24px, 2.5vw, 36px);
    background: var(--paper);
    display: flex;
    flex-direction: column;
  }
  .problem-num {
    font-family: var(--font-display);
    font-size: clamp(40px, 4vw, 64px);
    font-style: italic;
    color: var(--ink-2);
    line-height: 0.9;
    margin: 0 0 auto;
  }
  .problem-en {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 20px;
    margin-bottom: 8px;
    display: block;
  }
  .problem-title {
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
    color: var(--ink);
  }
  .problem-desc {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
  }
  .solutions-section {
    padding: clamp(80px, 10vw, 128px) 32px;
    border-bottom: 1px solid var(--hairline);
  }
  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(32px, 4vw, 64px) clamp(24px, 3vw, 48px);
    margin-top: clamp(40px, 5vw, 56px);
  }
  .solution-name {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
  }
  .solution-desc {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.65;
    color: var(--ink-2);
    margin: 0;
  }
  .metrics-section {
    padding: clamp(80px, 10vw, 128px) 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    margin-top: clamp(40px, 5vw, 56px);
  }
  .metric-item {
    padding: clamp(32px, 3.5vw, 48px) clamp(24px, 2.5vw, 36px);
    background: var(--paper-2);
  }
  .metric-val {
    font-family: var(--font-display);
    font-size: clamp(64px, 7vw, 112px);
    font-style: italic;
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: -0.04em;
    color: var(--ink);
    display: block;
  }
  .metric-unit {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 12px;
    display: block;
  }
  .metric-desc {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
    color: var(--muted);
    margin-top: 8px;
  }
  .citation-section {
    padding: clamp(80px, 10vw, 120px) 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--hairline);
  }
  .citation-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2.5vw, 36px);
    line-height: 1.3;
    letter-spacing: -0.01em;
    color: var(--ink);
    max-width: 760px;
    margin: 0 auto 24px;
    text-align: center;
    text-wrap: balance;
  }
  .citation-attr {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    display: block;
  }
  .sector-cta-section {
    padding: clamp(80px, 10vw, 120px) 32px;
    text-align: center;
  }
  .sector-cta-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 24px;
    display: block;
  }
  .sector-cta-h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 56px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 40px;
    text-wrap: balance;
  }
  .sector-cta-h2 i { font-style: italic; }
  .cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 16px 36px;
    border: 1px solid var(--ink);
    border-radius: 2px;
    transition: background 220ms var(--ease), color 220ms var(--ease), border-color 220ms var(--ease);
    text-decoration: none;
  }
  .cta-btn:hover { background: var(--accent); border-color: var(--accent); }
  @media (max-width: 1024px) {
    .problems-grid, .solutions-grid, .metrics-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 700px) {
    .mast { padding-top: 96px; padding-inline: 20px; }
    .problems-grid, .solutions-grid, .metrics-grid { grid-template-columns: 1fr; }
    .problems-section, .solutions-section, .metrics-section,
    .citation-section, .sector-cta-section { padding-inline: 20px; }
  }
</style>
