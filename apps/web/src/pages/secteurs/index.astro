---
// Page · /secteurs · Hub des secteurs satellites
export const prerender = true;

//
// Ces pages sont des landings SEO/GEO satellites. Elles adaptent la
// communication aux verticales sans fragmenter la delivery.
// Niveau 1 (cœur) = 5 cas d'usage business horizontaux dans /solutions.
// Niveau 2 (satellite) = ce hub + pages /secteurs/<slug>.

import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';

const sectorsLive = [
  {
    num: '01',
    kicker: 'SECTEUR · 01',
    label_fr: 'Services B2B',
    label_en: 'B2B Services',
    sub_fr: 'Cabinets, conseil, agences, prestataires',
    pains_fr: 'Pipeline qui tient sur 2 commerciaux. Contenu invisible. Reporting bricolé.',
    href: '/secteurs/services-b2b',
  },
  {
    num: '02',
    kicker: 'SECTEUR · 02',
    label_fr: 'Industrie & PME industrielles',
    label_en: 'Industrial SMEs',
    sub_fr: 'ERP connecté, maintenance, qualité',
    pains_fr: 'Données dispersées dans 3 ERPs. Maintenance réactive. Qualité tardive.',
    href: '/secteurs/industrie',
  },
  {
    num: '03',
    kicker: 'SECTEUR · 03',
    label_fr: 'Finance & cabinets comptables',
    label_en: 'Finance & Accounting',
    sub_fr: 'Réconciliation, reporting, conformité',
    pains_fr: 'Excel partout. Clôture en 9 jours. Audit qui dure 3 semaines.',
    href: '/secteurs/finance-compta',
  },
];

const sectorsToCome = [
  'Santé-tech',
  'Retail & e-commerce',
  'Immobilier',
  'BTP',
  'Cabinets juridiques',
];
---
<Base
  title="Secteurs · adaptés à votre métier · Waimia"
  description="Mêmes systèmes IA. Vocabulaire, KPIs et workflows adaptés à votre secteur. Trois secteurs visibles aujourd'hui — d'autres à venir."
>
  <section class="hub-mast">
    <div class="wrap-wide">
      <Kicker class="hub-kicker">§ Hub · Secteurs</Kicker>
      <h1 class="hub-h1 reveal">Mêmes <i>systèmes</i>. Votre <i>vocabulaire</i>.</h1>
      <p class="hub-lede">
        Pas une offre par secteur. Une méthode. Adaptée au vocabulaire, aux KPIs et aux workflows de votre métier.
      </p>
      <p class="hub-canonical">
        Trois secteurs aujourd'hui. D'autres à venir — quand on aura assez de cas pour parler juste.
      </p>
      <svg class="sector-svg-sig" viewBox="0 0 260 100" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <!-- Finance : balance -->
        <line x1="35" y1="15" x2="35" y2="75" stroke="currentColor" stroke-width="1.5"/>
        <line x1="15" y1="30" x2="35" y2="22" stroke="currentColor" stroke-width="1.5"/>
        <line x1="35" y1="22" x2="55" y2="32" stroke="currentColor" stroke-width="1.5"/>
        <!-- Séparateur -->
        <line x1="80" y1="10" x2="80" y2="90" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3"/>
        <!-- Industrie : modules -->
        <rect x="90" y="30" width="20" height="20" stroke="currentColor" stroke-width="1.5"/>
        <line x1="110" y1="40" x2="120" y2="40" stroke="currentColor" stroke-width="1.5"/>
        <rect x="120" y="25" width="24" height="30" stroke="currentColor" stroke-width="1.5"/>
        <line x1="144" y1="40" x2="154" y2="40" stroke="currentColor" stroke-width="1.5"/>
        <rect x="154" y="30" width="20" height="20" stroke="currentColor" stroke-width="1.5"/>
        <!-- Séparateur -->
        <line x1="188" y1="10" x2="188" y2="90" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 3"/>
        <!-- B2B : nœuds -->
        <circle cx="204" cy="45" r="10" stroke="currentColor" stroke-width="1.5"/>
        <circle cx="248" cy="45" r="10" stroke="currentColor" stroke-width="1.5"/>
        <line x1="214" y1="45" x2="238" y2="45" stroke="currentColor" stroke-width="1.5"/>
      </svg>
    </div>
  </section>

  <section class="hub-sectors-live wrap-wide" aria-label="Secteurs disponibles">
    {sectorsLive.map((s) => (
      <a href={s.href} class="sector-card">
        <div class="sector-num">{s.num}</div>
        <div class="sector-kicker">{s.kicker}</div>
        <span class="sector-en-label">{s.label_en}</span>
        <h2 class="sector-title">{s.label_fr}</h2>
        <p class="sector-sub">{s.sub_fr}</p>
        <p class="sector-pains">{s.pains_fr}</p>
        <span class="sector-cta">Voir le secteur →</span>
      </a>
    ))}
  </section>

  <section class="hub-coming">
    <div class="wrap-wide">
      <Kicker>§ À venir</Kicker>
      <h2 class="coming-h2">Quand on aura câblé assez de cas pour parler juste.</h2>
      <ul class="coming-list" aria-label="Secteurs à venir">
        {sectorsToCome.map((label) => (
          <li class="coming-pill">{label}</li>
        ))}
      </ul>
    </div>
  </section>

  <section class="hub-cta-band">
    <div class="wrap-wide">
      <p class="cta-question">Votre secteur n'est pas listé ?</p>
      <p class="cta-sub">
        Pas grave. Les <a href="/solutions" class="cta-link">5 cas d'usage</a> couvrent 80 % des PME. Le reste, on s'adapte.
      </p>
      <a href="/contact" class="cta-btn" data-mag="0.15">Démarrer un échange →</a>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hub-mast {
    padding: 140px 32px clamp(44px, 6vw, 84px);
    border-bottom: 1px solid var(--hairline);
  }
  :global(.hub-kicker) { display: block; margin-bottom: 24px; }

  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--accent); }

  .hub-lede {
    font-family: var(--font-sans);
    font-style: normal;
    font-size: clamp(18px, 2vw, 24px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.6;
    text-wrap: pretty;
  }
  .hub-canonical {
    max-width: 720px;
    margin: 22px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }

  .sector-svg-sig {
    width: 180px;
    height: auto;
    margin-top: 48px;
    color: var(--hairline-strong);
    opacity: 0.7;
    display: block;
  }

  /* ── Grille secteurs live ── */
  .hub-sectors-live {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--hairline);
    border: 1px solid var(--hairline);
    padding: 0 32px clamp(80px, 10vw, 128px);
    margin-top: clamp(48px, 6vw, 80px);
  }

  .sector-card {
    min-height: 480px;
    padding: clamp(24px, 2.5vw, 36px);
    background: var(--paper);
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: background 220ms var(--ease), transform 220ms var(--ease);
    text-decoration: none;
  }
  .sector-card:hover {
    background: var(--paper-2);
    transform: translateY(-4px);
  }

  .sector-num {
    font-family: var(--font-display);
    font-size: clamp(42px, 4.5vw, 72px);
    line-height: 0.9;
    color: var(--ink-2);
    font-style: italic;
    margin-bottom: auto;
  }
  .sector-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 24px;
  }
  .sector-en-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 8px;
    display: block;
  }
  .sector-title {
    font-family: var(--font-display);
    font-size: clamp(27px, 3vw, 42px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 16px 0 10px;
    text-wrap: balance;
  }
  .sector-sub {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 18px;
  }
  .sector-pains {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
    margin: 0 0 28px;
    flex-grow: 1;
  }
  .sector-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-top: auto;
  }

  /* ── À venir ── */
  .hub-coming {
    padding: clamp(80px, 10vw, 120px) 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .coming-h2 {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.022em;
    font-weight: 400;
    margin: 18px 0 clamp(32px, 4vw, 56px);
    max-width: 640px;
    text-wrap: balance;
  }
  .coming-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .coming-pill {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--hairline-strong);
    padding: 8px 18px;
    border-radius: 2px;
  }

  /* ── CTA bande ── */
  .hub-cta-band {
    padding: clamp(80px, 10vw, 120px) 32px;
    text-align: center;
  }
  .cta-question {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 52px);
    font-weight: 400;
    letter-spacing: -0.02em;
    margin: 0 0 16px;
  }
  .cta-sub {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 40px;
  }
  .cta-link {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 16px 36px;
    border: 1px solid var(--ink);
    transition: background 220ms var(--ease), color 220ms var(--ease);
    text-decoration: none;
  }
  .cta-btn:hover { background: var(--accent); border-color: var(--accent); }

  @media (max-width: 1180px) {
    .hub-sectors-live { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 700px) {
    .hub-mast { padding-top: 96px; }
    .hub-sectors-live {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }
    .sector-card { min-height: 360px; }
    .hub-coming { padding-inline: 20px; }
    .hub-cta-band { padding-inline: 20px; }
  }
</style>
