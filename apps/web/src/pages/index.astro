---
export const prerender = true;

/**
 * Homepage · refonte business-first PME/ETI · FR
 *
 * Pivot du récit manifeste vers conversion. 8 organisms scannables.
 * Le visiteur PME comprend en 5s : ce qu'on fait, pour quel ROI, pour qui.
 *
 * Organisms retirés de la home (sortis du parcours principal) :
 *   - WhyAIStalls + HowWeShip → réservés à /agence/methode
 *   - Manifesto → réservé à /manifesto
 *   - OperatingLayer → réservé à /agence/methode
 *   - WritingNotes → réservé à /ressources/blog
 *   - Offices → réservé à /agence/about
 */
import Base from '../layouts/Base.astro';
import BootSplash from '../components/motion/BootSplash.tsx';
import ScrollProgress from '../components/ui/atoms/ScrollProgress.astro';

import Hero             from '../components/ui/organisms/Hero.astro';
import TrustMarquee     from '../components/ui/organisms/TrustMarquee.astro';
import CapabilityStrip    from '../components/ui/organisms/CapabilityStrip.astro';
import SystemArchitecture from '../components/ui/organisms/SystemArchitecture.astro';
import SixServices        from '../components/ui/organisms/SixServices.astro';
import Pyramid          from '../components/ui/organisms/Pyramid.astro';
import Departments      from '../components/ui/organisms/Departments.astro';
import Cases            from '../components/ui/organisms/Cases.astro';
import FAQ              from '../components/seo/FAQ.astro';
import FieldNotes       from '../components/ui/organisms/FieldNotes.astro';
import BookSession      from '../components/ui/organisms/BookSession.astro';
import SigBand          from '../components/ui/organisms/SigBand.astro';
import FooterMarquee    from '../components/ui/organisms/FooterMarquee.astro';

import { faqPage } from '../lib/seo';
import { buildOrganization } from '../lib/seo/schema-builder';

// FAQ PME-first · 8 questions scannables (V5 : + CMS · + brand consistency)
const faqItems = [
  {
    q: "Combien coûte un premier engagement avec Waimia ?",
    a: "Activation IA · 1 semaine démarre à 1 500 € HT : audit, formation, premier workflow livré. Growth System IA démarre à 5 000 € HT. La plupart des PME commencent petit, mesurent en 5 jours, puis câblent le système complet.",
  },
  {
    q: "Pour qui c'est fait — et pour qui ce n'est pas fait.",
    a: "PME et ETI françaises et suisses, 20 à 500 collaborateurs. Pas les grands groupes déjà bardés de prestataires. Pas les startups trop jeunes, qui changent de cap toutes les semaines. Nos meilleurs clients : services B2B, industrie, cabinets finance et compta.",
  },
  {
    q: "En combien de temps voit-on un retour sur investissement ?",
    a: "Activation IA · 1 semaine : un workflow en production en 5 jours, mesure avant/après incluse. Growth System IA : système complet en 6 à 10 semaines. Le mardi on câble, le vendredi on mesure. ROI entre 3,4× et 4,1× à 12 mois sur nos cas clients PME.",
  },
  {
    q: "Et si on veut reprendre la main en interne ?",
    a: "Tout est documenté, ouvert, transmissible. Pas de boîte noire, pas de captivité. On forme votre équipe pendant la mission (2 à 3 jours) et on livre le mode opératoire complet. Vous gardez la plateforme quand on part.",
  },
  {
    q: "Comment garantissez-vous la conformité RGPD et AI Act ?",
    a: "Chaque système inclut par défaut : journal des actions, export CSV/JSON, retour arrière possible, classification du risque AI Act. Pour les missions ETI, on mène un PIA avant le sprint.",
  },
  {
    q: "Travaillez-vous avec notre stack actuelle (HubSpot, Salesforce, Excel, etc.) ?",
    a: "Oui — on se branche sur votre stack actuelle : HubSpot, Salesforce, Pipedrive, Notion, Excel, Office, ERP. Pas de migration imposée. Si vous n'avez pas de CRM, on en propose un adapté à votre volume, souvent HubSpot pour les PME B2B.",
  },
  {
    q: "Et notre site web et CMS actuels ? Faut-il tout refaire ?",
    a: "Non. On se branche sur votre CMS existant (WordPress, Webflow, Sanity, headless) ou on bascule vers un CMS Git-based si la maturité de l'équipe le permet. Sites IA-first, landing, tunnels et pages évolutives peuvent vivre en parallèle ou remplacer progressivement l'existant, à votre rythme.",
  },
  {
    q: "Comment garantissez-vous la cohérence de marque sur tous les supports ?",
    a: "On part de votre design system (ou on le construit), on encode votre charte et votre ton dans des templates, et on déploie des agents de production alignés. Résultat : site, posts, decks PowerPoint, PDF, ads et supports sales restent visuellement et verbalement cohérents même quand l'IA produit en volume.",
  },
];
---
<Base
  title="Waimia · Systèmes IA pour PME et ETI · Acquisition · CRM · Pilotage"
  description="On câble l'IA dans les outils des PME : acquisition, CRM, relances, pilotage. Activation en 1 semaine, Growth System IA, Productivité Opérationnelle. Paris · Genève."
  jsonLd={[faqPage(faqItems), buildOrganization()]}
>
  {/* Splash · respiration cinématique 1.1s · garde le signal premium */}
  <BootSplash client:only="react" lang="fr" />

  {/* 1 — Hero recadré business · phrase canonique + 4 metrics */}
  <Hero />

  {/* 2 — TrustMarquee · logos clients = preuve sociale immédiate */}
  <TrustMarquee />

  {/* 3 — CapabilityStrip · 8 piliers du scope Waimia complet (V5)
       → expose ads/content/web-CMS/CRM/data/automation/brand/governance
       → liens vers pages /solutions, /offres, /agence existantes */}
  <CapabilityStrip />

  {/* 4 — SystemArchitecture · SVG canonique 6 canaux → IA System → 4 sorties
       → matérialise la doctrine multi-agents de la boucle d'amélioration */}
  <SystemArchitecture />

  {/* 5 — SixServices · 6 leviers business (recadrés M1) + connecteurs (V5) */}
  <SixServices />

  {/* 5 — Pyramid · 4 paliers d'engagement (V10) */}
  <Pyramid />

  {/* 6 — Departments · 6 cas d'usage horizontaux (V5 : + site-web-ia) */}
  <Departments />

  {/* 7 — Cases · 4 dossiers vedettes (CASE_FEED) */}
  <Cases />

  {/* 8 — FAQ · 8 questions PME-first (V5 : + CMS, brand consistency) */}
  <FAQ
    items={faqItems}
    heading="Questions fréquentes"
    intro="Huit réponses nettes — pas des slides, pas du jargon. Ce qu'on écrit par mail avant de se parler."
  />

  {/* 9 — FieldNotes · doctrine + internal linking (V5 brief section 20)
       → entre FAQ et BookSession : FAQ enlève les objections,
         Notes construisent l'autorité, CTA convertit. */}
  <FieldNotes />

  {/* 10 — BookSession · CTA principal vers /contact */}
  <BookSession />

  {/* SigBand · signature pré-footer */}
  <SigBand />

  {/* FooterMarquee · ruban éditorial animé pré-scrollprogress */}
  <FooterMarquee />

  <ScrollProgress />
  <script>
    import { initHomepageNarrative } from '../lib/animations/signature/homepage-narrative';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    function bootstrap() {
      // Kill anciens ScrollTriggers (evite leak + double-init apres ClientRouter)
      ScrollTrigger.getAll().forEach((t) => t.kill());
      initHomepageNarrative();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', bootstrap);
    } else {
      bootstrap();
    }
    document.addEventListener('astro:page-load', bootstrap);
  </script>
</Base>
