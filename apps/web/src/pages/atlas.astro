---
// Page · /atlas · Test de la Direction 3 (Atlas) en parallèle de la home
export const prerender = true;

// Pacing : Hero court → Atlas grid 2×2 → Persona switcher → Cases → Field notes → CTA
// On réutilise les sections existantes pour comparer le rythme avec la Direction 1.

import Base from '../layouts/Base.astro';
import AtlasGrid       from '../components/ui/organisms/AtlasGrid.astro';
import PersonaSwitcher from '../components/ui/organisms/PersonaSwitcher.astro';
import Cases           from '../components/ui/organisms/Cases.astro';
import FieldNotes      from '../components/ui/organisms/FieldNotes.astro';
import CtaBand         from '../components/ui/organisms/CtaBand.astro';
import AtlasConnections from '../components/motion/AtlasConnections.astro';

import { langFromPath, localizeHref } from '../lib/i18n';
const lang = langFromPath(Astro.url.pathname);
---
<Base
  title={lang === 'fr' ? "Waimia · Atlas — quatre portes d'entrée" : 'Waimia · Atlas — four entry doors'}
  description={lang === 'fr'
    ? "Atlas Waimia : quatre piliers (Audit, Adoption, Orchestration, Souveraineté) et trois portes d'entrée par persona (CEO, DSI, CTO). Test direction 3 vs accueil."
    : 'Waimia Atlas: four pillars (Audit, Adoption, Orchestration, Sovereignty) and three entry doors per persona (CEO, CIO, CTO). Direction 3 test vs home.'}
>
  {/* Hero court · Direction 3 */}
  <section class="hero-atlas">
    <div class="signature-grid"></div>
    <div class="wrap-wide">
      <div class="kick">
        <span class="kick-dot" aria-hidden="true"></span>
        <span>{lang === 'fr' ? 'Atlas · Cartographier · Câbler · Orchestrer · Industrialiser' : 'Atlas · Map · Wire · Orchestrate · Industrialize'}</span>
      </div>
      <h1 class="hero-atlas-title reveal-mask-up">
        {lang === 'fr' ? (
          <>Une <i>cartographie</i><br />pour les pressés.</>
        ) : (
          <>A <i>map</i><br />for the time-pressed.</>
        )}
      </h1>
      <p class="hero-atlas-lead">
        {lang === 'fr'
          ? "Marketing, sales, contenu, web, CRM, analytics et marque — tous les territoires Waimia sur une seule carte. Cliquez là où vous reconnaissez votre douleur."
          : 'Marketing, sales, content, web, CRM, analytics and brand — every Waimia territory on one map. Click where you recognise your pain point.'}
      </p>
      <div class="hero-atlas-ctas">
        <a href={localizeHref('/contact', lang)} class="btn btn-primary btn-lg" data-mag="0.18">
          {lang === 'fr' ? 'Réserver un audit' : 'Book an audit'} <span aria-hidden>→</span>
        </a>
        <a href={localizeHref('/', lang)} class="btn btn-ghost btn-lg">
          {lang === 'fr' ? "← Retour à l'accueil" : '← Back to home'}
        </a>
      </div>
    </div>
  </section>

  <section style="padding:0 clamp(20px,4vw,48px) clamp(32px,4vw,56px)">
    <div style="max-width:1500px;margin:0 auto">
      <AtlasConnections />
    </div>
  </section>

  <AtlasGrid />
  <PersonaSwitcher />
  <Cases />
  <FieldNotes />
  <CtaBand />
</Base>

<style>
  /* V7 harmonisation · Atlas hero aligned avec doctrine site (cap 132 vs 180) */
  .hero-atlas{position:relative;padding:clamp(88px,9vw,128px) var(--gut) clamp(56px,7vw,88px);overflow:hidden;border-bottom:1px solid var(--hairline)}
  .hero-atlas .signature-grid{z-index:0}
  .hero-atlas > *:not(.signature-grid){position:relative;z-index:1}
  .hero-atlas .kick{display:flex;align-items:center;gap:12px;font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:24px}
  .hero-atlas .kick-dot{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--accent)}
  .hero-atlas-ctas{display:flex;gap:12px;margin-top:var(--space-7);flex-wrap:wrap;align-items:center}
  /* H1 page spéciale · 132px max (= 1.43× home H1 92px) · cohérent et imposant */
  .hero-atlas-title{font-family:var(--font-display);font-size:clamp(48px,9vw,132px);line-height:0.94;letter-spacing:-0.03em;font-weight:400;text-wrap:balance;max-width:1200px}
  .hero-atlas-title i{font-style:italic;color:var(--accent)}
  .hero-atlas-lead{font-family:var(--font-sans);font-size:var(--text-lede);color:var(--ink-2);margin-top:var(--space-5);max-width:720px;line-height:1.45;text-wrap:pretty}
</style>
