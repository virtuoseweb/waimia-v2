---
import { getEntry } from 'astro:content';
import WelcomeTemplate from '../../components/templates/WelcomeTemplate.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');
const entry = await getEntry('pages', slug);
if (!entry) return Astro.redirect('/404');
if (entry.data.template !== 'welcome' || entry.data.seo?.noindex) return Astro.redirect('/404');
const d = entry.data;

// Mapper nextSteps Zod (number: string, label_fr/label_en) vers NextStep WelcomeTemplate (num, title_fr/title_en)
const nextSteps = (d.nextSteps ?? []).map((s) => ({
  num: s.number,
  title_fr: s.label_fr,
  title_en: s.label_en,
  body_fr: s.body_fr,
  body_en: s.body_en,
  ctaLabel: s.ctaLabel_fr,
  ctaHref: s.ctaHref,
}));
---
<WelcomeTemplate
  title={d.title_fr}
  description={d.description_fr}
  kicker={d.kicker_fr ?? '§ Bienvenue'}
  nextSteps={nextSteps}
>
  <Fragment slot="headline">{d.title_fr}</Fragment>
  <Fragment slot="lede">{d.description_fr}</Fragment>
</WelcomeTemplate>
