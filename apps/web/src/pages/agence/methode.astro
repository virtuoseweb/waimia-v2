---
// Page · /agence/methode · Méthode Waimia · Process Intelligence
export const prerender = true;

//
// Documente comment Waimia travaille — pas un produit, pas un OS marketing.
// VirtuoseOS y apparaît comme framework interne, pas comme proposition commerciale.

import UtilityTemplate from '../../components/templates/UtilityTemplate.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import Timeline from '../../components/editorial/Timeline.astro';
import MethodeProcessDiagram from '../../components/svg/geometric/MethodeProcessDiagram.astro';

const phases = [
  {
    n: '01',
    label_fr: 'Cartographie',
    body_fr: "On regarde votre métier. Pas vos présentations. Vos vrais workflows, vos vrais outils, vos vrais bouchons. Le mardi on observe, le vendredi on chiffre.",
  },
  {
    n: '02',
    label_fr: 'Priorisation',
    body_fr: "On classe les workflows par ROI. Pas par sophistication technique. Le gain rapide passe en premier. Le reste — on planifie.",
  },
  {
    n: '03',
    label_fr: 'Câblage',
    body_fr: "On câble les agents IA dans vos outils existants — Excel, HubSpot, Outlook, votre ERP. Pas de migration. Pas de refonte lourde. On connecte ce qui marche.",
  },
  {
    n: '04',
    label_fr: 'Mesure',
    body_fr: "Chaque workflow a sa métrique avant/après. Si ça ne mesure rien, ça n'existe pas. Le vendredi, on lit les chiffres.",
  },
  {
    n: '05',
    label_fr: 'Passation',
    body_fr: "Vous prenez la main. Documentation, mode opératoire, formation. Pas de boîte noire, pas de captivité. Vous pouvez nous virer.",
  },
];

const timelineEvents = phases.map(p => ({
  num: p.n,
  title: p.label_fr,
  body: p.body_fr,
}));
---
<UtilityTemplate
  title="Notre méthode · Process Intelligence · Waimia"
  description="Cinq phases. Audit, priorisation, câblage, mesure, passation. Pas de diaporama. Pas de POC. Le mardi on câble, le vendredi on mesure."
  kicker="§ Notre méthode · Process Intelligence"
  align="left"
  showCta={true}
>
  <Fragment slot="headline">Cinq <i>phases</i>. Pas de <i>diaporama</i>.</Fragment>
  <Fragment slot="lede">
    On a une méthode. On l'écrit. On la mesure. On la corrige. Pas un secret de cabinet — un protocole que l'on peut rejouer.
  </Fragment>

  <Fragment slot="body">
    {/* ── PHASES via Timeline ── */}
    <Timeline events={timelineEvents} numbered={true} />

    {/* ── DIAGRAM ── */}
    <div class="meth-diagram reveal">
      <MethodeProcessDiagram />
    </div>

    {/* ── MENTION VIRTUOSEOS ── */}
    <div class="meth-os reveal">
      <Kicker class="meth-os-kicker">§ Sous le capot</Kicker>
      <h2 class="meth-os-h2">VirtuoseOS · le <i>cadre</i> qu'on a construit pour ça.</h2>
      <p class="meth-os-body">
        Cinq ans à câbler des systèmes IA pour PME nous ont appris une chose : sans cadre commun, chaque mission redémarre à zéro. VirtuoseOS est notre noyau multi-workspace — un système qui orchestre les agents, audite les actions et garde la trace.
      </p>
      <p class="meth-os-body">
        Vous n'avez pas à l'acheter. Vous n'avez pas à le voir. Il tourne sous chaque mission Waimia. C'est tout.
      </p>
    </div>

    {/* ── CTA INLINE ── */}
    <div class="meth-cta reveal">
      <h2 class="meth-cta-h2">Cinq phases. Quarante-cinq minutes pour démarrer.</h2>
      <a href="/contact" class="meth-cta-btn" data-mag="0.15">Démarrer →</a>
    </div>
  </Fragment>
</UtilityTemplate>

<style>
  /* ── Section VirtuoseOS ── */
  .meth-os {
    background: var(--paper-2);
    border: 1px solid var(--hairline);
    padding: clamp(36px, 4.5vw, 64px);
    margin-bottom: clamp(72px, 9vw, 120px);
  }

  :global(.meth-os-kicker) { display: block; margin-bottom: 20px; }

  .meth-os-h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 52px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.05;
    margin: 0 0 28px;
    text-wrap: balance;
  }
  .meth-os-h2 :global(i) { font-style: italic; color: var(--accent); }

  .meth-os-body {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.7;
    margin: 0 0 14px;
    max-width: 680px;
  }
  .meth-os-body:last-child { margin-bottom: 0; }

  /* ── CTA final ── */
  .meth-cta {
    text-align: left;
    border-top: 1px solid var(--hairline);
    padding-top: clamp(48px, 6vw, 72px);
    display: flex;
    align-items: center;
    gap: clamp(28px, 4vw, 56px);
    flex-wrap: wrap;
  }

  .meth-cta-h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 52px);
    font-weight: 400;
    letter-spacing: -0.022em;
    line-height: 1.1;
    margin: 0;
    flex: 1 1 360px;
    text-wrap: balance;
  }

  .meth-cta-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--paper);
    background: var(--ink);
    padding: 16px 36px;
    border: 1px solid var(--ink);
    transition: background 220ms var(--ease), border-color 220ms var(--ease);
    text-decoration: none;
    white-space: nowrap;
  }
  .meth-cta-btn:hover { background: var(--accent); border-color: var(--accent); }

  @media (max-width: 700px) {
    .meth-os { padding-inline: 24px; }
    .meth-cta { flex-direction: column; align-items: flex-start; }
  }

  .meth-diagram {
    margin: clamp(48px, 6vw, 80px) 0;
    max-width: 900px;
  }
</style>
