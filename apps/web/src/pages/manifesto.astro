---
// Page · /manifesto · Direction B · port de virtuoseweb/waimia src/components/directions/DirectionB.tsx
export const prerender = true;

// (legacy repo archivé GitHub 2026-05-08 · backup local : ~/Archives/waimia-vieux-2026-05-08.tar.gz)
// Pattern : composition Astro (Pattern 1) + 1 React island (Pattern 4 · LiquidHero canvas RAF)
// Pacing :
//   1. Hero LiquidHero canvas (terracotta blobs + grain + parallax mouse)
//   2. Dark marquee (logos clients massifs Instrument Serif)
//   3. Acte I dark · stats massives 43 · <9 · ×4
//   4. Acte II asymétriques · services alterne gauche/droite
//   5. Manifeste accent terracotta « On refuse... »
//   6. Acte III dark · console VirtuoseOS XL
//   7. Acte IV cards en grille décalée
//   8. Writing dark
//   9. Acte V « Stop rehearsing. Ship. »

import Base from '../layouts/Base.astro';
import LiquidHero from '../components/motion/LiquidHero.tsx';
import ManifestoAccent from '../components/ui/organisms/ManifestoAccent.astro';
import Button from '../components/ui/atoms/Button.astro';
import Kicker from '../components/ui/atoms/Kicker.astro';
import PillCTA from '../components/ui/atoms/PillCTA.astro';
import EditorialWriteRow from '../components/ui/molecules/EditorialWriteRow.astro';
import AsymmetricServiceRow from '../components/ui/molecules/AsymmetricServiceRow.astro';
import EditorialCaseCard from '../components/ui/molecules/EditorialCaseCard.astro';
import { CLIENT_LOGOS, SIX_SERVICES, CASE_FEED, FIELD_NOTES } from '../data/sitemap';
import { langFromPath, t as ft, localizeHref as flh } from '../lib/i18n';
import Breadcrumb from '../components/ui/molecules/Breadcrumb.astro';
import { buildArticle } from '../lib/seo/schema-builder';

const lang = langFromPath(Astro.url.pathname);

const STATS = [
  { n:'43',  text: { en: 'tools in the average RevOps stack.',                      fr: 'outils dans la stack RevOps moyenne.' } },
  { n:'< 9', text: { en: 'touch the same customer record.',                         fr: 'touchent le même enregistrement client.' } },
  { n:'× 4', text: { en: 'success rate for agents shipped in 6 weeks vs 6 months.', fr: 'de réussite pour les agents livrés en 6 semaines vs 6 mois.' } },
];

const tripled = [...CLIENT_LOGOS, ...CLIENT_LOGOS, ...CLIENT_LOGOS];

const articleLd = buildArticle({
  headline: lang === 'fr' ? 'Manifeste Waimia' : 'Waimia Manifesto',
  description: 'Build revenue, not demos. AI systems shipped, measured, documented.',
  datePublished: '2026-01-01',
  author: { '@type': 'Organization', name: 'Waimia' },
});
---
<Base
  title={lang === 'fr' ? "Waimia · Manifeste · Construire du revenu, pas des démos" : 'Waimia · Manifesto · Build revenue, not demos'}
  description={lang === 'fr'
    ? "Le manifeste Waimia : des systèmes IA livrés, mesurés, documentés. Pas de théâtre IA, pas de démos qui meurent en comité."
    : 'Waimia Manifesto — Build revenue, not demos. AI systems shipped, measured, documented.'}
  jsonLd={articleLd}
>
  <Breadcrumb items={[{label: lang === 'fr' ? 'Accueil' : 'Home', href: lang === 'fr' ? '/' : '/en'}, {label: lang === 'fr' ? 'Manifeste' : 'Manifesto'}]} lang={lang} />

  {/* HERO · LiquidHero canvas · plein viewport · GrainOverlay supprimé (flicker) */}
  <section class="manifesto-hero">
    <LiquidHero client:visible />
    <div class="manifesto-hero-inner">
      {/* top meta */}
      <div class="b-hero-meta">
        <Kicker as="span" class="b-hero-dim">Waimia · Manifeste 02</Kicker>
        <Kicker as="span" class="b-hero-dim">Paris · 2026</Kicker>
        <Kicker as="span" class="b-hero-dim"><span style="color:var(--accent)">◉</span> Booking T3</Kicker>
      </div>

      {/* headline */}
      <div style="max-width:1600px">
        <Kicker class="b-hero-tag">
          {lang === 'fr' ? (<>Une agence IA · <span style="color:var(--accent)">française dans l'exécution, internationale dans la finition</span></>) : (<>An AI agency · <span style="color:var(--accent)">French craft, international polish</span></>)}
        </Kicker>
        <h1 class="reveal-mask-up manifesto-h1">
          {lang === 'fr' ? (
            <>Construire du <i class="accent">revenu</i>,<br />pas des <i>démos</i>.</>
          ) : (
            <>Build <i class="accent">revenue</i>,<br />not <i>demos</i>.</>
          )}
        </h1>
      </div>

      {/* bottom CTAs */}
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:48px;align-items:end;max-width:1600px">
        <p style="font-family:var(--font-display);font-size:clamp(15px,1.4vw,22px);line-height:1.4;color:rgba(246,241,232,.85);max-width:380px;margin:0">
          {lang === 'fr'
            ? "Une agence IA pour SaaS, fintech et industrie. Pour les équipes dont le moteur commercial doit livrer — pas répéter."
            : 'An AI agency for SaaS, fintech and industry that want their revenue engine to ship — not to rehearse.'}
        </p>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <PillCTA href={flh('/contact', lang)} variant="accent" mag={0.18}>
            {lang === 'fr' ? 'Prendre RDV →' : 'Book a session →'}
          </PillCTA>
          <PillCTA href={flh('/console', lang)} variant="ghost-dark">
            {lang === 'fr' ? 'La plateforme' : 'The platform'}
          </PillCTA>
        </div>
        <div class="b-hero-foot">
          <Kicker class="b-hero-dim">SCROLL TO BEGIN ↓</Kicker>
          <Kicker class="b-hero-dim">FIVE ACTS · ONE DOCUMENT</Kicker>
        </div>
      </div>
    </div>
  </section>

  {/* DARK MARQUEE · logos massifs · padding réduit 24→14 pour rentrer sous fold */}
  <div aria-hidden="true" class="manifesto-marquee" style="background:var(--ink);color:var(--paper);border-top:1px solid rgba(246,241,232,.12);border-bottom:1px solid rgba(246,241,232,.12);padding:14px 0;overflow:hidden;white-space:nowrap">
    <div class="b-marquee-track">
      {tripled.map((logo) => (
        <>
          <span style="font-family:var(--font-display);font-size:clamp(24px,2.8vw,36px);padding:0 30px;color:var(--paper)">{logo}</span>
          <span style="padding:0 4px;color:var(--accent);font-size:24px;align-self:center">◦</span>
        </>
      ))}
    </div>
  </div>

  {/* ACTE I · stats dark */}
  <section style="padding:clamp(64px,8vw,112px) clamp(20px,4vw,48px);background:var(--ink);color:var(--paper)">
    <div style="max-width:1600px;margin:0 auto">
      <div style="display:grid;grid-template-columns:1fr 2fr;gap:clamp(40px,6vw,80px);margin-bottom:clamp(80px,10vw,120px)">
        <div style="position:sticky;top:120px;align-self:start">
          <Kicker class="b-acte-1">
            <span style="color:var(--accent)">I.</span> {lang === 'fr' ? 'Le constat' : 'The reckoning'}
          </Kicker>
          <Kicker class="b-acte-1-sub">{lang === 'fr' ? 'Acte I' : 'Act I'}</Kicker>
        </div>
        <p class="reveal manifesto-h2 manifesto-h2--paper">
          {lang === 'fr' ? (
            <>L'IA est <i class="accent">partout</i> et nulle part. Les stacks grossissent. Les pipelines s'aplatissent. Le goulot n'est <i>jamais</i> le modèle.</>
          ) : (
            <>AI is <i class="accent">everywhere</i> and nowhere. Stacks grow, pipelines flatten. The bottleneck is <i>never</i> the model.</>
          )}
        </p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:48px;padding-top:80px;border-top:1px solid rgba(246,241,232,.12)">
        {STATS.map((r) => (
          <div class="reveal">
            <div class="manifesto-stat">{r.n}</div>
            <p style="margin-top:18px;font-size:17px;line-height:1.5;color:rgba(246,241,232,.7);max-width:280px;font-family:var(--font-sans)">
              {ft(r.text, lang)}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ACTE II · services asymétriques */}
  <section style="padding:clamp(64px,8vw,112px) clamp(20px,4vw,48px);background:var(--paper);color:var(--ink)">
    <div style="max-width:1600px;margin:0 auto">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:clamp(60px,8vw,100px);flex-wrap:wrap;gap:14px">
        <Kicker>
          <span style="color:var(--accent)">II.</span> {lang === 'fr' ? 'La méthode' : 'The method'}
        </Kicker>
        <Kicker>6 · ALL IN HOUSE</Kicker>
      </div>
      <h2 class="reveal manifesto-h2">
        {lang === 'fr' ? (
          <>On fait la couche <i class="accent">sans prestige</i>. Exprès.</>
        ) : (
          <>We do the <i class="accent">unglamorous</i> layer. On purpose.</>
        )}
      </h2>
      {SIX_SERVICES.map((s, i) => (
        <AsymmetricServiceRow
          num={s.k}
          label={ft(s.label, lang)}
          body={ft(s.body, lang)}
          reverse={i % 2 === 1}
        />
      ))}
    </div>
  </section>

  {/* MANIFESTO ACCENT · réutilisé */}
  <ManifestoAccent />

  {/* ACTE III · CTA simplifié vers /console pour la console XL */}
  <section style="padding:clamp(64px,8vw,112px) clamp(20px,4vw,48px);background:var(--ink);color:var(--paper);text-align:center">
    <div class="signature-grid on-dark"></div>
    <div style="max-width:1100px;margin:0 auto;position:relative;z-index:1">
      <Kicker class="b-acte-3">
        <span style="color:var(--accent)">III.</span> {lang === 'fr' ? 'La plateforme' : 'The platform'}
      </Kicker>
      <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(48px,8vw,128px);line-height:.94;letter-spacing:-0.03em;color:var(--paper);text-wrap:balance;font-weight:400;margin-bottom:32px">
        {lang === 'fr' ? (
          <>Virtuose<i style="color:var(--accent)">OS</i>.<br />Le <i>noyau</i> sous chaque mission.</>
        ) : (
          <>Virtuose<i style="color:var(--accent)">OS</i>.<br />The <i>kernel</i> under every engagement.</>
        )}
      </h2>
      <PillCTA href={flh('/console', lang)} variant="accent-mono" mag={0.18}>
        ▸ {lang === 'fr' ? 'Voir la console' : 'Discover the platform'}
      </PillCTA>
    </div>
  </section>

  {/* ACTE IV · cards décalées */}
  <section style="padding:clamp(64px,8vw,112px) clamp(20px,4vw,48px);background:var(--paper);color:var(--ink)">
    <div style="max-width:1600px;margin:0 auto">
      <Kicker class="manifesto-acte-iv">
        <span style="color:var(--accent)">IV.</span> {lang === 'fr' ? 'Les preuves' : 'The proof'}
      </Kicker>
      <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(48px,8vw,148px);line-height:.92;letter-spacing:-0.03em;max-width:1400px;margin-bottom:clamp(60px,8vw,100px);text-wrap:balance;font-weight:400">
        {lang === 'fr' ? (<>Pas des démos. Des <i style="color:var(--accent)">résultats</i>.</>) : (<>Not demos. <i style="color:var(--accent)">Results</i>.</>)}
      </h2>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:32px">
        {CASE_FEED.slice(0, 4).map((c, i) => (
          <EditorialCaseCard
            idx={i + 1}
            client={c.client}
            sector={ft(c.sector, lang)}
            stack={c.stack}
            impact={ft(c.impact, lang)}
            duration={c.duration}
            href={flh(`/ressources/cas/${c.slug}`, lang)}
            offset={i % 2 === 1 ? 60 : 0}
          />
        ))}
      </div>
    </div>
  </section>

  {/* WRITING dark */}
  <section style="padding:clamp(120px,14vw,160px) clamp(20px,4vw,48px);background:var(--ink);color:var(--paper)">
    <div style="max-width:1600px;margin:0 auto;display:grid;grid-template-columns:400px 1fr;gap:clamp(40px,6vw,100px)">
      <div>
        <Kicker class="b-writing-tag">{lang === 'fr' ? 'Écrits' : 'Writing'}</Kicker>
        <div style="font-family:var(--font-sans);font-size:clamp(36px,6vw,88px);line-height:.96;letter-spacing:-0.025em;margin-top:28px;color:var(--paper)">
          {lang === 'fr' ? (<>Notes de <i style="color:var(--accent)">terrain</i>, lentement.</>) : (<>Field <i style="color:var(--accent)">notes</i>, slowly.</>)}
        </div>
      </div>
      <div>
        {FIELD_NOTES.map((s) => (
          <EditorialWriteRow
            date={s.date}
            tag={ft(s.tag, lang)}
            href={flh('/ressources/blog', lang)}
            tone="ink"
          >
            {ft(s.text, lang)}
          </EditorialWriteRow>
        ))}
      </div>
    </div>
  </section>

  {/* ACTE V · Stop rehearsing */}
  <section style="padding:clamp(72px,9vw,128px) clamp(20px,4vw,48px);background:var(--paper);text-align:center">
    <div style="max-width:1600px;margin:0 auto">
      <Kicker class="manifesto-acte-v">
        <span style="color:var(--accent)">V.</span> {lang === 'fr' ? "Passer à l'action" : 'Act'}
      </Kicker>
      <h2 class="reveal manifesto-quote-reveal" style="font-family:var(--font-display);font-size:clamp(72px,14vw,260px);line-height:.86;letter-spacing:-0.04em;text-wrap:balance;font-weight:400">
        {lang === 'fr' ? (<>Arrêtez de <i style="color:var(--accent)">répéter</i>.<br />Livrez.</>) : (<>Stop <i style="color:var(--accent)">rehearsing</i>.<br />Ship.</>)}
      </h2>
      <div style="display:inline-flex;gap:14px;margin-top:60px;flex-wrap:wrap;justify-content:center">
        <Button href={flh('/contact', lang)} variant="accent" size="lg" mag={0.22}>
          {lang === 'fr' ? 'Prendre 45 min →' : 'Book 45 min →'}
        </Button>
        <Button href={`mailto:${lang === 'fr' ? 'bonjour@waimia.fr' : 'hello@waimia.fr'}`} variant="ghost" size="lg">
          {lang === 'fr' ? 'bonjour@waimia.fr' : 'hello@waimia.fr'}
        </Button>
      </div>
    </div>
  </section>
  <script>
    // Text reveal Acte V — fade + slide up a l'entree dans le viewport
    // Utilise IntersectionObserver + CSS transitions composited (transform + opacity)
    // Aucun innerHTML — animation CSS pure via style properties
    (function () {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const el = document.querySelector('.manifesto-quote-reveal');
      if (!(el instanceof HTMLElement)) return;
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.9s cubic-bezier(0.22,1,0.36,1), transform 0.9s cubic-bezier(0.22,1,0.36,1)';
      el.style.transitionDelay = '0.2s';
      const obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          obs.unobserve(entry.target);
          var target = entry.target;
          if (!(target instanceof HTMLElement)) return;
          target.style.opacity = '1';
          target.style.transform = 'translateY(0)';
        });
      }, { threshold: 0.2 });
      obs.observe(el);
    })();
  </script>
</Base>

<style>
  /* V7 hero hauteur réduite · marquee remonte above-the-fold (Simon demande)
     · Avant : min-height 100vh + padding 160px/80px = hero seul = viewport entier
     · Après : min-height 84vh + padding 88px/40px = laisse ~144px pour marquee */
  /* V7 fix Simon · hero remplit le viewport JUSQU'AU marquee
     Calcul : viewport - header (79) - marquee (env. 78) = espace hero
     Le marquee complet est visible above-the-fold sans coupure */
  .manifesto-hero {
    position: relative;
    min-height: calc(100vh - 79px - 78px);
    overflow: hidden;
    background: var(--ink);
  }
  .manifesto-hero-inner {
    position: relative;
    z-index: 2;
    padding: clamp(48px, 5vw, 72px) clamp(20px, 4vw, 48px) clamp(36px, 4vw, 48px);
    color: var(--paper);
    min-height: calc(100vh - 79px - 78px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: clamp(28px, 3.5vw, 48px);
    max-width: 1560px;
    margin-inline: auto;
    width: 100%;
  }

  /* Marquee compacté · 86 → 78px pour gagner 8px sur hero */
  .b-marquee-track > span {
    font-size: clamp(20px, 2.4vw, 30px) !important;
  }

  /* V7 harmonisation typographique · Manifesto H1 + H2 cap cohérent
     · Page spéciale peut rester plus imposante que home mais dans la même famille
     · H1 cap 132px (vs ancien 220px) = 1.43× du H1 home tokenisé (92px) */
  .manifesto-h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 9vw, 132px);
    line-height: 0.94;
    letter-spacing: -0.035em;
    color: var(--paper);
    text-wrap: balance;
    font-weight: 400;
    margin: 0;
    max-width: 1400px;
  }
  .manifesto-h1 i { font-style: italic; }
  .manifesto-h1 i.accent { color: var(--accent); }

  /* H2 sections grandes (manifeste, déclaration) · cap 96px cohérent avec home text-h2-grand */
  .manifesto-h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 6vw, 96px);
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 1200px;
    margin: 0 0 clamp(48px, 6vw, 80px);
    text-wrap: balance;
    font-weight: 400;
  }
  .manifesto-h2 i { font-style: italic; }
  .manifesto-h2 i.accent { color: var(--accent); }
  /* Variant paper · sur fond ink (acte I) */
  .manifesto-h2--paper { color: var(--paper); font-family: var(--font-sans); }

  /* Stats inline page spéciale · cap 132 (vs 176) cohérent avec hero-1 page spéciale */
  .manifesto-stat {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 132px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--accent);
  }

  /* Spacing/colors pour les Kicker atoms rendus par les sous-composants
     Note : :global est requis car le scoping Astro ne descend pas dans les composants enfants */
  :global(.manifesto-acte-iv){margin-bottom:32px}
  :global(.manifesto-acte-v){margin-bottom:40px}
  :global(.b-hero-dim){color:rgba(246,241,232,.55) !important}
  :global(.b-hero-tag){color:rgba(246,241,232,.55) !important;margin-bottom:24px}
  :global(.b-acte-1){color:rgba(246,241,232,.5) !important}
  :global(.b-acte-1-sub){color:rgba(246,241,232,.3) !important;letter-spacing:.14em;margin-top:4px}
  :global(.b-acte-3){color:rgba(246,241,232,.5) !important;margin-bottom:32px}
  :global(.b-writing-tag){color:rgba(246,241,232,.5) !important}

  /* Hero meta + foot · layout */
  .b-hero-meta{display:flex;justify-content:space-between;align-items:baseline;flex-wrap:wrap;gap:14px}
  .b-hero-foot{display:flex;flex-direction:column;align-items:flex-end;gap:6px;text-align:right}

  /* Marquee local · plus rapide que le marquee paper du / */
  .b-marquee-track{display:inline-flex;animation:b-slide 80s linear infinite}
  @keyframes b-slide{to{transform:translateX(-33.333%)}}
  @media (prefers-reduced-motion:reduce){.b-marquee-track{animation:none}}

  @media (prefers-reduced-motion: reduce) {
    :global(.liquid-hero canvas) { display: none !important; }
    :global(.liquid-hero) { background: var(--ink); }
  }

</style>
