---
// Page · /cas/caserne · Cas Caserne Industrie FR — route principale nav
export const prerender = true;

import CaseStudyTemplate from '../../components/templates/CaseStudyTemplate.astro';

const specs = [
  { label_fr: 'Secteur',     label_en: 'Sector',      value: 'Industrie · FR' },
  { label_fr: 'Durée',       label_en: 'Duration',    value: '8 semaines' },
  { label_fr: 'Douleur',     label_en: 'Pain point',  value: 'Clôture 9 jours · Excel partout' },
  { label_fr: 'Livré',       label_en: 'Delivered',   value: '1 200 h/an récupérées' },
  { label_fr: 'ROI 12 mois', label_en: 'ROI 12 mo',  value: '3,8×' },
];

const steps = [
  {
    sn: '01', kicker_fr: 'Audit', kicker_en: 'Audit',
    title_fr: '9 jours de clôture. 2,5 jours de reporting CODIR. Excel partout.',
    title_en: '9-day close. 2.5-day CODIR reporting. Excel everywhere.',
    body_fr: "6 personnes en finance et contrôle de gestion. Chaque mois : 9 jours pour clôturer, 2,5 jours pour préparer les notes CODIR. Le reste du temps : maintenance des fichiers Excel et correction des erreurs de consolidation.",
    body_en: "6 people in finance and management control. Every month: 9 days to close, 2.5 days to prepare CODIR notes. The rest: maintaining Excel files and fixing consolidation errors.",
  },
  {
    sn: '02', kicker_fr: 'Excel augmenté', kicker_en: 'Augmented Excel',
    title_fr: "L'Excel ne disparaît pas. Il parle.",
    title_en: "Excel doesn't disappear. It talks.",
    body_fr: "On n'a pas remplacé l'Excel. On l'a augmenté : formules complexes à la voix, détection des anomalies automatique, consolidation sans copier-coller. Les contrôleurs dictent, Excel calcule.",
    body_en: "We didn't replace Excel. We augmented it: complex formulas by voice, automatic anomaly detection, consolidation without copy-paste. Controllers dictate, Excel calculates.",
  },
  {
    sn: '03', kicker_fr: 'Reporting', kicker_en: 'Reporting',
    title_fr: 'Notes CODIR générées automatiquement. Relu en 20 min.',
    title_en: 'CODIR notes generated automatically. Reviewed in 20 min.',
    body_fr: "Chaque note CODIR est générée à partir des données consolidées. Le DAF relit, ajuste les nuances de formulation, valide. 2,5 jours deviennent 4 heures. Le vendredi, le board pack est prêt.",
    body_en: "Each CODIR note is generated from consolidated data. The CFO reviews, adjusts formulation nuances, validates. 2.5 days become 4 hours. Friday, the board pack is ready.",
  },
  {
    sn: '04', kicker_fr: 'Pilotage', kicker_en: 'Dashboard',
    title_fr: 'Tableau de pilotage temps réel. La direction voit avant la clôture.',
    title_en: 'Real-time dashboard. Management sees before close.',
    body_fr: "Un tableau de pilotage financier en temps réel remplace les exports manuels. Les workflows administratifs récurrents (relances, validations, réconciliations) tournent sans intervention. La clôture est passée de 9 à 3 jours.",
    body_en: "A real-time financial dashboard replaces manual exports. Recurring administrative workflows (reminders, validations, reconciliations) run without intervention. Close went from 9 to 3 days.",
  },
];

const proofMetrics = [
  { k: '9 j → 3 j', label_fr: 'Clôture mensuelle',     label_en: 'Monthly close' },
  { k: '2,5 j → 4h', label_fr: 'Reporting CODIR',      label_en: 'CODIR reporting' },
  { k: '1 200 h/an', label_fr: 'Temps récupéré',        label_en: 'Time reclaimed' },
  { k: '3,8×',       label_fr: 'ROI 12 mois',           label_en: 'ROI 12 months' },
];

const techPills = [
  { label: 'Excel augmenté (voix)', kind: 'primary' as const },
  { label: 'Génération notes CODIR', kind: 'primary' as const },
  { label: 'Tableau de pilotage temps réel', kind: 'open' as const },
  { label: 'SAP', kind: 'neutral' as const },
  { label: 'Workflows admin automatisés', kind: 'open' as const },
];

const relatedCards = [
  { kicker: 'CAS 01', title_fr: 'Plateau · pipeline reconnecté', title_en: 'Plateau · pipeline reconnected',
    lead_fr: '+€2,4 M de pipeline récupéré.', lead_en: '+€2.4M pipeline recovered.',
    href: '/cas/plateau' },
  { kicker: 'CAS 02', title_fr: 'Halcyon · triage automatisé', title_en: 'Halcyon · automated triage',
    lead_fr: '−38 % de temps de triage.', lead_en: '−38% triage time.',
    href: '/cas/halcyon' },
  { kicker: 'CAS 03', title_fr: 'Northbound · scoring continu', title_en: 'Northbound · continuous scoring',
    lead_fr: '×3,1 conversion lead → SQL.', lead_en: '×3.1 lead → SQL.',
    href: '/cas/northbound' },
];
---
<CaseStudyTemplate
  title="Cas · Caserne · 1 200 h/an récupérées · Waimia"
  description="6 personnes finance, clôture 9 jours, Excel partout. 8 semaines. 1 200 h/an récupérées. Ce qu'on a câblé."
  caseNum="04"
  specs={specs}
  steps={steps}
  proofQuoteFr="On a remplacé l'Excel manuel par l'Excel parlant. Les contrôleurs sont redevenus analystes."
  proofQuoteEn="We replaced manual Excel with talking Excel. Controllers became analysts again."
  proofAttrFr="DAF · Industrie FR"
  proofAttrEn="CFO · French Industry"
  proofMetrics={proofMetrics}
  techPills={techPills}
  relatedCards={relatedCards}
>
  <Fragment slot="headline">
    <i>Industrie FR.</i><br/>1 200 h/an<br/>récupérées sur Excel.
  </Fragment>
  <Fragment slot="context">
    <p>6 personnes. 9 jours de clôture. 2,5 jours de reporting CODIR. <i>Et Excel partout.</i> Les contrôleurs de gestion passaient leurs semaines à maintenir des fichiers plutôt qu'à analyser.</p>
    <p>On n'a pas remplacé l'Excel. On l'a augmenté. <i>En 8 semaines : clôture à 3 jours, CODIR à 4 heures, 1 200 heures libérées par an.</i></p>
  </Fragment>
  <Fragment slot="approach-headline">
    8 semaines. Finance <i>câblée</i>, pas refondée.
  </Fragment>
  <Fragment slot="approach-aside">
    Excel augmenté → génération CODIR auto → tableau de pilotage → workflows récurrents. Même équipe. Même SAP. Zéro recrutement.
  </Fragment>
  <Fragment slot="stack-lead">
    Excel augmenté à la voix, génération CODIR automatisée, pilotage temps réel. <i>Même équipe. 1 200 h libérées.</i>
  </Fragment>
</CaseStudyTemplate>

<style is:global>
  .case-context-grid p {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.32;
    letter-spacing: -0.012em;
    margin: 0 0 24px;
    text-wrap: pretty;
  }
  .case-context-grid p i { font-style: italic; color: var(--accent); }
</style>
