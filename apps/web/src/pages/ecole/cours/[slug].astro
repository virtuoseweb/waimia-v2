---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import CourseDetailTemplate from '../../../components/templates/CourseDetailTemplate.astro';
import { langFromPath } from '../../../lib/i18n';

export async function getStaticPaths() {
  const allCourses = await getCollection('courses');
  const entries = allCourses.filter((c) => c.data.course_type === 'formation');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

type Props = { entry: CollectionEntry<'courses'> };
const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const lang = langFromPath(Astro.url.pathname);
---
<CourseDetailTemplate entry={entry} lang={lang}>
  <Content />
</CourseDetailTemplate>
