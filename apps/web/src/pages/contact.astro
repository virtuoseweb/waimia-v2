---
// Page · /contact · Form RDV
export const prerender = true;

import { actions, isInputError } from 'astro:actions';
import UtilityTemplate from '../components/templates/UtilityTemplate.astro';
import Button from '../components/ui/atoms/Button.astro';
import CalEmbed from '../components/ui/molecules/CalEmbed.astro';
import Kicker from '../components/ui/atoms/Kicker.astro';
import FormErrors from '../components/ui/atoms/FormErrors.astro';

const result = Astro.getActionResult(actions.contact);

if (result && !result.error && result.data?.redirect) {
  return Astro.redirect(result.data.redirect);
}

const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const otherError = result?.error && !isInputError(result.error)
  ? result.error.message
  : undefined;

const contactLd = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: 'Contact Waimia',
  url: 'https://waimia.com/contact',
  mainEntity: {
    '@type': 'Organization',
    name: 'Waimia',
    email: 'bonjour@waimia.fr',
    contactPoint: [{
      '@type': 'ContactPoint',
      contactType: 'sales',
      email: 'bonjour@waimia.fr',
      areaServed: ['FR', 'CH', 'BE', 'LU'],
      availableLanguage: ['French', 'English'],
    }],
  },
};
---
<UtilityTemplate
  title="Contact · Réserver une séance de travail · Waimia"
  description="Une séance de 45 minutes pour un problème diagnostiqué — ou pas de relance. Paris, Genève, Meet, Zoom. Réponse en 24 h ouvrées."
  kicker="§ Contact"
  align="centered"
  jsonLd={contactLd}
>
  <Fragment slot="headline">
    Une <i>séance</i>.<br />Pas un pitch.
  </Fragment>
  <Fragment slot="lede">
    45 minutes. On revient avec un problème diagnostiqué — ou on ne relance pas.
  </Fragment>

  <Fragment slot="body">
    <div class="contact-grid">
      {/* Form */}
      <form class="contact-form" method="POST" action={actions.contact} name="contact" data-enhanced novalidate>
        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden">
          <label for="contact-hp">Ne pas remplir</label>
          <input type="text" id="contact-hp" name="_hp" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="lang" value="fr" />
        <div class="form-row">
          <label for="company"><span>Entreprise</span><span aria-hidden>*</span></label>
          <input id="company" name="company" type="text" required autocomplete="organization" />
        </div>
        <div class="form-row">
          <label for="name"><span>Votre nom</span><span aria-hidden>*</span></label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="form-row">
          <label for="email"><span>Email pro</span><span aria-hidden>*</span></label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="form-row">
          <label for="role">Fonction</label>
          <input id="role" name="role" type="text" autocomplete="organization-title" />
        </div>
        <div class="form-row form-row-full">
          <label for="brief"><span>Le problème en 3 phrases</span><span aria-hidden>*</span></label>
          <textarea id="brief" name="brief" rows="4" required></textarea>
        </div>
        <FormErrors errors={inputErrors} id="contact-errors" />
        {otherError && <p class="form-error-global" role="alert">{otherError}</p>}
        <Button as="button" type="submit" variant="primary" size="lg">Réserver 45 min →</Button>
      </form>

      {/* Aside · contact direct */}
      <aside class="contact-aside">
        <h2 class="contact-aside-h2">Ou directement</h2>
        <ul class="contact-list">
          <li>
            <span class="contact-k">Email</span>
            <a href="mailto:bonjour@waimia.fr">bonjour@waimia.fr</a>
          </li>
          <li>
            <span class="contact-k">Booking</span>
            <a href="https://cal.com/simonberos/audit" rel="noopener" target="_blank">cal.com/simonberos/audit ↗</a>
          </li>
          <li>
            <span class="contact-k">LinkedIn</span>
            <a href="https://linkedin.com/company/waimia" rel="noopener" target="_blank">/company/waimia ↗</a>
          </li>
          <li>
            <span class="contact-k">Paris</span>
            <span>15 rue de la Paix · 75002</span>
          </li>
          <li>
            <span class="contact-k">Genève</span>
            <span>8 rue du Rhône · 1204</span>
          </li>
        </ul>
        <p class="contact-foot">Réponse en 24 h ouvrées. Tout est NDA-protected. Pas de pitch automatisé.</p>
      </aside>
    </div>

    {/* Cal.com embed inline · option directe sans passer par form */}
    <div class="contact-cal">
      <Kicker tone="accent" class="contact-cal-k">§ Ou directement · réserver maintenant</Kicker>
      <h2 class="contact-cal-h2">Pas de form. <i>Choisissez</i> un créneau.</h2>
      <p class="contact-cal-lead">
        Si vous savez déjà ce dont vous avez besoin, sautez le formulaire et bookez directement
        45 minutes ci-dessous. Calendrier synchronisé Paris-Genève.
      </p>
      <CalEmbed layout="inline" />
    </div>
  </Fragment>
</UtilityTemplate>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(40px, 6vw, 80px);
    max-width: 1100px;
    margin: 0 auto;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 22px;
  }
  .form-row { display: flex; flex-direction: column; gap: 6px; }
  .form-row-full { grid-column: 1 / -1; }
  .form-row label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    gap: 4px;
  }
  .form-row label span:last-child { color: var(--accent); }
  .form-row input,
  .form-row textarea {
    font-family: var(--font-sans);
    font-size: 17px;
    padding: 12px 14px;
    border: 1px solid var(--hairline-strong);
    border-radius: 2px;
    background: var(--paper);
    color: var(--ink);
    transition: border-color 200ms var(--ease);
  }
  .form-row input:focus,
  .form-row textarea:focus {
    border-color: var(--accent);
  }
  .form-errors { color: var(--accent); font-size: 14px; margin-top: 8px; min-height: 1em; }
  .contact-form :global(.btn) { border-radius: 2px; }

  .contact-aside {
    border-left: 1px solid var(--hairline);
    padding-left: clamp(20px, 3vw, 40px);
  }
  .contact-aside-h2 {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.1;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: 0 0 24px;
  }
  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .contact-list li { display: flex; flex-direction: column; gap: 4px; }
  .contact-k {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .contact-list a {
    color: var(--accent);
    transition: color 200ms var(--ease);
  }
  .contact-list a:hover { color: var(--accent-2, var(--accent)); }
  .contact-foot {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    margin: 0;
  }

  .contact-cal {
    max-width: 1100px;
    margin: clamp(60px, 8vw, 100px) auto 0;
    padding-top: clamp(40px, 5vw, 60px);
    border-top: 1px solid var(--hairline);
  }
  :global(.contact-cal-k) { display: block; margin-bottom: 18px; }
  .contact-cal-h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 0 0 18px;
    text-wrap: balance;
    font-weight: 400;
  }
  .contact-cal-h2 :global(i) { font-style: italic; color: var(--accent); }
  .contact-cal-lead {
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 32px;
    max-width: 680px;
  }

  @media (max-width: 800px) {
    .contact-grid { grid-template-columns: 1fr; }
    .contact-aside { border-left: none; padding-left: 0; border-top: 1px solid var(--hairline); padding-top: 32px; }
  }
</style>

<script>
  import { actions } from 'astro:actions';
  import { navigate } from 'astro:transitions/client';

  document.querySelectorAll<HTMLFormElement>('form[data-enhanced]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      const actionPath = form.getAttribute('action');
      if (!actionPath) return;

      try {
        const res = await fetch(actionPath, { method: 'POST', body: formData, headers: { Accept: 'application/json' } });
        const json = await res.json();
        if (res.ok && json?.data?.redirect) {
          navigate(json.data.redirect);
          return;
        }
        form.removeEventListener('submit', () => {});
        form.submit();
      } catch {
        if (submitBtn) submitBtn.disabled = false;
        form.submit();
      }
    });
  });
</script>
