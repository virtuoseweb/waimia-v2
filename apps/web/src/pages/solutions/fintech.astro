const techPills = [
  { label: 'Claude Opus 4.7', kind: 'primary' as const },
  { label: 'Claude Sonnet 4.6', kind: 'primary' as const },
  { label: 'VirtuoseOS', kind: 'primary' as const },
  { label: 'PostgreSQL', kind: 'open' as const },
  { label: 'dbt', kind: 'open' as const },
  { label: 'Snowflake', kind: 'neutral' as const },
  { label: 'Salesforce Financial Services', kind: 'neutral' as const },
];

const proofMetrics = [
  { k: '−72%',   label_fr: 'temps préparation dossier',        label_en: 'case prep time' },
  { k: '+38%',   label_fr: 'taux détection LCB-FT',             label_en: 'AML detection rate' },
  { k: '× 4',    label_fr: 'volume audits sans renforts équipe', label_en: 'audit volume without headcount' },
  { k: '0',      label_fr: 'incidents AI Act 12 derniers mois',  label_en: 'AI Act incidents last 12 months' },
];

const relatedCards = [
  { kicker: 'CASE 11', title_fr: 'Northbound (fintech UE)', title_en: 'Northbound (EU fintech)',
    lead_fr: '×3.1 conversion sans bug AI Act →', lead_en: '×3.1 conversion no AI Act incident →',
    href: '/ressources/cas/northbound' },
  { kicker: 'TRUST', title_fr: 'Trust Center · ACPR + AI Act', title_en: 'Trust Center · ACPR + AI Act',
    lead_fr: 'Notre politique conformité fintech →', lead_en: 'Our fintech compliance policy →',
    href: '/agence/trust-center' },
