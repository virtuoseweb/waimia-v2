    body_fr: "On dresse la carte ACPR / DSP2 / LCB-FT / AI Act applicable à vos lignes métier.",
    body_en: 'We map the ACPR / PSD2 / AML / EU AI Act surface across your business lines.' },
  { sn: '02', kicker_fr: 'Auditer', kicker_en: 'Audit',
    title_fr: "Lacunes données & process", title_en: 'Data & process gaps',
    body_fr: "Audit warehouse, KYC pipelines, scoring credit. On note où l'agent IA ne pourra pas passer.",
    body_en: 'Warehouse audit, KYC pipelines, credit scoring. We log where the AI agent cannot pass.' },
  { sn: '03', kicker_fr: 'Déployer', kicker_en: 'Ship',
    title_fr: 'Agents conformes', title_en: 'Compliant agents',
    body_fr: "Triage anti-fraude, mémo conformité, génération KYC — chacun audité, signé, traçable.",
    body_en: 'Anti-fraud triage, compliance memos, KYC generation — each audited, signed, traceable.' },
