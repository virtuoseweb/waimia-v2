---
// Page · /solutions · Hub des 5 cas d'usage business horizontaux.
// M2 : recadrage FR autour des douleurs PME récurrentes, sans créer les pages secteurs.

import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import Cases from '../../components/ui/organisms/Cases.astro';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';

const horizontalSolutions = [
  { num: '01', kicker: 'PROBLÈME · ACQUISITION',
    title_fr: 'Acquisition IA', sub_fr: 'Plus de leads qualifiés, sans recruter',
    lead_fr: "Pas de SDR à 80 k€. Pas de LinkedIn en continu. Un pipeline qui tourne la nuit.",
    href: '/solutions/acquisition-ia' },
  { num: '02', kicker: 'PROBLÈME · CRM & RELANCES',
    title_fr: 'CRM & relances IA', sub_fr: 'Pipeline qui ne dort jamais',
    lead_fr: 'CRM en jachère, leads oubliés, forecast au doigt mouillé. On répare en silence.',
    href: '/solutions/crm-relances-ia' },
  { num: '03', kicker: 'PROBLÈME · CONTENU',
    title_fr: 'Contenu SEO / GEO IA', sub_fr: 'Trouvé par Google et les IA',
    lead_fr: 'Articles SEO premium, fiches GEO-ready, indexation sur les assistants IA.',
    href: '/solutions/contenu-seo-geo-ia' },
  { num: '04', kicker: 'PROBLÈME · PRODUCTIVITÉ',
    title_fr: 'Productivité IA', sub_fr: 'Excel et Office augmentés',
    lead_fr: 'Reporting auto, formules à la voix, lisibilité retrouvée. Le temps qui change la décision.',
    href: '/solutions/productivite-ia' },
  { num: '05', kicker: 'PROBLÈME · SUPPORT CLIENT',
    title_fr: 'Support client IA', sub_fr: 'Réponses 24/7, escalade intelligente',
    lead_fr: "Triage automatique, premier niveau résolu, l'équipe humaine sur les vrais sujets.",
    href: '/solutions/support-client-ia' },
];

const sectorSatellites = [
  { kicker: 'SECTEUR · 01', title_fr: 'Services B2B', lead_fr: 'Cabinets, conseil, agences, prestataires →', href: '/secteurs/services-b2b' },
  { kicker: 'SECTEUR · 02', title_fr: 'Industrie & PME industrielles', lead_fr: 'ERP, maintenance, qualité →', href: '/secteurs/industrie' },
  { kicker: 'SECTEUR · 03', title_fr: 'Finance & cabinets comptables', lead_fr: 'Réconciliation, reporting, conformité →', href: '/secteurs/finance-compta' },
];
---
<Base
  title="Solutions · 5 cas d'usage business · Waimia"
  description="Cinq systèmes IA pour les douleurs récurrentes des PME : acquisition, CRM, contenu, productivité, support."
>
  <section class="hub-mast">
    <div class="wrap-wide">
      <Kicker class="hub-kicker">§ Solutions · 5 cas d'usage horizontaux</Kicker>
      <h1 class="hub-h1">Cinq <i>problèmes</i> business. Une <i>méthode</i>.</h1>
      <p class="hub-lede">
        Cinq douleurs récurrentes. Pas de slide sur l'IA — un système câblé à votre stack, mesuré dès la première semaine.
      </p>
      <p class="hub-canonical">
        Nous ne vendons pas de l'IA. Nous construisons des <strong>systèmes</strong> qui tournent dans vos outils, que vous pouvez reprendre en main.
      </p>
    </div>
  </section>

  <section class="hub-solutions wrap-wide" aria-label="Solutions horizontales">
    {horizontalSolutions.map((sol) => (
      <a href={sol.href} class="hub-sol-card">
        <div class="hub-sol-num">{sol.num}</div>
        <div class="hub-sol-kicker">{sol.kicker}</div>
        <h3 class="hub-sol-title">{sol.title_fr}</h3>
        <p class="hub-sol-sub">{sol.sub_fr}</p>
        <p class="hub-sol-lead">{sol.lead_fr}</p>
        <span class="hub-sol-cta">Voir la solution →</span>
      </a>
    ))}
  </section>

  <section class="hub-sectors">
    <div class="wrap-wide">
      <Kicker>§ Adapté à votre secteur</Kicker>
      <h2 class="hub-h2">Une méthode, votre <i>vocabulaire</i>.</h2>
      <p class="hub-lede">
        Mêmes systèmes, adaptés au métier — services B2B, industrie, finance & compta. Le reste à venir.
      </p>
      <div class="hub-sector-grid">
        {sectorSatellites.map((s) => (
          <a href={s.href} class="hub-sector-card">
            <div class="hub-sector-kicker">{s.kicker}</div>
            <h4>{s.title_fr}</h4>
            <p>{s.lead_fr}</p>
          </a>
        ))}
        <a href="/secteurs" class="hub-sector-card hub-sector-card--all">
          <div class="hub-sector-kicker">TOUS</div>
          <h4>Tous les secteurs</h4>
          <p>L'index complet, à venir →</p>
        </a>
      </div>
    </div>
  </section>

  <Cases />
  <CtaBand />
</Base>

<style>
  .hub-mast { padding: 140px 32px clamp(44px, 6vw, 84px); }
  :global(.hub-kicker) { display: block; margin-bottom: 24px; }
  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--accent); }
  .hub-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 28px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.4;
    text-wrap: pretty;
  }
  .hub-canonical {
    max-width: 720px;
    margin: 22px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }
  .hub-canonical strong {
    color: var(--accent);
    font-weight: 500;
  }

  .hub-solutions {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1px;
    padding: 0 32px clamp(80px, 10vw, 128px);
  }
  .hub-sol-card {
    min-height: 440px;
    padding: clamp(24px, 2.5vw, 34px);
    border: 1px solid var(--hairline);
    background: var(--paper);
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: background 220ms var(--ease), border-color 220ms var(--ease), transform 220ms var(--ease);
  }
  .hub-sol-card:hover {
    background: var(--paper-2);
    border-color: color-mix(in srgb, var(--accent) 48%, var(--hairline));
    transform: translateY(-4px);
  }
  .hub-sol-num {
    font-family: var(--font-display);
    font-size: clamp(42px, 4.5vw, 72px);
    line-height: 0.9;
    color: var(--accent);
    font-style: italic;
    margin-bottom: auto;
  }
  .hub-sol-kicker,
  .hub-sector-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .hub-sol-title {
    font-family: var(--font-display);
    font-size: clamp(27px, 3vw, 42px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 18px 0 10px;
    text-wrap: balance;
  }
  .hub-sol-sub {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 18px;
    text-wrap: balance;
  }
  .hub-sol-lead {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 28px;
  }
  .hub-sol-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-top: auto;
  }

  .hub-sectors {
    padding: clamp(80px, 10vw, 120px) 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .hub-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 18px 0 0;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-h2 :global(i) { font-style: italic; color: var(--accent); }
  .hub-sector-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin-top: clamp(40px, 5vw, 72px);
    border: 1px solid var(--hairline);
    background: var(--hairline);
  }
  .hub-sector-card {
    min-height: 230px;
    background: var(--paper);
    color: inherit;
    padding: clamp(24px, 2.6vw, 34px);
    display: flex;
    flex-direction: column;
    transition: background 220ms var(--ease), color 220ms var(--ease);
  }
  .hub-sector-card:hover { background: var(--ink); color: var(--paper); }
  .hub-sector-card:hover .hub-sector-kicker,
  .hub-sector-card:hover p { color: color-mix(in srgb, var(--paper) 72%, var(--accent)); }
  .hub-sector-card h4 {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.5vw, 34px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: auto 0 16px;
    text-wrap: balance;
  }
  .hub-sector-card p {
    color: var(--muted);
    line-height: 1.45;
    margin: 0;
  }
  .hub-sector-card--all { background: var(--ink); color: var(--paper); }
  .hub-sector-card--all .hub-sector-kicker,
  .hub-sector-card--all p { color: color-mix(in srgb, var(--paper) 72%, var(--accent)); }

  @media (max-width: 1180px) {
    .hub-solutions { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .hub-sector-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 700px) {
    .hub-mast { padding-top: 96px; }
    .hub-solutions {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }
    .hub-sol-card { min-height: 330px; }
    .hub-sectors { padding-inline: 20px; }
    .hub-sector-grid { grid-template-columns: 1fr; }
  }
</style>
