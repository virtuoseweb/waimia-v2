---
export const prerender = true;

import SolutionsDetailTemplate from '../../components/templates/SolutionsDetailTemplate.astro';
import { buildBreadcrumbList, buildFAQPage, buildOrganization } from '../../lib/seo/schema-builder';

const breadcrumb = buildBreadcrumbList([
  { name: 'Accueil', url: 'https://waimia.com' },
  { name: 'Solutions', url: 'https://waimia.com/solutions' },
  { name: 'Site web IA · PME B2B' },
]);

const faqItems = [
  { q: "Combien coûte un site web IA-native pour PME B2B ?", a: "Un site web IA-native pour PME B2B représente un investissement de 8 à 25 k€ selon la complexité (nombre de personas, volume éditorial, intégrations CRM). Ce budget couvre refonte ou création, landing pages par persona, pipeline éditorial automatisé et tracking complet. Le ROI médian sur 12 mois est de 4,1× grâce à l'augmentation des leads qualifiés et à la réduction du temps de qualification commerciale." },
  { q: "Quel ROI sur un site refondu en IA pour cabinet conseil ?", a: "Les cabinets conseil que nous accompagnons voient en médiane ×2,4 de leads qualifiés supplémentaires par mois dans les 90 jours suivant la mise en ligne. Sur 12 mois, le ROI mesuré dépasse 4× l'investissement initial. L'essentiel du gain vient du pipeline éditorial SEO/GEO qui capte l'intention de recherche des décideurs en phase d'évaluation." },
  { q: "Comment l'IA optimise les conversions d'un site B2B ?", a: "L'IA intervient sur trois leviers : personnalisation des landing pages par persona (copy + offre + CTA adaptés), scoring automatique des visiteurs entrants selon leur comportement (pages vues, temps, source), et pipeline éditorial qui produit du contenu indexé pour chaque requête longue-traîne de votre ICP. Le résultat est une chaîne de conversion mesurée de l'article jusqu'au premier rendez-vous." },
  { q: "Faut-il un développeur en interne pour maintenir ?", a: "Non. Le site est livré avec un runbook complet, une formation de 2 jours pour votre équipe et une documentation opérationnelle. Le pipeline éditorial est autonome (production + publication automatisées). Les seules interventions humaines sont la validation éditoriale (30 min/semaine) et les mises à jour stratégiques trimestrielles." },
  { q: "Le site web IA est-il compatible avec mon CRM HubSpot/Salesforce/Pipedrive ?", a: "Oui, le site est conçu pour se connecter nativement à votre CRM existant (HubSpot, Salesforce, Pipedrive — au choix). Les formulaires, le tracking comportemental et le scoring des leads s'alimentent directement dans votre CRM sans migration. Vous gardez votre historique et vos workflows existants." },
  { q: "Combien de temps pour refondre mon site avec IA ?", a: "Le délai médian de refonte complète est de 6 à 8 semaines : 1 semaine d'audit et cadrage, 2-3 semaines de développement et production des premières landing pages, 1-2 semaines d'intégration CRM et tracking, 1 semaine de tests et mise en ligne. Le pipeline éditorial démarre en semaine 4, avant même la mise en ligne du site complet." },
  { q: "Quelle différence avec un site fait par une agence web classique ?", a: "Une agence web classique livre un site statique — beau mais passif. Un site IA-native est un système d'acquisition actif : il produit du contenu en continu (8 articles/semaine), qualifie les visiteurs automatiquement, adapte le message selon le persona et alimente le CRM sans intervention humaine. La différence visible : un site classique génère des visites, un site IA-native génère des leads qualifiés." },
];

const faqSchema = buildFAQPage(faqItems);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Site web IA · PME B2B — Waimia',
  description: "Site web IA-native pour PME B2B : landing pages par persona, pipeline éditorial SEO/GEO automatisé, scoring leads, intégration CRM. Pas un site vitrine — un système d'acquisition.",
  provider: { '@type': 'Organization', name: 'Waimia', url: 'https://waimia.com' },
  areaServed: ['FR', 'CH'],
  serviceType: 'Site web IA-native · Acquisition B2B',
};

const schemas = [serviceSchema, faqSchema, breadcrumb].filter(Boolean);
---
<SolutionsDetailTemplate
  dept="SITE WEB IA"
  deptLabel="Site web IA · PME B2B"
  meta="Acquisition · PME B2B · Cabinet Conseil"
  title="Site web IA PME B2B — Agence refonte site éditorial IA | Waimia"
  description="Site web IA-native pour PME B2B : landing pages par persona, pipeline éditorial SEO/GEO automatisé, scoring leads, intégration CRM HubSpot/Salesforce/Pipedrive. ×2,4 leads qualifiés en 90 jours."
  ctaLabel="Câbler mon site →"
>
  <Fragment slot="title"><i>Site web</i><br />IA · PME B2B</Fragment>
  <Fragment slot="lead">
    Pas un site vitrine. Un site qui qualifie.
    <span>Landing pages, pipeline éditorial, scoring automatique — câblés dès la première semaine.</span>
  </Fragment>
  <Fragment slot="tags">
    <span class="sol-tag">Landing IA</span>
    <span class="sol-tag">SEO / GEO</span>
    <span class="sol-tag">Tracking B2B</span>
    <span class="sol-tag">Schema.org</span>
    <span class="sol-tag">CRM natif</span>
  </Fragment>
  <Fragment slot="pains">
    <div class="pain-card">
      <div class="pn">01</div>
      <div class="pk">Non mesuré</div>
      <h3>Le site vitrine<br />sans données</h3>
      <p>Votre site existe depuis 5 ans. Vous ne savez pas combien il génère de leads par mois, ni quel persona convertit. Le budget web est dépensé mais aucune ligne du pipeline ne lui est attribuable.</p>
    </div>
    <div class="pain-card">
      <div class="pn">02</div>
      <div class="pk">Invisible Google + IA</div>
      <h3>Contenu enfoui<br />page 4</h3>
      <p>Les articles de blog sont publiés par réflexe SEO mais restent en page 4 de Google. Les IA génératives ne citent pas votre marque. Vous produisez du contenu que personne ne trouve.</p>
    </div>
    <div class="pain-card">
      <div class="pn">03</div>
      <div class="pk">Pas de tracking</div>
      <h3>Zéro visibilité<br />sur l'intention</h3>
      <p>Les visiteurs arrivent et repartent. Sans scoring comportemental, aucun visiteur n'est qualifié avant qu'il vous contacte. Le commercial qualifie à la main — 40 % de son temps perdu.</p>
    </div>
    <div class="pain-card">
      <div class="pn">04</div>
      <div class="pk">Propositions chronophages</div>
      <h3>Chaque devis<br />fait à la main</h3>
      <p>La qualification commerciale prend 5 à 9 jours. Chaque proposition est rédigée de zéro. Le cycle de vente est long parce que le site ne prépare pas le terrain avant le premier appel.</p>
    </div>
  </Fragment>
  <Fragment slot="workflows">
    <div class="wf-row">
      <div class="wf-n">01</div>
      <div class="wf-name"><span class="wf-k">Persona</span><h3>Landing par profil décideur</h3></div>
      <div class="wf-model">Raisonnement IA<br />+ HubSpot</div>
      <div class="wf-gain">×2,4</div>
      <div class="wf-how">Une landing dédiée par persona (DSI, DG, DAF, RH…). Copy, offre et CTA adaptés à l'intention de chaque profil. Variations testées automatiquement sans intervention humaine.</div>
    </div>
    <div class="wf-row">
      <div class="wf-n">02</div>
      <div class="wf-name"><span class="wf-k">Éditorial</span><h3>Pipeline SEO / GEO automatisé</h3></div>
      <div class="wf-model">IA rédaction longue<br />+ Search APIs</div>
      <div class="wf-gain">8/sem</div>
      <div class="wf-how">8 articles par semaine optimisés pour Google et les IA génératives. Chaque article cible une requête longue-traîne de votre ICP, avec Schema.org Article et BreadcrumbList intégrés.</div>
    </div>
    <div class="wf-row">
      <div class="wf-n">03</div>
      <div class="wf-name"><span class="wf-k">Capture</span><h3>Formulaires connectés CRM</h3></div>
      <div class="wf-model">Intégration CRM<br />+ Email infra</div>
      <div class="wf-gain">−0j délai</div>
      <div class="wf-how">Chaque formulaire alimente directement votre CRM (HubSpot, Salesforce ou Pipedrive). Aucun lead ne tombe dans un fichier Excel. La relance automatique démarre dans la minute.</div>
    </div>
    <div class="wf-row">
      <div class="wf-n">04</div>
      <div class="wf-name"><span class="wf-k">Qualification</span><h3>Scoring comportemental automatique</h3></div>
      <div class="wf-model">IA volume<br />+ Analytics</div>
      <div class="wf-gain">−62%</div>
      <div class="wf-how">Chaque visiteur est scoré en temps réel : pages visitées, temps passé, source, récurrence. Le commercial reçoit uniquement les leads au-dessus du seuil de qualification — les autres sont nurtured.</div>
    </div>
    <div class="wf-row">
      <div class="wf-n">05</div>
      <div class="wf-name"><span class="wf-k">Pilotage</span><h3>Dashboards conversion temps réel</h3></div>
      <div class="wf-model">Analytics GA4<br />+ CRM KPI</div>
      <div class="wf-gain">J+1</div>
      <div class="wf-how">Dashboard de conversion accessible web et Slack. Vous voyez en temps réel : leads entrants, taux de qualification, temps moyen lead→RDV, articles générateurs de pipeline. Tout est attribué.</div>
    </div>
  </Fragment>
  <Fragment slot="roi">
    <div class="roi-cell"><div class="roi-v">×2,4</div><div class="roi-l">leads qualifiés<br />par mois</div></div>
    <div class="roi-cell"><div class="roi-v">+€840K</div><div class="roi-l">pipeline généré<br />médiane 12 mois</div></div>
    <div class="roi-cell"><div class="roi-v">8/sem</div><div class="roi-l">articles SEO/GEO<br />indexés</div></div>
    <div class="roi-cell"><div class="roi-v">4,1×</div><div class="roi-l">ROI mesuré<br />à 12 mois</div></div>
  </Fragment>
  <Fragment slot="case-kicker">Cas client · SaaS B2B</Fragment>
  <Fragment slot="case-title">Plateau, SaaS B2B.<br /><i>×3,4 vélocité</i><br />pipeline en 10 semaines.</Fragment>
  <Fragment slot="case-body">Plateau avait un site vitrine de 8 pages et un blog dormant à 4 articles/mois. Aucune landing dédiée par persona, zero tracking comportemental, 0 lien avec leur CRM HubSpot. Waimia a refondu le site en 6 semaines : 5 landings par persona, pipeline éditorial à 8 articles/semaine et scoring auto. En 10 semaines, le pipeline qualifié est passé de 480 à 1 720 opportunités.</Fragment>
  <Fragment slot="case-cta-label">Voir le cas Plateau →</Fragment>
  <Fragment slot="case-results">
    <div class="res-row"><div class="res-v">9→3j</div><div class="res-l">lead → premier RDV</div></div>
    <div class="res-row"><div class="res-v">+€2,4M</div><div class="res-l">pipeline reconnecté</div></div>
    <div class="res-row"><div class="res-v">4,1×</div><div class="res-l">ROI mesuré 12 mois</div></div>
  </Fragment>
  <Fragment slot="stack">
    <div class="stack-card">
      <span class="stack-k">Pipeline éditorial</span>
      <h3>Articles SEO / GEO</h3>
      <p>Production automatisée de 8 articles/semaine avec recherche de mots-clés, rédaction et publication. Chaque article cible une requête de votre ICP.</p>
      <span class="stack-pill primary">Éditorial IA · primary</span>
    </div>
    <div class="stack-card">
      <span class="stack-k">Scoring visiteurs</span>
      <h3>Qualification comportementale</h3>
      <p>Scoring temps réel des visiteurs selon intention de recherche, comportement on-site et signaux firmographiques. Qualification avant le premier contact commercial.</p>
      <span class="stack-pill primary">IA qualification · primary</span>
    </div>
    <div class="stack-card">
      <span class="stack-k">CRM connecté</span>
      <h3>HubSpot · Salesforce · Pipedrive</h3>
      <p>Intégration native avec votre CRM existant. Aucune migration. Chaque lead est dans votre CRM dans la minute qui suit sa conversion.</p>
      <span class="stack-pill secondary">Intégrations · secondary</span>
    </div>
    <div class="stack-card">
      <span class="stack-k">Analytics</span>
      <h3>GA4 + Dashboards</h3>
      <p>Tracking complet avec attribution multi-touch. Dashboard de pilotage commercial accessible web et Slack. Zéro point aveugle sur le pipeline.</p>
      <span class="stack-pill secondary">Analytics · secondary</span>
    </div>
    <div class="stack-card">
      <span class="stack-k">Schema.org</span>
      <h3>Balisage structuré</h3>
      <p>Chaque page et article est balisé avec les schémas adaptés (Service, Article, FAQPage, BreadcrumbList). Lisible par Google et les IA génératives.</p>
      <span class="stack-pill secondary">SEO technique · secondary</span>
    </div>
    <div class="stack-card">
      <span class="stack-k">Hébergement</span>
      <h3>Vercel · Cloudflare</h3>
      <p>Déploiement continu, edge network mondial, temps de chargement &lt; 1 s. Le site ne plante pas quand un article décolle.</p>
      <span class="stack-pill open">Infrastructure</span>
    </div>
  </Fragment>
  <Fragment slot="cta-title">Votre site,<br /><i>câblé.</i></Fragment>
  <Fragment slot="cta-body">45 minutes. On regarde votre site actuel, on identifie les 3 workflows à fort ROI. Si on n'a rien à proposer, on le dit — sans relance.</Fragment>
  <Fragment slot="related">
    <script type="application/ld+json" set:html={JSON.stringify(schemas)}></script>
    <section style="padding: clamp(48px,6vw,80px) 0; background: var(--paper-2, #EFEBE2);">
      <div style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
        <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:12px;">Vous avez besoin de plus ?</div>
        <p style="font-family:var(--font-display); font-size:clamp(18px,1.6vw,22px); line-height:1.4; color:var(--ink); max-width:600px; margin:0 0 20px;">Pour les cas d'usage qui nécessitent une <strong>app IA propriétaire</strong> au-delà du site — interfaces métier, données privées, workflow opérationnel — notre offre Application IA · PME prend le relais.</p>
        <a href="/offres/application-ia-pme" style="font-family:var(--font-mono); font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--accent); text-decoration:none; border-bottom:1px solid currentColor; padding-bottom:2px;">Découvrir Application IA · PME · 15–50 k€ →</a>
      </div>
    </section>
  </Fragment>
</SolutionsDetailTemplate>
