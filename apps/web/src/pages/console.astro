---
// Page · /console · Direction C · port DirectionC.tsx
export const prerender = true;

// Pacing :
//   1. Hero terminal · split (titre + console mockup blink)
//   2. 5 metrics strip
//   3. Marquee
//   4. Acte I paper-2 · 4 OBS rows (43 / 9 / ×4 / replatforming)
//   5. Acte II terminal-table · 6 services en grille [id|service|description|status]
//   6. Manifesto interlude dark
//   7. Acte III · ProductReel sticky scroll (signature)
//   8. Acte IV · cases en table [id|client|sector|duration|stack|impact]
//   9. Writing
//   10. Acte V dark · "Open a session. Not a pitch."

import Base from '../layouts/Base.astro';
import ProductReel from '../components/motion/ProductReel.tsx';
import Kicker from '../components/ui/atoms/Kicker.astro';
import TerminalCTA from '../components/ui/atoms/TerminalCTA.astro';
import TerminalMockup from '../components/ui/molecules/TerminalMockup.astro';
import EditorialWriteRow from '../components/ui/molecules/EditorialWriteRow.astro';
import TerminalTable from '../components/ui/molecules/TerminalTable.astro';
import { CASE_FEED, FIELD_NOTES, SIX_SERVICES } from '../data/sitemap';
import { langFromPath, t as ft, localizeHref as flh } from '../lib/i18n';

const lang = langFromPath(Astro.url.pathname);

// V7 obs alignées doctrine Waimia · marketing/sales/contenu/web/CRM/data/brand
const OBS = [
  { tag: '[obs.1]', text: { en: 'Ads + CRM + content + site disconnected = signals wasted.', fr: 'Ads + CRM + contenu + site déconnectés = signaux gaspillés.' } },
  { tag: '[obs.2]', text: { en: 'AI without business data = expensive guess.',                fr: 'IA sans données métier = conjecture chère.' } },
  { tag: '[obs.3]', text: { en: '5-day system beats 5-month rebuild ×4.',                     fr: 'Système 5 jours > refonte 5 mois ×4.' } },
  { tag: '[obs.4]', text: { en: 'Brand fragments when AI produces without rails.',            fr: "La marque se fragmente sans rails de production IA." } },
];

const METRICS = [
  ['uptime',    '99.98%'],
  ['workspaces','4 active'],
  ['agents',    '14 live'],
  ['locale',    'fr-FR / en-US'],
  ['release',   '2.4.1 · 04.2026'],
];
---
<Base
  title={lang === 'fr' ? "Waimia · Console · Un OS pour les opérations revenue" : 'Waimia · Console · An operating system for revenue ops'}
  description={lang === 'fr'
    ? "Direction C · Variante Console. Hero terminal + ProductReel sticky scroll · faire défiler la console pour voir VirtuoseOS opérer."
    : 'Direction C · Console variant. Terminal hero + sticky ProductReel · scroll the console to see VirtuoseOS in action.'}
>
  {/* HERO terminal split */}
  <section style="padding:clamp(72px,8vw,108px) clamp(20px,4vw,48px) clamp(48px,5vw,72px);background:var(--paper)">
    <div style="max-width:1500px;margin:0 auto">
      {/* meta bar */}
      <div class="c-meta-bar">
        <Kicker as="span"><span style="color:var(--accent)">◉</span> virtuoseos · v2.4.1 · {lang === 'fr' ? 'sortie 04.2026' : 'released 04.2026'}</Kicker>
        <Kicker as="span">Waimia · Paris · {lang === 'fr' ? 'bilingue FR · EN' : 'bilingual EN · FR'}</Kicker>
      </div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,5vw,56px);align-items:end">
        {/* left · headline */}
        <div>
          <Kicker tone="accent" class="c-platform-tag">
            [platform] · {lang === 'fr' ? "VirtuoseOS · OS interne propriétaire Waimia · pas un SaaS" : 'VirtuoseOS · Waimia proprietary OS · not a SaaS'}
          </Kicker>
          <h1 class="reveal-mask-up" style="font-family:var(--font-display);font-size:clamp(40px,6.5vw,96px);line-height:.92;letter-spacing:-0.028em;text-wrap:balance;font-weight:400;margin:0">
            {lang === 'fr' ? (
              <>Un <i>système d'exploitation</i><br />pour vos opérations <i>revenue</i>.</>
            ) : (
              <>An <i>operating system</i><br />for your <i>revenue</i> operations.</>
            )}
          </h1>
          <p style="margin-top:32px;font-size:clamp(15px,1.4vw,17px);line-height:1.55;color:var(--muted);max-width:560px;font-family:var(--font-sans)">
            {lang === 'fr'
              ? "VirtuoseOS orchestre acquisition, contenu, CRM, site, analytics et marque dans une couche commune — agents, règles, mesure, validation humaine. Vous gardez la plateforme quand on part."
              : "VirtuoseOS orchestrates acquisition, content, CRM, site, analytics and brand into one common layer — agents, rules, measurement, human validation. You keep the platform when we leave."}
          </p>
          <div style="margin-top:20px;font-family:var(--font-mono);font-size:12px;color:var(--accent);letter-spacing:.06em;line-height:1.5">
            {lang === 'fr'
              ? <>▸ 4 workspaces actifs · 14 agents IA · 99,98&nbsp;% uptime · audit trail signé</>
              : <>▸ 4 workspaces live · 14 AI agents · 99.98% uptime · signed audit trail</>}
          </div>
          <div style="display:flex;gap:10px;margin-top:36px;flex-wrap:wrap">
            <TerminalCTA href="#act-3" variant="ink" size="md" mag={0.18}>
              ▸ {lang === 'fr' ? 'ouvrir la console' : 'open the console'}
            </TerminalCTA>
            <TerminalCTA href={flh('/contact', lang)} variant="ink-ghost" size="md">
              {lang === 'fr' ? 'prendre une séance →' : 'book a working session →'}
            </TerminalCTA>
          </div>
        </div>

        {/* right · terminal mockup · molécule TerminalMockup */}
        <TerminalMockup
          label="waimia@virtuose ~ / plateau-saas"
          status="◉ 14:22 UTC+1"
          tone="ink"
          bodyPadding={18}
          class="c-hero-term"
        >
          <div id="console-terminal-body" style="color:rgba(246,241,232,.8);font-family:var(--font-mono);font-size:13px;line-height:1.6;min-height:180px">
            <div id="console-terminal-output"></div>
            <div style="padding:4px 0"><span style="color:var(--accent)">$ </span><span id="console-terminal-cursor" class="c-cursor"></span></div>
          </div>
        </TerminalMockup>
      </div>

      {/* 5 metrics strip */}
      <div style="margin-top:clamp(48px,5vw,72px);display:grid;grid-template-columns:repeat(5,1fr);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline)">
        {METRICS.map(([k, v], i) => (
          <div style={`padding:20px;border-right:${i < 4 ? '1px solid var(--hairline)' : 'none'}`}>
            <div style="font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)">{k}</div>
            <div style="font-family:var(--font-mono);font-size:15px;margin-top:6px;color:var(--ink)">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* ACTE I · paper-2 · 4 obs */}
  <section id="act-1" style="padding:clamp(120px,14vw,160px) clamp(20px,4vw,48px);background:var(--paper-2);border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline)">
    <div style="max-width:1500px;margin:0 auto;display:grid;grid-template-columns:280px 1fr;gap:clamp(32px,5vw,64px)">
      <div style="position:sticky;top:120px;align-self:start">
        <Kicker tone="accent">[act.01]</Kicker>
        <Kicker class="c-acte-sub">{lang === 'fr' ? 'Le constat' : 'The reckoning'}</Kicker>
      </div>
      <div>
        <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(36px,5.5vw,88px);line-height:1;letter-spacing:-0.02em;margin-bottom:48px;font-weight:400;text-wrap:balance">
          {lang === 'fr' ? (
            <>La plupart des projets IA livrent une <i style="color:var(--accent)">démo</i>. Pas un produit.</>
          ) : (
            <>Most AI projects ship a <i style="color:var(--accent)">demo</i>. Not a product.</>
          )}
        </h2>
        <p class="reveal" style="font-family:var(--font-sans);font-size:clamp(17px,1.4vw,20px);line-height:1.55;color:var(--ink-2);max-width:780px;margin-bottom:48px;text-wrap:pretty">
          {lang === 'fr'
            ? <>Quatre observations terrain. Recueillies entre Paris et Genève, sur 23 stacks différentes. Aucun modèle n&rsquo;a échoué&nbsp;: ce sont toujours <i style="color:var(--accent)">les rails</i> qui manquent.</>
            : <>Four field observations. Collected between Paris and Geneva, across 23 different stacks. No model ever failed: it&rsquo;s always <i style="color:var(--accent)">the rails</i> that were missing.</>}
        </p>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--hairline);border-radius:10px;overflow:hidden;background:var(--paper)">
          {OBS.map((r, i) => (
            <div class="reveal" style={`padding:28px 24px;border-right:${i % 2 === 0 ? '1px solid var(--hairline)' : 'none'};border-bottom:${i < 2 ? '1px solid var(--hairline)' : 'none'}`}>
              <Kicker tone="accent">{r.tag}</Kicker>
              <div style="font-family:var(--font-sans);font-size:clamp(20px,2vw,26px);line-height:1.18;margin-top:10px;letter-spacing:-0.01em">
                {ft(r.text, lang)}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* ACTE II · services terminal-table */}
  <section id="act-2" style="padding:clamp(120px,14vw,160px) clamp(20px,4vw,48px)">
    <div style="max-width:1500px;margin:0 auto">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:60px;padding-bottom:20px;border-bottom:1px solid var(--hairline);flex-wrap:wrap;gap:10px">
        <Kicker tone="accent">
          [act.02] · <span style="color:var(--muted)">{lang === 'fr' ? 'la méthode' : 'the method'}</span>
        </Kicker>
        <Kicker>6 services · in-house</Kicker>
      </div>
      <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(36px,6vw,96px);line-height:.96;letter-spacing:-0.025em;max-width:1300px;margin-bottom:60px;font-weight:400;text-wrap:balance">
        {lang === 'fr' ? (<>Six services. Une <i>seule</i> couche.</>) : (<>Six services. One <i>continuous</i> layer.</>)}
      </h2>
      <p class="reveal" style="font-family:var(--font-sans);font-size:clamp(17px,1.4vw,20px);line-height:1.55;color:var(--ink-2);max-width:820px;margin-bottom:48px;margin-top:-40px;text-wrap:pretty">
        {lang === 'fr'
          ? <>Pas de revendeur, pas de sous-traitance. Le contenu, l&rsquo;orchestration, les agents, le tracking, le brand system — tout sort de la même main. Une équipe, un calendrier, une signature.</>
          : <>No reseller, no subcontracting. Content, orchestration, agents, tracking, brand system — all from the same hand. One team, one timeline, one signature.</>}
      </p>
      <TerminalTable cols="60px 180px 1fr 120px" headers={['id', 'service', 'description', 'status']}>
        {SIX_SERVICES.map((s) => (
          <a href={flh('/contact', lang)} class="u-edit-tbl-row">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">{s.k}</span>
            <span style="font-family:var(--font-sans);font-size:clamp(20px,2vw,24px);line-height:1;letter-spacing:-0.01em">{ft(s.label, lang)}</span>
            <span style="font-size:13.5px;color:var(--muted);line-height:1.45;padding-right:20px">{ft(s.body, lang)}</span>
            <span style="font-family:var(--font-mono);font-size:11px;color:var(--accent);letter-spacing:.1em;text-align:right">◉ active</span>
          </a>
        ))}
      </TerminalTable>
    </div>
  </section>

  {/* MANIFESTO interlude dark */}
  <section style="padding:clamp(64px,8vw,112px) clamp(20px,4vw,48px);background:var(--ink);color:var(--paper)">
    <div style="max-width:1400px;margin:0 auto">
      <Kicker tone="accent" class="c-manifesto-tag">[manifesto]</Kicker>
      <p class="reveal" style="font-family:var(--font-display);font-size:clamp(32px,5.8vw,88px);line-height:1.05;letter-spacing:-0.02em;color:var(--paper);font-weight:400">
        {lang === 'fr' ? (
          <>On écrit en <span style="color:var(--accent)">français</span>, on lit la documentation Stripe, on livre du code le mardi, on mesure le pipeline le vendredi. Pas de cerveau-circuit. Pas de verre. Pas de <i>théâtre</i>. Et chaque ligne de prod a un humain qui l&rsquo;a relue.</>
        ) : (
          <>We write <span style="color:var(--accent)">French</span>, we read Stripe docs, we ship code on Tuesdays, we measure pipeline on Fridays. No cerebral circuits. No glass. No <i>theatre</i>. And every line in prod has a human who reviewed it.</>
        )}
      </p>
    </div>
  </section>

  {/* ACTE III · ProductReel sticky · SIGNATURE */}
  <section id="act-3" style="background:var(--paper)">
    <div style="padding:120px clamp(20px,4vw,48px) 60px;max-width:1500px;margin:0 auto">
      <div style="display:flex;justify-content:space-between;align-items:baseline;padding-bottom:20px;border-bottom:1px solid var(--hairline);flex-wrap:wrap;gap:10px">
        <Kicker tone="accent">
          [act.03] · <span style="color:var(--muted)">{lang === 'fr' ? 'la plateforme' : 'the platform'}</span>
        </Kicker>
        <Kicker>virtuoseos · live scroll · 4 steps</Kicker>
      </div>
      <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(36px,6vw,96px);line-height:.96;letter-spacing:-0.025em;max-width:1400px;margin-top:40px;margin-bottom:10px;font-weight:400">
        {lang === 'fr' ? (<>Faites défiler la <i>console</i>.</>) : (<>Scroll the <i>console</i>.</>)}
      </h2>
      <p class="reveal" style="font-family:var(--font-sans);font-size:clamp(15px,1.2vw,18px);line-height:1.55;color:var(--muted);max-width:680px;margin-top:24px;text-wrap:pretty">
        {lang === 'fr'
          ? <>Quatre étapes pour câbler un système. <i style="color:var(--ink)">Cartographier · Câbler · Orchestrer · Industrialiser.</i> Le scroll les déroule à la cadence d&rsquo;un terminal.</>
          : <>Four steps to wire a system. <i style="color:var(--ink)">Map · Wire · Orchestrate · Industrialize.</i> Scroll unfolds them at terminal pace.</>}
      </p>
    </div>
    <ProductReel client:visible lang={lang} />
  </section>

  {/* ACTE IV · table cases */}
  <section id="act-4" style="padding:clamp(120px,14vw,160px) clamp(20px,4vw,48px);background:var(--paper-2)">
    <div style="max-width:1500px;margin:0 auto">
      <Kicker tone="accent" class="c-act-04">
        [act.04] · <span style="color:var(--muted)">{lang === 'fr' ? 'preuves' : 'proof'}</span>
      </Kicker>
      <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(36px,6vw,96px);line-height:.96;letter-spacing:-0.025em;max-width:1300px;margin-bottom:60px;font-weight:400">
        {lang === 'fr' ? (<>Cas clients, en <i>table</i>.</>) : (<>Cases, as a <i>table</i>.</>)}
      </h2>
      <p class="reveal" style="font-family:var(--font-sans);font-size:clamp(17px,1.4vw,20px);line-height:1.55;color:var(--ink-2);max-width:820px;margin-top:-40px;margin-bottom:48px;text-wrap:pretty">
        {lang === 'fr'
          ? <>Quatre cas. Pas de logos de complaisance, pas de témoignage rédigé par le marketing. Données brutes&nbsp;: secteur, durée, stack, impact mesuré.</>
          : <>Four cases. No vanity logos, no marketing-written quotes. Raw data: sector, duration, stack, measured impact.</>}
      </p>
      <TerminalTable
        cols="50px 1.2fr 1fr 110px 1.6fr 1.2fr 40px"
        headers={['id', 'client', lang === 'fr' ? 'secteur' : 'sector', lang === 'fr' ? 'durée' : 'duration', 'stack', 'impact', '']}
      >
        {CASE_FEED.slice(0, 4).map((c, i) => (
          <a href={flh(`/ressources/cas/${c.slug}`, lang)} class="u-edit-tbl-row">
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">0{i + 1}</span>
            <span style="font-family:var(--font-sans);font-size:clamp(22px,2vw,26px);line-height:1">{c.client}</span>
            <span style="font-size:13px;color:var(--muted)">{ft(c.sector, lang)}</span>
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--muted)">{c.duration}</span>
            <span style="font-family:var(--font-mono);font-size:12px;color:var(--ink)">{c.stack}</span>
            <span style="font-size:14px;color:var(--accent);font-weight:500">{ft(c.impact, lang)}</span>
            <span style="font-family:var(--font-mono);color:var(--muted);text-align:right">↗</span>
          </a>
        ))}
      </TerminalTable>
    </div>
  </section>

  {/* WRITING */}
  <section id="writing" style="padding:clamp(100px,12vw,140px) clamp(20px,4vw,48px);border-top:1px solid var(--hairline)">
    <div style="max-width:1500px;margin:0 auto">
      <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:40px;padding-bottom:16px;border-bottom:1px solid var(--hairline);flex-wrap:wrap;gap:10px">
        <Kicker tone="accent">
          [writing] · <span style="color:var(--muted)">{lang === 'fr' ? 'notes & changelog' : 'field notes & changelog'}</span>
        </Kicker>
        <Kicker as="span"><a href={flh('/ressources/blog', lang)} style="color:var(--muted)">/feed.xml</a></Kicker>
      </div>
      <div>
        {FIELD_NOTES.map((s) => (
          <EditorialWriteRow
            date={s.date}
            tag={ft(s.tag, lang)}
            href={flh('/ressources/blog', lang)}
            tone="paper"
          >
            {ft(s.text, lang)}
          </EditorialWriteRow>
        ))}
      </div>
    </div>
  </section>

  {/* ACTE V · session terminal split */}
  <section id="act-5" style="padding:clamp(64px,8vw,112px) clamp(20px,4vw,48px);background:var(--ink);color:var(--paper)">
    <div style="max-width:1500px;margin:0 auto">
      <Kicker tone="accent" class="c-act-05">
        [act.05] · <span style="color:rgba(246,241,232,.5)">{lang === 'fr' ? "passer à l'action" : 'act'}</span>
      </Kicker>
      <div style="display:grid;grid-template-columns:1.2fr 1fr;gap:clamp(40px,6vw,80px);align-items:end">
        <h2 class="reveal" style="font-family:var(--font-display);font-size:clamp(48px,8vw,120px);line-height:.9;letter-spacing:-0.03em;color:var(--paper);text-wrap:balance;font-weight:400;margin:0">
          {lang === 'fr' ? (
            <>Ouvrir une <i style="color:var(--accent)">séance</i>.<br />Pas un <i>pitch</i>.</>
          ) : (
            <>Open a <i style="color:var(--accent)">session</i>.<br />Not a <i>pitch</i>.</>
          )}
        </h2>
        <div style="font-family:var(--font-mono);font-size:13px;color:rgba(246,241,232,.75);background:rgba(246,241,232,.04);border:1px solid rgba(246,241,232,.14);border-radius:10px;padding:22px">
          <div style="color:var(--accent);margin-bottom:10px">$ virtuose session.open --duration=45m</div>
          <div>&gt; workspace: your-company</div>
          <div>&gt; agenda: {lang === 'fr' ? 'un problème diagnostiqué' : 'one diagnosed problem'}</div>
          <div>&gt; outcome: {lang === 'fr' ? 'notes actionnables ou pas de relance' : 'actionable notes or no follow-up'}</div>
          <div>&gt; channel: Meet / Zoom / on-site Paris</div>
          <div>&gt; commitment: {lang === 'fr' ? 'aucun · 45 min, on coupe' : 'none · 45 min, we cut'}</div>
          <div style="margin-top:14px;padding-top:14px;border-top:1px solid rgba(246,241,232,.14);color:rgba(246,241,232,.55);font-size:12px">
            {lang === 'fr' ? '// vous repartez avec un audit ou rien. Pas de relance pénible.' : '// you leave with an audit or nothing. No annoying follow-up.'}
          </div>
          <div style="margin-top:18px;display:flex;gap:10px;flex-wrap:wrap">
            <TerminalCTA href={flh('/contact', lang)} variant="accent" size="sm" mag={0.18}>▸ schedule</TerminalCTA>
            <TerminalCTA href={`mailto:${lang === 'fr' ? 'bonjour@waimia.fr' : 'hello@waimia.fr'}`} variant="ghost-dark" size="sm">
              {lang === 'fr' ? 'bonjour@waimia.fr' : 'hello@waimia.fr'}
            </TerminalCTA>
          </div>
        </div>
      </div>
    </div>
  </section>
<script>
  // @ts-nocheck
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var output = document.getElementById('console-terminal-output');
    if (!output) return;

    // Séquence de boot : [délai avant (ms), texte, estCommande]
    var SEQUENCE = [
      [400,  '$ virtuose --version',                         true],
      [300,  'VirtuoseOS 2.4.1 · locale fr-FR · kernel ok', false],
      [600,  '$ virtuose ship pipeline.agent',                true],
      [200,  '  → hubspot.sync ok · 482 contacts',           false],
      [120,  '  → claude.triage ok · 14 handoffs',           false],
      [120,  '  → audit.trail open',                         false],
      [200,  '  ✓ pipeline shipped · +€19 540 pipeline',     false],
    ];

    var CHAR_DELAY = 30;   // ms par caractère (lignes de commande)
    var IDLE_RESET = 60000; // 60s sans interaction → relancer la séquence

    var idleTimer: ReturnType<typeof setTimeout> | null = null;
    var running = false;

    function makeRow(text, isCmd) {
      var row = document.createElement('div');
      row.style.padding = '4px 0';
      if (isCmd) {
        var prompt = document.createElement('span');
        prompt.style.color = 'var(--accent)';
        prompt.textContent = '$ ';
        row.appendChild(prompt);
      }
      var content = document.createElement('span');
      if (!isCmd) {
        content.style.color = 'rgba(246,241,232,.55)';
        content.textContent = text;
      }
      row.appendChild(content);
      return { row: row, content: content, text: isCmd ? text.replace(/^\$ /, '') : text };
    }

    function typeText(contentEl, text, charDelay, cb) {
      var i = 0;
      function next() {
        if (i >= text.length) { if (cb) cb(); return; }
        contentEl.textContent += text[i];
        i++;
        setTimeout(next, charDelay);
      }
      next();
    }

    function runSequence() {
      if (running) return;
      running = true;
      if (output) output.textContent = '';
      var step = 0;

      function runStep() {
        if (step >= SEQUENCE.length) {
          running = false;
          scheduleIdle();
          return;
        }
        var entry  = SEQUENCE[step];
        var delay  = entry[0];
        var text   = entry[1];
        var isCmd  = entry[2];
        step++;

        setTimeout(function () {
          if (!output) return;
          var r = makeRow(text, isCmd);
          output.appendChild(r.row);
          if (isCmd) {
            typeText(r.content, r.text, CHAR_DELAY, runStep);
          } else {
            runStep();
          }
        }, delay);
      }

      runStep();
    }

    function scheduleIdle() {
      if (idleTimer) clearTimeout(idleTimer);
      idleTimer = setTimeout(runSequence, IDLE_RESET);
    }

    function onUserActivity() { scheduleIdle(); }

    runSequence();

    document.addEventListener('mousemove', onUserActivity, { passive: true });
    document.addEventListener('keydown',   onUserActivity, { passive: true });
    document.addEventListener('scroll',    onUserActivity, { passive: true, capture: true });
  })();
</script>
</Base>

