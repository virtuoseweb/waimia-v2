---
export const prerender = true;

/**
 * Hub /equipe — liste des auteurs Waimia (status: active + featured first).
 *
 * Auto-jointure : pour chaque auteur, compte les articles publiés (blog +
 * cookbooks + livresBlancs + veilleIA) pour afficher un total dans la card.
 */
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import { langFromPath, t } from '../../lib/i18n';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';

type AuthorLinkedEntry =
  | CollectionEntry<'blog'>
  | CollectionEntry<'cookbooks'>
  | CollectionEntry<'livresBlancs'>
  | CollectionEntry<'veilleIA'>;

type AuthorRef = string | { id?: string; slug?: string; name?: string };

const lang = langFromPath(Astro.url.pathname);
const transitionIdFromHref = (href: string) =>
  href
    .replace(/^\/(?:en\/)?/, '')
    .replace(/\/$/, '')
    .replace(/[^a-z0-9]+/gi, '-')
    .replace(/^-|-$/g, '') || 'home';

const allAuthors = await getCollection('authors');

// Filtre status=active, featured=true en premier, puis ordre alphabétique
const activeAuthors = allAuthors
  .filter((author) => author.data.status === 'active')
  .sort((a, b) => {
    if (a.data.featured && !b.data.featured) return -1;
    if (!a.data.featured && b.data.featured) return 1;
    return a.data.title_fr.localeCompare(b.data.title_fr);
  });

// Compte articles par auteur (auto-jointure)
const [allBlog, allCookbooks, allLivresBlancs, allVeille] = await Promise.all([
  getCollection('blog'),
  getCollection('cookbooks'),
  getCollection('livresBlancs'),
  getCollection('veilleIA'),
]);

const allItems: AuthorLinkedEntry[] = [
  ...allBlog,
  ...allCookbooks,
  ...allLivresBlancs,
  ...allVeille,
];

const getAuthor = (contentEntry: AuthorLinkedEntry): AuthorRef | undefined => {
  if (!('author' in contentEntry.data)) return undefined;
  return contentEntry.data.author as AuthorRef | undefined;
};

const countByAuthor = (slug: string, name: string) =>
  allItems.filter((contentEntry) => {
    const author = getAuthor(contentEntry);
    if (!author) return false;
    if (typeof author === 'object' && author.id === slug) return true;
    if (typeof author === 'object' && author.slug === slug) return true;
    if (typeof author === 'object' && author.name === name) return true;
    if (typeof author === 'string' && author === slug) return true;
    return false;
  }).length;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://waimia.com/' },
    { '@type': 'ListItem', position: 2, name: "L'équipe" },
  ],
};

const collectionPageLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: "L'équipe Waimia",
  description: 'Les auteurs Waimia : fondateurs, contributeurs, invités. Bios, CV, publications.',
};
---

<Base
  title="L'équipe Waimia · auteurs et contributeurs"
  description="Les auteurs et contributeurs Waimia. Bios, CV, expertise, publications. Paris · Genève."
  jsonLd={[breadcrumbLd, collectionPageLd]}
>
  {/* MASTHEAD */}
  <section class="eq-mast">
    <div class="wrap-tight">
      <Kicker class="eq-kicker">
        § Hub · {t({ fr: "Équipe", en: 'Team' }, lang)} · {activeAuthors.length}{' '}
        {activeAuthors.length > 1
          ? t({ fr: 'auteurs', en: 'authors' }, lang)
          : t({ fr: 'auteur', en: 'author' }, lang)}
      </Kicker>
      <h1 class="eq-h1 reveal" transition:name={`hero-h1-${transitionIdFromHref(Astro.url.pathname)}`}>
        {lang === 'fr' ? (
          <>
            Qui <i>écrit</i>. Qui <i>cable</i>.
          </>
        ) : (
          <>
            Who <i>writes</i>. Who <i>ships</i>.
          </>
        )}
      </h1>
      <p class="eq-lede">
        {lang === 'fr'
          ? "Pas de ghostwriting. Pas d'agence anonyme. Chaque article, chaque cas, chaque livre blanc est signé. Voici qui écrit pour Waimia."
          : "No ghostwriting. No anonymous agency. Every article, case, white paper is signed. Here's who writes for Waimia."}
      </p>
    </div>
  </section>

  {/* GRID auteurs */}
  <section class="eq-grid-sec">
    <div class="wrap">
      <div class="eq-grid">
        {activeAuthors.map((author) => {
          const count = countByAuthor(author.id, author.data.title_fr);
          const href = lang === 'fr' ? `/equipe/${author.id}` : `/en/equipe/${author.id}`;
          return (
            <a href={href} class="eq-card" transition:name={`card-${transitionIdFromHref(href)}`}>
              {author.data.photo && (
                <img
                  src={author.data.photo}
                  alt={author.data.photoAlt_fr ?? author.data.title_fr}
                  class="eq-card-photo"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <div class="eq-card-body">
                <h2 class="eq-card-name">{author.data.title_fr}</h2>
                <p class="eq-card-role">{author.data.role_fr}</p>
                <p class="eq-card-desc">{author.data.description_fr}</p>
                {count > 0 && (
                  <div class="eq-card-meta">
                    <span class="eq-card-count">
                      {count} publication{count > 1 ? 's' : ''}
                    </span>
                  </div>
                )}
                <span class="eq-card-cta">Voir le profil →</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>
  <CtaBand />
</Base>

<style>
  .eq-mast {
    padding: clamp(80px, 10vw, 140px) 0 clamp(40px, 5vw, 64px);
    color: var(--ink);
  }
  :global(.eq-kicker) {
    color: var(--accent);
    margin-bottom: 24px;
  }
  .eq-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 120px);
    line-height: .92;
    letter-spacing: -.028em;
    font-weight: 400;
    margin: 0 0 32px;
  }
  .eq-h1 i {
    color: var(--accent);
    font-style: italic;
  }
  .eq-lede {
    font-family: var(--font-display);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--muted);
    max-width: 680px;
    font-style: italic;
  }

  .eq-grid-sec {
    padding: clamp(48px, 6vw, 80px) 0 clamp(80px, 10vw, 140px);
  }
  .eq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: clamp(24px, 3vw, 48px);
  }
  .eq-card {
    background: var(--paper);
    border: 1px solid rgba(0, 0, 0, .08);
    border-top: 2px solid transparent;
    border-radius: 16px;
    padding: 32px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 220ms var(--ease), border-top-color 220ms var(--ease), transform 220ms var(--ease), box-shadow 220ms var(--ease), background 220ms var(--ease);
    display: flex;
    flex-direction: column;
    gap: 20px;
    overflow: hidden;
  }
  .eq-card:hover {
    background: var(--paper-2);
    border-color: var(--accent);
    border-top-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, .06);
  }
  .eq-card-photo {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 12px;
    transition: transform 360ms var(--ease-out);
  }
  .eq-card-body {
    transition: transform 220ms var(--ease);
  }
  .eq-card:hover .eq-card-photo {
    transform: scale(1.02);
  }
  .eq-card:hover .eq-card-body {
    transform: translateX(1px);
  }
  .eq-card-name {
    font-family: var(--font-display);
    font-size: clamp(28px, 2.6vw, 36px);
    line-height: 1.05;
    font-weight: 400;
    margin: 0;
  }
  .eq-card-role {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0;
  }
  .eq-card-desc {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.55;
    color: var(--muted);
    font-style: italic;
    margin: 0;
  }
  .eq-card-meta {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid rgba(0, 0, 0, .08);
  }
  .eq-card-count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .eq-card-cta {
    font-family: var(--font-display);
    font-size: 15px;
    color: var(--accent);
    margin-top: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    .eq-card,
    .eq-card-photo,
    .eq-card-body {
      transition: none !important;
      transform: none !important;
      box-shadow: none !important;
    }
  }

  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .wrap-tight {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
</style>
