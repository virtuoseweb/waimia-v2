---
// Page · /en/technologies · Technologies hub — EN mirror
export const prerender = true;

import Base from '../../../layouts/Base.astro';
import Kicker from '../../../components/ui/atoms/Kicker.astro';
import TrustMarquee from '../../../components/ui/organisms/TrustMarquee.astro';
import CtaBand from '../../../components/ui/organisms/CtaBand.astro';
import RelatedCards from '../../../components/ui/molecules/RelatedCards.astro';
import TechPillRow from '../../../components/ui/molecules/TechPillRow.astro';

const stackLayers = [
  { num: '01', title: 'Claude · cognition',
    body: 'Opus 4.7 for analysis, Sonnet 4.6 for production, Haiku 4.5 for fast triage. Cost/latency routing, open-source fallback.' },
  { num: '02', title: 'Open-source · sovereignty',
    body: 'vLLM, Ollama, Llama 4 70B, DeepSeek R1, Qwen 3. For ACPR, SecNumCloud, HIPAA constraints — when data cannot leave.' },
  { num: '03', title: 'Decision layer · VirtuoseOS',
    body: 'Our multi-workspace kernel with replayable audit trail, AI Act guardrails, integrated LLM FinOps.' },
];

const flagshipTechs = [
  { num: '01', kicker: 'TECH · CLAUDE',
    title_en: 'Claude Models',
    sub_en: 'Haiku · Sonnet · Opus · Code',
    lead_en: 'The Anthropic model family — which model to choose, when to route to which, how to measure cost/latency.',
    href: '/technologies/claude-models' },
  { num: '02', kicker: 'TECH · KERNEL',
    title_en: 'VirtuoseOS',
    sub_en: 'The Waimia operational layer',
    lead_en: 'Our multi-workspace kernel — replayable audit trail, AI Act guardrails, integrated LLM FinOps.',
    href: '/technologies/virtuoseos' },
];

const frameworks = [
  { kicker: 'FRAMEWORK · 01', title_en: 'LangGraph + Claude',
    lead_en: 'Stateful multi-agent orchestration →', href: '/technologies/frameworks' },
  { kicker: 'FRAMEWORK · 02', title_en: 'CrewAI + Claude',
    lead_en: 'Role-based collaborative agents →', href: '/technologies/frameworks' },
  { kicker: 'FRAMEWORK · 03', title_en: 'Custom MCP',
    lead_en: 'Custom connectors open standard →', href: '/technologies/mcp-connectors' },
];

const claudePills = [
  { label: 'Claude Opus 4.7', kind: 'primary' as const },
  { label: 'Claude Sonnet 4.6', kind: 'primary' as const },
  { label: 'Claude Haiku 4.5', kind: 'primary' as const },
  { label: 'Claude Code', kind: 'primary' as const },
  { label: 'Claude Skills', kind: 'primary' as const },
  { label: 'MCP', kind: 'primary' as const },
];

const ossPills = [
  { label: 'Llama 4 70B', kind: 'open' as const },
  { label: 'DeepSeek R1', kind: 'open' as const },
  { label: 'Qwen 3', kind: 'open' as const },
  { label: 'vLLM', kind: 'open' as const },
  { label: 'Ollama', kind: 'open' as const },
  { label: 'GLM-5', kind: 'open' as const },
];

const transitionIdFromHref = (href: string) =>
  href
    .replace(/^\/(?:en\/)?/, '')
    .replace(/\/$/, '')
    .replace(/[^a-z0-9]+/gi, '-')
    .replace(/^-|-$/g, '') || 'home';
---
<Base
  title="Technologies · Claude + open-source + VirtuoseOS · Waimia"
  description="Our technical stack: Claude (Opus, Sonnet, Haiku, Code, Skills, MCP), open-source models for sovereignty, and VirtuoseOS as decision layer."
>
  {/* MASTHEAD */}
  <section class="hub-mast">
    <div class="wrap-wide">
      <Kicker class="hub-kicker">§ Tech stack · 3 layers · 1 system</Kicker>
      <h1 class="hub-h1 reveal-mask-up" transition:name={`hero-h1-${transitionIdFromHref(Astro.url.pathname)}`}>Three <i>layers</i>. One single <i>OS</i>.</h1>
      <p class="hub-lede reveal" style="transition-delay:180ms">
        Claude for cognition. Open-source for sovereignty. VirtuoseOS for decisions. Three technical choices, one architecture.
      </p>
    </div>
  </section>

  {/* PARTNER BAND */}
  <TrustMarquee />

  {/* 3 STACK LAYERS */}
  <section class="hub-layers">
    <div class="wrap-wide">
      <Kicker tone="accent" class="hub-layers-k">§ Stack · 3 superposed layers</Kicker>
      <h2 class="hub-layers-h2 reveal">How we <i>choose</i>. Without dogma.</h2>
      <svg class="hub-arch-svg reveal" viewBox="0 0 900 120" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <marker id="arr-v9x2" markerWidth="6" markerHeight="6" refX="5" refY="3" orient="auto">
            <path d="M0,0 L0,6 L6,3 z" fill="#0C0B09"/>
          </marker>
        </defs>
        <line x1="158" y1="60" x2="742" y2="60" stroke="rgba(12,11,9,0.09)" stroke-width="1"/>
        <circle cx="120" cy="60" r="40" stroke="#0C0B09" stroke-width="1" fill="#EFE9DD"/>
        <text x="120" y="53" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="10" fill="#6B6560" letter-spacing="0.1em">01</text>
        <text x="120" y="68" text-anchor="middle" font-family="'Inter Tight',sans-serif" font-size="12" fill="#0C0B09" font-weight="500">Claude</text>
        <path d="M163 60 L277 60" stroke="#0C0B09" stroke-width="0.75" marker-end="url(#arr-v9x2)"/>
        <circle cx="320" cy="60" r="40" stroke="#0C0B09" stroke-width="1" fill="#EFE9DD"/>
        <text x="320" y="53" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="10" fill="#6B6560" letter-spacing="0.1em">02</text>
        <text x="320" y="68" text-anchor="middle" font-family="'Inter Tight',sans-serif" font-size="12" fill="#0C0B09" font-weight="500">Open-source</text>
        <path d="M363 60 L477 60" stroke="#0C0B09" stroke-width="0.75" marker-end="url(#arr-v9x2)"/>
        <circle cx="520" cy="60" r="40" stroke="#C94F2E" stroke-width="1.5" fill="#EFE9DD"/>
        <text x="520" y="53" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="10" fill="#C94F2E" letter-spacing="0.1em">03</text>
        <text x="520" y="68" text-anchor="middle" font-family="'Inter Tight',sans-serif" font-size="12" fill="#0C0B09" font-weight="500">VirtuoseOS</text>
        <text x="520" y="115" text-anchor="middle" font-family="'JetBrains Mono',monospace" font-size="9" fill="#6B6560" letter-spacing="0.08em">DECISION LAYER</text>
      </svg>
      <ol class="hub-stack">
        {stackLayers.map((s, i) => (
          <li class="hub-stack-row reveal" style={`transition-delay:${i * 80}ms`}>
            <div class="hub-stack-num reveal-zoom-in">{s.num}</div>
            <div class="hub-stack-body">
              <h3 class="hub-stack-title">{s.title}</h3>
              <p class="hub-stack-text">{s.body}</p>
              {s.num === '01' && <TechPillRow pills={claudePills} />}
              {s.num === '02' && <TechPillRow pills={ossPills} />}
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* DEPLOYED TECHNOLOGIES · cards to real sub-pages */}
  <section class="hub-flagship">
    <div class="wrap-wide">
      <Kicker tone="accent" class="hub-flagship-k">§ Deployed technologies · detailed pages</Kicker>
      <h2 class="hub-flagship-h2 reveal">Two <i>building blocks</i>. Documented in plain language.</h2>
      <p class="hub-flagship-lead">
        The models we route and the kernel we operate — everything else articulates around these two.
      </p>
      <ol class="hub-flagship-list">
        {flagshipTechs.map((t) => (
          <li class="hub-flagship-row">
            <a class="hub-flagship-link" href={t.href} transition:name={`card-${transitionIdFromHref(t.href)}`}>
              <span class="hub-flagship-num">{t.num}</span>
              <span class="hub-flagship-body">
                <span class="hub-flagship-kicker">{t.kicker}</span>
                <span class="hub-flagship-title">{t.title_en} <i>· {t.sub_en}</i></span>
                <span class="hub-flagship-text">{t.lead_en}</span>
              </span>
              <span class="hub-flagship-arr" aria-hidden>→</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* DECISION FRAMEWORK · 3 orchestration frameworks */}
  <section class="hub-frameworks">
    <div class="wrap-wide">
      <Kicker tone="accent" class="hub-frameworks-k">§ Frameworks · agent orchestration</Kicker>
      <h2 class="hub-frameworks-h2 reveal">Three <i>frameworks</i>. Three grammars.</h2>
      <RelatedCards cards={frameworks.map(f => ({ ...f, title_fr: f.title_en, lead_fr: f.lead_en }))} />
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hub-mast { padding: 140px 32px clamp(40px, 5vw, 72px); }
  :global(.hub-kicker) { display: block; margin-bottom: 24px; }
  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--accent); }
  .hub-lede {
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.8vw, 22px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.55;
  }

  .hub-arch-svg {
    display: block;
    width: 100%;
    max-width: 840px;
    height: auto;
    margin: 0 0 clamp(32px, 4vw, 56px);
    overflow: visible;
  }

  .hub-layers { padding: clamp(80px, 10vw, 120px) 32px; }
  :global(.hub-layers-k) { display: block; margin-bottom: 18px; }
  .hub-layers-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 0 0 clamp(48px, 5vw, 72px);
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-layers-h2 :global(i) { font-style: italic; color: var(--accent); }
  .hub-stack {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--ink);
  }
  .hub-stack-row {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: clamp(20px, 3vw, 48px);
    padding: clamp(36px, 4vw, 60px) 0;
    border-bottom: 1px solid var(--hairline);
    align-items: start;
  }
  .hub-stack-num {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 96px);
    line-height: 0.9;
    color: var(--muted);
    font-style: italic;
  }
  .hub-stack-title {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1.05;
    letter-spacing: -0.022em;
    font-weight: 400;
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .hub-stack-text {
    font-size: clamp(15px, 1.5vw, 18px);
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 18px;
    max-width: 780px;
    text-wrap: pretty;
  }

  .hub-flagship { padding: clamp(80px, 10vw, 120px) 32px; }
  :global(.hub-flagship-k) { display: block; margin-bottom: 18px; }
  .hub-flagship-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 0 0 24px;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-flagship-h2 :global(i) { font-style: italic; color: var(--muted); }
  .hub-flagship-lead {
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.8vw, 22px);
    color: var(--muted);
    max-width: 760px;
    margin: 0 0 clamp(40px, 5vw, 64px);
    line-height: 1.55;
  }
  .hub-flagship-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--ink);
  }
  .hub-flagship-row { border-bottom: 1px solid var(--hairline); }
  .hub-flagship-link {
    display: grid;
    grid-template-columns: 80px 1fr 60px;
    gap: clamp(20px, 3vw, 40px);
    padding: clamp(28px, 3vw, 44px) 0;
    align-items: start;
    color: inherit;
    transition: background 240ms var(--ease);
  }
  .hub-flagship-link:hover { background: rgba(0, 0, 0, 0.02); }
  .hub-flagship-num {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 72px);
    line-height: 0.9;
    color: var(--muted);
    font-style: italic;
  }
  .hub-flagship-body { display: flex; flex-direction: column; gap: 8px; }
  .hub-flagship-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.14em;
  }
  .hub-flagship-title {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 40px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    text-wrap: balance;
  }
  .hub-flagship-title :global(i) { font-style: italic; color: var(--muted); font-size: 0.7em; }
  .hub-flagship-text {
    font-size: clamp(14px, 1.4vw, 16px);
    line-height: 1.55;
    color: var(--muted);
    max-width: 720px;
    text-wrap: pretty;
  }
  .hub-flagship-arr {
    font-family: var(--font-mono);
    font-size: 28px;
    color: var(--ink);
    align-self: center;
    text-align: right;
  }
  @media (max-width: 700px) {
    .hub-flagship-link { grid-template-columns: 56px 1fr; }
    .hub-flagship-arr { display: none; }
  }

  .hub-frameworks { padding: clamp(80px, 10vw, 120px) 32px; background: var(--paper-2); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  :global(.hub-frameworks-k) { display: block; margin-bottom: 18px; }
  .hub-frameworks-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 0 0 clamp(40px, 5vw, 72px);
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-frameworks-h2 :global(i) { font-style: italic; color: var(--muted); }

  @media (max-width: 700px) {
    .hub-stack-row { grid-template-columns: 1fr; }
  }
</style>
