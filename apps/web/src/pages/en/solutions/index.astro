---
// Page · /en/solutions · Solutions hub — 5 horizontal business use cases · EN mirror
export const prerender = true;

import Base from '../../../layouts/Base.astro';
import Kicker from '../../../components/ui/atoms/Kicker.astro';
import Cases from '../../../components/ui/organisms/Cases.astro';
import type { SectionByType } from '../../../schemas/sections';
import CtaFinal from '../../../components/sections/CtaFinal.astro';

const horizontalSolutions = [
  { num: '01', kicker: 'PROBLEM · ACQUISITION',
    title: 'AI Acquisition', sub: 'More qualified leads, without hiring',
    lead: "No €80k SDR. No continuous LinkedIn. A pipeline that runs at night.",
    href: '/solutions/acquisition-ia' },
  { num: '02', kicker: 'PROBLEM · CRM & FOLLOW-UPS',
    title: 'AI CRM & Follow-ups', sub: 'A pipeline that never sleeps',
    lead: 'Fallow CRM, forgotten leads, finger-in-the-air forecast. We fix it silently.',
    href: '/solutions/crm-relances-ia' },
  { num: '03', kicker: 'PROBLEM · CONTENT',
    title: 'AI SEO / GEO Content', sub: 'Found by Google and AI assistants',
    lead: 'Premium SEO articles, GEO-ready sheets, indexing on AI assistants.',
    href: '/solutions/contenu-seo-geo-ia' },
  { num: '04', kicker: 'PROBLEM · PRODUCTIVITY',
    title: 'AI Productivity', sub: 'Augmented Excel and Office',
    lead: 'Auto-reporting, voice formulas, clarity restored. The time that changes decisions.',
    href: '/solutions/productivite-ia' },
  { num: '05', kicker: 'PROBLEM · CUSTOMER SUPPORT',
    title: 'AI Customer Support', sub: '24/7 answers, intelligent escalation',
    lead: "Automatic triage, first level resolved, human team on the real issues.",
    href: '/solutions/support-client-ia' },
];

const sectorSatellites = [
  { kicker: 'SECTOR · 01', title: 'B2B Services', lead: 'Consulting, agencies, service providers →', href: '/secteurs/services-b2b' },
  { kicker: 'SECTOR · 02', title: 'Industry & Industrial SMBs', lead: 'ERP, maintenance, quality →', href: '/secteurs/industrie' },
  { kicker: 'SECTOR · 03', title: 'Finance & Accounting', lead: 'Reconciliation, reporting, compliance →', href: '/secteurs/finance-compta' },
];

const transitionIdFromHref = (href: string) =>
  href
    .replace(/^\/(?:en\/)?/, '')
    .replace(/\/$/, '')
    .replace(/[^a-z0-9]+/gi, '-')
    .replace(/^-|-$/g, '') || 'home';

const ctaData = {
  type: 'cta-final' as const,
  h2_fr: 'Prêt à livrer un <em>agent</em>,<br />pas un slide deck ?',
  h2_en: 'Ready to ship an <em>agent</em>,<br />not a slide deck?',
  body_fr: 'Audit IA en 5 jours. Premier agent en production en 4 semaines. ROI mesuré, jamais estimé.',
  body_en: 'AI audit in 5 days. First agent in production in 4 weeks. Measured ROI, never estimated.',
  cta_primary: { label_fr: 'Réserver un audit →', label_en: 'Book an audit →', href: '/en/contact', variant: 'primary' as const },
  cta_secondary: { label_fr: 'Voir la pyramide →', label_en: 'See the pyramid →', href: '/en/offres', variant: 'ghost' as const },
  background: 'paper' as const,
} satisfies SectionByType<'cta-final'>;
---
<Base
  title="Solutions · 5 business use cases · Waimia"
  description="Five AI systems for recurring SMB pain points: acquisition, CRM, content, productivity, support."
>
  <section class="hub-mast">
    <svg class="hub-mast-geo" viewBox="0 0 1440 560" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <rect x="1060" y="-20" width="360" height="360" fill="none" stroke="currentColor" stroke-width="0.6" transform="rotate(12 1240 160)"/>
      <rect x="1140" y="60" width="220" height="220" fill="none" stroke="currentColor" stroke-width="0.4" transform="rotate(12 1250 170)"/>
      <line x1="0" y1="380" x2="1440" y2="260" stroke="currentColor" stroke-width="0.4"/>
    </svg>
    <div class="wrap-wide">
      <Kicker class="hub-kicker">§ Solutions · 5 horizontal use cases</Kicker>
      <h1 class="hub-h1 reveal-mask-up" transition:name={`hero-h1-${transitionIdFromHref(Astro.url.pathname)}`}>Five <i>business</i> problems. One <i>method</i>.</h1>
      <p class="hub-lede">
        Five recurring pain points. No AI slide — a system wired to your stack, measured from the first week.
      </p>
      <p class="hub-canonical">
        We don't sell AI. We build <strong>systems</strong> that run in your tools, that you can take back in hand.
      </p>
    </div>
  </section>

  <section class="hub-solutions wrap-wide reveal-blur-clip" aria-label="Horizontal solutions">
    {horizontalSolutions.map((sol) => (
      <a href={sol.href} class="hub-sol-card" transition:name={`card-${transitionIdFromHref(sol.href)}`}>
        <div class="hub-sol-num">{sol.num}</div>
        <div class="hub-sol-kicker">{sol.kicker}</div>
        <h3 class="hub-sol-title">{sol.title}</h3>
        <p class="hub-sol-sub">{sol.sub}</p>
        <p class="hub-sol-lead">{sol.lead}</p>
        <span class="hub-sol-cta">See the solution →</span>
      </a>
    ))}
  </section>

  <section class="hub-sectors reveal-blur-clip">
    <div class="wrap-wide">
      <Kicker>§ Tailored to your sector</Kicker>
      <h2 class="hub-h2">One method, your <i>vocabulary</i>.</h2>
      <p class="hub-lede">
        Same systems, adapted to the trade — B2B services, industry, finance and accounting. More to come.
      </p>
      <div class="hub-sector-grid">
        {sectorSatellites.map((s) => (
          <a href={s.href} class="hub-sector-card" transition:name={`card-${transitionIdFromHref(s.href)}`}>
            <div class="hub-sector-kicker">{s.kicker}</div>
            <h4>{s.title}</h4>
            <p>{s.lead}</p>
          </a>
        ))}
        <a href="/secteurs" class="hub-sector-card hub-sector-card--all">
          <div class="hub-sector-kicker">ALL</div>
          <h4>All sectors</h4>
          <p>Full index, coming soon →</p>
        </a>
      </div>
    </div>
  </section>

  <Cases />
  <CtaFinal data={ctaData} lang="en" />
</Base>

<style>
  .hub-mast { position: relative; overflow: hidden; padding: 140px 32px clamp(44px, 6vw, 84px); }
  .hub-mast-geo {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none;
    opacity: 0.08;
    mix-blend-mode: multiply;
  }
  :global(.hub-kicker) { display: block; margin-bottom: 24px; }
  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--ink); }
  .hub-lede {
    font-family: var(--font-sans);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 28px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.4;
    text-wrap: pretty;
  }
  .hub-canonical {
    max-width: 720px;
    margin: 22px 0 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
  }
  .hub-canonical strong {
    color: var(--ink);
    font-weight: 600;
  }

  .hub-solutions {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1px;
    padding: 0 32px clamp(80px, 10vw, 128px);
  }
  .hub-sol-card {
    min-height: 440px;
    padding: clamp(24px, 2.5vw, 34px);
    border: 1px solid var(--hairline);
    background: var(--paper);
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: background 220ms var(--ease), border-color 220ms var(--ease), transform 220ms var(--ease);
  }
  .hub-sol-card:hover {
    background: var(--paper-2);
    border-color: var(--ink);
    transform: translateY(-4px);
  }
  .hub-sol-num {
    font-family: var(--font-display);
    font-size: clamp(42px, 4.5vw, 72px);
    line-height: 0.9;
    color: var(--accent);
    font-style: italic;
    margin-bottom: auto;
  }
  .hub-sol-kicker,
  .hub-sector-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .hub-sol-title {
    font-family: var(--font-display);
    font-size: clamp(27px, 3vw, 42px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 18px 0 10px;
    text-wrap: balance;
  }
  .hub-sol-sub {
    font-family: var(--font-display);
    font-size: 18px;
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 18px;
    text-wrap: balance;
  }
  .hub-sol-lead {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.55;
    margin: 0 0 28px;
  }
  .hub-sol-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-top: auto;
  }

  .hub-sectors {
    padding: clamp(80px, 10vw, 120px) 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .hub-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 18px 0 0;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-h2 :global(i) { font-style: italic; color: var(--ink); }
  .hub-sector-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1px;
    margin-top: clamp(40px, 5vw, 72px);
    border: 1px solid var(--hairline);
    background: var(--hairline);
  }
  .hub-sector-card {
    min-height: 230px;
    background: var(--paper);
    color: inherit;
    padding: clamp(24px, 2.6vw, 34px);
    display: flex;
    flex-direction: column;
    transition: background 220ms var(--ease), color 220ms var(--ease);
  }
  .hub-sector-card:hover { background: var(--ink); color: var(--paper); }
  .hub-sector-card:hover .hub-sector-kicker,
  .hub-sector-card:hover p { color: rgba(246,241,232,0.72); }
  .hub-sector-card h4 {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.5vw, 34px);
    line-height: 1.05;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: auto 0 16px;
    text-wrap: balance;
  }
  .hub-sector-card p {
    color: var(--muted);
    line-height: 1.45;
    margin: 0;
  }
  .hub-sector-card--all { background: var(--ink); color: var(--paper); }
  .hub-sector-card--all .hub-sector-kicker,
  .hub-sector-card--all p { color: rgba(246,241,232,0.65); }

  @media (max-width: 1180px) {
    .hub-solutions { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .hub-sector-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 700px) {
    .hub-mast { padding-top: 96px; }
    .hub-solutions {
      grid-template-columns: 1fr;
      padding-inline: 20px;
    }
    .hub-sol-card { min-height: 330px; }
    .hub-sectors { padding-inline: 20px; }
    .hub-sector-grid { grid-template-columns: 1fr; }
  }
</style>
