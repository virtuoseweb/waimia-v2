---
export const prerender = true;

import OffresDetailTemplate from '../../components/templates/OffresDetailTemplate.astro';
import { buildBreadcrumbList, buildFAQPage } from '../../lib/seo/schema-builder';

const faqItems = [
  { q: "Combien coûte une application IA pour PME ?", a: "Entre 15 et 50 k€ selon la complexité, les intégrations et le nombre d'utilisateurs. Le budget couvre tout : cadrage produit, MVP fonctionnel, 4 à 6 semaines de bêta et transfert de compétences." },
  { q: "Faut-il une équipe data science en interne ?", a: "Non. L'application est conçue pour être opérée par votre équipe actuelle, sans équipe data ni machine learning. On livre un mode opératoire complet, 2 jours de formation et une documentation exploitable. La seule compétence requise en interne : connaître vos cas d'usage métier." },
  { q: "Quelle différence avec ChatGPT for Teams ou Notion AI ?", a: "ChatGPT for Teams et Notion AI sont des outils génériques. Une application IA dédiée travaille sur vos données, votre vocabulaire et vos workflows. Elle reprend ce que votre équipe fait déjà, mais plus vite et avec moins d'erreurs. La différence concrète : l'outil générique répond en général, votre application répond avec vos règles." },
  { q: "L'application peut-elle être auto-hébergée ?", a: "Oui, si vos contraintes l'exigent : souveraineté des données, audit interne, conformité sectorielle. L'architecture par défaut est hébergée dans le cloud (Vercel + Supabase/Postgres), mais on peut déployer sur site ou cloud privé (AWS, Azure, OVH). Ce choix se décide au cadrage, pas au milieu du chantier." },
  { q: "Quelle conformité RGPD / AI Act ?", a: "On intègre le RGPD dès le cadrage : minimisation des données, droit à l'effacement, journal des accès. Pour l'AI Act, on documente le système IA (article 13) et la politique d'usage dans le mode opératoire livré." },
  { q: "Quel délai MVP raisonnable ?", a: "Notre médiane est de 12 semaines entre le premier atelier et le MVP en production. Détail : 1 semaine de cadrage produit, 4 semaines de développement, 4 à 6 semaines de bêta avec vos premiers utilisateurs, 1 semaine de mise en production et formation. Un périmètre clair peut sortir en 8 semaines. Beaucoup d'intégrations legacy poussent plutôt vers 16 semaines." },
  { q: "Et si on veut pivoter le produit en cours de route ?", a: "Le pivot se gère pendant la bêta (semaines 5 à 10). Cette phase sert à exposer le MVP à vos vrais utilisateurs et à corriger avant d'élargir. Les gros pivots de périmètre demandent un avenant. Les ajustements d'UX et les fonctionnalités secondaires sont inclus dans l'itération." },
];

const faqSchema = buildFAQPage(faqItems);

const breadcrumb = buildBreadcrumbList([
  { name: 'Accueil', url: 'https://waimia.com' },
  { name: 'Offres', url: 'https://waimia.com/offres' },
  { name: 'Application IA · PME' },
]);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Application IA · PME — Waimia',
  description: "MVP d'application IA dédiée pour PME B2B : interface, backend IA, données propriétaires, workflow métier. 15–50 k€ · 12 semaines.",
  provider: { '@type': 'Organization', name: 'Waimia', url: 'https://waimia.com' },
  areaServed: ['FR', 'CH'],
  serviceType: 'Application IA sur-mesure · PME B2B',
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: 15000,
      maxPrice: 50000,
      priceCurrency: 'EUR',
    },
  },
};

const schemas = [serviceSchema, faqSchema, breadcrumb].filter(Boolean);
---
<OffresDetailTemplate
  tier="§ NIVEAU INTERMÉDIAIRE · 15–50 k€"
  tierLabel="Application IA · PME"
  meta="Niveau intermédiaire · 15–50 k€ · délai 12-16 sem"
  title="Application IA PME — MVP dédié 15–50 k€ | Waimia"
  description="MVP d'application IA dédiée pour PME B2B : interface, backend IA, données propriétaires, workflow métier. Entre le site éditorial et l'infrastructure complète. 15–50 k€ · 12 semaines."
  ctaLabel="Câbler mon application IA →"
>
  <Fragment slot="title"><i>Application</i><br />IA · PME</Fragment>
  <Fragment slot="lead">
    Pas un site. Pas un widget. Une vraie application IA.
    <span>Interfaces métier, données propriétaires, workflow dédié — câblés et livrés en 12 semaines.</span>
  </Fragment>
  <Fragment slot="problem-statement">
    Vous avez un cas d'usage IA spécifique. Les outils génériques ne suffisent pas. Vous avez besoin d'<em>une app dédiée</em> — vos données, votre workflow, votre interface.
  </Fragment>
  <Fragment slot="problem-annotations">
    <div><div class="ann-value">12 sem</div><div class="ann-label">délai MVP médian</div></div>
    <div><div class="ann-value">×3</div><div class="ann-label">productivité utilisateurs cibles</div></div>
    <div><div class="ann-value">15–50 k€</div><div class="ann-label">investissement tout compris</div></div>
  </Fragment>
  <Fragment slot="method-aside">Quatre phases. Douze semaines. Un MVP en production avec vos utilisateurs réels.</Fragment>
  <Fragment slot="method-steps">
    <div class="step">
      <div class="step-n">01</div>
      <div class="step-k">Cadrage produit · 5 jours</div>
      <h3>Spec MVP + utilisateurs cibles + KPI</h3>
      <p>5 jours d'ateliers pour définir le périmètre exact du MVP, les utilisateurs cibles, les KPI de succès et l'architecture technique. Livrable : spec produit signée + plan de développement.</p>
    </div>
    <div class="step">
      <div class="step-n">02</div>
      <div class="step-k">MVP fonctionnel · 4 sem</div>
      <h3>Interface + backend IA + bêta</h3>
      <p>Développement du MVP : interface (Astro ou Next.js), backend IA avec les modèles adaptés, base de données (Postgres/Supabase) et intégrations clés. Déploiement auprès de votre première cohorte bêta.</p>
    </div>
    <div class="step">
      <div class="step-n">03</div>
      <div class="step-k">Itération bêta · 4-6 sem</div>
      <h3>Retours terrain + ajustements + montée en charge</h3>
      <p>Cycles de retours avec vos utilisateurs réels. Ajustements UX, corrections de logique métier, montée en charge. Les pivots de fonctionnalités secondaires sont inclus dans cette phase.</p>
    </div>
    <div class="step">
      <div class="step-n">04</div>
      <div class="step-k">Production + passation</div>
      <h3>Documentation + formation + supervision</h3>
      <p>Mise en production complète, supervision Helicone (coût et latence IA), formation équipe 2 jours, mode opératoire. Vous prenez la main — nous restons disponibles 30 jours après livraison.</p>
    </div>
  </Fragment>
  <Fragment slot="deliverables-aside">Six livrables tangibles. Tout est documenté, transmissible, ouvrable. Pas de boîte noire.</Fragment>
  <Fragment slot="deliverables">
    <div class="del-card">
      <h3>MVP fonctionnel déployé</h3>
      <p>Application complète en production sur votre domaine. Interface, backend IA, base de données — prête pour vos utilisateurs cibles.</p>
      <span class="del-tag">APP LIVE</span>
    </div>
    <div class="del-card">
      <h3>Backend IA câblé</h3>
      <p>Intégration des modèles IA adaptés à vos cas d'usage (raisonnement, volume, créatif). Vos données propriétaires connectées via RAG ou fine-tuning si nécessaire.</p>
      <span class="del-tag">BACKEND IA</span>
    </div>
    <div class="del-card">
      <h3>Interface Astro ou Next.js</h3>
      <p>Interface utilisateur performante, responsive, accessible. Composants réutilisables, architecture maintenable par votre équipe après transfert.</p>
      <span class="del-tag">INTERFACE</span>
    </div>
    <div class="del-card">
      <h3>Base de données Postgres / Supabase</h3>
      <p>Architecture données robuste avec migrations versionnées, backups automatiques et politiques d'accès par rôle (RLS).</p>
      <span class="del-tag">DATA</span>
    </div>
    <div class="del-card">
      <h3>Supervision Helicone</h3>
      <p>Tableau de supervision IA : coût par requête, latence, taux d'erreur, usage par fonctionnalité. Vous voyez exactement ce que l'IA consomme.</p>
      <span class="del-tag">SUPERVISION</span>
    </div>
    <div class="del-card">
      <h3>Mode opératoire + formation 2 jours</h3>
      <p>Documentation technique et opérationnelle complète. Formation équipe sur les cas d'usage et la supervision. Votre équipe est autonome dès le lendemain.</p>
      <span class="del-tag">DOCS + FORMATION</span>
    </div>
  </Fragment>
  <Fragment slot="proof-quote">"Nous avions un cas d'usage IA précis et aucun outil du marché ne le couvrait. Waimia a livré un MVP en 11 semaines — interface, backend, données internes connectées. L'équipe l'utilise tous les jours. Le temps de traitement est passé de 4 heures à 18 minutes."</Fragment>
  <Fragment slot="proof-attr">Directrice des Opérations · Cabinet Conseil B2B · Paris</Fragment>
  <Fragment slot="proof-metrics">
    <div><div class="metric-v">11 sem</div><div class="metric-l">MVP en production</div></div>
    <div><div class="metric-v">×13</div><div class="metric-l">vitesse traitement</div></div>
    <div><div class="metric-v">100%</div><div class="metric-l">adoption équipe</div></div>
    <div><div class="metric-v">0 DS</div><div class="metric-l">data scientist requis</div></div>
  </Fragment>
  <Fragment slot="cta-title"><i>Câbler votre<br />application IA.</i></Fragment>
  <Fragment slot="cta-body">45 minutes. On regarde votre cas d'usage, on cadre le MVP et on chiffre. Si ce n'est pas le bon niveau d'offre pour vous, on vous dirige vers le bon format.</Fragment>
  <Fragment slot="related">
    <script type="application/ld+json" set:html={JSON.stringify(schemas)}></script>

    <!-- FAQ Application IA · PME -->
    <section style="padding: clamp(72px,8vw,120px) 0; position:relative;">
      <div style="max-width:880px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
        <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--accent); margin-bottom:16px;">Questions fréquentes</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(32px,4vw,56px); line-height:.96; letter-spacing:-.018em; font-weight:400; margin:0 0 48px;"><i style="color:var(--accent); font-style:italic;">FAQ</i><br />Application IA · PME</h2>
        <div style="border-top:1px solid rgba(0,0,0,.12);">
          {faqItems.map(item => (
            <details style="border-bottom:1px solid rgba(0,0,0,.08); padding:0;">
              <summary style="font-family:var(--font-display); font-size:clamp(17px,1.5vw,20px); line-height:1.3; font-weight:400; padding:24px 0; cursor:pointer; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:16px;">
                {item.q}
                <span style="font-family:var(--font-display); font-size:24px; color:var(--accent); flex-shrink:0; transition:transform 220ms;">+</span>
              </summary>
              <div style="font-size:15px; line-height:1.6; color:var(--ink); padding:0 0 24px; max-width:720px;">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Navigation inter-offres -->
    <section style="padding: clamp(48px,6vw,80px) 0; background: var(--paper-2, #EFEBE2);">
      <div style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:clamp(24px,4vw,64px); align-items:start;">
          <div>
            <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:12px;">Aussi dans notre gamme</div>
            <p style="font-family:var(--font-display); font-size:clamp(16px,1.4vw,19px); line-height:1.5; color:var(--ink); margin:0 0 16px;">Besoin d'abord de <strong>câbler votre acquisition</strong> avant de développer une application ? Le Growth System IA (5–20 k€) pose les bases : site, CRM, pipeline éditorial.</p>
            <a href="/offres/growth-system-ia" style="font-family:var(--font-mono); font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--accent); text-decoration:none; border-bottom:1px solid currentColor; padding-bottom:2px;">Growth System IA · 5–20 k€ →</a>
          </div>
          <div>
            <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:12px;">Niveau supérieur</div>
            <p style="font-family:var(--font-display); font-size:clamp(16px,1.4vw,19px); line-height:1.5; color:var(--ink); margin:0 0 16px;">Pour une <strong>infrastructure IA complète</strong> (base de données vectorielle, pipelines de données, modèles fine-tunés), l'offre Infrastructure IA démarre à 25 k€.</p>
            <a href="/offres/infrastructure-ia" style="font-family:var(--font-mono); font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); text-decoration:none; border-bottom:1px solid currentColor; padding-bottom:2px;">Infrastructure IA · 25–150 k€ →</a>
          </div>
        </div>
      </div>
    </section>
  </Fragment>
  <Fragment slot="body-end">
    <script>
      import { initOffresRich } from '../../lib/animations/signature/offres-rich';
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initOffresRich);
      } else {
        initOffresRich();
      }
    </script>
  </Fragment>
</OffresDetailTemplate>
