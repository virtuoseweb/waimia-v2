---
export const prerender = true;

import OffresDetailTemplate from '../../components/templates/OffresDetailTemplate.astro';
import { buildBreadcrumbList, buildFAQPage } from '../../lib/seo/schema-builder';

const faqItems = [
  { q: "Combien coûte une app IA pour PME ?", a: "Entre 15 et 50 k€ selon la complexité, les intégrations et le nombre d'utilisateurs. Ce budget couvre tout : cadrage produit, MVP fonctionnel, 4 à 6 semaines de bêta et transfert de compétences." },
  { q: "Faut-il une équipe data science en interne ?", a: "Non. L'application est conçue pour être opérée par votre équipe existante sans compétences en data science ou machine learning. Nous livrons un runbook complet, une formation de 2 jours et une documentation opérationnelle. La seule compétence requise en interne : comprendre les cas d'usage métier — c'est vous l'expert." },
  { q: "Quelle différence avec ChatGPT for Teams ou Notion AI ?", a: "ChatGPT for Teams et Notion AI sont des outils génériques. Une application IA dédiée est construite sur vos données propriétaires, votre vocabulaire métier, vos workflows spécifiques. Elle fait exactement ce que votre équipe fait — mais plus vite et sans erreur. La différence concrète : un outil générique donne des réponses génériques, votre app répond avec vos données, vos formats, votre logique." },
  { q: "L'app peut-elle être self-hostée ?", a: "Oui, si requis par vos contraintes (souveraineté des données, audit interne, conformité sectorielle). L'architecture par défaut est cloud-hébergée (Vercel + Supabase/Postgres) mais nous pouvons adapter pour un déploiement on-premise ou cloud privé (AWS, Azure, OVH). Ce choix est décidé en phase de cadrage, pas en cours de développement." },
  { q: "Quelle conformité RGPD / AI Act ?", a: "Nous intégrons la conformité RGPD dès la phase de cadrage : minimisation des données, droit à l'effacement, journalisation des accès. Pour l'AI Act, les applications IA à risque limité (assistance, recommandation) ne sont pas soumises aux obligations de haute surveillance. Nous documentons le système IA (article 13 AI Act) et la politique d'utilisation acceptable dans le runbook livré." },
  { q: "Quel time-to-MVP raisonnable ?", a: "Notre médiane est de 12 semaines entre le premier atelier de cadrage et le MVP en production. Détail : 1 semaine de cadrage produit, 4 semaines de développement MVP, 4 à 6 semaines d'itération beta avec votre première cohorte utilisateurs, 1 semaine de mise en production et formation. Les projets avec périmètre clairement défini vont plus vite (8 semaines). Les projets avec beaucoup d'intégrations legacy prennent plus de temps (16 semaines)." },
  { q: "Et si on veut pivoter le produit en cours de route ?", a: "Le pivot est géré en phase d'itération beta (semaines 5 à 10). C'est précisément l'objectif de cette phase : exposer le MVP à vos utilisateurs réels et ajuster avant de scaler. Les pivots de périmètre majeurs (refonte de la proposition de valeur ou du modèle de données) sont possibles mais entraînent un avenant au contrat. Les pivots d'UX et de fonctionnalités secondaires sont inclus dans le budget d'itération." },
];

const faqSchema = buildFAQPage(faqItems);

const breadcrumb = buildBreadcrumbList([
  { name: 'Accueil', url: 'https://waimia.com' },
  { name: 'Offres', url: 'https://waimia.com/offres' },
  { name: 'Application IA · PME' },
]);

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Application IA · PME — Waimia',
  description: "MVP d'application IA dédiée pour PME B2B : frontend + backend IA + données propriétaires + workflow métier. 15–50 k€ · 12 semaines.",
  provider: { '@type': 'Organization', name: 'Waimia', url: 'https://waimia.com' },
  areaServed: ['FR', 'CH'],
  serviceType: 'Application IA sur-mesure · PME B2B',
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      minPrice: 15000,
      maxPrice: 50000,
      priceCurrency: 'EUR',
    },
  },
};

const schemas = [serviceSchema, faqSchema, breadcrumb].filter(Boolean);
---
<OffresDetailTemplate
  tier="§ NIVEAU INTERMÉDIAIRE · 15–50 k€"
  tierLabel="Application IA · PME"
  meta="Niveau intermédiaire · 15–50 k€ · délai 12-16 sem"
  title="Application IA PME — MVP app dédiée 15-50 k€ | Waimia"
  description="MVP d'application IA dédiée pour PME B2B : frontend + backend IA + données propriétaires + workflow métier. Entre le site éditorial et l'infrastructure complète. 15–50 k€ · 12 semaines."
  ctaLabel="Câbler mon app IA →"
>
  <Fragment slot="title"><i>Application</i><br />IA · PME</Fragment>
  <Fragment slot="lead">
    Pas un site. Pas un widget. Une vraie app IA.
    <span>Interfaces métier, données propriétaires, workflow dédié — câblés et livrés en 12 semaines.</span>
  </Fragment>
  <Fragment slot="problem-statement">
    Vous avez un cas d'usage IA spécifique. Les outils génériques ne suffisent pas. Vous avez besoin d'<em>une app dédiée</em> — vos données, votre workflow, votre interface.
  </Fragment>
  <Fragment slot="problem-annotations">
    <div><div class="ann-value">12 sem</div><div class="ann-label">time-to-MVP médian</div></div>
    <div><div class="ann-value">×3</div><div class="ann-label">productivité utilisateurs cibles</div></div>
    <div><div class="ann-value">15–50 k€</div><div class="ann-label">investissement tout compris</div></div>
  </Fragment>
  <Fragment slot="method-aside">Quatre phases. Douze semaines. Un MVP en production avec vos utilisateurs réels.</Fragment>
  <Fragment slot="method-steps">
    <div class="step">
      <div class="step-n">01</div>
      <div class="step-k">Cadrage produit · 5 jours</div>
      <h3>Spec MVP + ICP user + KPI</h3>
      <p>5 jours d'ateliers pour définir le périmètre fonctionnel exact du MVP, les utilisateurs cibles (ICP), les KPI de succès et l'architecture technique. Livrable : spec produit signée + plan de développement.</p>
    </div>
    <div class="step">
      <div class="step-n">02</div>
      <div class="step-k">MVP fonctionnel · 4 sem</div>
      <h3>Frontend + backend IA + beta</h3>
      <p>Développement du MVP : frontend (Astro ou Next.js), backend IA avec les modèles appropriés, base de données (Postgres/Supabase) et intégrations clés. Déploiement sur votre première cohorte beta.</p>
    </div>
    <div class="step">
      <div class="step-n">03</div>
      <div class="step-k">Itération beta · 4-6 sem</div>
      <h3>Feedback + ajustements + scaling</h3>
      <p>Cycles de feedback avec vos utilisateurs réels. Ajustements UX, corrections de logique métier, montée en charge. Les pivots de fonctionnalités secondaires sont inclus dans cette phase.</p>
    </div>
    <div class="step">
      <div class="step-n">04</div>
      <div class="step-k">Production + handover</div>
      <h3>Docs + formation + monitoring</h3>
      <p>Mise en production complète, monitoring Helicone (coût et latence IA), formation équipe 2 jours, runbook opérationnel. Vous prenez la main — nous restons disponibles 30 jours post-livraison.</p>
    </div>
  </Fragment>
  <Fragment slot="deliverables-aside">Six livrables tangibles. Tout documenté, transmissible, ouvrable. Pas de boîte noire.</Fragment>
  <Fragment slot="deliverables">
    <div class="del-card">
      <h3>MVP fonctionnel déployé</h3>
      <p>Application complète en production sur votre domaine. Frontend, backend IA, base de données — prête à l'usage par vos utilisateurs cibles.</p>
      <span class="del-tag">APP LIVE</span>
    </div>
    <div class="del-card">
      <h3>Backend IA câblé</h3>
      <p>Intégration des modèles IA adaptés à vos cas d'usage (raisonnement, volume, créatif). Vos données propriétaires connectées via RAG ou fine-tuning si nécessaire.</p>
      <span class="del-tag">BACKEND IA</span>
    </div>
    <div class="del-card">
      <h3>Frontend Astro ou Next.js</h3>
      <p>Interface utilisateur performante, responsive, accessible. Composants réutilisables, architecture maintenable par votre équipe après transfert.</p>
      <span class="del-tag">FRONTEND</span>
    </div>
    <div class="del-card">
      <h3>Base de données Postgres / Supabase</h3>
      <p>Architecture données robuste avec migrations versionnées, backups automatiques et politiques d'accès par rôle (RLS).</p>
      <span class="del-tag">DATA</span>
    </div>
    <div class="del-card">
      <h3>Monitoring Helicone</h3>
      <p>Dashboard de supervision IA : coût par requête, latence, taux d'erreur, usage par feature. Vous voyez exactement ce que l'IA consomme.</p>
      <span class="del-tag">MONITORING</span>
    </div>
    <div class="del-card">
      <h3>Runbook + formation 2 jours</h3>
      <p>Documentation technique et opérationnelle complète. Formation équipe sur les cas d'usage et la supervision. Votre équipe est autonome dès le lendemain.</p>
      <span class="del-tag">DOCS + FORMATION</span>
    </div>
  </Fragment>
  <Fragment slot="proof-quote">"Nous avions un cas d'usage IA précis mais aucun outil du marché ne le couvrait. Waimia a livré un MVP en 11 semaines — interface, backend, données internes connectées. L'équipe l'utilise tous les jours. Le temps de traitement est passé de 4 heures à 18 minutes."</Fragment>
  <Fragment slot="proof-attr">Directrice des Opérations · Cabinet Conseil B2B · Paris</Fragment>
  <Fragment slot="proof-metrics">
    <div><div class="metric-v">11 sem</div><div class="metric-l">MVP en production</div></div>
    <div><div class="metric-v">×13</div><div class="metric-l">vitesse traitement</div></div>
    <div><div class="metric-v">100%</div><div class="metric-l">adoption équipe</div></div>
    <div><div class="metric-v">0 DS</div><div class="metric-l">data scientist requis</div></div>
  </Fragment>
  <Fragment slot="cta-title"><i>Câbler votre<br />app IA.</i></Fragment>
  <Fragment slot="cta-body">45 minutes. On regarde votre cas d'usage, on cadre le périmètre MVP et on chiffre. Si ce n'est pas le bon niveau d'offre pour vous, on vous dirige vers ce qui correspond.</Fragment>
  <Fragment slot="related">
    <script type="application/ld+json" set:html={JSON.stringify(schemas)}></script>

    <!-- FAQ Application IA · PME -->
    <section style="padding: clamp(72px,8vw,120px) 0; position:relative;">
      <div style="max-width:880px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
        <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--accent); margin-bottom:16px;">Questions fréquentes</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(32px,4vw,56px); line-height:.96; letter-spacing:-.018em; font-weight:400; margin:0 0 48px;"><i style="color:var(--accent); font-style:italic;">FAQ</i><br />Application IA · PME</h2>
        <div style="border-top:1px solid rgba(0,0,0,.12);">
          {faqItems.map(item => (
            <details style="border-bottom:1px solid rgba(0,0,0,.08); padding:0;">
              <summary style="font-family:var(--font-display); font-size:clamp(17px,1.5vw,20px); line-height:1.3; font-weight:400; padding:24px 0; cursor:pointer; list-style:none; display:flex; justify-content:space-between; align-items:center; gap:16px;">
                {item.q}
                <span style="font-family:var(--font-display); font-size:24px; color:var(--accent); flex-shrink:0; transition:transform 220ms;">+</span>
              </summary>
              <div style="font-size:15px; line-height:1.6; color:var(--ink); padding:0 0 24px; max-width:720px;">{item.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Navigation inter-offres -->
    <section style="padding: clamp(48px,6vw,80px) 0; background: var(--paper-2, #EFEBE2);">
      <div style="max-width:1240px; margin:0 auto; padding:0 clamp(20px,4vw,48px);">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:clamp(24px,4vw,64px); align-items:start;">
          <div>
            <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:12px;">Aussi dans notre gamme</div>
            <p style="font-family:var(--font-display); font-size:clamp(16px,1.4vw,19px); line-height:1.5; color:var(--ink); margin:0 0 16px;">Besoin d'abord de <strong>câbler votre acquisition</strong> avant de développer une app ? Le Growth System IA (5–20 k€) pose les bases : site, CRM, pipeline éditorial.</p>
            <a href="/offres/growth-system-ia" style="font-family:var(--font-mono); font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--accent); text-decoration:none; border-bottom:1px solid currentColor; padding-bottom:2px;">Growth System IA · 5–20 k€ →</a>
          </div>
          <div>
            <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:12px;">Niveau supérieur</div>
            <p style="font-family:var(--font-display); font-size:clamp(16px,1.4vw,19px); line-height:1.5; color:var(--ink); margin:0 0 16px;">Pour une <strong>infrastructure IA complète</strong> (base de données vectorielle, pipelines de données, modèles fine-tunés), l'offre Infrastructure IA démarre à 25 k€.</p>
            <a href="/offres/infrastructure-ia" style="font-family:var(--font-mono); font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--muted); text-decoration:none; border-bottom:1px solid currentColor; padding-bottom:2px;">Infrastructure IA · 25–150 k€ →</a>
          </div>
        </div>
      </div>
    </section>
  </Fragment>
  <Fragment slot="body-end">
    <script>
      import { initOffresRich } from '../../lib/animations/signature/offres-rich';
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initOffresRich);
      } else {
        initOffresRich();
      }
    </script>
  </Fragment>
</OffresDetailTemplate>
