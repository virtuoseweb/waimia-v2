---
// Page · /offres/conseil · Hub Consulting, Audit & Strategy
export const prerender = true;

// Source : waimia-handoff2 / hub-consulting.html (page primaire selon README)
//
// Composé de · HubTemplate (squelette) + ServiceCatalogRow × 7 (catalogue)
// Le contenu du handoff est intégré ici — données structurées, slots HTML riche.

import HubTemplate from '../../components/templates/HubTemplate.astro';
import ServiceCatalogRow from '../../components/ui/molecules/ServiceCatalogRow.astro';
import EditorialTable from '../../components/editorial/EditorialTable.astro';
import ConseilAuditDiagram from '../../components/svg/geometric/ConseilAuditDiagram.astro';

const stats = [
  { k: '43',    label_fr: 'interventions',         label_en: 'engagements' },
  { k: '18 M€+', label_fr: 'pipeline restructuré', label_en: 'pipeline audited' },
  { k: '0',     label_fr: 'ateliers vendus',       label_en: 'workshops sold' },
  { k: '12',    label_fr: 'juridictions UE',       label_en: 'EU jurisdictions' },
];

// Catalogue services · 7 services hub-consulting
const services = [
  { num: '02.1', slug: 'audit-maturite-ia', meta: '10 j · 10 days',
    title_fr: 'Audit de maturité IA', title_en: 'AI Readiness Assessment',
    desc_fr: "Un diagnostic de 10 jours. Données, outillage, équipe, gouvernance. Une grille lisible.",
    desc_en: "A 10-day diagnostic. Data, tooling, team, governance. One readable scorecard." },
  { num: '02.2', slug: 'roadmap-ia', meta: '3–5 sem · 3–5 wks',
    title_fr: "Cadrage & feuille de route IA", title_en: 'Strategic Scoping & AI Roadmap',
    desc_fr: "On rédige le backlog ordonné qu'une direction peut approuver et qu'un lead technique peut livrer.",
    desc_en: "We write the ordered backlog a board can approve and an eng lead can ship against." },
  { num: '02.3', slug: 'gouvernance-donnees', meta: '4 sem · 4 wks',
    title_fr: 'Audit gouvernance & qualité des données', title_en: 'Data Governance & Quality Audit',
    desc_fr: "Là où l'entrepôt ment, là où le CRM ment, quel chiffre la finance peut croire.",
    desc_en: 'Where the warehouse lies, where the CRM lies, where finance can trust which number.' },
  { num: '02.4', slug: 'dette-technique-ia', meta: '4 sem · 4 wks',
    title_fr: "Audit dette technique pour l'IA", title_en: 'IT & Technical Debt Audit for AI',
    desc_fr: "Ce qui empêche les agents de partir en prod. Classé par coût de correction, pas par drame.",
    desc_en: 'What blocks agents from shipping to production. Ranked by cost-to-fix, not by drama.' },
  { num: '02.5', slug: 'rpa-vers-agents', meta: '3 sem · 3 wks',
    title_fr: 'Migration RPA → agents IA', title_en: 'RPA → Agentic AI Migration Mapping',
    desc_fr: "Lesquels de vos 200 bots RPA survivent en agents. Lesquels doivent mourir. Lesquels étaient du théâtre.",
    desc_en: 'Which of your 200 RPA bots survive as agents. Which should die. Which were always theatre.' },
  { num: '02.6', slug: 'finops-ia', meta: '2 sem · 2 wks',
    title_fr: 'AI FinOps — coûts LLM & cloud', title_en: 'AI FinOps — LLM & Cloud Cost Optimization',
    desc_fr: "Tokenisation, lots, cache, routage. On coupe 40–70 % sur les factures LLM, sans grand discours.",
    desc_en: 'Tokenization, batching, caching, model routing. We cut LLM bills by 40–70% without telling anyone.' },
  { num: '02.7', slug: 'cybersecurite-ia', meta: '3–6 sem · 3–6 wks',
    title_fr: "Cybersécurité & pen test des systèmes IA", title_en: 'AI Systems Cybersecurity & Pen Testing',
    desc_fr: "Injection de prompt, exfil, jailbreaks, supply chain. On attaque d'abord, à l'écrit.",
    desc_en: 'Prompt injection, data exfil, jailbreaks, supply chain. We attack it first, in writing.' },
];

const serviceComparisonRows = [
  ['Décider avant budget', 'Audit de maturité IA', 'Grille de score, risques, priorités, feu vert ou arrêt en 10 jours'],
  ['Obtenir un accord direction', 'Cadrage & feuille de route IA', 'Backlog chiffré, séquencé, lisible par DSI et COMEX'],
  ['Fiabiliser les chiffres', 'Gouvernance & qualité des données', 'Sources de vérité, ownership, contrôles et anomalies'],
  ['Préparer la production', "Dette technique pour l'IA", 'Freins agents, API, sécurité, coûts de correction'],
  ['Sortir du RPA fragile', 'Migration RPA → agents IA', 'Bots à garder, remplacer, arrêter ou documenter'],
  ['Réduire les coûts IA', 'AI FinOps', 'Routage modèles, cache, traitement par lots, garde-fous budget'],
  ['Tester la surface de risque', 'Cybersécurité IA', 'Prompt injection, exfiltration, jailbreaks, supply chain'],
];

const decisionTreeItems = [
  "Vous ne savez pas par où commencer : Audit de maturité IA.",
  "Vous devez faire valider un budget : Cadrage & feuille de route IA.",
  "Vos données ou votre CRM ne sont pas fiables : Gouvernance & qualité des données.",
  "Vos agents restent bloqués avant la production : Dette technique pour l'IA.",
  "Vos bots RPA coûtent trop cher à maintenir : Migration RPA → agents IA.",
  "La facture LLM grimpe sans contrôle : AI FinOps.",
  "Le RSSI demande des preuves : Cybersécurité IA.",
];

const fitYesItems = [
  "Vous avez un CRM que personne ne croit et un entrepôt qui dit autre chose.",
  "Votre équipe GRC réclame des traces d'audit que votre stack IA actuelle ne produit pas.",
  "Vous avez essayé un cabinet piloté par ateliers — vous avez eu 72 slides et aucune décision.",
  "Vous avez entre 50 et 500 collaborateurs en Europe et de vraies obligations de gouvernance.",
  "Votre DSI a arrêté de répondre aux demandes IA internes faute de méthode d'arbitrage documentée.",
  "Vous êtes en cours d'audit DORA, ISO 42001 ou NIS2 et votre stack IA n'est pas encore documentée.",
];
const fitNoItems = [
  "Vous cherchez un logo pour votre rapport innovation.",
  "Vous voulez un chatbot pour vendredi.",
  "Vous voulez entraîner votre propre modèle de fondation.",
  "Vous cherchez quelqu'un pour animer 12 ateliers.",
];

const relatedCards = [
  { kicker: 'CASE 04', title_fr: 'Plateau SaaS', title_en: 'Plateau SaaS',
    lead_fr: '+2,4 M€ pipeline →', lead_en: '+€2.4M pipeline →',
    href: '/cas/plateau' },
  { kicker: 'CASE 07', title_fr: 'Halcyon Health', title_en: 'Halcyon Health',
    lead_fr: '−38% temps de triage →', lead_en: '−38% triage time →',
    href: '/cas/halcyon' },
  { kicker: 'CASE 09', title_fr: 'Caserne Industrie', title_en: 'Caserne Industry',
    lead_fr: '780 k€ FinOps économisés →', lead_en: '€780k FinOps saved →',
    href: '/cas/caserne' },
];
---
<HubTemplate
  title="Conseil, audit & stratégie · Waimia"
  description="Sept services pour solidifier une intervention IA : données, gouvernance, coût, sécurité. Faits par nous-mêmes, par écrit."
  hubNum="02"
  metaKickerFr="Hub · Pilier Entreprise · 7 services"
  metaKickerEn="Hub · Enterprise pillar · 7 services"
  stats={stats}
  fitYesTitleFr="Vous êtes fait pour nous si"
  fitYesTitleEn="You're a fit if"
  fitYesItems={fitYesItems}
  fitNoTitleFr="On refusera si"
  fitNoTitleEn="We'll say no if"
  fitNoItems={fitNoItems}
  relatedKickerFr="Cas issus de ce hub"
  relatedKickerEn="Cases that came out of this hub"
  relatedCards={relatedCards}
>
  {/* HEADLINE — méthode Slots Astro, JSX riche (italic, br) sans sérialisation */}
  <Fragment slot="headline">
    Le conseil qui commence par <i>lire</i> — pas par présenter.
  </Fragment>
  <Fragment slot="lede">
    Nous refusons les ateliers de découverte vendus comme du conseil. Un engagement Waimia commence par la lecture de vos données réelles, se termine par un livrable écrit, et produit une décision — pas 72 slides dans un SharePoint.
  </Fragment>

  {/* MANIFESTO PULL · stance éditorial */}
  <Fragment slot="manifesto">
    Une mission de conseil n'est pas un <i>diagnostic de 72 slides</i>. C'est une décision prise plus tôt, un risque nommé et un livrable que l'équipe peut exploiter. <i>Nous ne vendons pas d'ateliers. Nous livrons des documents signés.</i>
  </Fragment>

  {/* CATALOGUE · 7 ServiceCatalogRow */}
  <Fragment slot="catalog-meta">07 · TRIÉ DANS L'ORDRE D'UTILISATION</Fragment>
  <Fragment slot="catalog">
    {services.map((s) => (
      <ServiceCatalogRow
        num={s.num}
        title_fr={s.title_fr} title_en={s.title_en}
        desc_fr={s.desc_fr} desc_en={s.desc_en}
        meta={s.meta}
        href={`/offres/${s.slug}`}
      />
    ))}
    <section class="reveal-stagger" style="padding: clamp(64px,7vw,96px) 0 0;">
      <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); margin-bottom:16px;">Comparateur services</div>
      <h2 style="font-family:var(--font-display); font-size:clamp(34px,4.5vw,64px); line-height:.96; font-weight:400; margin:0 0 28px;"><i style="color:var(--accent); font-style:italic;">Quel service</i><br/>pour quelle décision ?</h2>
      <EditorialTable
        caption="Lecture rapide du catalogue conseil"
        columns={['Besoin', 'Service', 'Livrable de décision']}
        rows={serviceComparisonRows}
        align="left"
        variant="editorial"
      />
    </section>
    <section class="reveal-stagger" style="padding: clamp(48px,5vw,72px) 0 0;">
      <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:clamp(28px,5vw,64px); border-top:1px solid rgba(0,0,0,.16); padding-top:32px;">
        <div>
          <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); margin-bottom:16px;">Arbre de décision</div>
          <h2 style="font-family:var(--font-display); font-size:clamp(30px,3.8vw,54px); line-height:.98; font-weight:400; margin:0;"><i style="color:var(--accent); font-style:italic;">Quel service</i><br/>pour vous ?</h2>
        </div>
        <ol style="list-style:none; margin:0; padding:0; counter-reset:decision;">
          {decisionTreeItems.map((item, index) => (
            <li style="display:grid; grid-template-columns:48px 1fr; gap:18px; padding:18px 0; border-bottom:1px solid rgba(0,0,0,.08); color:var(--ink); font-size:16px; line-height:1.55;">
              <span style="font-family:var(--font-mono); font-size:11px; letter-spacing:.12em; color:var(--accent);">0{index + 1}</span>
              <span>{item}</span>
            </li>
          ))}
        </ol>
      </div>
    </section>
    <div class="reveal-fade" style="padding: clamp(48px,6vw,80px) 0 0; max-width: 640px; margin-inline: auto;">
      <ConseilAuditDiagram />
    </div>
  </Fragment>

  {/* FIT HEADLINE */}
  <Fragment slot="fit-headline">
    Pour la <i>DSI</i>, la COO, le RSSI — quand il faut décider vite, par écrit, sans théâtre.
  </Fragment>
</HubTemplate>
