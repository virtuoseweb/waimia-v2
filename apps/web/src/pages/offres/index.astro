---
// Page · /offres · Hub Offres M3
export const prerender = true;

// Mission M3 · 3 piliers + 2 niveaux · Growth System IA en vedette

import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import Pyramid from '../../components/ui/organisms/Pyramid.astro';
import CtaBand from '../../components/ui/organisms/CtaBand.astro';

const offresHero = {
  num: '01',
  kicker: 'OFFRE PHARE · 5 à 20 k€',
  title_fr: 'Growth System IA',
  sub_fr: "Pas un site. Pas un CRM. Pas un dashboard. Un système.",
  lead_fr: "Site, CRM, relances, pilotage — connectés et mesurés. Le mardi on câble. Le vendredi on mesure.",
  href: '/offres/growth-system-ia',
};

const offresPiliers = [
  { num: '02', kicker: 'PILIER · 8 à 35 k€',
    title_fr: 'Growth Intelligence', sub_fr: 'Pilotage temps réel',
    lead_fr: 'KPI commerciaux et opérationnels en temps réel. La lisibilité qui change la décision.',
    href: '/offres/growth-intelligence' },
  { num: '03', kicker: 'PILIER · 6 à 25 k€',
    title_fr: 'Productivité Opérationnelle IA', sub_fr: 'Tâches répétitives éliminées',
    lead_fr: 'Excel augmenté, Office connecté, workflows internes fluidifiés.',
    href: '/offres/productivite-operationnelle-ia' },
];

const offresNiveaux = [
  { kicker: 'STARTER · 1 à 5 k€',
    title_fr: 'Activation IA · 1 semaine',
    lead_fr: "Cinq jours. Un workflow en production. Pas un POC, pas une démo.",
    href: '/offres/activation-ia' },
  { kicker: 'ETI · 25 à 150 k€+',
    title_fr: 'Infrastructure IA · ETI',
    lead_fr: "Quand les pilotes IA s'éparpillent. Une infra commune, une gouvernance, une équipe interne formée.",
    href: '/offres/infrastructure-ia' },
];
---
<Base
  title="Offres · 3 piliers + 2 niveaux · Waimia"
  description="Trois systèmes pour les leviers business des PME — Growth System IA, Growth Intelligence, Productivité Opérationnelle. Plus deux niveaux : Activation 1 semaine, Infrastructure ETI."
>
  <section class="hub-mast">
    <div class="wrap-wide">
      <Kicker class="hub-kicker">§ Offres · 3 piliers + 2 niveaux</Kicker>
      <h1 class="hub-h1 reveal">Trois <i>systèmes</i>. Deux <i>niveaux</i>. Une <i>méthode</i>.</h1>
      <p class="hub-lede">
        Pas un module. Pas un add-on. Trois systèmes complets, deux niveaux d'engagement. Le reste, ce sont des slides.
      </p>
    </div>
  </section>

  <section class="hub-hero-offre wrap-wide">
    <a href={offresHero.href} class="hub-hero-card">
      <div class="hub-hero-num">{offresHero.num}</div>
      <div class="hub-hero-kicker">{offresHero.kicker}</div>
      <h2 class="hub-hero-title">{offresHero.title_fr}</h2>
      <p class="hub-hero-sub">{offresHero.sub_fr}</p>
      <p class="hub-hero-lead">{offresHero.lead_fr}</p>
      <span class="hub-hero-cta">Activer →</span>
    </a>
  </section>

  <section class="hub-piliers wrap-wide">
    <Kicker>§ Les autres piliers</Kicker>
    <h3 class="hub-h3">Voir clair. Travailler moins vite — et mieux.</h3>
    <div class="hub-pilier-grid">
      {offresPiliers.map((p) => (
        <a href={p.href} class="hub-pilier-card">
          <div class="hub-pilier-num">{p.num}</div>
          <div class="hub-pilier-kicker">{p.kicker}</div>
          <h4>{p.title_fr}</h4>
          <p class="hub-pilier-sub">{p.sub_fr}</p>
          <p class="hub-pilier-lead">{p.lead_fr}</p>
          <span class="hub-pilier-cta">Voir l'offre →</span>
        </a>
      ))}
    </div>
  </section>

  <Pyramid />

  <section class="hub-niveaux wrap-wide">
    <Kicker>§ Niveaux d'engagement</Kicker>
    <h3 class="hub-h3">Une porte d'entrée. Un toit.</h3>
    <div class="hub-niveau-grid">
      {offresNiveaux.map((n) => (
        <a href={n.href} class="hub-niveau-card">
          <div class="hub-niveau-kicker">{n.kicker}</div>
          <h4>{n.title_fr}</h4>
          <p>{n.lead_fr}</p>
          <span class="hub-niveau-cta">→</span>
        </a>
      ))}
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hub-mast { padding: 140px 32px clamp(48px, 6vw, 88px); }
  :global(.hub-kicker) { display: block; margin-bottom: 24px; }
  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--accent); }
  .hub-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 28px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.4;
    text-wrap: pretty;
  }

  .hub-hero-offre { padding: 0 32px clamp(88px, 10vw, 132px); }
  .hub-hero-card {
    position: relative;
    display: grid;
    grid-template-columns: minmax(96px, 0.18fr) 1fr minmax(220px, 0.34fr);
    gap: clamp(24px, 4vw, 72px);
    padding: clamp(36px, 5vw, 72px);
    background: var(--ink);
    color: var(--paper);
    border: 2px solid var(--accent);
    min-height: clamp(420px, 48vw, 620px);
    align-items: end;
    overflow: hidden;
    transition: transform 260ms var(--ease), box-shadow 260ms var(--ease);
  }
  .hub-hero-card::before {
    content: "";
    position: absolute;
    inset: 24px;
    border: 1px solid rgba(246, 241, 232, 0.14);
    pointer-events: none;
  }
  .hub-hero-card:hover { transform: translateY(-4px); box-shadow: 0 24px 80px rgba(12, 11, 9, 0.18); }
  .hub-hero-num {
    font-family: var(--font-display);
    font-size: clamp(88px, 11vw, 176px);
    line-height: 0.8;
    color: var(--accent);
    font-style: italic;
    z-index: 1;
  }
  .hub-hero-kicker,
  .hub-pilier-kicker,
  .hub-niveau-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .hub-hero-kicker {
    position: absolute;
    top: clamp(28px, 4vw, 52px);
    left: clamp(36px, 5vw, 72px);
    color: var(--accent);
  }
  .hub-hero-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 8vw, 136px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    font-weight: 400;
    margin: 0 0 22px;
    text-wrap: balance;
  }
  .hub-hero-sub {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 34px);
    font-style: italic;
    line-height: 1.15;
    color: var(--accent);
    margin: 0;
    text-wrap: balance;
  }
  .hub-hero-lead {
    font-size: clamp(16px, 1.6vw, 21px);
    line-height: 1.55;
    color: rgba(246, 241, 232, 0.78);
    margin: 0 0 28px;
  }
  .hub-hero-cta,
  .hub-pilier-cta {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .hub-piliers,
  .hub-niveaux { padding: clamp(88px, 10vw, 128px) 32px; }
  .hub-h3 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    font-weight: 400;
    margin: 18px 0 clamp(36px, 5vw, 64px);
    text-wrap: balance;
  }
  .hub-h3 :global(i) { color: var(--accent); font-style: italic; }
  .hub-pilier-grid,
  .hub-niveau-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(20px, 3vw, 40px);
  }
  .hub-pilier-card {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: clamp(20px, 3vw, 36px);
    min-height: 320px;
    padding: clamp(28px, 4vw, 44px);
    background: var(--paper-2);
    border: 1px solid var(--hairline-strong);
    color: var(--ink);
    transition: border-color 240ms var(--ease), transform 240ms var(--ease);
  }
  .hub-pilier-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .hub-pilier-num {
    font-family: var(--font-display);
    font-size: clamp(48px, 6vw, 88px);
    line-height: 0.9;
    color: var(--accent);
    font-style: italic;
  }
  .hub-pilier-kicker { color: var(--accent); margin-bottom: 18px; }
  .hub-pilier-card h4,
  .hub-niveau-card h4 {
    font-family: var(--font-display);
    font-size: clamp(30px, 3.4vw, 52px);
    line-height: 1;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .hub-pilier-sub {
    font-family: var(--font-display);
    font-size: clamp(18px, 1.8vw, 24px);
    font-style: italic;
    color: var(--accent);
    line-height: 1.2;
    margin: 0 0 18px;
  }
  .hub-pilier-lead {
    color: var(--muted);
    line-height: 1.55;
    max-width: 520px;
    margin: 0 0 28px;
  }

  .hub-niveaux {
    background: var(--paper);
    border-top: 1px solid var(--hairline);
  }
  .hub-niveau-card {
    position: relative;
    min-height: 220px;
    padding: clamp(24px, 3vw, 36px);
    border: 1px solid var(--hairline);
    background: transparent;
    color: var(--ink);
    transition: background 220ms var(--ease), border-color 220ms var(--ease);
  }
  .hub-niveau-card:hover { background: var(--paper-2); border-color: var(--accent); }
  .hub-niveau-kicker { color: var(--muted); margin-bottom: 18px; }
  .hub-niveau-card p {
    color: var(--muted);
    line-height: 1.55;
    max-width: 520px;
    margin: 0;
  }
  .hub-niveau-cta {
    position: absolute;
    right: 28px;
    bottom: 24px;
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 24px;
  }

  @media (max-width: 900px) {
    .hub-hero-card {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: 96px;
    }
    .hub-pilier-grid,
    .hub-niveau-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 640px) {
    .hub-mast,
    .hub-hero-offre,
    .hub-piliers,
    .hub-niveaux { padding-left: 20px; padding-right: 20px; }
    .hub-pilier-card { grid-template-columns: 1fr; }
    .hub-hero-card::before { inset: 14px; }
  }
</style>
