---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import TunnelNav from '../../../components/ui/molecules/TunnelNav.astro';
---
<Base
  title="Site Web IA-first — Étape 2/4 : La mécanique · Waimia"
  description="Trois agents IA. Un site. Lead-gen automatisé. Découvrez l'architecture Agent Content, Agent CRM, Agent Social."
>
  <TunnelNav currentStep={2} />
  <main class="tunnel-page">

    <section class="tnl-hero wrap-wide">
      <p class="tnl-eyebrow reveal">§ Étape 2/4 — La mécanique <span aria-hidden="true">·</span> <span lang="en">Step 2/4 — How it works</span></p>
      <h1 class="tnl-h1 reveal-mask-up">
        Trois agents.<br/>
        Un site. <em>Lead-gen<br/>automatisé.</em>
        <span lang="en">Three agents. One site. <em>Automated lead-gen.</em></span>
      </h1>
      <p class="tnl-lede reveal">
        Pas de SaaS générique. Pas de no-code qui dépend d'une API externe. Une architecture propriétaire : trois agents Claude spécialisés, branchés sur votre repo Git, votre CRM et vos réseaux sociaux.
        <span lang="en">No generic SaaS. No no-code dependent on an external API. A proprietary architecture: three specialised Claude agents wired to your Git repo, your CRM, and your social channels.</span>
      </p>
    </section>

    <section class="tnl-schema wrap-wide reveal-zoom-in">
      <h2 class="tnl-sh2">Le flux <em>bout en bout</em> <span lang="en">The <em>end-to-end</em> flow</span></h2>
      <div class="tnl-schema__svg-wrap">
        <svg viewBox="0 0 900 160" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Flux architectural : Agent Content, Agent CRM, Agent Social">
          <defs>
            <marker id="arr" markerWidth="8" markerHeight="8" refX="6" refY="3" orient="auto">
              <path d="M0 0 L0 6 L6 3 Z" fill="rgba(0,0,0,.3)"/>
            </marker>
          </defs>
          <rect x="0" y="74" width="900" height="2" fill="rgba(0,0,0,.1)" rx="1"/>
          <rect x="0" y="48" width="120" height="64" rx="2" fill="#1a1a1a"/>
          <text x="60" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(246,241,232,.5)" letter-spacing="0.06em">AGENT</text>
          <text x="60" y="92" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#F6F1E8" font-weight="600">Content</text>
          <path d="M124 75 L168 75" stroke="rgba(0,0,0,.2)" stroke-width="1.5" marker-end="url(#arr)"/>
          <text x="146" y="67" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#888">8/sem</text>
          <rect x="172" y="48" width="120" height="64" rx="2" fill="#F6F1E8" stroke="rgba(0,0,0,.15)" stroke-width="1"/>
          <text x="232" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#888" letter-spacing="0.06em">ARTICLES</text>
          <text x="232" y="92" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#1a1a1a" font-weight="600">SEO / GEO</text>
          <path d="M296 75 L340 75" stroke="rgba(0,0,0,.2)" stroke-width="1.5" marker-end="url(#arr)"/>
          <rect x="344" y="34" width="120" height="92" rx="2" fill="#C94F2E"/>
          <text x="404" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(246,241,232,.7)" letter-spacing="0.06em">SITE</text>
          <text x="404" y="92" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="13" fill="#F6F1E8" font-weight="700">IA-first</text>
          <path d="M468 75 L512 75" stroke="rgba(0,0,0,.2)" stroke-width="1.5" marker-end="url(#arr)"/>
          <text x="490" y="67" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#888">lead</text>
          <rect x="516" y="48" width="120" height="64" rx="2" fill="#F6F1E8" stroke="rgba(0,0,0,.15)" stroke-width="1"/>
          <text x="576" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#888" letter-spacing="0.06em">PROSPECT</text>
          <text x="576" y="92" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#1a1a1a" font-weight="600">Qualifié</text>
          <path d="M640 75 L684 75" stroke="rgba(0,0,0,.2)" stroke-width="1.5" marker-end="url(#arr)"/>
          <rect x="688" y="48" width="100" height="64" rx="2" fill="#1a1a1a"/>
          <text x="738" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="rgba(246,241,232,.5)" letter-spacing="0.06em">AGENT</text>
          <text x="738" y="92" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="11" fill="#F6F1E8" font-weight="600">CRM</text>
          <path d="M792 75 L836 75" stroke="rgba(0,0,0,.2)" stroke-width="1.5" marker-end="url(#arr)"/>
          <text x="814" y="67" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#888">1h</text>
          <rect x="840" y="48" width="60" height="64" rx="2" fill="#F6F1E8" stroke="rgba(0,0,0,.15)" stroke-width="1"/>
          <text x="870" y="74" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#888">AUTO</text>
          <text x="870" y="92" text-anchor="middle" font-family="JetBrains Mono, monospace" font-size="9" fill="#1a1a1a" font-weight="600">Relance</text>
        </svg>
      </div>
    </section>

    <section class="tnl-agents wrap-wide">
      <h2 class="tnl-sh2 reveal">Trois agents. Chacun a un rôle. <span lang="en">Three agents. Each with a role.</span></h2>

      <div class="tnl-agent-block reveal">
        <div class="tnl-agent-block__header">
          <div class="tnl-agent-block__num">01</div>
          <div>
            <div class="tnl-agent-block__kicker">Agent Content <span lang="en">Content Agent</span></div>
            <h3 class="tnl-agent-block__title">SEO &amp; GEO — Contenu indexé automatiquement <span lang="en">SEO &amp; GEO — Automatically indexed content</span></h3>
          </div>
        </div>
        <div class="tnl-agent-block__body">
          <p>Claude Opus 4.7 produit 8 articles/semaine optimisés pour Google et pour les IA génératives (Perplexity, ChatGPT, Google AI Overview). Il génère les JSON-LD, les balises Schema.org, le maillage interne. Vous validez avant publication — ou activez le mode full-auto.</p>
          <p lang="en">Claude Opus 4.7 produces 8 articles/week optimised for Google and generative AI (Perplexity, ChatGPT, Google AI Overview). It generates JSON-LD, Schema.org tags, internal linking. You validate before publishing — or activate full-auto mode.</p>
          <ul class="tnl-stack-pills">
            <li>Claude Opus 4.7</li>
            <li>Search APIs</li>
            <li>Schema.org</li>
            <li>llms.txt</li>
            <li>Vercel CDN</li>
          </ul>
        </div>
      </div>

      <div class="tnl-agent-block reveal">
        <div class="tnl-agent-block__header">
          <div class="tnl-agent-block__num">02</div>
          <div>
            <div class="tnl-agent-block__kicker">Agent CRM <span lang="en">CRM Agent</span></div>
            <h3 class="tnl-agent-block__title">Qualification &amp; relances — Dans l'heure, pas dans trois jours <span lang="en">Qualification &amp; follow-ups — Within the hour, not three days later</span></h3>
          </div>
        </div>
        <div class="tnl-agent-block__body">
          <p>Claude Sonnet 4.6 score chaque lead entrant sur ICP, intent, budget et timing. Il déclenche les relances dans l'heure (taux de conversion 7× plus élevé qu'après 24h). Connecteurs natifs HubSpot, Salesforce, Pipedrive.</p>
          <p lang="en">Claude Sonnet 4.6 scores each incoming lead on ICP, intent, budget and timing. It triggers follow-ups within the hour (7× higher conversion rate than after 24h). Native HubSpot, Salesforce, Pipedrive connectors.</p>
          <ul class="tnl-stack-pills">
            <li>Claude Sonnet 4.6</li>
            <li>Claude Haiku 4.5</li>
            <li>HubSpot MCP</li>
            <li>Resend</li>
            <li>LangGraph</li>
          </ul>
        </div>
      </div>

      <div class="tnl-agent-block reveal">
        <div class="tnl-agent-block__header">
          <div class="tnl-agent-block__num">03</div>
          <div>
            <div class="tnl-agent-block__kicker">Agent Social <span lang="en">Social Agent</span></div>
            <h3 class="tnl-agent-block__title">Réseaux sociaux — Posts générés, planifiés, publiés <span lang="en">Social networks — Posts generated, scheduled, published</span></h3>
          </div>
        </div>
        <div class="tnl-agent-block__body">
          <p>Claude Sonnet 4.6 transforme chaque article SEO en 3 posts LinkedIn + 1 thread X + 1 carrousel Instagram. La ligne éditoriale est calibrée sur votre ton de marque. Planification et publication automatiques.</p>
          <p lang="en">Claude Sonnet 4.6 turns each SEO article into 3 LinkedIn posts + 1 X thread + 1 Instagram carousel. The editorial line is calibrated to your brand voice. Automatic scheduling and publishing.</p>
          <ul class="tnl-stack-pills">
            <li>Claude Sonnet 4.6</li>
            <li>LinkedIn API</li>
            <li>Buffer / Hootsuite</li>
            <li>Astro Islands</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="tnl-cta wrap-wide reveal">
      <div class="tnl-cta__inner">
        <a href="/offres/site-web-ia-tunnel/preuves" class="btn-primary">
          Voir les preuves → <span lang="en">See the proof →</span>
        </a>
        <a href="/offres/site-web-ia-tunnel" class="btn-secondary">
          ← Étape précédente <span lang="en">← Previous step</span>
        </a>
        <p class="tnl-cta__meta">Étape 2/4 · <span lang="en">Step 2/4</span></p>
      </div>
    </section>

  </main>
</Base>

<style>
.tunnel-page { padding-block: 0; }
.wrap-wide { max-width: 1200px; margin-inline: auto; padding-inline: clamp(20px, 5vw, 80px); }
.tnl-eyebrow { font-family: var(--font-mono, 'JetBrains Mono', monospace); font-size: clamp(11px, 1.2vw, 13px); text-transform: uppercase; letter-spacing: .1em; color: var(--muted); margin-bottom: 24px; padding-top: clamp(48px, 8vw, 96px); }
.tnl-h1 { font-family: var(--font-serif, 'Instrument Serif', Georgia, serif); font-size: clamp(36px, 6vw, 80px); line-height: 1.05; letter-spacing: -.02em; color: var(--ink); margin-bottom: clamp(24px, 4vw, 48px); max-width: 16ch; }
.tnl-h1 em { font-style: italic; color: var(--accent); }
.tnl-lede { font-family: var(--font-body, 'Inter Tight', sans-serif); font-size: clamp(16px, 1.8vw, 20px); line-height: 1.6; color: var(--ink); max-width: 62ch; margin-bottom: clamp(48px, 8vw, 96px); }
.tnl-sh2 { font-family: var(--font-serif, 'Instrument Serif', Georgia, serif); font-size: clamp(24px, 3vw, 40px); letter-spacing: -.01em; margin-bottom: clamp(32px, 4vw, 56px); color: var(--ink); }
.tnl-sh2 em { font-style: italic; color: var(--accent); }
.tnl-hero { padding-bottom: clamp(48px, 6vw, 80px); }
.tnl-schema { padding-block: clamp(64px, 8vw, 112px); border-top: 1px solid rgba(0,0,0,.07); }
.tnl-agents { padding-block: clamp(64px, 8vw, 112px); border-top: 1px solid rgba(0,0,0,.07); }
.tnl-cta { padding-block: clamp(64px, 8vw, 112px); border-top: 1px solid rgba(0,0,0,.07); }
.tnl-schema__svg-wrap { overflow-x: auto; }
.tnl-schema__svg-wrap svg { width: 100%; min-width: 600px; height: auto; }
.tnl-agent-block { padding: clamp(24px, 3vw, 40px); border: 1px solid rgba(0,0,0,.08); border-radius: 2px; margin-bottom: 16px; background: var(--paper); }
.tnl-agent-block__header { display: flex; align-items: flex-start; gap: 20px; margin-bottom: 20px; }
.tnl-agent-block__num { font-family: var(--font-mono, 'JetBrains Mono', monospace); font-size: 11px; color: var(--muted); letter-spacing: .08em; padding-top: 2px; min-width: 24px; }
.tnl-agent-block__kicker { font-family: var(--font-mono, 'JetBrains Mono', monospace); font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--accent); margin-bottom: 6px; }
.tnl-agent-block__title { font-family: var(--font-serif, 'Instrument Serif', Georgia, serif); font-size: clamp(18px, 2vw, 24px); line-height: 1.3; color: var(--ink); }
.tnl-agent-block__body p { font-family: var(--font-body, 'Inter Tight', sans-serif); font-size: 15px; line-height: 1.65; color: var(--ink); margin-bottom: 16px; max-width: 70ch; }
.tnl-stack-pills { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; padding: 0; margin-top: 20px; }
.tnl-stack-pills li { font-family: var(--font-mono, 'JetBrains Mono', monospace); font-size: 11px; padding: 4px 10px; border: 1px solid rgba(0,0,0,.12); border-radius: 2px; color: var(--ink); }
.tnl-cta__inner { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; }
.btn-primary { font-family: var(--font-body, 'Inter Tight', sans-serif); font-size: 15px; font-weight: 600; background: var(--ink); color: var(--paper); padding: 14px 28px; border-radius: 2px; text-decoration: none; transition: opacity .2s; }
.btn-primary:hover { opacity: .85; }
.btn-secondary { font-family: var(--font-body, 'Inter Tight', sans-serif); font-size: 15px; color: var(--ink); border: 1px solid rgba(0,0,0,.18); padding: 14px 28px; border-radius: 2px; text-decoration: none; transition: border-color .2s; }
.btn-secondary:hover { border-color: var(--ink); }
.tnl-cta__meta { font-family: var(--font-mono, 'JetBrains Mono', monospace); font-size: 11px; color: var(--muted); letter-spacing: .06em; margin-left: auto; }
[lang="en"] { display: block; font-size: .88em; color: var(--muted); margin-top: 4px; font-style: italic; }
</style>
