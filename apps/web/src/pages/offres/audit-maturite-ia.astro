---
// Page · /offres/audit-maturite-ia · Sous-page mega-menu (offres/detail template)
export const prerender = true;

// Source : adaptation hub-consulting service 02.1 + offres/detail.html structure
//
// Composé de · DetailMenuTemplate (8 sections) avec slot deliverables custom.

import DetailMenuTemplate from '../../components/templates/DetailMenuTemplate.astro';
import AuditMaturityTimeline from '../../components/svg/geometric/AuditMaturityTimeline.astro';

const annotation = [
  { k: '10 j',  label_fr: 'durée fixe',                label_en: 'fixed duration' },
  { k: '47',    label_fr: 'critères évalués',          label_en: 'criteria evaluated' },
  { k: '1',     label_fr: 'grille de score livrée',    label_en: 'scorecard delivered' },
];

const steps = [
  { sn: '01', kicker_fr: 'J1-J2', kicker_en: 'D1-D2',
    title_fr: 'Cadrage initial', title_en: 'Initial scoping',
    body_fr: "Demi-journée comité élargi. On lit votre stack, votre feuille de route, vos incidents récents non résolus. On établit la liste des 8-12 interlocuteurs à auditer. Livrable J2 : rapport de cadrage validé.",
    body_en: 'Half-day with extended committee. We read your stack, roadmap, recent unresolved incidents. We set the list of 8-12 interviewees. Deliverable D2: validated scoping report.' },
  { sn: '02', kicker_fr: 'J3-J6', kicker_en: 'D3-D6',
    title_fr: 'Audit terrain', title_en: 'Field audit',
    body_fr: "Entretiens 1-1 avec 8-12 personnes : data engineer, DPO, responsable GRC, CFO, lead tech, ops métier. Questionnaire asynchrone 47 points sur Notion. Aucun atelier collectif — la vérité se dit en individuel.",
    body_en: '1-on-1 interviews with 8-12 people: data engineer, DPO, GRC lead, CFO, tech lead, ops. 47-point async survey on Notion. No group workshop — truth is told individually.' },
  { sn: '03', kicker_fr: 'J7-J8', kicker_en: 'D7-D8',
    title_fr: 'Analyse', title_en: 'Analysis',
    body_fr: "Grille de 47 critères notée 0-3 par dimension (données, outillage, équipe, gouvernance). Cartographie des chantiers actionnables. Estimation effort : Quick wins (< 3 mois) vs Chantiers structurants (6-18 mois).",
    body_en: '47-criteria scorecard scored 0-3 per dimension (data, tooling, team, governance). Actionable workstream map. Effort estimation: Quick wins (< 3 months) vs Structural workstreams (6-18 months).' },
  { sn: '04', kicker_fr: 'J9-J10', kicker_en: 'D9-D10',
    title_fr: 'Restitution', title_en: 'Debrief',
    body_fr: "2 sessions structurées. Direction (1h) : grille résumée, 3 décisions à prendre, arbitrages chiffrés. Équipe technique (2h) : détails chantiers, risques, questions. Document final 30 pages signé remis en fin de J10.",
    body_en: '2 structured sessions. Board (1h): summarized scorecard, 3 decisions to make, costed arbitrations. Tech team (2h): workstream details, risks, Q&A. Final 30-page document signed and delivered end of D10.' },
];

const techPills = [
  { label: 'Claude Opus (analyse)', kind: 'primary' as const },
  { label: 'Notion / Confluence',   kind: 'neutral' as const },
  { label: 'Whimsical',              kind: 'neutral' as const },
];

const proofMetrics = [
  { k: '32',   label_fr: 'audits livrés en 18 mois',          label_en: 'audits delivered last 18 months' },
  { k: '94%',  label_fr: 'NPS post-restitution',               label_en: 'post-debrief NPS' },
  { k: '78%',  label_fr: 'engagent le chantier suivant',       label_en: 'engage the next workstream' },
  { k: '0 j',  label_fr: 'de dépassement sur 32 audits',      label_en: 'days over budget across 32 audits' },
];

const relatedCards = [
  { kicker: 'OFFRE 02.2', title_fr: 'Feuille de route IA stratégique', title_en: 'Strategic AI Roadmap',
    lead_fr: 'La suite naturelle après audit →', lead_en: 'The natural follow-up to an audit →',
    href: '/offres/roadmap-ia' },
  { kicker: 'OFFRE 02.3', title_fr: 'Audit gouvernance données', title_en: 'Data governance audit',
    lead_fr: 'Service complémentaire fréquent →', lead_en: 'Frequent companion service →',
    href: '/offres/gouvernance-donnees' },
  { kicker: 'CASE 04', title_fr: 'Plateau SaaS', title_en: 'Plateau SaaS',
    lead_fr: 'Audit suivi de RevOps Rebuild →', lead_en: 'Audit followed by RevOps Rebuild →',
    href: '/ressources/cas/plateau' },
];
---
<DetailMenuTemplate
  title="Audit de maturité IA · 10 jours · Waimia"
  description="Un diagnostic IA en 10 jours fixes. 47 critères évalués sur données, outillage, équipe, gouvernance. Une grille de score lisible par la direction."
  detailNum="02.1"
  parentKickerFr="Hub Conseil · Audit & Stratégie"
  parentKickerEn="Consulting Hub · Audit & Strategy"
  annotation={annotation}
  steps={steps}
  proofQuoteFr="Un audit où on lit nos vrais workflows au lieu de dérouler un modèle PowerPoint. La restitution a permis de couper deux chantiers fantômes immédiatement."
  proofQuoteEn="An audit where they actually read our workflows instead of running a template deck. The debrief killed two phantom workstreams immediately."
  proofAttrFr="Marie Cousin · COO Plateau"
  proofAttrEn="Marie Cousin · COO Plateau"
  proofMetrics={proofMetrics}
  techPills={techPills}
  relatedCards={relatedCards}
>
  <Fragment slot="headline">
    Dix jours pour savoir <i>exactement</i> où vous en êtes. Lu par la direction. Signé par nous.
  </Fragment>
  <Fragment slot="lede">
    Pas un atelier. Pas un modèle PowerPoint. 10 jours fixes pour évaluer 47 critères sur vos données, vos outils, votre équipe, votre gouvernance — et vous éviter d'engager 18 mois de transformation sur un diagnostic fantaisiste.
  </Fragment>
  <Fragment slot="problem">
    La majorité des audits IA livrent <i>72 slides</i> qui finissent dans le SharePoint. La direction ne les lit pas. Les ingénieurs ne savent pas quoi en faire. Notre audit produit l'inverse : 30 pages denses, une grille signée, des actions priorisées par coût de correction.
    <br/><br/>Nous ne partons pas d'un modèle. Nous partons de vos données réelles : logs, workflows documentés, incidents GRC ouverts. La grille de 47 critères est renseignée par nos consultants, pas par vos déclaratifs.
  </Fragment>
  <Fragment slot="approach-headline">
    Dix <i>jours</i> calibrés. Pas un de plus, pas un de moins.
  </Fragment>
  <Fragment slot="approach-aside">
    Le périmètre est volontairement borné. On audite ce qui est lisible en 10 jours — au-delà, c'est l'objet d'un autre service (feuille de route IA stratégique).
    Chaque journée a un livrable intermédiaire : rapport de cadrage validé (J2), audit terrain clos (J6), grille pré-scorée (J8), document final signé (J10).
  </Fragment>
  <Fragment slot="deliverables-headline">
    Une <i>grille de score</i>, un <i>document</i>, deux <i>restitutions</i>.
  </Fragment>
  <Fragment slot="deliverables-aside">
    Tout est signé par notre équipe et par votre référent technique. Aucun livrable « anonyme ».
  </Fragment>
  <Fragment slot="deliverables">
    <div class="del-grid">
      <div class="del-card">
        <div class="del-tag">GRILLE</div>
        <h3>47 critères notés 0-3</h3>
        <p>Notation pondérée par chantier · justifications dans le document · benchmark anonymisé secteur.</p>
      </div>
      <div class="del-card">
        <div class="del-tag">DOCUMENT</div>
        <h3>30 pages denses, signées</h3>
        <p>Constats, hypothèses, recommandations priorisées par coût de correction · pas de remplissage.</p>
      </div>
      <div class="del-card">
        <div class="del-tag">RESTITUTION</div>
        <h3>2 sessions en direct</h3>
        <p>Direction (1h Q&amp;A lisible) + équipe technique (2h Q&amp;A approfondie).</p>
      </div>
    </div>

    <!-- Timeline SVG -->
    <div class="reveal-fade" style="margin-top:clamp(48px,5vw,72px); max-width:600px; margin-inline:auto;">
      <AuditMaturityTimeline />
    </div>

    <!-- Section prix -->
    <div class="reveal-stagger" style="margin-top:clamp(48px,5vw,72px); border-top:1px solid var(--hairline-strong); padding-top:clamp(32px,4vw,48px);">
      <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); margin-bottom:16px;">Investissement</div>
      <h3 style="font-family:var(--font-display); font-size:clamp(28px,3.2vw,44px); line-height:1.05; font-weight:400; margin:0 0 20px;"><i style="color:var(--accent); font-style:italic;">À partir de 8 000 €</i> HT</h3>
      <p style="font-family:var(--font-sans); font-size:16px; line-height:1.6; color:var(--ink); max-width:560px; margin:0 0 12px;">Prix fixe. Pas d'heure supplémentaire, pas de dépassement. 10 jours, un document, deux restitutions.</p>
      <p style="font-family:var(--font-sans); font-size:14px; line-height:1.55; color:var(--muted); max-width:560px; margin:0;">Pour les groupes ≥ 3 entités légales à auditer en simultané : tarification sur devis. Les audits complémentaires (gouvernance données, dette technique) font l'objet de services distincts.</p>
    </div>

    <!-- Section cas typique -->
    <div class="reveal-stagger" style="margin-top:clamp(48px,5vw,72px); border-top:1px solid var(--hairline); padding-top:clamp(32px,4vw,48px);">
      <div style="font-family:var(--font-mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; color:var(--muted); margin-bottom:16px;">Cas typique</div>
      <div class="audit-case-grid">
        <div>
          <h3 style="font-family:var(--font-display); font-size:clamp(24px,2.8vw,38px); line-height:1.1; font-weight:400; margin:0 0 18px;"><i style="font-style:italic;">Plateau SaaS</i> — 180 personnes</h3>
          <p style="font-family:var(--font-sans); font-size:15px; line-height:1.65; color:var(--ink); margin:0 0 14px;">Groupe SaaS européen. La direction technique veut déployer des agents IA sur les flux support client et comptabilité. Budget IA prévu : 380 k€. Le comité exécutif demande un feu vert documenté avant engagement.</p>
          <p style="font-family:var(--font-sans); font-size:15px; line-height:1.65; color:var(--muted); margin:0;">Résultat : 2 chantiers prioritaires validés, 1 chantier stoppé avant développement (données non conformes RGPD), budget recalibré à 140 k€ pour un périmètre livrable en 6 mois.</p>
        </div>
        <div class="audit-case-metrics">
          <div class="audit-case-kpi">
            <div style="font-family:var(--font-mono); font-size:9px; letter-spacing:.12em; text-transform:uppercase; color:var(--accent); margin-bottom:4px;">Décision prise en J10</div>
            <div style="font-family:var(--font-display); font-size:clamp(18px,2.2vw,26px); line-height:1.1; font-weight:400;">Budget réduit de 380 → 140 k€</div>
          </div>
          <div class="audit-case-kpi">
            <div style="font-family:var(--font-mono); font-size:9px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:4px;">Chantier arrêté avant dev</div>
            <div style="font-family:var(--font-display); font-size:clamp(18px,2.2vw,26px); line-height:1.1; font-weight:400;">1 agent IA sur 3 stoppé</div>
          </div>
          <div class="audit-case-kpi">
            <div style="font-family:var(--font-mono); font-size:9px; letter-spacing:.12em; text-transform:uppercase; color:var(--muted); margin-bottom:4px;">NPS restitution</div>
            <div style="font-family:var(--font-display); font-size:clamp(18px,2.2vw,26px); line-height:1.1; font-weight:400;">94 %</div>
          </div>
        </div>
      </div>
    </div>
  </Fragment>
  <Fragment slot="stack-lead">
    Stack volontairement <i>légère</i>. Claude Opus pour l'analyse · Notion pour la collaboration · Whimsical pour les schémas. Aucun outil de cadrage propriétaire.
  </Fragment>
</DetailMenuTemplate>

<style is:global>
  /* Pattern deliverables 3 cards · spécifique à DetailMenuTemplate (1 instance ici).
     Pas extrait en molécule car contenu trop variable d'un detail à l'autre. */
  .del-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 1px solid var(--hairline-strong);
  }
  .del-card {
    padding: clamp(24px, 3vw, 40px) clamp(20px, 2.5vw, 32px);
    border-right: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background 220ms var(--ease);
  }
  .del-card:last-child { border-right: none; }
  .del-card:hover { background: var(--paper-2); }
  .del-tag {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .del-card h3 {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.1;
    letter-spacing: -0.013em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .del-card p {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.55;
    text-wrap: pretty;
    margin: 0;
  }
  @media (max-width: 800px) {
    .del-grid { grid-template-columns: 1fr; }
    .del-card { border-right: none; border-bottom: 1px solid var(--hairline); }
    .del-card:last-child { border-bottom: none; }
  }

  /* Cas typique grid */
  .audit-case-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 56px);
    align-items: start;
  }
  .audit-case-metrics {
    border-left: 1px solid var(--hairline);
    padding-left: clamp(24px, 3vw, 40px);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .audit-case-kpi {
    padding-bottom: 16px;
    border-bottom: 1px solid var(--hairline);
  }
  .audit-case-kpi:last-child { border-bottom: none; }
  @media (max-width: 800px) {
    .audit-case-grid { grid-template-columns: 1fr; }
    .audit-case-metrics { border-left: none; padding-left: 0; margin-top: clamp(24px, 3vw, 36px); }
  }
</style>
