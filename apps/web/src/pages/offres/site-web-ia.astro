---
// Page · /offres/site-web-ia · Tunnel de conversion offre flagship
// Site web IA-native (Astro+React 95% IA · agent éditeur GEO · routine SEO)
import ConversionFunnelTemplate from '../../components/templates/ConversionFunnelTemplate.astro';

const heroStats = [
  { k: '95%',   label_fr: 'généré par IA',         label_en: 'AI-generated' },
  { k: '6 sem', label_fr: 'go-live médian',         label_en: 'median go-live' },
  { k: '×3.4',  label_fr: 'conversion vs WordPress', label_en: 'conversion vs WordPress' },
  { k: '100/100', label_fr: 'Lighthouse',          label_en: 'Lighthouse' },
];

const steps = [
  { sn: '01', kicker_fr: 'Audit', kicker_en: 'Audit',
    title_fr: 'Brand DNA + GEO mapping', title_en: 'Brand DNA + GEO mapping',
    body_fr: "On lit votre marque, vos personas, vos requêtes Google et LLM. On dresse la carte des intents prioritaires.",
    body_en: 'We read your brand, personas, Google + LLM queries. We map priority intents.' },
  { sn: '02', kicker_fr: 'Génération', kicker_en: 'Generation',
    title_fr: 'Site complet par agents IA', title_en: 'Full site by AI agents',
    body_fr: "Astro 6 + React 19 · 95 % du code et du contenu généré par agents Claude. Vous validez chaque page avant publication.",
    body_en: 'Astro 6 + React 19 · 95% code and content generated by Claude agents. You validate each page.' },
  { sn: '03', kicker_fr: 'Édition', kicker_en: 'Editing',
    title_fr: 'Agent éditeur intégré', title_en: 'Embedded editor agent',
    body_fr: "Un agent IA est branché sur votre repo. Vous lui parlez, il édite, vous validez. Pas de CMS gourmand.",
    body_en: 'An AI agent is wired into your repo. You talk, it edits, you validate. No bloated CMS.' },
  { sn: '04', kicker_fr: 'GEO', kicker_en: 'GEO',
    title_fr: 'Routine GEO mensuelle', title_en: 'Monthly GEO routine',
    body_fr: "Tous les mois, un agent regenère les contenus optimisés pour les LLM (ChatGPT, Perplexity, Google AI). Indexable sans hydratation client.",
    body_en: 'Each month, an agent regenerates LLM-optimized content (ChatGPT, Perplexity, Google AI). Indexable without client hydration.' },
];

const tiers = [
  { idx: '01', tier: 'Starter', highlight: false,
    price: '7 900 €', period: 'HT · forfait livraison',
    desc_fr: 'Site IA-native MVP', desc_en: 'IA-native MVP site',
    features: [
      'Astro 6 + React 19 (95% IA)',
      "Jusqu'à 8 pages (home + 6 services + contact)",
      'Agent éditeur de contenu inclus',
      'GEO baseline (sitemap + JSON-LD + llms.txt)',
      '1 mois de routine GEO offerte',
      'Hébergement Vercel optimisé',
    ],
    ctaLabel: 'Démarrer Starter →', ctaHref: '/contact?offer=site-web-ia&tier=starter' },
  { idx: '02', tier: 'Standard', highlight: true,
    price: '14 900 €', period: 'HT · forfait livraison',
    desc_fr: 'Site complet + IA continue', desc_en: 'Full site + continuous AI',
    features: [
      'Tout Starter inclus',
      "Jusqu'à 25 pages (hubs + sous-pages)",
      'Agent éditeur multi-langues (FR + EN)',
      'GEO routine mensuelle 6 mois',
      'Email & lead magnets templates Resend',
      'Cal.com intégré + tracking custom',
      'A/B testing IA sur landing pages',
    ],
    ctaLabel: 'Démarrer Standard →', ctaHref: '/contact?offer=site-web-ia&tier=standard' },
  { idx: '03', tier: 'Custom', highlight: false,
    price: 'Sur devis', period: 'À partir de 35 000 €',
    desc_fr: 'Plateforme sur-mesure', desc_en: 'Custom platform',
    features: [
      'Tout Standard inclus',
      'Pages illimitées + multi-tenant',
      'VirtuoseOS agents internes (pricing, devis, support)',
      'Intégrations CRM/warehouse natives',
      'Self-hosting possible (vLLM/Ollama)',
      'SLA 24/7 + astreinte humaine nommée',
      'Routine GEO 12 mois inclus',
    ],
    ctaLabel: 'Demander un devis →', ctaHref: '#devis' },
];

const techPills = [
  { label: 'Astro 6', kind: 'open' as const },
  { label: 'React 19', kind: 'open' as const },
  { label: 'Tailwind v4', kind: 'open' as const },
  { label: 'Claude Opus 4.7', kind: 'primary' as const },
  { label: 'Claude Sonnet 4.6', kind: 'primary' as const },
  { label: 'Resend', kind: 'neutral' as const },
  { label: 'Cal.com', kind: 'neutral' as const },
  { label: 'Vercel Edge', kind: 'neutral' as const },
];

const proofMetrics = [
  { k: '×3.4',   label_fr: 'conversion vs WordPress', label_en: 'conversion vs WordPress' },
  { k: '100/100', label_fr: 'score Lighthouse',       label_en: 'Lighthouse score' },
  { k: '−85%',   label_fr: "temps d'édition",         label_en: 'edit time' },
  { k: '0 €',    label_fr: 'CMS license',              label_en: 'CMS license' },
];

const faq = [
  { q: "Pourquoi Astro+React au lieu de Next.js ou WordPress ?",
    a: "Astro génère du HTML statique pré-rendu côté serveur — indexable instantanément par Google, ChatGPT, Perplexity et Google AI Overview. React reste disponible pour les îlots interactifs. Next.js fait pareil mais reste plus lourd côté JS. WordPress livre une stack PHP+MySQL coûteuse à maintenir et lente à indexer pour les LLM. Notre stack délivre 100/100 Lighthouse à coût marginal nul." },
  { q: "Comment l'agent éditeur de contenu fonctionne ?",
    a: "Un agent Claude est branché sur votre repo Git. Vous lui parlez en français — « ajoute un cas client ACME sur la page services » — il édite les fichiers, fait une PR, vous validez. Aucun CMS visuel à apprendre. Le contenu est versionné dans Git avec historique complet." },
  { q: "Qu'est-ce que la routine GEO mensuelle ?",
    a: "Chaque mois, un agent regenère les contenus en s'appuyant sur les nouvelles requêtes LLM détectées (Perplexity Trends, ChatGPT Search), les changements de votre catalogue, et les meilleures pratiques GEO/AIO. Vous validez les diffs avant publication." },
  { q: "Êtes-vous compatible avec mon CMS actuel (HubSpot, Webflow, WordPress) ?",
    a: "Oui. On peut migrer le contenu existant via parsing automatique, ou hybrider (Astro pour les pages publiques + votre CMS pour le blog/admin). Devis exact après audit gratuit de 10 jours." },
  { q: "Combien coûte le maintien après livraison ?",
    a: "L'hébergement Vercel coûte 0-20€/mois selon trafic. La routine GEO est un forfait mensuel optionnel (à partir de 490€/mois pour Starter, 1490€/mois pour Standard). Aucun coût caché." },
  { q: "Puis-je récupérer le code et l'auto-héberger ?",
    a: "Oui, toujours. Le code est livré sous votre compte GitHub avec doc complète. Vous restez propriétaire à 100%. Migration vers self-hosting (Vercel, OVH, Scaleway) en 1 jour." },
];

const relatedCards = [
  { kicker: 'CASE 04', title_fr: 'Plateau · refonte RevOps', title_en: 'Plateau · RevOps rebuild',
    lead_fr: 'Site IA + agents Claude →', lead_en: 'IA site + Claude agents →',
    href: '/ressources/cas/plateau' },
  { kicker: 'OFFRE 02.1', title_fr: 'Audit maturité IA', title_en: 'AI maturity audit',
    lead_fr: '10 jours · pré-requis recommandé →', lead_en: '10 days · recommended prereq →',
    href: '/offres/audit-maturite-ia' },
  { kicker: 'OFFRE 03.1', title_fr: 'RevOps Rebuild', title_en: 'RevOps Rebuild',
    lead_fr: 'Service complémentaire fréquent →', lead_en: 'Frequent companion service →',
    href: '/offres/revops' },
];
---
<ConversionFunnelTemplate
  title="Site web IA-native · Astro+React 95% généré par IA · Waimia"
  description="Un site web généré et édité par agents IA. Astro+React 95% natif IA, agent éditeur intégré, routine GEO mensuelle. À partir de 7 900€."
  funnelNum="01"
  heroStats={heroStats}
  steps={steps}
  tiers={tiers}
  techPills={techPills}
  proofQuoteFr="On a remplacé notre site WordPress par un site Waimia en 6 semaines. L'agent éditeur a éliminé les 12 heures hebdo qu'on passait dans le CMS. Et on est passé de 23 à 78 sur Lighthouse."
  proofQuoteEn="We replaced our WordPress site with a Waimia site in 6 weeks. The editor agent killed the 12h/week we spent in the CMS. We went from 23 to 78 on Lighthouse."
  proofAttrFr="Antoine Mercier · CMO · Plateau SaaS B2B"
  proofAttrEn="Antoine Mercier · CMO · Plateau SaaS B2B"
  proofMetrics={proofMetrics}
  faq={faq}
  relatedCards={relatedCards}
  slug="site-web-ia"
>
  <Fragment slot="headline">
    Un site pensé pour les <i>agents IA</i>. Édité par eux. Indexé par eux.
  </Fragment>
  <Fragment slot="lede">
    Astro + React natif, 95 % généré par agents Claude. Un agent éditeur de contenu branché sur votre repo. Une routine GEO mensuelle qui réécrit le contenu pour les LLM. Tout en français, en 6 semaines.
  </Fragment>
  <Fragment slot="cta-primary">Voir les tarifs ↓</Fragment>
  <Fragment slot="cta-secondary">Voir un cas réel</Fragment>

  <Fragment slot="demo-headline">Le site se construit <i>tout seul</i>. Vous validez.</Fragment>
  <Fragment slot="demo-lede">
    Démo en cours d'enregistrement. Pour l'instant, voir le cas Plateau (lien ci-dessus) qui a été
    livré avec cette stack en 6 semaines.
  </Fragment>
  <Fragment slot="demo-mockup">
    <div style="font-family:var(--font-mono);font-size:13px;color:rgba(246,241,232,.6);padding:32px;text-align:center">
      <div style="font-size:48px;margin-bottom:14px">▸</div>
      Démo vidéo · enregistrement en cours
      <div style="margin-top:14px;font-size:11px">En attendant, voir le cas live <a href="/ressources/cas/plateau" style="color:var(--accent);text-decoration:underline">Plateau →</a></div>
    </div>
  </Fragment>

  <Fragment slot="features-headline">
    Quatre <i>phases</i>. Vous validez chacune.
  </Fragment>

  <Fragment slot="pricing-headline">
    Trois <i>paliers</i>. Pas de frais cachés.
  </Fragment>

  <Fragment slot="stack-headline">La <i>stack</i> · délibérément open-source.</Fragment>
  <Fragment slot="stack-lead">
    Pas de SaaS propriétaire. Vous gardez le code, vous gardez les agents, vous gardez la liberté de migrer.
  </Fragment>

  <Fragment slot="faq-headline">Questions <i>courantes</i>.</Fragment>

  <Fragment slot="devis-headline">Demander un <i>devis</i>.</Fragment>
</ConversionFunnelTemplate>
