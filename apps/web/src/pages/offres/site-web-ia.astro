const faq = [
  { q: "Pourquoi Astro+React au lieu de Next.js ou WordPress ?",
    a: "Astro génère du HTML statique pré-rendu côté serveur — indexable tout de suite par Google, ChatGPT, Perplexity et Google AI Overview. React reste disponible pour les îlots interactifs. Next.js peut faire pareil, mais sort souvent plus lourd côté JS. WordPress impose une stack PHP+MySQL coûteuse à maintenir et plus lente à indexer pour les LLM. Notre stack vise 100/100 Lighthouse sans coût marginal." },
  { q: "Comment fonctionne l'agent éditeur de contenu ?",
    a: "Un agent Claude est branché sur votre repo Git. Vous lui parlez en français — « ajoute un cas client ACME sur la page services » — il édite les fichiers, ouvre une PR, vous validez. Aucun CMS visuel à apprendre. Le contenu est versionné dans Git avec historique complet." },
