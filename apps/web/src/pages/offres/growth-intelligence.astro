---
// Page · /offres/growth-intelligence · Pilier Growth Intelligence
export const prerender = true;

// Mission M3 · 3 piliers + 2 niveaux · FR uniquement

import OffresDetailTemplate from '../../components/templates/OffresDetailTemplate.astro';
---
<OffresDetailTemplate
  tier="§ 02 · PILIER"
  tierLabel="Growth Intelligence"
  meta="Pilier 02 · 8 à 35 k€ · délai 4 à 8 sem"
  title="Offres · Growth Intelligence · Pilotage temps réel"
  description="Des données lisibles pour décider plus vite. KPI commerciaux et opérationnels en temps réel, alertes utiles, commentaires IA."
>
  <Fragment slot="title"><i>Growth</i><br/>Intelligence</Fragment>
  <Fragment slot="lead">
    Des données lisibles pour décider plus vite.
    <span>Pas un fichier Excel de 4 jours de retard. Des KPI vivants, lus en 4 minutes le lundi.</span>
  </Fragment>
  <Fragment slot="problem-statement">Votre prévision tient sur des impressions et un fichier Excel de 4 jours de retard. <em>Vous décidez sans voir.</em></Fragment>
  <Fragment slot="problem-annotations">
    <div><div class="ann-value">J+15</div><div class="ann-label">âge moyen des KPI dans une PME</div></div>
    <div><div class="ann-value">−89%</div><div class="ann-label">temps de production des rapports</div></div>
    <div><div class="ann-value">×4,2</div><div class="ann-label">vélocité de décision après déploiement</div></div>
  </Fragment>
  <Fragment slot="method-aside">Quatre à huit semaines. Pas un chantier souterrain, pas un entrepôt de données à 18 mois.</Fragment>
  <Fragment slot="method-steps">
    <div class="step"><div class="step-n">01</div><div class="step-k">Cartographie données</div><h3>Recenser vos sources réelles</h3><p>3 jours pour lister toutes les sources de données métier (CRM, ERP, marketing, finance, ops). Identifier ce qui parle à quoi.</p></div>
    <div class="step"><div class="step-n">02</div><div class="step-k">Couche centralisée</div><h3>Une seule source de vérité</h3><p>Mise en place d'une couche de données centralisée (entrepôt léger). Pas de migration imposée, on travaille avec votre stack.</p></div>
    <div class="step"><div class="step-n">03</div><div class="step-k">Pilotage temps réel</div><h3>Les KPI qui comptent, vivants</h3><p>Tableaux métier par fonction (commercial, finance, ops). Rafraîchissement continu. Alertes sur seuils, commentaires IA sur les tendances.</p></div>
    <div class="step"><div class="step-n">04</div><div class="step-k">Commentaires IA & livraison</div><h3>L'IA qui commente, vous décidez</h3><p>Génération automatique de notes CODIR, mémos d'écart, rapports d'activité. Formation équipe + mode opératoire.</p></div>
  </Fragment>
  <Fragment slot="deliverables-aside">Le pilotage qui s'adapte à votre rythme — quotidien, hebdomadaire, mensuel.</Fragment>
  <Fragment slot="deliverables">
    <div class="del-card"><h3>Carte des données métier</h3><p>Cartographie complète des sources, qualité, fraîcheur, gouvernance.</p><span class="del-tag">PDF</span></div>
    <div class="del-card"><h3>Couche de données centralisée</h3><p>DuckDB / BigQuery / Snowflake selon volume. Connecteurs vers vos sources.</p><span class="del-tag">CODE</span></div>
    <div class="del-card"><h3>Tableaux par fonction</h3><p>3 à 6 tableaux métier (commercial, finance, ops, marketing). Web + mobile.</p><span class="del-tag">TABLEAU</span></div>
    <div class="del-card"><h3>Notes & mémos auto</h3><p>Génération hebdomadaire ou mensuelle des notes CODIR, mémos d'écart, rapports.</p><span class="del-tag">DOC</span></div>
    <div class="del-card"><h3>Alertes & commentaires IA</h3><p>Alertes contextuelles (chute de conversion, dépassement budget, etc.) avec recommandations.</p><span class="del-tag">ALERT</span></div>
    <div class="del-card"><h3>Mode opératoire & formation</h3><p>Documentation + 1 jour de formation.</p><span class="del-tag">NOTION + VIDÉO</span></div>
  </Fragment>
  <Fragment slot="proof-quote">"Avant Waimia, mon point CODIR me prenait 2,5 jours par semaine. Aujourd'hui je le lis en 4 minutes le lundi matin sur mon téléphone. Et il est juste."</Fragment>
  <Fragment slot="proof-attr">Sophie Marchand · DAF · Caserne, industrie FR</Fragment>
  <Fragment slot="proof-metrics">
    <div><div class="metric-v">−89%</div><div class="metric-l">temps de production reporting CODIR</div></div>
    <div><div class="metric-v">J+1</div><div class="metric-l">fraîcheur KPI (vs J+15 avant)</div></div>
    <div><div class="metric-v">×4,2</div><div class="metric-l">vélocité de décision (mesurée)</div></div>
    <div><div class="metric-v">100%</div><div class="metric-l">des sources couvertes</div></div>
    <div><div class="metric-v">−72%</div><div class="metric-l">temps de clôture mensuelle</div></div>
    <div><div class="metric-v">3,9×</div><div class="metric-l">ROI mesuré à 9 mois</div></div>
  </Fragment>
  <Fragment slot="cta-title"><i>Décider</i><br/>les yeux ouverts.</Fragment>
  <Fragment slot="cta-body">45 minutes. On ouvre votre stack de données, on chiffre les gains, on revient avec une architecture. Si on n'a rien à proposer, on le dit.</Fragment>
</OffresDetailTemplate>
