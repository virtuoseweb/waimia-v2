---
export const prerender = true;

// Page SSG · /ressources/personas · Index personas (Tier 4.1d)

import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Kicker from '../../../components/ui/atoms/Kicker.astro';
import Breadcrumb from '../../../components/ui/molecules/Breadcrumb.astro';
import { langFromPath } from '../../../lib/i18n';

const entries = await getCollection('personas');
const lang = langFromPath(Astro.url.pathname);
---
<Base
  title={lang === 'fr' ? "Personas · Profils acheteurs IA · Waimia" : "Personas · AI Buyer Profiles · Waimia"}
  description={lang === 'fr' ? "Profils des décideurs PME/ETI typiques pour les engagements Waimia : CEO, CTO, CMO. Pain points, critères, objections." : "Typical SMB decision-maker profiles for Waimia engagements: CEO, CTO, CMO. Pain points, criteria, objections."}
>
  <section class="personas-index">
    <div class="wrap-wide">
      <Breadcrumb
        items={[
          { href: '/ressources', label: lang === 'fr' ? 'Ressources' : 'Resources' },
          { href: '/ressources/personas', label: lang === 'fr' ? 'Personas' : 'Personas', current: true },
        ]}
      />

      <header class="personas-index__hd">
        <Kicker tone="muted">§ Référence · Personas Waimia</Kicker>
        <h1 class="personas-index__h1">
          {lang === 'fr' ? <>3 <i>profils</i> d'acheteurs</> : <>3 buyer <i>profiles</i></>}
        </h1>
        <p class="personas-index__lede">
          {lang === 'fr'
            ? "Profils des décideurs PME/ETI typiques pour qui Waimia conçoit ses engagements. Pain points · critères · objections · proof points."
            : "Typical SMB decision-maker profiles for whom Waimia designs engagements. Pain points · criteria · objections · proof points."}
        </p>
      </header>

      <ul class="personas-index__list">
        {entries.map((entry) => (
          <li class="personas-index__item">
            <a href={`/ressources/personas/${entry.id}`} class="personas-index__link">
              <Kicker tone="accent" size={10}>§ {lang === 'fr' ? entry.data.role_fr : entry.data.role_en}</Kicker>
              <h2 class="personas-index__title">
                {lang === 'fr' ? entry.data.title_fr : entry.data.title_en}
              </h2>
              <p class="personas-index__short">
                {lang === 'fr' ? entry.data.description_fr : entry.data.description_en}
              </p>
              <span class="personas-index__cta">
                {lang === 'fr' ? 'Voir le profil complet →' : 'View full profile →'}
              </span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<style>
  .personas-index {
    padding-top: calc(var(--spacing-section) + var(--header-height));
    padding-bottom: var(--spacing-section);
  }
  .personas-index__hd {
    margin-bottom: clamp(48px, 6vw, 80px);
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 32px;
  }
  .personas-index__h1 {
    font-family: var(--font-display);
    font-size: var(--text-h1-hero);
    line-height: 1.02;
    color: var(--ink);
    margin: 24px 0 0;
  }
  .personas-index__h1 i { font-style: italic; color: var(--accent); }
  .personas-index__lede {
    font-family: var(--font-sans);
    font-size: var(--text-lede);
    line-height: 1.5;
    color: var(--ink-2);
    margin: 24px 0 0;
    max-width: 64ch;
  }
  .personas-index__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 0;
    border-top: 1px solid var(--hairline);
    border-left: 1px solid var(--hairline);
  }
  .personas-index__item {
    border-right: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .personas-index__link {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 32px;
    text-decoration: none;
    color: var(--ink);
    height: 100%;
    transition: background var(--dur-fast) var(--ease);
  }
  .personas-index__link:hover {
    background: var(--paper-2);
  }
  .personas-index__title {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.8vw, 28px);
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
  }
  .personas-index__short {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
    flex: 1;
  }
  .personas-index__cta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--accent);
    margin-top: auto;
  }
</style>
