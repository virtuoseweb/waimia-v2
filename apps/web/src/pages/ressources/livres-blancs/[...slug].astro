---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import LeadMagnetTemplate from '../../../components/templates/LeadMagnetTemplate.astro';
import AuthorByline from '../../../components/ui/molecules/AuthorByline.astro';
import AuthorCard from '../../../components/ui/molecules/AuthorCard.astro';

export async function getStaticPaths() {
  const entries = await getCollection('livresBlancs');
  return entries
    .filter((entry) => !entry.data.seo?.noindex)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

type Props = { entry: CollectionEntry<'livresBlancs'> };

const slugifyAuthorName = (name: string) =>
  name.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

const getAuthorSlug = (author: unknown): string | undefined => {
  if (!author) return undefined;
  if (typeof author === 'string') return author;
  if (typeof author !== 'object') return undefined;

  const ref = author as { id?: unknown; slug?: unknown; url?: unknown; name?: unknown };
  if (typeof ref.id === 'string') return ref.id;
  if (typeof ref.slug === 'string') return ref.slug;
  if (typeof ref.url === 'string') return ref.url.split('/').filter(Boolean).at(-1);
  if (typeof ref.name === 'string') return slugifyAuthorName(ref.name);
  return undefined;
};

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const d = entry.data;
const authorSlug = getAuthorSlug(d.author);

const toc = d.chapters_fr.map((c, i) => ({
  num: String(i + 1).padStart(2, '0'),
  title: c,
}));
---
<LeadMagnetTemplate
  title={`${d.title_fr} · Livre blanc Waimia`}
  description={d.description_fr}
  slug={d.apiSlug}
  kicker={`§ Livre blanc · ${d.pages} pages · ${d.format_fr}`}
  format={d.format_fr}
  publishedAt={d.publishedAt.toISOString().slice(0, 10)}
  toc={toc}
  coverUrl={d.coverUrl}
>
  <Fragment slot="headline">{d.title_fr}</Fragment>
  <Fragment slot="lede">{d.description_fr}</Fragment>
  <Fragment slot="extra">
    <div class="lb-prose">
      <AuthorByline authorSlug={authorSlug} date={d.publishedAt} />
      <Content />
      <AuthorCard authorSlug={authorSlug} variant="full" />
    </div>
  </Fragment>
</LeadMagnetTemplate>

<style>
  .lb-prose {
    margin-top: 32px;
    padding-top: 32px;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-display);
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1.65;
    color: var(--ink-2);
  }
  .lb-prose :global(p:first-of-type::first-letter) {
    float: left;
    font-family: var(--font-display);
    font-size: 4.5em;
    line-height: 0.85;
    margin: 0.05em 0.08em -0.05em 0;
    color: var(--accent);
    font-style: italic;
  }
  .lb-prose :global(h2) {
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 400;
    font-style: italic;
    margin: 32px 0 16px;
    line-height: 1.2;
  }
  .lb-prose :global(p) { margin: 0 0 1.2em; }
  .lb-prose :global(a) {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .lb-prose :global(ul), .lb-prose :global(ol) { margin: 0 0 1.2em 1.5em; }
  .lb-prose :global(li) { margin-bottom: 0.4em; }
</style>
