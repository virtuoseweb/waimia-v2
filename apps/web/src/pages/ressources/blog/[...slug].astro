---
import { getCollection, render } from 'astro:content';
import EssayTemplate from '../../../components/templates/EssayTemplate.astro';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries
    .filter((e) => !e.data.seo?.noindex)
    .map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const dateStr = d.publishedAt.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });

const allBlog = await getCollection('blog');
const relatedCards = d.relatedPosts.length > 0
  ? d.relatedPosts
      .map((id) => allBlog.find((b) => b.id === id))
      .filter(Boolean)
      .map((c) => ({
        kicker: `§ Blog · ${c!.data.category}`,
        title_fr: c!.data.title_fr,
        title_en: c!.data.title_en,
        lead_fr: c!.data.description_fr,
        lead_en: c!.data.description_en,
        href: `/ressources/blog/${c!.id}`,
      }))
  : [];
---
<EssayTemplate
  title={`${d.title_fr} · Blog Waimia`}
  description={d.description_fr}
  kicker={`§ Blog · ${d.category}`}
  date={dateStr}
  author={d.author.name}
  readingTime={d.readingTime ? `${d.readingTime} min lecture` : undefined}
  relatedCards={relatedCards}
>
  <Fragment slot="headline">{d.title_fr}</Fragment>
  <Fragment slot="lede">{d.description_fr}</Fragment>
  <Fragment slot="body"><Content /></Fragment>
</EssayTemplate>
