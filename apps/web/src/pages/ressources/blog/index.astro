---
// Page · /ressources/blog · Index notes & essais
export const prerender = true;

import { getCollection } from 'astro:content';
import ListIndexTemplate from '../../../components/templates/ListIndexTemplate.astro';
import EditorialWriteRow from '../../../components/ui/molecules/EditorialWriteRow.astro';
import { langFromPath } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);

const allBlog = await getCollection('blog');
const sortedBlog = [...allBlog].sort(
  (a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime(),
);

const formatDate = (d: Date) => {
  const mm = String(d.getMonth() + 1).padStart(2, '0');
  return `${mm}.${d.getFullYear()}`;
};
---
<ListIndexTemplate
  title="Notes & essais · Waimia"
  description="Pas de pensum SEO. Notes courtes, cas concrets, recettes pratiques. Un essai mensuel, jamais de promotion."
  kicker="§ Notes & essais · monthly"
>
  <Fragment slot="headline">
    Notes <i>lentes</i> du terrain.
  </Fragment>
  <Fragment slot="lede">
    Une newsletter mensuelle, jamais de promotion. Tout ce qu'on aurait voulu lire avant de commencer un chantier.
  </Fragment>

  <Fragment slot="list">
    <div class="blog-list">
      {sortedBlog.map((entry) => (
        <EditorialWriteRow
          date={formatDate(entry.data.publishedAt)}
          tag={(entry.data.editorialType ?? entry.data.type ?? 'NOTE').toUpperCase()}
          href={`/ressources/blog/${entry.id}`}
          tone="paper"
        >
          {lang === 'fr' ? entry.data.title_fr : entry.data.title_en}
        </EditorialWriteRow>
      ))}
    </div>
  </Fragment>
</ListIndexTemplate>

<style>
  .blog-list { max-width: 1100px; }
</style>
