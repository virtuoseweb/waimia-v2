const relatedCards = [
  { kicker: 'CASE 07', title_fr: 'Halcyon Health', title_en: 'Halcyon Health',
    lead_fr: '−38% temps de triage →', lead_en: '−38% triage time →',
    href: '/ressources/cas/halcyon' },
  { kicker: 'CASE 12', title_fr: 'VirtuoseOS interne', title_en: 'VirtuoseOS internal',
    lead_fr: 'Le delivery industrialisé →', lead_en: 'Industrialized delivery →',
    href: '/ressources/cas/virtuoseos' },
