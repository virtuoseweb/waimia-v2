const proofMetrics = [
  { k: '−38%',   label_fr: 'Temps de triage moyen',  label_en: 'Average triage time' },
  { k: '2h45',   label_fr: 'Délai moyen vs 6h',      label_en: 'Average delay vs 6h' },
  { k: '99.2%',  label_fr: 'Accuracy classification', label_en: 'Classification accuracy' },
  { k: '0',      label_fr: 'Faux négatif vital',     label_en: 'Vital false negatives' },
];

const techPills = [
  { label: 'Claude Sonnet 4', kind: 'primary' as const },
  { label: 'MCP', kind: 'primary' as const },
  { label: 'DocLib', kind: 'neutral' as const },
  { label: 'Doctolib', kind: 'neutral' as const },
  { label: 'Hébergeur HDS', kind: 'open' as const },
  { label: 'LangSmith', kind: 'neutral' as const },
];

const relatedCards = [
  { kicker: 'CASE 04', title_fr: 'Plateau SaaS', title_en: 'Plateau SaaS',
    lead_fr: '+2,4 M€ de pipeline récupéré →', lead_en: '+€2.4M pipeline recovered →',
    href: '/ressources/cas/plateau' },
  { kicker: 'CASE 09', title_fr: 'Caserne Souverain', title_en: 'Caserne Sovereign',
    lead_fr: '100% souveraineté data →', lead_en: '100% data sovereignty →',
    href: '/ressources/cas/caserne' },
  { kicker: 'SERVICE 02.1', title_fr: 'Agents métier', title_en: 'Business agents',
    lead_fr: 'Le service inspiré par ce cas →', lead_en: 'The service inspired by this case →',
