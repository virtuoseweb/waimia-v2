  { label_fr: 'Secteur',     label_en: 'Sector',      value: 'Santé · groupe de cliniques' },
  { label_fr: 'Durée',       label_en: 'Duration',    value: '8 sem · Q1 2026' },
  { label_fr: 'Stack',       label_en: 'Stack',       value: 'Claude Sonnet 4 · MCP · DocLib' },
