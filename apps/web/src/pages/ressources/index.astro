---
// Page · /ressources · Hub landing Ressources
export const prerender = true;

// Source : waimia-handoff2 / ressources.html (450 LoC)
//
// Composition directe d'organismes existants : masthead + Featured tool +
// Cases + WritingNotes (blog) + Cookbooks + Newsletter band + CtaBand.

import { getCollection } from 'astro:content';
import { actions, isInputError } from 'astro:actions';
import Base from '../../layouts/Base.astro';
import Kicker from '../../components/ui/atoms/Kicker.astro';
import type { SectionByType } from '../../schemas/sections';
import CtaFinal from '../../components/sections/CtaFinal.astro';
import RelatedCards from '../../components/ui/molecules/RelatedCards.astro';
import Button from '../../components/ui/atoms/Button.astro';
import Bi from '../../components/ui/atoms/Bi.astro';
import FormErrors from '../../components/ui/atoms/FormErrors.astro';
import { langFromPath } from '../../lib/i18n';
import { buildCollectionPage } from '../../lib/seo/schema-builder';

const nlResult = Astro.getActionResult(actions.newsletter);

if (nlResult && !nlResult.error && nlResult.data?.redirect) {
  return Astro.redirect(nlResult.data.redirect);
}

const nlInputErrors = isInputError(nlResult?.error) ? nlResult.error.fields : {};
const nlOtherError = nlResult?.error && !isInputError(nlResult.error)
  ? nlResult.error.message
  : undefined;

const lang = langFromPath(Astro.url.pathname);

const collectionLd = buildCollectionPage(
  'Ressources Waimia',
  'Hub éditorial : blog, cookbooks, livres blancs, veille IA, outils, cas clients.',
  ['Blog', 'Cookbooks', 'Livres blancs', 'Veille IA', 'Outils', 'Cas clients'],
);

const [allBlog, allCases, allCookbooks, allLivresBlancs] = await Promise.all([
  getCollection('blog'),
  getCollection('cases'),
  getCollection('cookbooks'),
  getCollection('livresBlancs'),
]);

const byDate = (
  a: { data: { publishedAt: Date } },
  b: { data: { publishedAt: Date } },
) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime();

const sortedBlog = [...allBlog].sort(byDate);
const sortedCases = [...allCases].sort(byDate);
const sortedCookbooks = [...allCookbooks].sort(byDate);
const sortedLivresBlancs = [...allLivresBlancs].sort(byDate);

// Trois lectures vedettes : livre blanc le plus récent · blog le plus récent · veille-ia
const _lb0 = sortedLivresBlancs[0];
const _b0 = sortedBlog[0];
const tools = [
  ...(_lb0 ? [{
    kicker: 'LIVRE BLANC · 01',
    title_fr: _lb0.data.title_fr,
    title_en: _lb0.data.title_en,
    lead_fr: `${_lb0.data.pages} pages · téléchargeable →`,
    lead_en: `${_lb0.data.pages} pages · downloadable →`,
    href: `/ressources/livres-blancs/${_lb0.id}`,
  }] : []),
  ...(_b0 ? [{
    kicker: `${(_b0.data.editorialType ?? 'ESSAI').toUpperCase()} · 02`,
    title_fr: _b0.data.title_fr,
    title_en: _b0.data.title_en,
    lead_fr: `${_b0.data.description_fr} →`,
    lead_en: `${_b0.data.description_en} →`,
    href: `/ressources/blog/${_b0.id}`,
  }] : []),
  {
    kicker: 'VEILLE · 03',
    title_fr: 'Veille IA · hebdo',
    title_en: 'AI watch · weekly',
    lead_fr: 'Synthèses signées Waimia, sans bruit →',
    lead_en: 'Signed Waimia briefs, no noise →',
    href: '/ressources/veille-ia',
  },
];

const cookbookCards = sortedCookbooks.map((c, i) => ({
  kicker: `COOKBOOK · ${String(i + 1).padStart(2, '0')}`,
  title_fr: c.data.title_fr,
  title_en: c.data.title_en,
  lead_fr: `${c.data.description_fr} →`,
  lead_en: `${c.data.description_en} →`,
  href: `/ressources/cookbooks/${c.id}`,
}));

// hrefs corrigés : /cas/{slug} (pas /ressources/cas/)
const caseCards = sortedCases.map((c, i) => ({
  num: String(i + 1).padStart(2, '0'),
  kicker: `CAS · ${c.data.sector_fr.toUpperCase()}`,
  title_fr: c.data.client,
  sub_fr: c.data.impact_fr,
  lead_fr: c.data.description_fr,
  href: `/cas/${c.id}`,
}));

const blogCards = sortedBlog.slice(0, 3).map((b, i) => ({
  kicker: `BLOG · ${String(i + 1).padStart(2, '0')}`,
  title_fr: b.data.title_fr,
  title_en: b.data.title_en,
  lead_fr: `${b.data.description_fr} →`,
  lead_en: `${b.data.description_en} →`,
  href: `/ressources/blog/${b.id}`,
}));

const livresBlancsCards = sortedLivresBlancs.map((lb, i) => ({
  kicker: `LIVRE BLANC · ${String(i + 1).padStart(2, '0')}`,
  title_fr: lb.data.title_fr,
  title_en: lb.data.title_en,
  lead_fr: `${lb.data.description_fr} →`,
  lead_en: `${lb.data.description_en} →`,
  href: `/ressources/livres-blancs/${lb.id}`,
}));

const ctaData = {
  type: 'cta-final' as const,
  h2_fr: 'Prêt à livrer un <em>agent</em>,<br />pas un slide deck ?',
  h2_en: 'Ready to ship an <em>agent</em>,<br />not a slide deck?',
  body_fr: 'Audit IA en 5 jours. Premier agent en production en 4 semaines. ROI mesuré, jamais estimé.',
  body_en: 'AI audit in 5 days. First agent in production in 4 weeks. Measured ROI, never estimated.',
  cta_primary: { label_fr: 'Réserver un audit →', label_en: 'Book an audit →', href: '/contact', variant: 'primary' as const },
  cta_secondary: { label_fr: 'Voir la pyramide →', label_en: 'See the pyramid →', href: '/offres', variant: 'ghost' as const },
  background: 'paper' as const,
} satisfies SectionByType<'cta-final'>;
---
<Base
  title="Ressources · Cas, blog, cookbooks, outils · Waimia"
  description="Toutes les ressources Waimia — cas clients NDA-protected, notes de terrain, cookbooks de méthodes, calculateurs TCO/ROI/AI Act."
  jsonLd={collectionLd}
>
  {/* MASTHEAD */}
  <section class="hub-mast">
    <div class="wrap-wide">
      <Kicker class="hub-kicker">§ Hub · Ressources</Kicker>
      <h1 class="hub-h1 reveal-mask-up">Tout ce qu'on <i>publie</i>.</h1>
      <p class="hub-lede">
        Cas mesurables, notes de terrain, cookbooks de méthodes, calculateurs gratuits. Pas de pensum SEO. Tout est relu, signé, et NDA-protected quand pertinent.
      </p>
    </div>
  </section>

  {/* FEATURED TOOLS */}
  <section class="hub-tools">
    <div class="wrap-wide">
      <Kicker tone="accent" class="hub-tools-k">§ Lectures · trois entrées gratuites sans sign-up</Kicker>
      <h2 class="hub-tools-h2">Trois <i>lectures</i>. Pas de funnel commercial.</h2>
      <RelatedCards cards={tools} />
    </div>
  </section>

  {/* CAS CLIENTS · 5 cards vers vraies sub-pages */}
  <section class="hub-cases-detail">
    <div class="wrap-wide">
      <Kicker tone="accent" class="hub-cd-k">§ Cas clients · 5 dossiers signés</Kicker>
      <h2 class="hub-cd-h2">Cinq <i>missions</i>. Toutes mesurées.</h2>
      <p class="hub-cd-lead">
        Pas de témoignages publicitaires — chaque cas est lu, validé et signé par le client. Quatre clients externes plus notre blueprint interne.
      </p>
      <ol class="hub-cd-list reveal-stagger">
        {caseCards.map((c) => (
          <li class="hub-cd-row">
            <a class="hub-cd-link" href={c.href}>
              <span class="hub-cd-num">{c.num}</span>
              <span class="hub-cd-body">
                <span class="hub-cd-kicker">{c.kicker}</span>
                <span class="hub-cd-title">{c.title_fr} <i>· {c.sub_fr}</i></span>
                <span class="hub-cd-text">{c.lead_fr}</span>
              </span>
              <span class="hub-cd-arr" aria-hidden>→</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* COOKBOOKS · 3 cards vers vraies sub-pages */}
  <section class="hub-cookbooks">
    <div class="wrap-wide">
      <Kicker tone="accent" class="hub-cookbooks-k">§ Cookbooks · 3 recettes signées</Kicker>
      <h2 class="hub-cookbooks-h2">Les <i>recettes</i> qu'on applique en mission.</h2>
      <RelatedCards cards={cookbookCards} />
      <div class="hub-cookbooks-cta">
        <Button href="/ressources/cookbooks" variant="ghost" size="lg">Tous les cookbooks →</Button>
      </div>
    </div>
  </section>

  {/* BLOG + LIVRES BLANCS · pages détaillées */}
  <section class="hub-blog-lb">
    <div class="wrap-wide hub-blog-lb-grid reveal-stagger">
      <div>
        <Kicker tone="accent" class="hub-blog-k">§ Blog · notes longues</Kicker>
        <h2 class="hub-blog-h2">Une <i>note</i> à la fois.</h2>
        <p class="hub-blog-lead">
          Pas de calendrier éditorial. On publie quand on a vraiment quelque chose à dire.
        </p>
        <RelatedCards cards={blogCards} />
        <div class="hub-blog-cta">
          <Button href="/ressources/blog" variant="ghost" size="md">Tous les articles →</Button>
        </div>
      </div>
      <div>
        <Kicker tone="accent" class="hub-lb-k">§ Livres blancs · documents PDF</Kicker>
        <h2 class="hub-lb-h2">Un <i>document</i> par sujet.</h2>
        <p class="hub-lb-lead">
          Téléchargeable sans formulaire. Cité par nos clients en comité de direction.
        </p>
        <RelatedCards cards={livresBlancsCards} />
        <div class="hub-lb-cta">
          <Button href="/ressources/livres-blancs" variant="ghost" size="md">Tous les livres blancs →</Button>
        </div>
      </div>
    </div>
  </section>

  {/* NEWSLETTER BAND */}
  <section class="hub-nl">
    <div class="wrap-wide hub-nl-wrap">
      <div>
        <Kicker tone="accent" class="hub-nl-k">§ Newsletter · une fois par mois</Kicker>
        <h2 class="hub-nl-h2">Un <i>essai</i> par mois. Jamais de promotion.</h2>
        <p class="hub-nl-lead">
          Notes longues, cas concrets, recettes pratiques. Désabonnement en 1 clic, RGPD-compliant.
        </p>
      </div>
      <form class="hub-nl-form" method="POST" action={actions.newsletter} data-enhanced novalidate>
        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden">
          <label for="nl-hp">Ne pas remplir</label>
          <input type="text" id="nl-hp" name="_hp" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="lang" value={lang} />
        <label for="nl-email" class="sr-only">Email professionnel</label>
        <input id="nl-email" name="email" type="email" required placeholder="prénom@entreprise.com" autocomplete="email" aria-describedby="nl-hint" />
        <Button as="button" type="submit" variant="primary" size="md">S'abonner →</Button>
        <FormErrors errors={nlInputErrors} id="nl-errors" />
        {nlOtherError && <p class="form-error-global" role="alert">{nlOtherError}</p>}
      </form>
      <p class="nl-hint" id="nl-hint">
        <Bi fr="Sans spam · Désinscription en 1 clic" en="No spam · Unsubscribe anytime" />
        {' · '}
        <a href={lang === 'fr' ? '/legal/privacy' : '/en/legal/privacy'}>
          <Bi fr="Politique de confidentialité" en="Privacy policy" />
        </a>
      </p>
    </div>
  </section>

  <CtaFinal data={ctaData} lang="fr" />
</Base>

<style>
  .hub-mast { padding: 140px 32px clamp(40px, 5vw, 72px); }
  :global(.hub-kicker) { display: block; margin-bottom: 24px; }
  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--accent); }
  .hub-lede {
    font-family: var(--font-sans);
    font-size: clamp(20px, 2.2vw, 28px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.4;
  }

  .hub-tools,
  .hub-cookbooks { padding: clamp(80px, 10vw, 120px) 32px; }
  :global(.hub-tools-k),
  :global(.hub-cookbooks-k) { display: block; margin-bottom: 18px; }
  .hub-tools-h2,
  .hub-cookbooks-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 0 0 clamp(40px, 5vw, 72px);
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-tools-h2 :global(i),
  .hub-cookbooks-h2 :global(i) { font-style: italic; color: var(--accent); }

  .hub-cookbooks { background: var(--paper-2); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  .hub-cookbooks-cta { margin-top: clamp(28px, 3vw, 44px); }

  .hub-cases-detail { padding: clamp(80px, 10vw, 120px) 32px; }
  :global(.hub-cd-k) { display: block; margin-bottom: 18px; }
  .hub-cd-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: -0.024em;
    margin: 0 0 24px;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-cd-h2 :global(i) { font-style: italic; color: var(--accent); }
  .hub-cd-lead {
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.8vw, 22px);
    color: var(--muted);
    max-width: 760px;
    margin: 0 0 clamp(40px, 5vw, 64px);
    line-height: 1.45;
  }
  .hub-cd-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--ink);
  }
  .hub-cd-row { border-bottom: 1px solid var(--hairline); }
  .hub-cd-link {
    display: grid;
    grid-template-columns: 80px 1fr 60px;
    gap: clamp(20px, 3vw, 40px);
    padding: clamp(24px, 2.5vw, 36px) 0;
    align-items: start;
    color: inherit;
    transition: background 240ms var(--ease);
  }
  .hub-cd-link:hover { background: rgba(0, 0, 0, 0.02); }
  .hub-cd-num {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.5vw, 64px);
    line-height: 0.9;
    color: var(--accent);
    font-style: italic;
  }
  .hub-cd-body { display: flex; flex-direction: column; gap: 6px; }
  .hub-cd-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.14em;
  }
  .hub-cd-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.6vw, 36px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    text-wrap: balance;
  }
  .hub-cd-title :global(i) { font-style: italic; color: var(--muted); font-size: 0.7em; }
  .hub-cd-text {
    font-size: clamp(13px, 1.3vw, 15px);
    line-height: 1.55;
    color: var(--muted);
    max-width: 720px;
    text-wrap: pretty;
  }
  .hub-cd-arr {
    font-family: var(--font-mono);
    font-size: 24px;
    color: var(--accent);
    align-self: center;
    text-align: right;
  }
  @media (max-width: 700px) {
    .hub-cd-link { grid-template-columns: 48px 1fr; }
    .hub-cd-arr { display: none; }
  }

  .hub-blog-lb { padding: clamp(80px, 10vw, 120px) 32px; border-top: 1px solid var(--hairline); }
  .hub-blog-lb-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 5vw, 80px);
  }
  :global(.hub-blog-k),
  :global(.hub-lb-k) { display: block; margin-bottom: 14px; }
  .hub-blog-h2,
  .hub-lb-h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1;
    letter-spacing: -0.022em;
    margin: 0 0 18px;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-blog-h2 :global(i),
  .hub-lb-h2 :global(i) { font-style: italic; color: var(--accent); }
  .hub-blog-lead,
  .hub-lb-lead {
    font-family: var(--font-sans);
    font-size: clamp(15px, 1.6vw, 18px);
    color: var(--muted);
    margin: 0 0 28px;
    line-height: 1.45;
  }
  .hub-blog-cta,
  .hub-lb-cta { margin-top: clamp(20px, 2.5vw, 32px); }
  @media (max-width: 800px) {
    .hub-blog-lb-grid { grid-template-columns: 1fr; }
  }

  .hub-nl { padding: clamp(80px, 10vw, 120px) 32px; background: var(--ink); color: var(--paper); }
  .hub-nl-wrap { display: grid; grid-template-columns: 1.2fr 1fr; gap: clamp(40px, 6vw, 80px); align-items: center; }
  :global(.hub-nl-k) { display: block; margin-bottom: 18px; }
  .hub-nl-h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -0.024em;
    color: var(--paper);
    margin: 0 0 18px;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-nl-h2 :global(i) { font-style: italic; color: var(--accent); }
  .hub-nl-lead {
    font-size: 15px;
    line-height: 1.55;
    color: rgba(246, 241, 232, 0.7);
    max-width: 520px;
    margin: 0;
  }
  .hub-nl-form {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hub-nl-form input {
    flex: 1;
    min-width: 240px;
    padding: 14px 18px;
    background: rgba(246, 241, 232, 0.08);
    border: 1px solid rgba(246, 241, 232, 0.2);
    border-radius: 2px;
    color: var(--paper);
    font-family: var(--font-display);
    font-size: 16px;
  }
  .hub-nl-form input:focus { outline: none; border-color: var(--accent); }
  .nl-hint {
    font-size: 13px;
    color: rgba(246, 241, 232, 0.5);
    margin: 10px 0 0;
    line-height: 1.5;
  }
  .nl-hint a { color: rgba(246, 241, 232, 0.7); text-decoration: underline; }
  .nl-hint a:hover { color: var(--paper); }

  @media (max-width: 800px) {
    .hub-nl-wrap { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { actions } from 'astro:actions';
  import { navigate } from 'astro:transitions/client';

  document.querySelectorAll<HTMLFormElement>('form[data-enhanced]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      const actionPath = form.getAttribute('action');
      if (!actionPath) return;

      try {
        const res = await fetch(actionPath, { method: 'POST', body: formData, headers: { Accept: 'application/json' } });
        const json = await res.json();
        if (res.ok && json?.data?.redirect) {
          navigate(json.data.redirect);
          return;
        }
        form.removeEventListener('submit', () => {});
        form.submit();
      } catch {
        if (submitBtn) submitBtn.disabled = false;
        form.submit();
      }
    });
  });
</script>
