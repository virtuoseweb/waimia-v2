---
export const prerender = true;

import { getCollection, render, type CollectionEntry } from 'astro:content';
import EssayTemplate from '../../../components/templates/EssayTemplate.astro';

export async function getStaticPaths() {
  const entries = await getCollection('outils');
  return entries
    .filter((entry) => !entry.data.seo?.noindex)
    .map((entry) => ({
      params: { slug: entry.id },
      props: { entry },
    }));
}

type Props = { entry: CollectionEntry<'outils'> };

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const d = entry.data;

const dateStr = d.publishedAt.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
const categoryKicker = d.category_fr ? ` · ${d.category_fr}` : '';
---
<EssayTemplate
  title={`${d.title_fr} · Outils Waimia`}
  description={d.description_fr}
  kicker={`§ Outil · ${d.type}${categoryKicker}`}
  date={dateStr}
  datePublished={d.publishedAt.toISOString().slice(0, 10)}
  author="Waimia"
  relatedCards={[]}
  lang="fr"
  breadcrumbItems={[
    { label: 'Accueil', href: '/' },
    { label: 'Outils', href: '/ressources/outils' },
    { label: d.title_fr },
  ]}
>
  <Fragment slot="headline">{d.title_fr}</Fragment>
  <Fragment slot="lede">{d.description_fr}</Fragment>
  <Fragment slot="body">
    <Content />
  </Fragment>
</EssayTemplate>
