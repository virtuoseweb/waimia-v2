---
export const prerender = true;

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Kicker from '../../../components/ui/atoms/Kicker.astro';
import Breadcrumb from '../../../components/ui/molecules/Breadcrumb.astro';
import type { SectionByType } from '../../../schemas/sections';
import CtaFinal from '../../../components/sections/CtaFinal.astro';

type ResourceEntry =
  | CollectionEntry<'blog'>
  | CollectionEntry<'cookbooks'>
  | CollectionEntry<'livresBlancs'>
  | CollectionEntry<'veilleIA'>
  | CollectionEntry<'cases'>;

type Item = {
  id: string;
  type: string;
  data: ResourceEntry['data'];
  href: string;
};

export async function getStaticPaths() {
  const collections = await Promise.all([
    getCollection('blog'),
    getCollection('cookbooks'),
    getCollection('livresBlancs'),
    getCollection('veilleIA'),
    getCollection('cases'),
  ]);
  const [blog, cookbooks, livresBlancs, veilleIA, cas] = collections;

  const getItems = (slug: string): Item[] => [
    ...blog
      .filter((e) => !e.data.seo?.noindex && e.data.tags.includes(slug))
      .map((e) => ({ id: e.id, type: 'blog', data: e.data, href: `/ressources/blog/${e.id}` })),
    ...cookbooks
      .filter((e) => !e.data.seo?.noindex && e.data.tags.includes(slug))
      .map((e) => ({ id: e.id, type: 'cookbook', data: e.data, href: `/ressources/cookbooks/${e.id}` })),
    ...livresBlancs
      .filter((e) => !e.data.seo?.noindex && e.data.tags.includes(slug))
      .map((e) => ({ id: e.id, type: 'livre-blanc', data: e.data, href: `/ressources/livres-blancs/${e.id}` })),
    ...veilleIA
      .filter((e) => !e.data.seo?.noindex && e.data.tags.includes(slug))
      .map((e) => ({ id: e.id, type: 'veille', data: e.data, href: `/ressources/veille-ia/${e.id}` })),
    ...cas
      .filter((e) => !e.data.seo?.noindex && e.data.tags.includes(slug))
      .map((e) => ({ id: e.id, type: 'cas', data: e.data, href: `/cas/${e.id}` })),
  ].sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

  const slugs = new Set<string>();
  for (const collection of collections) {
    for (const entry of collection) {
      if (!entry.data.seo?.noindex) {
        entry.data.tags.forEach((tag) => slugs.add(tag));
      }
    }
  }

  return [...slugs].map((slug) => ({
    params: { slug },
    props: { slug, items: getItems(slug) },
  }));
}

type Props = { slug: string; items: Item[] };

const { slug, items } = Astro.props as Props;

const tagDisplay = slug.replace(/-/g, ' ');

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://waimia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Ressources', item: 'https://waimia.com/ressources' },
    { '@type': 'ListItem', position: 3, name: `Tag : ${tagDisplay}` },
  ],
};

const ctaData = {
  type: 'cta-final' as const,
  h2_fr: 'Prêt à livrer un <em>agent</em>,<br />pas un slide deck ?',
  h2_en: 'Ready to ship an <em>agent</em>,<br />not a slide deck?',
  body_fr: 'Audit IA en 5 jours. Premier agent en production en 4 semaines. ROI mesuré, jamais estimé.',
  body_en: 'AI audit in 5 days. First agent in production in 4 weeks. Measured ROI, never estimated.',
  cta_primary: { label_fr: 'Réserver un audit →', label_en: 'Book an audit →', href: '/contact', variant: 'primary' as const },
  cta_secondary: { label_fr: 'Voir la pyramide →', label_en: 'See the pyramid →', href: '/offres', variant: 'ghost' as const },
  background: 'paper' as const,
} satisfies SectionByType<'cta-final'>;
---

<Base
  title={`Tag · ${tagDisplay} · ${items.length} ressources · Waimia`}
  description={`Toutes les ressources Waimia avec le tag "${tagDisplay}". ${items.length} contenus liés.`}
  jsonLd={[breadcrumbLd]}
>
  <Breadcrumb lang="fr" items={[
    { label: 'Accueil', href: '/' },
    { label: 'Ressources', href: '/ressources' },
    { label: `#${slug}` },
  ]} />
  <section class="tag-mast">
    <div class="wrap-tight">
      <Kicker class="tag-kicker">§ Tag · {items.length} {items.length > 1 ? 'ressources' : 'ressource'}</Kicker>
      <h1 class="tag-h1 reveal-mask-up">#{slug}</h1>
    </div>
  </section>

  <section class="tag-list-sec">
    <div class="wrap-tight">
      <ul class="tag-list">
        {items.map((it) => (
          <li>
            <a href={it.href}>
              <span class="tag-type">{it.type}</span>
              <span class="tag-title">{it.data.title_fr}</span>
              <span class="tag-date">{new Date(it.data.publishedAt).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' })}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
  <CtaFinal data={ctaData} lang="fr" />
</Base>

<style>
  .tag-mast { padding: clamp(80px, 10vw, 140px) 0 clamp(40px, 5vw, 64px); }
  :global(.tag-kicker) { color: var(--accent); margin-bottom: 24px; }
  .tag-h1 {
    font-family: var(--font-mono);
    font-size: clamp(36px, 6vw, 80px);
    line-height: 1;
    letter-spacing: -.02em;
    font-weight: 500;
    margin: 0;
    color: var(--ink);
  }
  .tag-list-sec { padding: clamp(40px, 5vw, 80px) 0 clamp(80px, 10vw, 140px); }
  .tag-list { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--hairline-strong); }
  .tag-list li { border-bottom: 1px solid var(--hairline); }
  .tag-list a {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 24px;
    padding: 18px 0;
    color: var(--ink);
    text-decoration: none;
    align-items: baseline;
    transition: padding 220ms;
  }
  .tag-list a:hover { padding-left: 8px; color: var(--accent); }
  .tag-type {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .tag-title { font-family: var(--font-display); font-size: 17px; line-height: 1.35; }
  .tag-date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .wrap-tight { max-width: 880px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } }),
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal, .reveal-mask-up').forEach((el) => io.observe(el));
</script>
