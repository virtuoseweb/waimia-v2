---
export const prerender = true;

import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import Kicker from '../../../components/ui/atoms/Kicker.astro';
import { CLUSTERS } from '../../../data/taxonomies';
import CtaBand from '../../../components/ui/organisms/CtaBand.astro';

type ResourceEntry =
  | CollectionEntry<'blog'>
  | CollectionEntry<'cookbooks'>
  | CollectionEntry<'livresBlancs'>
  | CollectionEntry<'veilleIA'>
  | CollectionEntry<'cases'>;

type Item = {
  id: string;
  type: string;
  data: ResourceEntry['data'];
  href: string;
};

export async function getStaticPaths() {
  const [blog, cookbooks, livresBlancs, veilleIA, cas] = await Promise.all([
    getCollection('blog'),
    getCollection('cookbooks'),
    getCollection('livresBlancs'),
    getCollection('veilleIA'),
    getCollection('cases'),
  ]);

  const getItems = (slug: string): Item[] => [
    ...blog
      .filter((e) => !e.data.seo?.noindex && e.data.cluster === slug)
      .map((e) => ({ id: e.id, type: 'blog', data: e.data, href: `/ressources/blog/${e.id}` })),
    ...cookbooks
      .filter((e) => !e.data.seo?.noindex && e.data.cluster === slug)
      .map((e) => ({ id: e.id, type: 'cookbook', data: e.data, href: `/ressources/cookbooks/${e.id}` })),
    ...livresBlancs
      .filter((e) => !e.data.seo?.noindex && e.data.cluster === slug)
      .map((e) => ({ id: e.id, type: 'livre-blanc', data: e.data, href: `/ressources/livres-blancs/${e.id}` })),
    ...veilleIA
      .filter((e) => !e.data.seo?.noindex && e.data.cluster === slug)
      .map((e) => ({ id: e.id, type: 'veille', data: e.data, href: `/ressources/veille-ia/${e.id}` })),
    ...cas
      .filter((e) => !e.data.seo?.noindex && e.data.cluster === slug)
      .map((e) => ({ id: e.id, type: 'cas', data: e.data, href: `/cas/${e.id}` })),
  ].sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

  return Object.keys(CLUSTERS).map((slug) => ({
    params: { slug },
    props: { slug, items: getItems(slug) },
  }));
}

type Props = { slug: string; items: Item[] };

const { slug, items } = Astro.props as Props;
const cluster = CLUSTERS[slug];

const pillar = cluster.pillarSlug ? items.find((it) => it.id === cluster.pillarSlug) : null;
const otherItems = pillar ? items.filter((it) => it.id !== pillar.id) : items;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Accueil', item: 'https://waimia.com/' },
    { '@type': 'ListItem', position: 2, name: 'Ressources', item: 'https://waimia.com/ressources' },
    { '@type': 'ListItem', position: 3, name: cluster.label.fr },
  ],
};

const collectionPageLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `Silo · ${cluster.label.fr} · Waimia`,
};
---

<Base
  title={`Silo · ${cluster.label.fr} · ${items.length} ressources`}
  description={`Cluster éditorial : ${cluster.label.fr}. ${items.length} ressources liées (pillar + clusters).`}
  jsonLd={[breadcrumbLd, collectionPageLd]}
>
  <section class="silo-mast">
    <div class="wrap-tight">
      <Kicker class="silo-kicker">§ Silo · cluster éditorial · {items.length} ressources</Kicker>
      <h1 class="silo-h1 reveal">{cluster.label.fr}</h1>
    </div>
  </section>

  {pillar && (
    <section class="silo-pillar-sec">
      <div class="wrap-tight">
        <Kicker>§ Article pillar</Kicker>
        <a href={pillar.href} class="silo-pillar-card">
          <h2>{pillar.data.title_fr}</h2>
          <p>{pillar.data.description_fr}</p>
          <span>Lire le pillar →</span>
        </a>
      </div>
    </section>
  )}

  <section class="silo-list-sec">
    <div class="wrap-tight">
      <Kicker>§ Articles clusters</Kicker>
      <ul class="silo-list">
        {otherItems.map((it) => (
          <li>
            <a href={it.href}>
              <span class="silo-type">{it.type}</span>
              <span class="silo-title">{it.data.title_fr}</span>
              <span class="silo-date">{new Date(it.data.publishedAt).toLocaleDateString('fr-FR', { year: 'numeric', month: 'short' })}</span>
            </a>
          </li>
        ))}
      </ul>
      {otherItems.length === 0 && <p class="silo-empty">Cluster en construction. Articles à venir.</p>}
    </div>
  </section>
  <CtaBand />
</Base>

<style>
  .silo-mast { padding: clamp(80px, 10vw, 140px) 0 clamp(40px, 5vw, 64px); }
  :global(.silo-kicker) { color: var(--accent); margin-bottom: 24px; }
  .silo-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 120px);
    line-height: .92;
    letter-spacing: -.028em;
    font-weight: 400;
    margin: 0;
  }
  .silo-pillar-sec { padding: clamp(40px, 5vw, 80px) 0; background: var(--paper-2, #EFEBE2); }
  .silo-pillar-card {
    display: block;
    padding: 32px;
    background: var(--paper);
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 16px;
    text-decoration: none;
    color: var(--ink);
    margin-top: 16px;
    transition: border-color 220ms;
  }
  .silo-pillar-card:hover { border-color: var(--accent); }
  .silo-pillar-card h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.05;
    margin: 0 0 12px;
    font-weight: 400;
  }
  .silo-pillar-card p {
    font-family: var(--font-display);
    font-size: 16px;
    line-height: 1.5;
    color: var(--muted);
    font-style: italic;
    margin: 0 0 16px;
  }
  .silo-pillar-card span {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    letter-spacing: .08em;
  }
  .silo-list-sec { padding: clamp(40px, 5vw, 80px) 0 clamp(80px, 10vw, 140px); }
  .silo-list { list-style: none; padding: 0; margin: 16px 0 0; border-top: 1px solid rgba(0,0,0,.12); }
  .silo-list li { border-bottom: 1px solid rgba(0,0,0,.08); }
  .silo-list a {
    display: grid;
    grid-template-columns: 100px 1fr auto;
    gap: 24px;
    padding: 18px 0;
    color: var(--ink);
    text-decoration: none;
    align-items: baseline;
    transition: padding 220ms;
  }
  .silo-list a:hover { padding-left: 8px; color: var(--accent); }
  .silo-type {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .silo-title { font-family: var(--font-display); font-size: 17px; line-height: 1.35; }
  .silo-date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .silo-empty { font-family: var(--font-display); font-style: italic; color: var(--muted); padding: 32px 0; }
  .wrap-tight { max-width: 880px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
</style>
