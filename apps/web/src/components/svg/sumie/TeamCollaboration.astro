---
interface Props {
  size?: 'sm' | 'md' | 'lg';
  variant?: 'default' | 'mono';
}

const { size = 'md', variant = 'default' } = Astro.props;
---

<svg
  viewBox="0 0 200 200"
  preserveAspectRatio="xMidYMid meet"
  class={`sumie-collab sumie-collab-${size}`}
  role="img"
  aria-label="Trois silhouettes en collaboration, encre sumi-e"
>
  <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
    <path d="M44 55 C43 47 47 40 54 40 C61 40 66 47 66 57 C66 66 62 72 55 72 C48 72 44 65 44 55" stroke-width="1.3" />
    <path d="M55 72 C53 92 52 114 54 142" stroke-width="1.55" />
    <path d="M55 88 C67 97 80 104 90 112" stroke-width="1.1" />

    <path d="M90 42 C89 34 94 27 101 27 C108 27 112 34 112 44 C112 53 108 60 101 60 C94 60 90 53 90 42" stroke-width="1.45" />
    <path d="M93 31 C100 24 108 25 113 34" stroke-width="2.1" />
    <path d="M101 60 C99 84 98 112 100 150" stroke-width="1.8" />
    <path d="M101 80 C89 89 74 95 62 99" stroke-width="1.15" />
    <path d="M101 80 C113 89 128 95 140 99" stroke-width="1.15" />

    <path d="M134 55 C134 47 138 40 145 40 C152 40 157 47 157 57 C157 66 152 72 145 72 C138 72 134 65 134 55" stroke-width="1.3" />
    <path d="M145 72 C147 92 148 114 146 142" stroke-width="1.55" />
    <path d="M145 88 C133 97 120 104 110 112" stroke-width="1.1" />

    <path d="M18 157 C65 151 135 151 182 158" stroke-width="0.65" stroke-dasharray="34 13" />
    <path d="M24 170 C70 165 130 165 176 170" stroke-width="0.55" stroke-dasharray="24 10" />
  </g>
  {
    variant === 'default' && (
      <path
        d="M97 107 C100 103 105 104 107 108 C105 113 99 113 96 109 C95 108 97 107 97 107 Z"
        fill="#C94F2E"
      />
    )
  }
</svg>

<style>
  .sumie-collab {
    display: block;
    color: var(--ink-2);
  }

  .sumie-collab-sm {
    width: 100px;
  }

  .sumie-collab-md {
    width: 200px;
  }

  .sumie-collab-lg {
    width: 280px;
  }
</style>
