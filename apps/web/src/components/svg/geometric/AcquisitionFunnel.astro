---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const accentColor = 'var(--waimia-accent, #C94F2E)';
---
<svg
  viewBox="0 0 480 460"
  preserveAspectRatio="xMidYMid meet"
  class:list={['acquisition-funnel', compact && 'acquisition-funnel-compact']}
  role="img"
  aria-label="Entonnoir d'acquisition : Awareness, Interest, Décision, Action"
>
  <rect x="50" y="20" width="380" height="72" fill="var(--paper-2, #F6F1E8)"
    stroke="currentColor" stroke-width="1"
    vector-effect="non-scaling-stroke"/>
  <text x="240" y="46" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="11" letter-spacing="1.4"
    fill="currentColor">AWARENESS</text>
  <text x="240" y="75" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="18" fill="currentColor">visibilité organique</text>

  <line x1="240" y1="92" x2="240" y2="128" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" opacity="0.4"/>
  <path d="M236 124 L240 128 L244 124" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.4"/>

  <rect x="100" y="132" width="280" height="72" fill="var(--paper-2, #F6F1E8)"
    stroke="currentColor" stroke-width="1"
    vector-effect="non-scaling-stroke"/>
  <text x="240" y="158" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="11" letter-spacing="1.4"
    fill="currentColor">INTEREST</text>
  <text x="240" y="187" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="18" fill="currentColor">engagement contenu</text>

  <line x1="240" y1="204" x2="240" y2="240" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" opacity="0.4"/>
  <path d="M236 236 L240 240 L244 236" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.4"/>

  <rect x="150" y="244" width="180" height="72" fill="var(--paper-2, #F6F1E8)"
    stroke={accentColor} stroke-width="1.5"
    vector-effect="non-scaling-stroke"/>
  <text x="240" y="270" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="11" letter-spacing="1.4"
    fill={accentColor}>DÉCISION</text>
  <text x="240" y="299" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="18" fill="currentColor">comparaison offre</text>

  <line x1="240" y1="316" x2="240" y2="352" stroke={accentColor} stroke-width="1" vector-effect="non-scaling-stroke"/>
  <path d="M236 348 L240 352 L244 348" fill="none" stroke={accentColor} stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>

  <rect x="190" y="356" width="100" height="72" fill="var(--paper-2, #F6F1E8)"
    stroke={accentColor} stroke-width="1.5"
    vector-effect="non-scaling-stroke"/>
  <text x="240" y="382" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="11" letter-spacing="1.4"
    fill={accentColor}>ACTION</text>
  <text x="240" y="411" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="18" fill="currentColor">conversion client</text>
</svg>
<style>
  .acquisition-funnel {
    display: block;
    width: 100%;
    max-width: 540px;
    margin-inline: auto;
    color: var(--ink, #0c0b09);
  }
  .acquisition-funnel-compact { max-width: 480px; }
</style>
