---
interface Props {
  size?: number;
  accent?: boolean;
}
const { size = 120, accent = false } = Astro.props;
const accentColor = 'var(--waimia-accent, #C94F2E)';
---
<svg
  viewBox="0 0 200 60"
  preserveAspectRatio="xMidYMid meet"
  width={size}
  height={size * 60 / 200}
  class="ornament-section"
  aria-hidden="true">
  <!-- Cercle externe -->
  <circle cx="100" cy="30" r="22" fill="none" stroke="currentColor" stroke-width="0.7" vector-effect="non-scaling-stroke" opacity="0.38"/>
  <!-- Cercle interne -->
  <circle cx="100" cy="30" r="10" fill="none" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.28"/>
  <!-- Lignes rayonnantes diagonales -->
  <line x1="116" y1="14" x2="127" y2="3" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.35"/>
  <line x1="84" y1="14" x2="73" y2="3" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.35"/>
  <line x1="84" y1="46" x2="73" y2="57" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.35"/>
  <line x1="116" y1="46" x2="127" y2="57" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.35"/>
  <!-- Arcs intérieurs horizontaux -->
  <path d="M78 30 C82 24 118 24 122 30" fill="none" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.3"/>
  <path d="M78 30 C82 36 118 36 122 30" fill="none" stroke="currentColor" stroke-width="0.6" vector-effect="non-scaling-stroke" opacity="0.3"/>
  <!-- Dot central -->
  <circle cx="100" cy="30" r="2" fill={accent ? accentColor : 'currentColor'} opacity={accent ? '1' : '0.45'}/>
</svg>
<style>
  .ornament-section { display: inline-block; color: var(--ink, #0c0b09); }
</style>
