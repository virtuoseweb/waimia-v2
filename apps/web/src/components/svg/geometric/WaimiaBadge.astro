---
interface Props {
  size?: number;
  variant?: 'default' | 'light';
  label?: string;
}
const { size = 48, variant = 'default', label } = Astro.props;
const accentColor = 'var(--waimia-accent, #C94F2E)';
---
<svg viewBox="0 0 48 48"
  width={size}
  height={size}
  class="waimia-badge"
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={!label ? 'true' : undefined}>
  <!-- Cercle contour -->
  <circle cx="24" cy="24" r="21" fill="none" stroke="currentColor" stroke-width="1" vector-effect="non-scaling-stroke" opacity="0.28"/>
  <!-- Lettre W italic serif centrée -->
  <text x="9" y="31"
    font-family="Instrument Serif, Georgia, serif"
    font-style="italic"
    font-size="26"
    letter-spacing="-0.5"
    fill="currentColor">W</text>
  <!-- Dot accent terracotta bas-droite -->
  <circle cx="36" cy="30" r="3" fill={accentColor}/>
</svg>
<style>
  .waimia-badge { display: inline-block; color: var(--ink, #0c0b09); vertical-align: middle; }
</style>
