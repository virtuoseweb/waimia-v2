---
interface Props {
  active?: 0 | 1 | 2 | 3 | 4;
  variant?: 'default' | 'compact';
}

const { active, variant = 'default' } = Astro.props;
const accentColor = 'var(--waimia-accent, #C94F2E)';
const phases = [
  { num: '01', label: 'Cartographie' },
  { num: '02', label: 'Priorisation' },
  { num: '03', label: 'Câblage' },
  { num: '04', label: 'Mesure' },
  { num: '05', label: 'Passation' },
];
---

<svg
  viewBox="0 0 800 120"
  preserveAspectRatio="xMidYMid meet"
  class:list={['process-diagram', `process-diagram-${variant}`, 'methode-anim']}
  role="img"
  aria-label="Méthode Waimia : Cartographie, Priorisation, Câblage, Mesure, Passation"
>
  <line
    x1="80"
    y1="60"
    x2="720"
    y2="60"
    stroke="currentColor"
    stroke-width="1"
    stroke-linecap="round"
    vector-effect="non-scaling-stroke"
    stroke-opacity="0.4"
    class="meth-connector"
  />

  {
    phases.map((phase, idx) => {
      const cx = 80 + idx * 160;
      const isActive = idx === active;

      return (
        <g class="meth-phase-node" style="opacity:0">
          <text
            x={cx}
            y="32"
            text-anchor="middle"
            font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
            font-size="11"
            letter-spacing="1.2"
            fill="currentColor"
            opacity={isActive ? '1' : '0.5'}
          >
            {phase.num}
          </text>
          <circle
            cx={cx}
            cy="60"
            r="7"
            fill={isActive ? accentColor : 'transparent'}
            stroke={isActive ? accentColor : 'currentColor'}
            stroke-width="1.5"
            vector-effect="non-scaling-stroke"
          />
          <text
            x={cx}
            y="98"
            text-anchor="middle"
            font-family="Instrument Serif, Georgia, serif"
            font-style="italic"
            font-size="16"
            fill="currentColor"
          >
            {phase.label}
          </text>
        </g>
      );
    })
  }
</svg>

<style>
  .process-diagram {
    display: block;
    width: 100%;
    max-width: 880px;
    margin-inline: auto;
    color: var(--ink, #0c0b09);
  }

  .process-diagram-compact {
    max-width: 640px;
  }

  @media (max-width: 600px) {
    .process-diagram {
      min-width: 560px;
    }
  }

  .methode-anim .meth-phase-node {
    transform-origin: center;
    transform-box: fill-box;
    transform: scale(0.6);
  }

  @media (prefers-reduced-motion: reduce) {
    .methode-anim .meth-phase-node {
      opacity: 1 !important;
      transform: none !important;
    }
    .methode-anim .meth-connector {
      stroke-dashoffset: 0 !important;
    }
  }
</style>

<script>
  (function () {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    var svgs = document.querySelectorAll('.methode-anim');
    svgs.forEach(function (svg) {
      if (!(svg instanceof SVGElement)) return;

      var connector = svg.querySelector('.meth-connector');
      if (connector instanceof SVGLineElement) {
        var len = Math.hypot(
          connector.x2.baseVal.value - connector.x1.baseVal.value,
          connector.y2.baseVal.value - connector.y1.baseVal.value
        );
        connector.style.strokeDasharray = String(len);
        connector.style.strokeDashoffset = String(len);
        connector.style.transition = 'none';
      }

      var nodes = svg.querySelectorAll('.meth-phase-node');

      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          obs.unobserve(entry.target);

          if (connector instanceof SVGLineElement) {
            var lineEl = connector;
            setTimeout(function () {
              lineEl.style.transition = 'stroke-dashoffset 1.1s cubic-bezier(0.22,1,0.36,1)';
              lineEl.style.strokeDashoffset = '0';
            }, 100);
          }

          nodes.forEach(function (node, i) {
            if (!(node instanceof SVGGElement)) return;
            setTimeout(function () {
              node.style.transition = 'opacity 0.5s ease, transform 0.5s cubic-bezier(0.34,1.56,0.64,1)';
              node.style.opacity = '1';
              node.style.transform = 'scale(1)';
            }, 300 + i * 160);
          });
        });
      }, { threshold: 0.25 });

      obs.observe(svg);
    });
  })();
</script>
