---
interface Props {
  active?: 0 | 1 | 2 | 3 | 4;
  variant?: 'default' | 'compact';
}

const { active, variant = 'default' } = Astro.props;
const accentColor = 'var(--waimia-accent, #C94F2E)';
const phases = [
  { num: '01', label: 'Cartographie' },
  { num: '02', label: 'Priorisation' },
  { num: '03', label: 'Câblage' },
  { num: '04', label: 'Mesure' },
  { num: '05', label: 'Passation' },
];
---

<svg
  viewBox="0 0 800 120"
  preserveAspectRatio="xMidYMid meet"
  class:list={['process-diagram', `process-diagram-${variant}`]}
  role="img"
  aria-label="Méthode Waimia : Cartographie, Priorisation, Câblage, Mesure, Passation"
>
  <line
    x1="80"
    y1="60"
    x2="720"
    y2="60"
    stroke="currentColor"
    stroke-width="1"
    stroke-linecap="round"
    vector-effect="non-scaling-stroke"
    opacity="0.18"
  />

  {
    phases.map((phase, idx) => {
      const cx = 80 + idx * 160;
      const isActive = idx === active;

      return (
        <g>
          <text
            x={cx}
            y="32"
            text-anchor="middle"
            font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
            font-size="11"
            letter-spacing="1.2"
            fill="currentColor"
            opacity={isActive ? '1' : '0.5'}
          >
            {phase.num}
          </text>
          <circle
            cx={cx}
            cy="60"
            r="7"
            fill={isActive ? accentColor : 'transparent'}
            stroke={isActive ? accentColor : 'currentColor'}
            stroke-width="1.5"
            vector-effect="non-scaling-stroke"
          />
          <text
            x={cx}
            y="98"
            text-anchor="middle"
            font-family="Instrument Serif, Georgia, serif"
            font-style="italic"
            font-size="16"
            fill="currentColor"
          >
            {phase.label}
          </text>
        </g>
      );
    })
  }
</svg>

<style>
  .process-diagram {
    display: block;
    width: 100%;
    max-width: 880px;
    margin-inline: auto;
    color: var(--ink, #0c0b09);
  }

  .process-diagram-compact {
    max-width: 640px;
  }

  @media (max-width: 600px) {
    .process-diagram {
      min-width: 560px;
    }
  }
</style>
