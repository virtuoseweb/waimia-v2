---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const accent = 'var(--waimia-accent, #C94F2E)';
---
<svg
  viewBox="0 0 520 280"
  preserveAspectRatio="xMidYMid meet"
  class:list={['revops-funnel', compact && 'revops-funnel--compact']}
  role="img"
  aria-label="Entonnoir RevOps : de Leads à Deal — conversion type après RevOps Rebuild"
>
  <defs>
    <style>
      .rm { font-family: JetBrains Mono, ui-monospace, SFMono-Regular, monospace; }
      .rs { font-family: Instrument Serif, Georgia, serif; font-style: italic; }
    </style>
  </defs>

  <!-- Couche 1 : LEADS — pleine largeur -->
  <rect x="30" y="20" width="460" height="44" fill="var(--paper-2,#F6F1E8)" stroke="currentColor" stroke-width="0.8" opacity="0.25" vector-effect="non-scaling-stroke"/>
  <text x="46" y="47" class="rm" font-size="9" letter-spacing="0.8" fill="currentColor">LEADS</text>
  <text x="472" y="47" text-anchor="end" class="rm" font-size="9" fill="currentColor" opacity="0.45" letter-spacing="0.7">100 %</text>

  <!-- Flèche 1→2 -->
  <polyline points="260,64 260,78" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.30"/>

  <!-- Couche 2 : MQL — 68% largeur -->
  <rect x="87" y="78" width="346" height="44" fill="var(--paper-2,#F6F1E8)" stroke="currentColor" stroke-width="0.8" opacity="0.25" vector-effect="non-scaling-stroke"/>
  <text x="103" y="105" class="rm" font-size="9" letter-spacing="0.8" fill="currentColor">MQL</text>
  <text x="415" y="105" text-anchor="end" class="rm" font-size="9" fill="currentColor" opacity="0.45" letter-spacing="0.7">~58 %</text>

  <!-- Flèche 2→3 -->
  <polyline points="260,122 260,136" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.30"/>

  <!-- Couche 3 : SQL — 42% largeur -->
  <rect x="151" y="136" width="218" height="44" fill="var(--paper-2,#F6F1E8)" stroke="currentColor" stroke-width="0.8" opacity="0.25" vector-effect="non-scaling-stroke"/>
  <text x="167" y="163" class="rm" font-size="9" letter-spacing="0.8" fill="currentColor">SQL</text>
  <text x="351" y="163" text-anchor="end" class="rm" font-size="9" fill="currentColor" opacity="0.45" letter-spacing="0.7">~24 %</text>

  <!-- Flèche 3→4 -->
  <polyline points="260,180 260,194" stroke="currentColor" stroke-width="0.8" fill="none" opacity="0.30"/>

  <!-- Couche 4 : DEAL — 24% largeur, accent -->
  <rect x="196" y="194" width="128" height="44" fill="var(--paper-2,#F6F1E8)" stroke={accent} stroke-width="1" opacity="0.9" vector-effect="non-scaling-stroke"/>
  <text x="212" y="221" class="rm" font-size="9" letter-spacing="0.8" fill="currentColor">DEAL</text>
  <text x="302" y="221" text-anchor="end" class="rm" font-size="9.5" fill={accent} letter-spacing="0.7" font-weight="500">×3.1</text>

  <!-- Label bas -->
  <text x="260" y="258" text-anchor="middle" class="rm" font-size="8" fill="currentColor" opacity="0.40" letter-spacing="0.9">SQL→DEAL ×3.1 APRÈS REVOPS REBUILD · PLATEAU SAAS</text>
</svg>
<style>
  .revops-funnel {
    display: block;
    width: 100%;
    max-width: 540px;
    margin-inline: auto;
    margin-top: clamp(24px, 3vw, 40px);
    color: var(--ink, #0c0b09);
  }
  .revops-funnel--compact { max-width: 380px; }
</style>
