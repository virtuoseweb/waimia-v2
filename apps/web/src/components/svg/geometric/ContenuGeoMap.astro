---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
const accentColor = 'var(--waimia-accent, #C94F2E)';
---
<svg
  viewBox="0 0 480 320"
  preserveAspectRatio="xMidYMid meet"
  class:list={['contenu-geo-map', compact && 'contenu-geo-map-compact']}
  role="img"
  aria-label="Convergence contenu : Google Search, LLM Crawler GEO, trafic Direct"
>
  <rect x="0" y="68" width="160" height="64" fill="var(--paper-2, #F6F1E8)"
    stroke="currentColor" stroke-width="1"
    vector-effect="non-scaling-stroke"/>
  <text x="80" y="90" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="10" letter-spacing="1.2"
    fill="currentColor">GOOGLE SEARCH</text>
  <text x="80" y="116" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="16" fill="currentColor">SEO classique</text>

  <rect x="160" y="8" width="160" height="64" fill="var(--paper-2, #F6F1E8)"
    stroke={accentColor} stroke-width="1.5"
    vector-effect="non-scaling-stroke"/>
  <text x="240" y="30" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="10" letter-spacing="1.2"
    fill={accentColor}>LLM CRAWLER</text>
  <text x="240" y="56" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="16" fill="currentColor">GEO citations</text>

  <rect x="320" y="68" width="160" height="64" fill="var(--paper-2, #F6F1E8)"
    stroke="currentColor" stroke-width="1"
    vector-effect="non-scaling-stroke"/>
  <text x="400" y="90" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="10" letter-spacing="1.2"
    fill="currentColor">DIRECT</text>
  <text x="400" y="116" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="16" fill="currentColor">partage organique</text>

  <line x1="80" y1="132" x2="196" y2="194" stroke="currentColor" stroke-width="0.8" vector-effect="non-scaling-stroke" opacity="0.3"/>
  <path d="M192 191 L196 194 L193 198" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.3"/>

  <line x1="240" y1="72" x2="240" y2="196" stroke={accentColor} stroke-width="1" vector-effect="non-scaling-stroke"/>
  <path d="M236 192 L240 196 L244 192" fill="none" stroke={accentColor} stroke-width="1" stroke-linecap="round" vector-effect="non-scaling-stroke"/>

  <line x1="400" y1="132" x2="284" y2="194" stroke="currentColor" stroke-width="0.8" vector-effect="non-scaling-stroke" opacity="0.3"/>
  <path d="M287 198 L284 194 L280 197" fill="none" stroke="currentColor" stroke-width="0.8" stroke-linecap="round" vector-effect="non-scaling-stroke" opacity="0.3"/>

  <rect x="130" y="200" width="220" height="72" fill="var(--paper-2, #F6F1E8)"
    stroke="currentColor" stroke-width="1"
    vector-effect="non-scaling-stroke"/>
  <text x="240" y="226" text-anchor="middle"
    font-family="JetBrains Mono, ui-monospace, SFMono-Regular, monospace"
    font-size="11" letter-spacing="1.4"
    fill="currentColor">CONTENU PUBLIÉ</text>
  <text x="240" y="255" text-anchor="middle"
    font-family="Instrument Serif, Georgia, serif" font-style="italic"
    font-size="18" fill="currentColor">diffusion IA</text>
</svg>
<style>
  .contenu-geo-map {
    display: block;
    width: 100%;
    max-width: 560px;
    margin-inline: auto;
    color: var(--ink, #0c0b09);
  }
  .contenu-geo-map-compact { max-width: 480px; }
</style>
