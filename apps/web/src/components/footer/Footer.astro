---
// Footer · 5 colonnes éditoriales · pur Astro (pas d'interactivité)
import { FOOTER_COLS, TRUST_BADGES } from '../../data/sitemap';
import { langFromPath, t } from '../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
// `year` est résolu au build (SSG). En cas de site non rebuilt en début d'année,
// le copyright reste figé. Atténuation : Vercel cron annuel ou simplement push
// d'un commit start-of-year. À défaut, accepter le glissement (faible criticité).
const year = new Date().getFullYear();
---
<footer class="ft" aria-labelledby="ft-heading">
  <h2 id="ft-heading" class="sr-only">
    {lang === 'fr' ? 'Pied de page' : 'Footer'}
  </h2>

  {/* Top — wordmark vibration · hover anime le dot pour ressentir l'identité */}
  <div class="wrap" style="padding-top:clamp(80px,10vw,160px);padding-bottom:clamp(40px,5vw,80px)">
    <div class="ft-wordmark" style="font-family:var(--font-display);font-size:clamp(60px,12vw,200px);line-height:.88;letter-spacing:-0.03em;font-weight:400;color:var(--ink)">
      Waim<i>i</i>a<span class="dot">.</span>
    </div>
    <p style="font-family:var(--font-display);font-style:italic;font-size:clamp(20px,2vw,28px);color:var(--muted);max-width:640px;margin-top:clamp(16px,2vw,32px);line-height:1.4;text-wrap:balance">
      {lang === 'fr'
        ? 'Systèmes IA pour PME et ETI. Acquisition. Opérations. Pilotage. Paris · Genève.'
        : 'AI systems for SMBs. Acquisition. Operations. Intelligence. Paris · Geneva.'}
    </p>
  </div>

  {/* Trust badges row */}
  <div class="wrap" style="padding-bottom:clamp(40px,4vw,60px)">
    <div class="trust-row">
      {TRUST_BADGES.map((b) => (
        <span class={`trust-pill ${b.kind}`}>
          <span class="dot"></span>
          {t(b.label, lang)}
        </span>
      ))}
    </div>
  </div>

  {/* Tier 1 — 5 colonnes */}
  <div class="wrap hline" style="padding-top:clamp(40px,4vw,60px);padding-bottom:clamp(60px,6vw,100px)">
    <div class="ft-tier1-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(24px,3vw,48px)">
      {FOOTER_COLS.map((col) => (
        <div>
          <h3 style="font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);margin-bottom:18px;font-weight:500">
            {t(col.heading, lang)}
          </h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
            {col.items.map((it) => (
              <li>
                <a href={it.href} style="font-size:13.5px;color:var(--ink-2);transition:color 220ms var(--ease);display:inline-block;line-height:1.4" class="ft-link">
                  {t(it.label, lang)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  {/* ──── DEV-INDEX · visible en prod ET dev (Simon le préfère pour validation
       visuelle continue). Trade-off SEO/AIO accepté : signal "site en chantier"
       côté crawlers. À retirer/déplacer vers /agence/sitemap dédiée plus tard
       quand le contenu sera figé. */}
  <div class="wrap hline ft-devindex" style="padding-top:clamp(40px,4vw,60px);padding-bottom:clamp(40px,4vw,60px)">
    <div class="ft-dev-hd">
      <span class="ft-dev-tag">⌘ DEV INDEX</span>
      <span class="ft-dev-meta">{lang === 'fr' ? 'Navigation complète · 8 templates · 25+ pages' : 'Full navigation · 8 templates · 25+ pages'}</span>
    </div>

    {/* Section A · Templates et leur exemple live */}
    <div class="ft-dev-block">
      <h4 class="ft-dev-h4">{lang === 'fr' ? 'A · Templates → page exemple' : 'A · Templates → live example'}</h4>
      <ol class="ft-dev-list">
        <li><span class="ft-dev-num">01</span><span class="ft-dev-name">HubTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Pillar page (hub d\'offres)' : 'Pillar page'}</span><a href="/offres/conseil" class="ft-link">/offres/conseil ↗</a></li>
        <li><span class="ft-dev-num">02</span><span class="ft-dev-name">HubTemplate · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Pillar produit' : 'Product pillar'}</span><a href="/technologies/virtuoseos" class="ft-link">/technologies/virtuoseos ↗</a></li>
        <li><span class="ft-dev-num">03</span><span class="ft-dev-name">ServiceDetailTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Service détaillé' : 'Service detail'}</span><a href="/offres/revops" class="ft-link">/offres/revops ↗</a></li>
        <li><span class="ft-dev-num">04</span><span class="ft-dev-name">ServiceDetail · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Solution industry' : 'Industry solution'}</span><a href="/solutions/fintech" class="ft-link">/solutions/fintech ↗</a></li>
        <li><span class="ft-dev-num">05</span><span class="ft-dev-name">DetailMenuTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Sous-page mega-menu' : 'Mega-menu detail'}</span><a href="/offres/audit-maturite-ia" class="ft-link">/offres/audit-maturite-ia ↗</a></li>
        <li><span class="ft-dev-num">06</span><span class="ft-dev-name">CaseStudyTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Cas client long-form' : 'Case study'}</span><a href="/ressources/cas/plateau" class="ft-link">/ressources/cas/plateau ↗</a></li>
        <li><span class="ft-dev-num">07</span><span class="ft-dev-name">EssayTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Essai éditorial' : 'Editorial essay'}</span><a href="/ressources/blog/brain-circuit" class="ft-link">/ressources/blog/brain-circuit ↗</a></li>
        <li><span class="ft-dev-num">08</span><span class="ft-dev-name">ListIndexTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Index cas (cards)' : 'Cases index (cards)'}</span><a href="/ressources/cas" class="ft-link">/ressources/cas ↗</a></li>
        <li><span class="ft-dev-num">09</span><span class="ft-dev-name">ListIndex · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Blog (rows)' : 'Blog (rows)'}</span><a href="/ressources/blog" class="ft-link">/ressources/blog ↗</a></li>
        <li><span class="ft-dev-num">10</span><span class="ft-dev-name">ListIndex · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Cookbooks (cards)' : 'Cookbooks (cards)'}</span><a href="/ressources/cookbooks" class="ft-link">/ressources/cookbooks ↗</a></li>
        <li><span class="ft-dev-num">11</span><span class="ft-dev-name">ListIndex · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Changelog (timeline)' : 'Changelog (timeline)'}</span><a href="/ressources/changelog" class="ft-link">/ressources/changelog ↗</a></li>
        <li><span class="ft-dev-num">12</span><span class="ft-dev-name">TrustLegalTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Compliance & légal' : 'Compliance & legal'}</span><a href="/agence/trust-center" class="ft-link">/agence/trust-center ↗</a></li>
        <li><span class="ft-dev-num">13</span><span class="ft-dev-name">TrustLegal · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Gouvernance interne' : 'Internal governance'}</span><a href="/agence/governance" class="ft-link">/agence/governance ↗</a></li>
        <li><span class="ft-dev-num">14</span><span class="ft-dev-name">TrustLegal · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Documentation tech' : 'Tech documentation'}</span><a href="/agence/docs" class="ft-link">/agence/docs ↗</a></li>
        <li><span class="ft-dev-num">15</span><span class="ft-dev-name">UtilityTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Contact (centered+form)' : 'Contact (centered+form)'}</span><a href="/contact" class="ft-link">/contact ↗</a></li>
        <li><span class="ft-dev-num">16</span><span class="ft-dev-name">Utility · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'À propos (left+story)' : 'About (left+story)'}</span><a href="/agence/about" class="ft-link">/agence/about ↗</a></li>
        <li><span class="ft-dev-num">17</span><span class="ft-dev-name">Utility · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Carrières (left+jobs)' : 'Careers (left+jobs)'}</span><a href="/agence/careers" class="ft-link">/agence/careers ↗</a></li>
        <li><span class="ft-dev-num">18</span><span class="ft-dev-name">Utility · variant</span><span class="ft-dev-type">{lang === 'fr' ? 'Diagnostic (form 12Q)' : 'Diagnostic (12Q form)'}</span><a href="/ressources/academy" class="ft-link">/ressources/academy ↗</a></li>
      </ol>
    </div>

    {/* Section B · Pages static (sans template) */}
    <div class="ft-dev-block">
      <h4 class="ft-dev-h4">{lang === 'fr' ? 'B · Pages static (sans template, justifiées)' : 'B · Static pages (no template, justified)'}</h4>
      <ol class="ft-dev-list">
        <li><span class="ft-dev-num">19</span><span class="ft-dev-name">404.astro</span><span class="ft-dev-type">{lang === 'fr' ? 'UX 4xx (1 instance/site)' : '4xx UX (1 instance/site)'}</span><a href="/404" class="ft-link">/404 ↗</a></li>
        <li><span class="ft-dev-num">20</span><span class="ft-dev-name">design-system.astro</span><span class="ft-dev-type">{lang === 'fr' ? 'Showcase atomes/molécules' : 'Atoms/molecules showcase'}</span><a href="/agence/design-system" class="ft-link">/agence/design-system ↗</a></li>
      </ol>
    </div>

    {/* Section C · Pages homepage variants (Direction A/B/C/Atlas) */}
    <div class="ft-dev-block">
      <h4 class="ft-dev-h4">{lang === 'fr' ? 'C · Variantes homepage (4 directions)' : 'C · Homepage variants (4 directions)'}</h4>
      <ol class="ft-dev-list">
        <li><span class="ft-dev-num">21</span><span class="ft-dev-name">Direction A · Apparatus</span><span class="ft-dev-type">{lang === 'fr' ? 'Manifeste 5 actes (home)' : 'Manifesto 5 acts (home)'}</span><a href="/" class="ft-link">/ ↗</a></li>
        <li><span class="ft-dev-num">22</span><span class="ft-dev-name">Direction B · Manifesto</span><span class="ft-dev-type">{lang === 'fr' ? 'LiquidHero canvas + asym' : 'LiquidHero canvas + asym'}</span><a href="/manifesto" class="ft-link">/manifesto ↗</a></li>
        <li><span class="ft-dev-num">23</span><span class="ft-dev-name">Direction C · Console</span><span class="ft-dev-type">{lang === 'fr' ? 'Terminal + ProductReel' : 'Terminal + ProductReel'}</span><a href="/console" class="ft-link">/console ↗</a></li>
        <li><span class="ft-dev-num">24</span><span class="ft-dev-name">✦ Atlas</span><span class="ft-dev-type">{lang === 'fr' ? 'Cartographie 4 piliers' : '4 pillars cartography'}</span><a href="/atlas" class="ft-link">/atlas ↗</a></li>
      </ol>
    </div>

    {/* Section D · Hub landings (composition d'organismes, sans template) */}
    <div class="ft-dev-block">
      <h4 class="ft-dev-h4">{lang === 'fr' ? 'D · Hub landings (composition d\'organismes)' : 'D · Hub landings (organism composition)'}</h4>
      <p class="ft-dev-stub-lead">
        {lang === 'fr'
          ? "Ces 4 hubs sont des compositions directes d'organismes existants (Hero · Pyramid · Departments · TrustMarquee · Cases · WritingNotes · CtaBand) — pas de template intermédiaire (rigidifierait inutilement, chaque hub est unique)."
          : 'These 4 hubs are direct compositions of existing organisms (Hero · Pyramid · Departments · TrustMarquee · Cases · WritingNotes · CtaBand) — no intermediate template (would rigidify unnecessarily, each hub is unique).'}
      </p>
      <ol class="ft-dev-list">
        <li><span class="ft-dev-num">25</span><span class="ft-dev-name">/offres</span><span class="ft-dev-type">{lang === 'fr' ? 'Hero + Pyramid + Fit + CTA' : 'Hero + Pyramid + Fit + CTA'}</span><a href="/offres" class="ft-link">/offres ↗</a></li>
        <li><span class="ft-dev-num">26</span><span class="ft-dev-name">/solutions</span><span class="ft-dev-type">{lang === 'fr' ? 'Hero + Departments + Cases + Industry' : 'Hero + Departments + Cases + Industry'}</span><a href="/solutions" class="ft-link">/solutions ↗</a></li>
        <li><span class="ft-dev-num">27</span><span class="ft-dev-name">/technologies</span><span class="ft-dev-type">{lang === 'fr' ? 'Hero + TrustMarquee + 3 layers + Frameworks' : 'Hero + TrustMarquee + 3 layers + Frameworks'}</span><a href="/technologies" class="ft-link">/technologies ↗</a></li>
        <li><span class="ft-dev-num">28</span><span class="ft-dev-name">/ressources</span><span class="ft-dev-type">{lang === 'fr' ? 'Hero + Tools + Cases + Blog + Cookbooks + NL' : 'Hero + Tools + Cases + Blog + Cookbooks + NL'}</span><a href="/ressources" class="ft-link">/ressources ↗</a></li>
      </ol>
    </div>

    {/* Section F · Templates + pages conversion (NEW · Phase A-E) */}
    <div class="ft-dev-block">
      <h4 class="ft-dev-h4">{lang === 'fr' ? 'F · Conversion + Resend + Cal (NEW)' : 'F · Conversion + Resend + Cal (NEW)'}</h4>
      <p class="ft-dev-stub-lead">
        {lang === 'fr'
          ? "Tunnel offre flagship, lead magnets, welcome pages, API routes Resend et Cal.com embed. Toute l'infra conversion d'agence web/IA."
          : 'Flagship offer funnel, lead magnets, welcome pages, Resend API routes and Cal.com embed. Full conversion infra for web/AI agency.'}
      </p>
      <ol class="ft-dev-list">
        <li><span class="ft-dev-num">29</span><span class="ft-dev-name">ConversionFunnelTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Tunnel offre flagship · 8 sections' : 'Flagship funnel · 8 sections'}</span><a href="/offres/site-web-ia" class="ft-link">/offres/site-web-ia ↗</a></li>
        <li><span class="ft-dev-num">30</span><span class="ft-dev-name">LeadMagnetTemplate</span><span class="ft-dev-type">{lang === 'fr' ? 'Download gated · form + ToC' : 'Gated download · form + ToC'}</span><a href="/ressources/livres-blancs/ai-act-readiness" class="ft-link">/livres-blancs/ai-act ↗</a></li>
        <li><span class="ft-dev-num">31</span><span class="ft-dev-name">WelcomeTemplate · newsletter</span><span class="ft-dev-type">{lang === 'fr' ? 'Post-signup confirmation' : 'Post-signup confirmation'}</span><a href="/bienvenue/newsletter" class="ft-link">/bienvenue/newsletter ↗</a></li>
        <li><span class="ft-dev-num">32</span><span class="ft-dev-name">WelcomeTemplate · livre blanc</span><span class="ft-dev-type">{lang === 'fr' ? 'Post-download confirmation' : 'Post-download confirmation'}</span><a href="/bienvenue/livre-blanc" class="ft-link">/bienvenue/livre-blanc ↗</a></li>
        <li><span class="ft-dev-num">33</span><span class="ft-dev-name">WelcomeTemplate · audit</span><span class="ft-dev-type">{lang === 'fr' ? 'Post-RDV booké confirmation' : 'Post-booking confirmation'}</span><a href="/bienvenue/audit" class="ft-link">/bienvenue/audit ↗</a></li>
        <li><span class="ft-dev-num">34</span><span class="ft-dev-name">CalEmbed (molecule)</span><span class="ft-dev-type">{lang === 'fr' ? 'Cal.com inline · /contact' : 'Cal.com inline · /contact'}</span><a href="/contact" class="ft-link">/contact (embed) ↗</a></li>
        <li><span class="ft-dev-num">35</span><span class="ft-dev-name">PricingTier (molecule)</span><span class="ft-dev-type">{lang === 'fr' ? '3 tiers pricing dans funnel' : '3-tier pricing in funnel'}</span><a href="/offres/site-web-ia#pricing" class="ft-link">site-web-ia#pricing ↗</a></li>
      </ol>
    </div>

    {/* Section G · API routes Resend + Email templates */}
    <div class="ft-dev-block">
      <h4 class="ft-dev-h4">{lang === 'fr' ? 'G · API routes (POST · SSR Vercel)' : 'G · API routes (POST · Vercel SSR)'}</h4>
      <p class="ft-dev-stub-lead">
