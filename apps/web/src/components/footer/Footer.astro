          : '5 Astro SSR endpoints connected to Resend (email sending + Automations tags). 6 React Email templates in src/lib/emails/.'}
      </p>
      <ol class="ft-dev-list">
        <li><span class="ft-dev-num">36</span><span class="ft-dev-name">POST /api/contact</span><span class="ft-dev-type">{lang === 'fr' ? 'Form contact → 2 emails (client+équipe)' : 'Contact form → 2 emails (client+team)'}</span><span class="ft-dev-more">SSR · prerender:false</span></li>
        <li><span class="ft-dev-num">37</span><span class="ft-dev-name">POST /api/newsletter</span><span class="ft-dev-type">{lang === 'fr' ? 'Newsletter signup → welcome' : 'Newsletter signup → welcome'}</span><span class="ft-dev-more">SSR</span></li>
        <li><span class="ft-dev-num">38</span><span class="ft-dev-name">POST /api/lead-magnet</span><span class="ft-dev-type">{lang === 'fr' ? 'Download → PDF + nurturing' : 'Download → PDF + nurturing'}</span><span class="ft-dev-more">SSR</span></li>
        <li><span class="ft-dev-num">39</span><span class="ft-dev-name">POST /api/academy</span><span class="ft-dev-type">{lang === 'fr' ? 'Diagnostic 12Q → scorecard' : 'Diagnostic 12Q → scorecard'}</span><span class="ft-dev-more">SSR</span></li>
