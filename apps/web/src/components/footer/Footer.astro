          <ul>
            <li><a href="/solutions/finance" class="ft-link">finance</a></li>
            <li><a href="/solutions/sante" class="ft-link">sante</a></li>
            <li><a href="/solutions/ventes-marketing" class="ft-link">ventes-marketing</a></li>
            <li><a href="/solutions/it-engineering" class="ft-link">it-engineering</a></li>
            <li><span class="ft-dev-more">+ 8 autres</span></li>
          </ul>
        </div>
        <div>
          <span class="ft-dev-stub-cat">{lang === 'fr' ? 'Sous-pages /technologies' : '/technologies sub-pages'}</span>
          <ul>
            <li><a href="/technologies/claude-models" class="ft-link">claude-models</a></li>
            <li><a href="/technologies/claude-code" class="ft-link">claude-code</a></li>
            <li><a href="/technologies/mcp-connectors" class="ft-link">(via offres)</a></li>
            <li><a href="/technologies/rag-prive" class="ft-link">rag-prive</a></li>
            <li><span class="ft-dev-more">+ 7 autres</span></li>
