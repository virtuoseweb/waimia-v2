---
/* Waimia · KeyMetric
   Métrique chiffrée magnifiée typographiquement (style FT/Bloomberg).
   Asymétrie volontaire : chiffre dominant + label petit + delta optionnel.
   Usage :
     <KeyMetric value="×2,4" label="leads qualifiés" delta="+62 %" />
     <KeyMetric value="€840K" label="pipeline 12 mois" size="hero" />
*/

interface Props {
  value: string;
  label: string;
  delta?: string;
  trend?: 'up' | 'down' | 'flat';
  size?: 'sm' | 'md' | 'lg' | 'hero';
  align?: 'left' | 'center' | 'right';
  variant?: 'default' | 'inverted' | 'accent';
}

const {
  value,
  label,
  delta,
  trend,
  size = 'md',
  align = 'left',
  variant = 'default'
} = Astro.props;
---

<div class:list={["key-metric", `key-metric-${size}`, `key-metric-${align}`, `key-metric-${variant}`, "reveal-zoom-in"]}>
  <span class="key-metric-value">{value}</span>
  <span class="key-metric-label">{label}</span>
  {delta && (
    <span class={`key-metric-delta key-metric-delta-${trend ?? 'flat'}`}>
      {delta}
    </span>
  )}
</div>

<style>
  .key-metric {
    display: grid;
    grid-template-rows: auto auto auto;
    gap: var(--space-2, 8px);
    padding: var(--space-4, 16px) 0;
  }
  .key-metric-value {
    font-family: var(--font-display, 'Instrument Serif', serif);
    line-height: 0.92;
    letter-spacing: var(--tracking-display, -0.025em);
    color: var(--ink, #0C0B09);
    font-weight: 400;
    font-size: clamp(48px, 5vw, 72px);
  }
  .key-metric-sm .key-metric-value { font-size: clamp(32px, 3.4vw, 48px); }
  .key-metric-lg .key-metric-value { font-size: clamp(64px, 7vw, 96px); }
  .key-metric-hero .key-metric-value {
    font-size: clamp(96px, 12vw, 180px);
    font-style: italic;
  }
  .key-metric-label {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-mono-md, 11px);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono, 0.12em);
    color: var(--muted, #6B6560);
    line-height: 1.3;
    max-width: 180px;
  }
  .key-metric-hero .key-metric-label { font-size: 13px; max-width: 240px; }
  .key-metric-delta {
    font-family: var(--font-mono, 'JetBrains Mono', monospace);
    font-size: var(--text-mono-lg, 13px);
    color: var(--accent, #C94F2E);
    align-self: start;
  }
  .key-metric-delta-up::before    { content: '\2191 '; }
  .key-metric-delta-down::before  { content: '\2193 '; color: var(--accent, #C94F2E); }
  .key-metric-delta-flat::before  { content: '\2192 '; color: var(--muted, #6B6560); }
  .key-metric-center { text-align: center; }
  .key-metric-center .key-metric-label { margin-inline: auto; }
  .key-metric-right { text-align: right; }
  .key-metric-right .key-metric-label { margin-left: auto; }
  .key-metric-inverted {
    color: var(--paper, #F6F1E8);
    background: var(--ink, #0C0B09);
    padding: var(--space-5, 24px) var(--space-6, 32px);
  }
  .key-metric-inverted .key-metric-value { color: var(--paper, #F6F1E8); }
  .key-metric-inverted .key-metric-label { color: var(--muted-2, rgba(246,241,232,0.5)); }
  .key-metric-accent .key-metric-value { color: var(--accent, #C94F2E); }
</style>
