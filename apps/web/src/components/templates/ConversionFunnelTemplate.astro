---
// Template · ConversionFunnelTemplate · tunnel offre flagship
//
// Mapping :
//  - /offres/site-web-ia (offre site web IA-native + agent éditeur GEO · principale)
//  - Futurs flagships (poc-mvp-sprint, agents-sur-mesure...)
//
// Squelette · 8 sections : Hero magnétique + Demo + Features + Pricing + Cas (proof)
// + FAQ (GEO/AIO) + Form devis intégré + Trust bar.
//
// Composé de · Kicker · Button · PricingTier · RelatedCards · TechPillRow
// + briques éditoriales Callout · KeyMetric · Timeline · PullQuote · Dingbat.

import Base from '../../layouts/Base.astro';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import Button from '../ui/atoms/Button.astro';
import { langFromPath } from '../../lib/i18n';
import PricingTier from '../ui/molecules/PricingTier.astro';
import TechPillRow from '../ui/molecules/TechPillRow.astro';
import RelatedCards from '../ui/molecules/RelatedCards.astro';
import Callout from '../editorial/Callout.astro';
import KeyMetric from '../editorial/KeyMetric.astro';
import Timeline from '../editorial/Timeline.astro';
import PullQuote from '../editorial/PullQuote.astro';
import Dingbat from '../editorial/Dingbat.astro';

interface Stat { k: string; label_fr: string; label_en: string; }
interface Step { sn: string; kicker_fr: string; kicker_en: string; title_fr: string; title_en: string; body_fr: string; body_en: string; }
interface Tier {
  idx: string; tier: string; highlight?: boolean;
  price: string; period?: string;
  desc_fr: string; desc_en: string;
  features: string[];
  ctaLabel: string; ctaHref: string;
}
interface FaqItem { q: string; a: string; }
interface Pill { label: string; kind?: 'primary' | 'open' | 'neutral'; }
interface Metric { k: string; label_fr: string; label_en: string; }
interface RelatedCard { kicker: string; title_fr: string; title_en: string; lead_fr: string; lead_en: string; href: string; }

interface Props {
  title: string;
  description: string;
  /** Numéro éditorial (Funnel 01, Flagship 02…) */
  funnelNum: string;
  /** Stats hero (4 chiffres clés) */
  heroStats: Stat[];
  /** Process steps (4 étapes) */
  steps: Step[];
  /** Pricing tiers (3 typiquement) */
  tiers: Tier[];
  /** Tech pills */
  techPills: Pill[];
  /** Proof band */
  proofQuoteFr: string; proofQuoteEn: string;
  proofAttrFr: string; proofAttrEn: string;
  proofMetrics: Metric[];
  /** FAQ pour GEO/AIO indexation */
  faq: FaqItem[];
  /** Related cards (3 cas/services connexes) */
  relatedCards: RelatedCard[];
  /** Slug pour l'API devis */
  slug: string;
  /** CTA hero principal (défaut historique : tarifs) */
  heroPrimaryHref?: string;
  /** CTA hero secondaire (défaut historique : démo) */
  heroSecondaryHref?: string;
  /** CTA fixe optionnel pour les offres signature */
  stickyCtaHref?: string;
  stickyCtaLabel?: string;
  stickyCtaMeta?: string;
}
const {
  title, description, funnelNum, heroStats, steps, tiers, techPills,
  proofQuoteFr, proofAttrFr, proofMetrics,
  faq, relatedCards, slug,
  heroPrimaryHref = '#pricing',
  heroSecondaryHref = '#demo',
  stickyCtaHref,
  stickyCtaLabel = 'Réserver un audit 45 min',
  stickyCtaMeta = 'Audit 45 min · diagnostic conversion',
} = Astro.props as Props;

const phaseMetas = ['Acquisition', 'Conversion', 'Activation', 'Optimisation', 'Transmission'];
const timelineEvents = steps.map((step, idx) => ({
  num: step.sn,
  title: step.title_fr,
  meta: `${phaseMetas[idx] ?? step.kicker_fr} · ${step.kicker_fr}`,
  body: step.body_fr,
  variant: idx === 1 ? 'highlight' as const : 'default' as const,
}));

const beforeAfter = [
  {
    before: 'Un site vitrine dépendant du CMS, lent à modifier et rarement aligné avec les nouvelles requêtes Google ou LLM.',
    after: 'Un site Astro édité par agent, versionné dans Git, pré-rendu et prêt pour les recherches IA dès la livraison.',
  },
  {
    before: 'Des arbitrages contenu dispersés entre marketing, agence, plugins et développeurs.',
    after: 'Un flux court : vous demandez, l’agent édite, l’équipe valide, le changement part en production.',
  },
  {
    before: 'Une refonte qui s’arrête au go-live, puis se dégrade au fil des campagnes.',
    after: 'Une routine GEO mensuelle qui enrichit les pages selon les signaux commerciaux et les nouvelles questions prospects.',
  },
];

// JSON-LD FAQPage pour AIO
const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const lang = langFromPath(Astro.url.pathname);
const offresHref = lang === 'fr' ? '/offres' : '/en/offres';
const homeHref = lang === 'fr' ? '/' : '/en';

// JSON-LD Service + Offer (GEO/AIO indexable par crawlers IA)
const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: title.split(' · ')[0],
  description,
  provider: { '@id': 'https://waimia.com/#organization' },
  areaServed: ['FR', 'CH', 'BE', 'LU'],
  serviceType: 'AI Integration',
};

const offerLd = {
  '@context': 'https://schema.org',
  '@type': 'Offer',
  name: title.split(' · ')[0],
  priceCurrency: 'EUR',
  availability: 'https://schema.org/InStock',
  url: 'https://waimia.com' + Astro.url.pathname,
};
---
<Base title={title} description={description} jsonLd={[faqLd, serviceLd, offerLd]}>
  <Breadcrumb
    lang={lang}
    items={[
      { label: lang === 'fr' ? 'Accueil' : 'Home', href: homeHref },
      { label: lang === 'fr' ? 'Offres' : 'Services', href: offresHref },
      { label: title.split(' · ')[0] },
    ]}
  />
  {/* HERO MAGNÉTIQUE */}
  <section class="cf-hero">
    <div class="wrap-wide">
      <Kicker tone="accent" class="cf-num reveal">§ Flagship {funnelNum}</Kicker>
      <h1 class="cf-h1 reveal-mask-up"><slot name="headline" /></h1>
      <p class="cf-lede reveal"><slot name="lede" /></p>
      <div class="cf-hero-meta reveal-stagger" aria-label="Repères de l'offre">
        <span>Offre signature</span>
        <span>Acquisition → conversion → activation</span>
        <span>Agent éditeur inclus</span>
      </div>
      {Astro.slots.has('hero-benefits') && (
        <div class="cf-hero-benefits reveal">
          <slot name="hero-benefits" />
        </div>
      )}
      {Astro.slots.has('hero-proof') && (
        <p class="cf-hero-proof reveal">
          <slot name="hero-proof" />
        </p>
      )}
      <div class="cf-hero-cta">
        <Button href={heroPrimaryHref} variant="primary" size="lg" mag={0.18}>
          <slot name="cta-primary">Voir les tarifs ↓</slot>
        </Button>
        <Button href={heroSecondaryHref} variant="ghost" size="lg">
          <slot name="cta-secondary">Voir la démo</slot>
        </Button>
      </div>
      <div class="cf-hero-stats reveal-stagger">
        {heroStats.map((stat, idx) => (
          <KeyMetric
            value={stat.k}
            label={stat.label_fr}
            size={idx === 0 ? 'lg' : 'md'}
            variant={idx === 0 ? 'accent' : 'default'}
          />
        ))}
      </div>
    </div>
  </section>

  {/* DEMO · slot ouvert pour mockup interactif */}
  <section id="demo" class="cf-demo">
    <div class="wrap-wide">
      <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.1 · La démo</Kicker>
      <h2 class="cf-section-h2"><slot name="demo-headline" /></h2>
      <p class="cf-section-lead"><slot name="demo-lede" /></p>
      <div class="cf-demo-mockup">
        <slot name="demo-mockup" />
      </div>
      <Callout variant="manifesto" size="lg">
        Le site n’est plus un support figé. C’est une surface commerciale vivante, éditée par agents, validée par vos équipes, mesurée sur les leads.
      </Callout>
    </div>
  </section>

  {/* FEATURES · process steps */}
  <section class="cf-features">
    <div class="wrap-wide cf-split">
      <div class="cf-col-prose">
        <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.2 · Comment ça marche</Kicker>
        <h2 class="cf-section-h2"><slot name="features-headline" /></h2>
        <Callout variant="info">
          La phase active est la conversion : elle transforme le diagnostic d’acquisition en pages, preuves, formulaires et routines mesurables.
        </Callout>
      </div>
      <div class="cf-col-aside reveal-stagger">
        <Timeline events={timelineEvents} orientation="vertical" numbered={true} />
      </div>
    </div>
  </section>

  {/* PRICING · 3 tiers PricingTier molecule */}
  <section id="pricing" class="cf-pricing">
    <div class="wrap-wide">
      <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.3 · Tarifs indicatifs</Kicker>
      <h2 class="cf-section-h2"><slot name="pricing-headline" /></h2>
      <p class="cf-pricing-aside">
        <slot name="pricing-aside">
          Devis exact après audit gratuit de 10 jours. Pas de frais cachés. TVA non incluse.
        </slot>
      </p>
      <div class="cf-tiers" style={`--cols:${tiers.length}`}>
        {tiers.map((t) => (
          <PricingTier
            idx={t.idx} tier={t.tier} highlight={t.highlight}
            price={t.price} period={t.period}
            desc_fr={t.desc_fr} desc_en={t.desc_en}
            features={t.features}
            ctaLabel={t.ctaLabel} ctaHref={t.ctaHref}
          />
        ))}
      </div>
    </div>
  </section>

  {/* PROOF */}
  <section class="cf-proof">
    <div class="wrap-wide cf-proof-grid">
      <div class="cf-proof-copy reveal">
        <Kicker tone="accent" class="cf-section-k">§ Preuve · ROI</Kicker>
        <PullQuote attribution={proofAttrFr} variant="inline">
          {proofQuoteFr}
        </PullQuote>
      </div>
      <div class="cf-proof-metrics reveal-stagger">
        {proofMetrics.map((metric, idx) => (
          <KeyMetric
            value={metric.k}
            label={metric.label_fr}
            size={idx === 0 ? 'lg' : 'md'}
            variant={idx === 0 ? 'accent' : 'default'}
          />
        ))}
      </div>
    </div>
  </section>

  {/* TECH STACK */}
  <section class="cf-stack">
    <div class="wrap-wide cf-split">
      <div class="cf-col-prose">
        <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.4 · La stack</Kicker>
        <h2 class="cf-section-h2"><slot name="stack-headline" /></h2>
        <p class="cf-stack-lead"><slot name="stack-lead" /></p>
      </div>
      <aside class="cf-col-aside">
        <Callout variant="info" size="sm">
          Livraison SSR, HTML indexable, schémas JSON-LD, <code>llms.txt</code>, formulaires connectés et code propriétaire livré sur votre dépôt.
        </Callout>
        <TechPillRow pills={techPills} />
      </aside>
    </div>
  </section>

  {/* COMPARAISON */}
  <section class="cf-before-after">
    <div class="wrap-wide cf-split reveal-stagger">
      <div class="cf-col-prose">
        <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.5 · Avant / après</Kicker>
        <h2 class="cf-section-h2">Ce qui change <i>vraiment</i>.</h2>
        <p class="cf-section-lead">
          La refonte ne se limite pas à un meilleur site. Elle remplace une chaîne marketing lente par un système éditorial pilotable.
        </p>
      </div>
      <div class="cf-col-aside cf-compare-list">
        {beforeAfter.map((row) => (
          <article class="cf-compare-row">
            <div>
              <span>Avant</span>
              <p>{row.before}</p>
            </div>
            <div>
              <span>Après</span>
              <p>{row.after}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* FAQ · indexable AIO via JSON-LD */}
  <section class="cf-faq">
    <div class="wrap-wide">
      <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.6 · Questions courantes</Kicker>
      <h2 class="cf-section-h2"><slot name="faq-headline" /></h2>
      <ol class="cf-faq-list reveal-stagger">
        {faq.map((item) => (
          <li class="cf-faq-item">
            <details>
              <summary>{item.q}</summary>
              <p>{item.a}</p>
            </details>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* FORM DEVIS INTÉGRÉ */}
  <section id="devis" class="cf-devis">
    <div class="wrap-wide cf-devis-grid">
      <div>
        <Kicker tone="accent" class="cf-section-k">§ {funnelNum}.7 · Demande de devis</Kicker>
        <h2 class="cf-section-h2"><slot name="devis-headline" /></h2>
        <PullQuote attribution="Waimia" variant="inline">
          Un bon site IA ne promet pas seulement plus de trafic. Il raccourcit le chemin entre une intention chaude et un brief qualifié.
        </PullQuote>
      </div>
      <form class="cf-form" method="post" action="/api/devis" name="devis">
        <input type="hidden" name="slug" value={slug} />
        <div class="cf-form-row">
          <label for="cf-company">Entreprise *</label>
          <input id="cf-company" name="company" type="text" required autocomplete="organization" />
        </div>
        <div class="cf-form-row">
          <label for="cf-email">Email pro *</label>
          <input id="cf-email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="cf-form-row">
          <label for="cf-budget">Budget visé</label>
          <select id="cf-budget" name="budget">
            <option value="starter">Starter (≤ 10 k€)</option>
            <option value="standard">Standard (10-25 k€)</option>
            <option value="custom">Custom (sur devis)</option>
          </select>
        </div>
        <div class="cf-form-row cf-form-full">
          <label for="cf-brief">Brief en 3 phrases *</label>
          <textarea id="cf-brief" name="brief" rows="4" required></textarea>
        </div>
        <Button as="button" type="submit" variant="primary" size="lg" mag={0.18}>
          Envoyer le brief →
        </Button>
      </form>
    </div>
  </section>

  {/* RELATED · cas/services connexes */}
  <section class="cf-related">
    <div class="wrap-wide">
      <Dingbat variant="section" />
      <Kicker class="cf-related-k">§ {funnelNum}.8 · Connexes</Kicker>
      <RelatedCards cards={relatedCards} />
    </div>
  </section>

  {stickyCtaHref && (
    <aside class="cf-sticky-cta" aria-label="Action principale">
      <span class="cf-sticky-copy">{stickyCtaMeta}</span>
      <a class="cf-sticky-link" href={stickyCtaHref}>{stickyCtaLabel}</a>
    </aside>
  )}
</Base>

<style>
  .cf-hero { padding: 140px 32px clamp(60px, 8vw, 100px); }
  :global(.cf-num) { display: block; margin-bottom: 20px; }
  .cf-h1 {
    font-family: var(--font-display);
    font-size: clamp(64px, 12vw, 200px);
    line-height: 0.88;
    letter-spacing: 0;
    text-wrap: balance;
    font-weight: 400;
    margin: 0 0 32px;
  }
  .cf-h1 :global(i) { font-style: italic; color: var(--accent); }
  .cf-lede {
    font-family: var(--font-sans);
    font-size: clamp(20px, 2.4vw, 30px);
    line-height: 1.3;
    margin: 0 0 36px;
    max-width: 980px;
    color: var(--muted);
    text-wrap: balance;
  }
  .cf-hero-meta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin: 0 0 32px;
  }
  .cf-hero-meta span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--hairline-strong);
    border-radius: 999px;
    padding: 7px 11px;
    background: color-mix(in srgb, var(--paper) 86%, transparent);
  }
  .cf-hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 60px; }
  .cf-hero-benefits {
    max-width: 920px;
    margin: 0 0 24px;
  }
  .cf-hero-benefits :global(ul) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px clamp(18px, 3vw, 34px);
  }
  .cf-hero-benefits :global(li) {
    position: relative;
    padding-left: 18px;
    font-family: var(--font-display);
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.42;
    color: var(--ink);
  }
  .cf-hero-benefits :global(li)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.7em;
    width: 7px;
    height: 7px;
    border-top: 1px solid var(--ink-2);
    border-right: 1px solid var(--ink-2);
    transform: rotate(45deg);
  }
  .cf-hero-proof {
    margin: 0 0 28px;
    max-width: 760px;
    padding-top: 16px;
    border-top: 1px solid var(--hairline);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    line-height: 1.5;
  }
  .cf-hero-stats {
    margin-top: 60px;
    display: grid;
    grid-template-columns: 1.25fr repeat(3, 1fr);
    gap: clamp(20px, 4vw, 56px);
    border-top: 1px solid var(--hairline);
    padding-top: 28px;
  }

  .cf-demo,
  .cf-features,
  .cf-pricing,
  .cf-proof,
  .cf-stack,
  .cf-before-after,
  .cf-faq,
  .cf-devis,
  .cf-related { padding: var(--section-base, clamp(80px, 10vw, 120px)) 32px; }
  .cf-demo,
  .cf-pricing,
  .cf-stack { background: var(--paper-2); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }

  :global(.cf-section-k) { display: block; margin-bottom: 16px; }
  .cf-section-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 88px);
    line-height: 0.96;
    letter-spacing: 0;
    margin: 0 0 24px;
    text-wrap: balance;
    font-weight: 400;
  }
  .cf-section-h2 :global(i) { font-style: italic; color: var(--accent); }
  .cf-section-lead,
  .cf-stack-lead {
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.8vw, 22px);
    color: var(--muted);
    max-width: 760px;
    margin: 0 0 clamp(40px, 5vw, 60px);
    line-height: 1.45;
  }

  .cf-demo-mockup {
    margin-top: clamp(40px, 5vw, 60px);
    border: 1px solid var(--hairline-strong);
    border-radius: 12px;
    overflow: hidden;
    background: var(--ink);
    color: var(--paper);
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .cf-split,
  .cf-proof-grid,
  .cf-devis-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.38fr);
    gap: clamp(36px, 7vw, 96px);
    align-items: start;
  }
  .cf-col-prose {
    max-width: 680px;
  }
  .cf-col-aside {
    min-width: 0;
  }
  .cf-proof-grid {
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 1fr);
  }
  .cf-proof-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(20px, 3vw, 40px);
    border-top: 1px solid var(--hairline);
    padding-top: 24px;
  }
  .cf-before-after {
    background: var(--paper);
  }
  .cf-compare-list {
    display: grid;
    gap: 18px;
  }
  .cf-compare-row {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    gap: clamp(16px, 3vw, 32px);
    padding: 24px 0;
    border-top: 1px solid var(--hairline);
  }
  .cf-compare-row:last-child {
    border-bottom: 1px solid var(--hairline);
  }
  .cf-compare-row span {
    display: block;
    margin-bottom: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .cf-compare-row p {
    margin: 0;
    color: var(--ink-2);
    font-size: 15.5px;
    line-height: 1.58;
  }

  .cf-pricing-aside {
    font-size: 14px;
    color: var(--muted);
    max-width: 640px;
    margin: 0 0 clamp(40px, 5vw, 60px);
    line-height: 1.5;
  }
  .cf-tiers {
    display: grid;
    grid-template-columns: repeat(var(--cols, 3), 1fr);
    gap: clamp(20px, 2.4vw, 32px);
  }

  .cf-faq-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
  }
  .cf-faq-item { border-bottom: 1px solid var(--hairline); }
  .cf-faq-item summary {
    cursor: pointer;
    padding: 24px 0;
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.3;
    letter-spacing: 0;
    text-wrap: balance;
    list-style: none;
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: baseline;
  }
  .cf-faq-item summary::after {
    content: '+';
    font-family: var(--font-mono);
    color: var(--ink);
    font-size: 22px;
    transition: transform 240ms var(--ease);
  }
  .cf-faq-item details[open] summary::after { transform: rotate(45deg); }
  .cf-faq-item p {
    font-size: 15.5px;
    line-height: 1.6;
    color: var(--muted);
    margin: 0 0 24px;
    max-width: 800px;
  }

  .cf-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
    max-width: 760px;
  }
  .cf-devis {
    background: var(--ink);
    color: var(--paper);
  }
  .cf-devis .cf-section-h2,
  .cf-devis :global(.pull-quote-body),
  .cf-devis :global(.pull-quote-attr) {
    color: var(--paper);
  }
  .cf-devis :global(.pull-quote-cite),
  .cf-devis :global(.cf-section-k) {
    color: color-mix(in srgb, var(--paper) 68%, transparent);
  }
  .cf-devis-grid {
