---
// Template · EssayTemplate · article éditorial long-form (essais, blog)
//
// Mapping handoff2 :
//  - essay-brain-circuit.html → /ressources/blog/brain-circuit
//  - changelog.html (variant)
//
// Squelette : Masthead minimaliste + lede + body slot (rich text) + Author footer
//             + Related cards + CTABand
//
// Décision : pas de spec bar (différencie d'un Case). Le squelette est plus simple
// et laisse 100 % du body en slot pour le HTML rich text (h2, h3, p, blockquote, code).

import Base from '../../layouts/Base.astro';
import Bi from '../ui/atoms/Bi.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import RelatedCards from '../ui/molecules/RelatedCards.astro';
import AuthorCard from '../ui/molecules/AuthorCard.astro';
import CtaBand from '../ui/organisms/CtaBand.astro';
import { buildArticle } from '../../lib/seo/schema-builder';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';
import TableOfContents from '../ui/molecules/TableOfContents.astro';
import ShareButtons from '../ui/molecules/ShareButtons.astro';
import RelatedByCluster from '../ui/molecules/RelatedByCluster.astro';
import TagPills from '../ui/molecules/TagPills.astro';

interface RelatedCard {
  kicker: string;
  title_fr: string;
  title_en: string;
  lead_fr: string;
  lead_en: string;
  href: string;
}
interface Props {
  title: string;
  description: string;
  /** Catégorie + numéro éditorial (Essay 03, Note 12) */
  kicker: string;
  /** Date publication ISO ou format libre */
  date: string;
  /** Auteur */
  author: string;
  /** Reading time approximé */
  readingTime?: string;
  /** Related cards (3 articles connexes) */
  relatedCards: RelatedCard[];
  /** Slug auteur pour AuthorCard dans le footer */
  authorSlug?: string;
  /** Sources bibliographiques (depuis frontmatter) */
  sources?: Array<{ name: string; url: string; type: string }>;
  /** Image absolue ou relative pour Article schema. */
  image?: string;
  /** Date ISO optionnelle quand la date affichée est localisée. */
  datePublished?: string;
  /** Date de mise à jour ISO optionnelle. */
  dateModified?: string;
  /** Canonical absolue optionnelle. */
  canonical?: string;
  /** Catégorie éditoriale FR/EN. */
  category?: string;
  /** Tags SEO/GEO. */
  tags?: string[];
  /** Breadcrumb custom (si absent, calcule automatiquement depuis kicker) */
  breadcrumbItems?: Array<{ label: string; href?: string }>;
  /** Lang pour breadcrumb */
  lang?: 'fr' | 'en';
  /** Cas clients liés (cross-collection) */
  relatedCasesData?: Array<{ id: string; title: string; href: string }>;
  /** Offres liées (cross-collection) */
  relatedOffresData?: Array<{ id: string; title: string; href: string }>;
  /** Headings pour la table des matières (issus de render() Astro MDX) */
  headings?: Array<{ depth: number; slug: string; text: string }>;
  /** Cluster éditorial pour RelatedByCluster */
  cluster?: string;
  /** ID de l'article courant (pour exclure de RelatedByCluster) */
  articleId?: string;
}
const {
  title,
  description,
  kicker,
  date,
  author,
  readingTime,
  relatedCards,
  authorSlug,
  sources,
  image,
  datePublished,
  dateModified,
  canonical,
  category,
  tags = [],
  breadcrumbItems,
  lang = 'fr',
  relatedCasesData,
  relatedOffresData,
  headings,
  cluster,
  articleId,
} = Astro.props as Props;

const siteUrl = 'https://waimia.com';
const pageTransitionId = Astro.url.pathname
  .replace(/^\/(?:en\/)?/, '')
  .replace(/\/$/, '')
  .replace(/[^a-z0-9]+/gi, '-')
  .replace(/^-|-$/g, '') || 'home';
const canonicalUrl = canonical ?? Astro.url.href;
const absoluteImage = image
  ? (image.startsWith('http') ? image : `${siteUrl}${image}`)
  : `${siteUrl}/og/default.png`;
const articleSection = category ?? kicker.replace(/^§\s*/, '').split('·')[0]?.trim();

// JSON-LD Article schema · GEO/AIO indexable par crawlers LLM
const articleLd = buildArticle({
  headline: title,
  description,
  image: absoluteImage,
  datePublished: datePublished ?? date,
  dateModified: dateModified ?? datePublished ?? date,
  author: {
    '@type': 'Person',
    ...(authorSlug ? { '@id': `${siteUrl}/equipe/${authorSlug}#person`, url: `${siteUrl}/equipe/${authorSlug}` } : {}),
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteUrl}/#organization`,
    name: 'Waimia',
    logo: { '@type': 'ImageObject', url: `${siteUrl}/og/default.png` },
  },
  mainEntityOfPage: canonicalUrl,
  articleSection,
  keywords: tags,
});
---
<Base title={title} description={description} jsonLd={articleLd}>
  {breadcrumbItems && breadcrumbItems.length > 0 && (
    <Breadcrumb lang={lang ?? 'fr'} items={breadcrumbItems} />
  )}
  <article class="essay">
    {/* MASTHEAD */}
    <header class="essay-hd" transition:name={`card-${pageTransitionId}`}>
      <div class="wrap-wide">
        <Kicker class="essay-kicker">{kicker}</Kicker>
        <h1 class="essay-h1 reveal-mask-up" transition:name={`hero-h1-${pageTransitionId}`}>
          <slot name="headline" />
        </h1>
        <p class="essay-lede">
          <slot name="lede" />
        </p>
        <div class="essay-meta">
          <span>{author}</span>
          <span aria-hidden>·</span>
          <time datetime={date}>{date}</time>
          {readingTime && (<><span aria-hidden>·</span><span>{readingTime}</span></>)}
        </div>
      </div>
    </header>

    {Astro.slots.has('hero-image') && <div class="essay-hero-image"><slot name="hero-image" /></div>}

    {/* BODY */}
    <div class="essay-body">
      {(() => {
        const hasSources = sources && sources.length > 0;
        const hasToc = headings && headings.filter((h) => h.depth === 2 || h.depth === 3).length >= 2;
        const layoutClass = hasToc && hasSources
          ? 'essay-layout--three-col'
          : hasToc
          ? 'essay-layout--with-toc'
          : hasSources
          ? 'essay-layout--with-aside'
          : '';
        return null;
      })()}
      {/* Layout calculé dans les attributs inline ci-dessous */}
      <div class:list={['essay-layout', {
        'essay-layout--three-col': headings && headings.filter((h) => h.depth === 2 || h.depth === 3).length >= 2 && sources && sources.length > 0,
        'essay-layout--with-toc': headings && headings.filter((h) => h.depth === 2 || h.depth === 3).length >= 2 && !(sources && sources.length > 0),
        'essay-layout--with-aside': !(headings && headings.filter((h) => h.depth === 2 || h.depth === 3).length >= 2) && sources && sources.length > 0,
      }]}>
        {headings && headings.filter((h) => h.depth === 2 || h.depth === 3).length >= 2 && (
          <aside class="essay-toc">
            <TableOfContents headings={headings} lang={lang} />
          </aside>
        )}
        <div class="essay-prose reveal">
          <slot name="body" />
          <div class="essay-share-end">
            <ShareButtons url={canonicalUrl} title={title} lang={lang} />
          </div>
          {tags.length > 0 && (
            <div class="essay-tags-end">
              <TagPills tags={tags} cluster={cluster} lang={lang} />
            </div>
          )}
        </div>
        {sources && sources.length > 0 && (
          <aside class="essay-sources">
            <span class="essay-sources-label">§ Sources</span>
            <ul class="essay-sources-list">
              {sources.map(src => (
                <li class="essay-source-item">
                  <a href={src.url} class="essay-source-link" target="_blank" rel="noopener noreferrer">
                    {src.name}
                  </a>
                  <span class="essay-source-type">{src.type}</span>
                </li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </div>

    {cluster && (
      <div class="wrap-wide essay-related-cluster">
        <RelatedByCluster cluster={cluster} excludeId={articleId} limit={4} />
      </div>
    )}

    {/* FOOTER 3-COL · Related + Author + CTA */}
    <footer class="essay-footer reveal">
      <div class="wrap-wide essay-footer-grid">
        <div class="essay-footer-related">
          <Kicker class="essay-related-k"><Bi fr="À lire ensuite" en="Related notes" /></Kicker>
          {(relatedCasesData?.length || relatedOffresData?.length) && (
            <section class="essay-related-cross">
              <h2 class="essay-related-cross__title">
                {lang === 'en' ? 'Related to this article' : 'En lien avec cet article'}
              </h2>
              <div class="essay-related-cross__grid">
                {relatedCasesData?.map(cas => (
                  <a href={cas.href} class="related-card related-card--case">
                    <Kicker as="span">{lang === 'en' ? '§ Customer case' : '§ Cas client'}</Kicker>
                    <h3>{cas.title}</h3>
                  </a>
                ))}
                {relatedOffresData?.map(off => (
                  <a href={off.href} class="related-card related-card--offre">
                    <Kicker as="span">{lang === 'en' ? '§ Service' : '§ Offre'}</Kicker>
                    <h3>{off.title}</h3>
                  </a>
                ))}
              </div>
            </section>
          )}
          <RelatedCards cards={relatedCards} />
        </div>
        {authorSlug && (
          <div class="essay-footer-author">
            <Kicker>§ Auteur</Kicker>
            <AuthorCard authorSlug={authorSlug} variant="mini" />
          </div>
        )}
        <div class="essay-footer-cta">
          <Kicker>§ Contact</Kicker>
          <p class="essay-cta-text">Une question sur ce sujet&nbsp;?</p>
          <a href="/contact" class="essay-cta-link">Discutons-en →</a>
        </div>
      </div>
    </footer>
  </article>

  <CtaBand />
</Base>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.08 }
  );
  document.querySelectorAll('.reveal').forEach((el) => observer.observe(el));
</script>

<style>
/* ── Hero ─────────────────────────────────────────────── */
.essay-hd {
  padding: 140px 32px clamp(40px, 6vw, 80px);
  border-bottom: 1px solid var(--hairline);
}
:global(.essay-kicker) { display: block; margin-bottom: 24px; }
.essay-h1 {
  font-family: var(--font-display);
  font-size: clamp(48px, 7vw, 96px);
  line-height: 0.96;
  letter-spacing: -0.026em;
  font-weight: 400;
  text-wrap: balance;
  margin: 0;
  max-width: 1200px;
}
.essay-h1 :global(i) { font-style: italic; color: var(--accent); }
.essay-lede {
  font-family: var(--font-display);
  font-style: italic;
  font-size: clamp(20px, 2.2vw, 28px);
  line-height: 1.4;
  color: var(--muted);
  margin: 24px 0 32px;
  max-width: 760px;
  text-wrap: pretty;
}
.essay-meta {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  color: var(--muted);
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  text-transform: uppercase;
}

.essay-hero-image { aspect-ratio: 16/9; margin: clamp(48px, 6vw, 80px) 32px 0; overflow: hidden; }
.essay-hero-image :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }

/* ── Body layout ──────────────────────────────────────── */
.essay-body {
  padding: clamp(60px, 8vw, 100px) 32px;
}
.essay-layout {
  max-width: 1200px;
  margin: 0 auto;
}
.essay-layout--with-aside {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: clamp(40px, 5vw, 80px);
  align-items: start;
}

/* TOC sidebar layout */
.essay-layout--with-toc {
  display: grid;
  grid-template-columns: 220px 1fr;
  gap: clamp(32px, 4vw, 64px);
  align-items: start;
  max-width: 1200px;
  margin: 0 auto;
}
.essay-layout--three-col {
  display: grid;
  grid-template-columns: 220px 1fr 260px;
  gap: clamp(32px, 4vw, 64px);
  align-items: start;
  max-width: 1200px;
  margin: 0 auto;
}
.essay-toc {
  position: sticky;
  top: clamp(64px, 8vw, 100px);
  align-self: start;
}
.essay-share-end {
  margin: clamp(40px, 5vw, 64px) 0 24px;
  padding-top: 24px;
  border-top: 1px solid var(--hairline);
}
.essay-tags-end {
  margin: 0;
}
.essay-related-cluster {
  padding: 0 32px clamp(40px, 5vw, 64px);
}

/* ── Prose ────────────────────────────────────────────── */
.essay-prose {
  max-width: 720px;
  font-family: var(--font-display);
  font-size: clamp(17px, 1.45vw, 19px);
  line-height: 1.65;
  color: var(--ink);
}

/* Drop cap sur premier paragraphe */
.essay-prose :global(p:first-of-type::first-letter) {
  float: left;
  font-family: var(--font-display);
  font-size: 5em;
  line-height: 0.85;
  margin: 0.05em 0.08em -0.05em 0;
  color: var(--ink);
  font-style: italic;
}

/* Drop cap apres chaque hr = nouveau chapitre */
.essay-prose :global(hr + p::first-letter) {
  float: left;
  font-family: var(--font-display);
  font-size: 5em;
  line-height: 0.85;
  margin: 0.05em 0.08em -0.05em 0;
  color: var(--ink);
  font-style: italic;
}

.essay-prose :global(h2) {
  font-family: var(--font-display);
  font-size: clamp(28px, 3vw, 40px);
  font-style: italic;
  font-weight: 400;
  letter-spacing: -0.012em;
  line-height: 1.15;
  margin: clamp(48px, 6vw, 72px) 0 24px;
  color: var(--ink);
  max-width: 880px;
  text-wrap: balance;
}
.essay-prose :global(h2)::before {
  content: '§';
  display: inline-block;
  margin-right: 0.4em;
  color: var(--accent);
  font-style: normal;
  font-family: var(--font-mono);
  font-size: 0.6em;
  vertical-align: 0.2em;
  letter-spacing: 0;
}
.essay-prose :global(h2 i) { font-style: italic; color: var(--accent); }
.essay-prose :global(h3) {
  font-family: var(--font-display);
  font-size: clamp(20px, 1.8vw, 24px);
  font-weight: 400;
  margin: clamp(32px, 4vw, 48px) 0 16px;
  line-height: 1.2;
}
.essay-prose :global(p) { margin: 0 0 1.4em; }

.essay-prose :global(blockquote) {
  border-left: 2px solid var(--ink-2);
  padding: 12px 0 12px 24px;
  margin: clamp(28px, 3vw, 40px) 0;
  font-family: var(--font-display);
  font-size: clamp(20px, 1.8vw, 24px);
  font-style: italic;
  line-height: 1.45;
  color: var(--ink-2);
  max-width: 640px;
}
.essay-prose :global(blockquote p:last-child) {
  margin: 12px 0 0;
  font-size: 13px;
  font-family: var(--font-mono);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
  font-style: normal;
}

.essay-prose :global(a) {
  color: var(--ink);
  background-image: linear-gradient(var(--accent), var(--accent));
  background-size: 100% 1px;
  background-repeat: no-repeat;
  background-position: 0 100%;
  text-decoration: none;
  padding-bottom: 1px;
  transition: background-size 120ms var(--ease);
}
.essay-prose :global(a:hover) {
  background-size: 100% 2px;
}

.essay-prose :global(code) {
  font-family: var(--font-mono);
  font-size: 0.85em;
  background: var(--paper-2);
  padding: 2px 8px;
  border-radius: 4px;
  border: 1px solid var(--hairline);
}

.essay-prose :global(ul),
.essay-prose :global(ol) {
  margin: 0 0 1.4em 1.5em;
  max-width: 640px;
}
.essay-prose :global(li) { margin-bottom: 0.4em; line-height: 1.5; }

.essay-prose :global(hr) {
  border: none;
  height: 1px;
  background: var(--hairline-strong);
  margin: clamp(48px, 6vw, 72px) 0;
  width: 100%;
}

/* ── Aside sources ────────────────────────────────────── */
.essay-sources {
  position: sticky;
  top: clamp(64px, 8vw, 100px);
  align-self: start;
  padding-left: 24px;
  border-left: 1px solid var(--hairline-strong);
}
.essay-sources-label {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--muted);
  margin-bottom: 16px;
}
.essay-sources-list {
  list-style: none;
  padding: 0;
  margin: 0;
}
.essay-source-item {
  padding: 10px 0;
  border-bottom: 1px solid var(--hairline);
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.essay-source-item:last-child { border-bottom: none; }
.essay-source-link {
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--ink);
  text-decoration: underline;
  text-underline-offset: 3px;
  word-break: break-word;
}
.essay-source-link:hover { color: var(--accent); }
.essay-source-type {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--muted);
}

.essay-related-cross {
  margin: var(--space-8, 3rem) 0;
  padding-top: var(--space-6, 2rem);
  border-top: 1px solid var(--hairline-strong, rgba(255,255,255,0.15));
}
.essay-related-cross__title {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: var(--space-4, 1.5rem);
}
.essay-related-cross__grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: var(--space-3, 1rem);
}
.related-card {
  display: block;
  padding: var(--space-4, 1.5rem);
  border: 1px solid var(--hairline-strong, rgba(255,255,255,0.15));
  text-decoration: none;
  transition: border-color 200ms var(--ease);
}
.related-card:hover {
  border-color: var(--accent);
}
.related-card .kicker {
  display: block;
  font-family: var(--font-mono);
  font-size: 10px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 6px;
}
.related-card h3 {
  font-size: 15px;
  color: var(--ink);
  margin: 0;
  line-height: 1.3;
}
.related-card--case { border-left: 3px solid var(--accent); }
.related-card--offre { border-left: 3px solid var(--ink-2); }

/* ── Footer 3-col ─────────────────────────────────────── */
.essay-footer {
  padding: clamp(60px, 8vw, 100px) 32px;
  border-top: 1px solid var(--hairline);
}
.essay-footer-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: clamp(40px, 5vw, 64px);
}
:global(.essay-related-k) { display: block; margin-bottom: 30px; }
.essay-footer-cta {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.essay-cta-text {
  font-family: var(--font-display);
  font-size: 16px;
  color: var(--ink-2);
  margin: 8px 0 0;
  max-width: 240px;
  line-height: 1.45;
}
.essay-cta-link {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 120ms var(--ease);
}
.essay-cta-link:hover { color: var(--accent); }

/* ── Scroll reveal ────────────────────────────────────── */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 600ms var(--ease), transform 600ms var(--ease);
}
.reveal.is-visible {
  opacity: 1;
  transform: translateY(0);
}

/* ── Responsive ───────────────────────────────────────── */
@media (min-width: 1100px) {
  .essay-footer-grid {
    grid-template-columns: 1fr 280px 240px;
    align-items: start;
  }
}

@media (max-width: 1099px) {
  .essay-layout--with-aside {
    grid-template-columns: 1fr;
  }
  .essay-sources {
    position: static;
    border-left: none;
    border-top: 1px solid var(--hairline-strong);
    padding-left: 0;
    padding-top: 24px;
    margin-top: 32px;
  }
  .essay-layout--with-toc,
  .essay-layout--three-col {
    grid-template-columns: 1fr;
  }
  .essay-toc {
    position: static;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 24px;
    margin-bottom: 32px;
  }
}
</style>
