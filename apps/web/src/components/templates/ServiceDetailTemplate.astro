---
// Template · ServiceDetailTemplate · page service détaillée (1 service du catalogue)
//
// Mapping handoff2 :
//  - service-revops.html       → /offres/revops
//  - silo-anthropic.html       → /technologies/anthropic
//  - industry-fintech.html     → /solutions/fintech
//  - loc-paris.html            → /agence/paris
//  - offres/detail.html (template handoff officiel)
//
// Squelette : Masthead + Problem statement + Approach steps + Deliverables grid
//             + Proof + FitColumns (optionnel) + Tech stack + Related + CTA
//
// Plus dense que HubTemplate (qui contient un catalogue de services), ce template
// présente UN service avec problème → méthode → livrables → preuve.

import Base from '../../layouts/Base.astro';
import Bi from '../ui/atoms/Bi.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import MethodTimeline from '../sections/MethodTimeline.astro';
import { langFromPath, localizeHref } from '../../lib/i18n';
import ProofBand from '../ui/molecules/ProofBand.astro';
import TechPillRow from '../ui/molecules/TechPillRow.astro';
import RelatedCards from '../ui/molecules/RelatedCards.astro';
import CtaFinal from '../sections/CtaFinal.astro';
import ProofBarSection from '../sections/ProofBarSection.astro';
import type { SectionByType } from '../../schemas/sections';

interface Stat {
  k: string;
  label_fr: string;
  label_en: string;
}
interface Step {
  sn: string;
  kicker_fr: string;
  kicker_en: string;
  title_fr: string;
  title_en: string;
  body_fr: string;
  body_en: string;
}
interface Pill {
  label: string;
  kind?: 'primary' | 'open' | 'neutral';
}
interface Metric {
  k: string;
  label_fr: string;
  label_en: string;
}
interface RelatedCard {
  kicker: string;
  title_fr: string;
  title_en: string;
  lead_fr: string;
  lead_en: string;
  href: string;
}
interface Props {
  title: string;
  description: string;
  /** Numéro éditorial (Service 02.1, Service 02.2…) */
  serviceNum: string;
  /** Stats annotation problem (3 chiffres clés) */
  problemStats?: Stat[];
  /** Steps approach */
  steps: Step[];
  /** Proof (optionnel) */
  proofQuoteFr?: string;
  proofQuoteEn?: string;
  proofAttrFr?: string;
  proofAttrEn?: string;
  proofMetrics?: Metric[];
  /** Tech pills */
  techPills: Pill[];
  /** Related cards */
  relatedCards: RelatedCard[];
}
const {
  title, description, serviceNum, problemStats, steps,
  proofQuoteFr, proofQuoteEn, proofAttrFr, proofAttrEn, proofMetrics,
  techPills, relatedCards,
} = Astro.props;
const lang = langFromPath(Astro.url.pathname);
const hasProof = proofQuoteFr && proofQuoteEn && proofMetrics;
const serviceLabel = title.split(' · ')[0];
const collectionHref = Astro.url.pathname.includes('/technologies/')
  ? localizeHref('/technologies', lang)
  : Astro.url.pathname.includes('/solutions/')
  ? localizeHref('/solutions', lang)
  : Astro.url.pathname.includes('/agence/')
  ? localizeHref('/agence', lang)
  : localizeHref('/offres', lang);
const collectionLabelFr = Astro.url.pathname.includes('/technologies/')
  ? 'Voir les technologies →'
  : Astro.url.pathname.includes('/solutions/')
  ? 'Voir les solutions →'
  : Astro.url.pathname.includes('/agence/')
  ? "Voir l'agence →"
  : 'Voir les offres →';
const collectionLabelEn = Astro.url.pathname.includes('/technologies/')
  ? 'See technologies →'
  : Astro.url.pathname.includes('/solutions/')
  ? 'See solutions →'
  : Astro.url.pathname.includes('/agence/')
  ? 'See the agency →'
  : 'See services →';
const ctaData = {
  type: 'cta-final',
  h2_fr: 'Prêt à rendre ce <i>chantier</i> opérable ?',
  h2_en: 'Ready to make this <i>engagement</i> operational?',
  body_fr: `On part de ${serviceLabel} et on vous dit vite si le sujet mérite un sprint, un audit ou un non ferme.`,
  body_en: `We start from ${serviceLabel} and tell you quickly whether the topic deserves a sprint, an audit, or a firm no.`,
  cta_primary: {
    label_fr: 'Réserver un audit →',
    label_en: 'Book an audit →',
    href: localizeHref('/contact', lang),
    variant: 'primary',
  },
  cta_secondary: {
    label_fr: collectionLabelFr,
    label_en: collectionLabelEn,
    href: collectionHref,
    variant: 'ghost',
  },
  background: 'paper',
} satisfies SectionByType<'cta-final'>;
---
<Base title={title} description={description}>
  {/* MASTHEAD */}
  <section class="svc-masthead">
    <div class="wrap-wide">
      <Kicker class="svc-num">§ Service {serviceNum}</Kicker>
      <h1 class="svc-h1"><slot name="headline" /></h1>
      <p class="svc-lede"><slot name="lede" /></p>
    </div>
  </section>

  {/* PROBLEM STATEMENT */}
  <section class="svc-problem">
    <div class="wrap-wide">
      <Kicker tone="accent" class="svc-section-k">§ 01 · <Bi fr="Le problème" en="The problem" /></Kicker>
      <p class="svc-problem-text"><slot name="problem" /></p>
      {problemStats && (
        <div class="svc-problem-stats">
          <ProofBarSection
            data={{
              type: 'proof-bar',
              layout: 'horizontal',
              metrics: problemStats.map((s) => ({ value: s.k, label_fr: s.label_fr, label_en: s.label_en, emphasis: false })),
            }}
            lang={lang}
          />
        </div>
      )}
    </div>
  </section>

  {/* APPROACH · steps */}
  <section class="svc-approach">
    <div class="wrap-wide">
      <header class="svc-section-hd">
        <div>
          <Kicker tone="accent" class="svc-section-k">§ 02 · <Bi fr="L'approche" en="The approach" /></Kicker>
          <h2 class="svc-section-h2"><slot name="approach-headline" /></h2>
        </div>
        <p class="svc-section-aside"><slot name="approach-aside" /></p>
      </header>
      <MethodTimeline
        data={{
          type: 'method-timeline',
          h2_fr: '',
          h2_en: '',
          steps: steps.map((s) => ({
            num: s.sn,
            label_fr: s.title_fr,
            label_en: s.title_en,
            body_fr: s.body_fr,
            body_en: s.body_en,
            meta_fr: s.kicker_fr || undefined,
            meta_en: s.kicker_en || undefined,
          })),
        }}
        lang={lang}
      />
    </div>
  </section>

  {/* DELIVERABLES (slot ouvert pour grid custom) */}
  {Astro.slots.has('deliverables') && (
    <section class="svc-deliverables">
      <div class="wrap-wide">
        <Kicker tone="accent" class="svc-section-k">§ 03 · <Bi fr="Livrables" en="Deliverables" /></Kicker>
        <slot name="deliverables" />
      </div>
    </section>
  )}

  {/* PROOF */}
  {hasProof && (
    <section class="svc-proof">
      <div class="wrap-wide">
        <ProofBand
          quote_fr={proofQuoteFr!} quote_en={proofQuoteEn!}
          attr_fr={proofAttrFr!} attr_en={proofAttrEn!}
          metrics={proofMetrics!}
        />
      </div>
    </section>
  )}

  {/* STACK */}
  <section class="svc-stack">
    <div class="wrap-wide">
      <Kicker tone="accent" class="svc-section-k">§ 04 · <Bi fr="La stack" en="The stack" /></Kicker>
      <p class="svc-stack-lead"><slot name="stack-lead" /></p>
      <TechPillRow pills={techPills} />
    </div>
  </section>

  {/* RELATED */}
  <section class="svc-related">
    <div class="wrap-wide">
      <Kicker class="svc-related-k">§ 05 · <Bi fr="Connexes" en="Related" /></Kicker>
      <RelatedCards cards={relatedCards} />
    </div>
  </section>

  <CtaFinal data={ctaData} lang={lang} />
</Base>

<style>
  .svc-masthead { padding: 140px 32px 0; }
  :global(.svc-num) { display: block; margin-bottom: var(--space-5); }
  .svc-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 156px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    text-wrap: balance;
    font-weight: 400;
    margin: 0 0 32px;
  }
  .svc-h1 :global(i) { font-style: italic; color: var(--accent); }
  .svc-lede {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 24px);
    line-height: 1.45;
    max-width: 880px;
    color: var(--muted);
    text-wrap: balance;
    margin: 0;
  }

  .svc-problem,
  .svc-approach,
  .svc-stack,
  .svc-related,
  .svc-proof,
  .svc-deliverables { padding: clamp(80px, 12vw, 120px) 32px; }
  :global(.svc-section-k) { display: block; margin-bottom: 24px; }
  .svc-problem-text {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 56px);
    line-height: 1.1;
    letter-spacing: -0.018em;
    text-wrap: balance;
    max-width: 1100px;
    margin: 0 0 clamp(36px, 5vw, 72px);
  }
  .svc-problem-text :global(i) { font-style: italic; color: var(--accent); }
  .svc-problem-stats { margin-top: clamp(36px, 5vw, 72px); }

  .svc-approach { background: var(--paper-2); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  .svc-section-hd {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(24px, 4vw, 60px);
    margin-bottom: clamp(36px, 5vw, 70px);
    align-items: end;
  }
  .svc-section-h2 {
    font-family: var(--font-display);
    font-size: clamp(34px, 5.5vw, 88px);
    line-height: 0.95;
    letter-spacing: -0.024em;
    text-wrap: balance;
    font-weight: 400;
    margin: 14px 0 0;
  }
  .svc-section-h2 :global(i) { font-style: italic; color: var(--accent); }
  .svc-section-aside {
    font-size: clamp(13px, 1.3vw, 15px);
    line-height: 1.55;
    color: var(--muted);
    max-width: 400px;
    text-wrap: pretty;
    margin: 0;
  }

  .svc-stack-lead {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 30px);
    line-height: 1.3;
    color: var(--muted);
    max-width: 760px;
    text-wrap: balance;
    margin: 0 0 clamp(28px, 3vw, 44px);
  }

  :global(.svc-related-k) { display: block; margin-bottom: var(--space-6); }

  @media (max-width: 900px) {
    .svc-section-hd { grid-template-columns: 1fr; }
  }
</style>
