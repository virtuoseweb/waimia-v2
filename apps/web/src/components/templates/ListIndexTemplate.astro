---
// Template · ListIndexTemplate · index/listing d'éléments (cas, articles, knowledge base)
//
// Mapping handoff2 :
//  - cases-index.html        → /ressources/cas
//  - writing-index.html      → /ressources/blog
//  - knowledge-base.html     → /ressources/cookbooks
//  - changelog.html          → /ressources/changelog
//
// Squelette : Masthead minimaliste + Filter row (slot) + List slot + CTA
//
// Le pattern liste/grid est géré par le slot `list` — la page utilisatrice choisit
// EditorialWriteRow (writing-index), EditorialCaseCard grid (cases-index), ou autre.

import Base from '../../layouts/Base.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import CtaBandSection from '../sections/CtaBandSection.astro';
import type { SectionByType } from '../../schemas/sections';
import { langFromPath, localizeHref } from '../../lib/i18n';

interface Props {
  title: string;
  description: string;
  /** Section éditoriale (Cas clients, Notes, Cookbooks…) */
  kicker: string;
}
const { title, description, kicker } = Astro.props;
const lang = langFromPath(Astro.url.pathname);
const listLabel = title.split(' · ')[0];
const ctaData = {
  type: 'cta-band',
  text_fr: `Après ${listLabel}, passons à votre cas réel et à votre premier livrable utile.`,
  text_en: `After ${listLabel}, let us move to your real use case and your first useful deliverable.`,
  cta: {
    label_fr: 'Réserver un audit →',
    label_en: 'Book an audit →',
    href: localizeHref('/contact', lang),
    variant: 'primary',
  },
  background: 'paper-2',
} satisfies SectionByType<'cta-band'>;
---
<Base title={title} description={description}>
  {/* MASTHEAD */}
  <section class="list-hd">
    <div class="wrap-wide">
      <Kicker class="list-kicker">{kicker}</Kicker>
      <h1 class="list-h1 reveal-mask-up"><slot name="headline" /></h1>
      <p class="list-lede"><slot name="lede" /></p>

      {Astro.slots.has('filters') && (
        <div class="list-filters">
          <slot name="filters" />
        </div>
      )}
    </div>
  </section>

  {/* LIST (slot ouvert) */}
  <section class="list-body">
    <div class="wrap-wide">
      <slot name="list" />
    </div>
  </section>

  <CtaBandSection data={ctaData} lang={lang} />
</Base>

<style>
  .list-hd {
    padding: 140px 32px clamp(40px, 5vw, 72px);
    border-bottom: 1px solid var(--hairline);
  }
  :global(.list-kicker) { display: block; margin-bottom: 24px; }
  .list-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .list-h1 :global(i) { font-style: italic; color: var(--accent); }
  .list-lede {
    font-family: var(--font-sans);
    font-size: clamp(20px, 2.2vw, 32px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.4;
    text-wrap: pretty;
  }
  .list-filters {
    margin-top: clamp(36px, 4vw, 56px);
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .list-body { padding: clamp(60px, 8vw, 100px) 32px; }
</style>
