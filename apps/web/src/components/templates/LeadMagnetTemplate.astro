---
// Template · LeadMagnetTemplate · download gated d'un livre blanc / outil PDF
//
// Mapping :
//  - /ressources/livres-blancs/ai-act-readiness
//  - /ressources/livres-blancs/revops-guide
//  - /ressources/livres-blancs/finops-llm-playbook
//  (4-6 livres blancs prévus · justification template)
//
// Squelette · 3 sections : Hero (titre + cover) + Form gated + Preview content (ToC)
// Submit form → POST /api/lead-magnet → email PDF link → redirect /bienvenue/livre-blanc
//
// Composé de · Bi · Kicker · Button · CtaBand · NON inclus (c'est le CTA principal de la page)

import { actions, isInputError } from 'astro:actions';
import Base from '../../layouts/Base.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import Button from '../ui/atoms/Button.astro';
import Callout from '../editorial/Callout.astro';
import KeyMetric from '../editorial/KeyMetric.astro';
import Timeline from '../editorial/Timeline.astro';
import PullQuote from '../editorial/PullQuote.astro';
import Dingbat from '../editorial/Dingbat.astro';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';
import FormErrors from '../ui/atoms/FormErrors.astro';
import { langFromPath } from '../../lib/i18n';

const result = Astro.getActionResult(actions.leadMagnet);

if (result && !result.error && result.data?.redirect) {
  return Astro.redirect(result.data.redirect);
}

const inputErrors = isInputError(result?.error) ? result.error.fields : {};
const otherError = result?.error && !isInputError(result.error)
  ? result.error.message
  : undefined;

interface ToCItem { num: string; title: string; }

interface Props {
  title: string;
  description: string;
  /** Identifiant slug pour /api/lead-magnet (ex: 'ai-act-readiness') */
  slug: string;
  /** Kicker section (ex: "§ Livre blanc · 32 pages · gratuit") */
  kicker: string;
  /** Format teaser ("PDF · 32 pages") */
  format: string;
  /** Date publication (ISO) */
  publishedAt: string;
  /** Table des matières */
  toc: ToCItem[];
  /** URL image cover (relatif /og/) ou ressource interne */
  coverUrl?: string;
  /** Label personnalisé pour le breadcrumb. */
  breadcrumbLabel?: string;
  /** JSON-LD schemas spécifiques (Book, Offer, BreadcrumbList…) passés depuis la page. */
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}
const { title, description, slug, kicker, format, publishedAt, toc, coverUrl, breadcrumbLabel, jsonLd } = Astro.props as Props;
const lang = langFromPath(Astro.url.pathname);
const pageTransitionId = Astro.url.pathname
  .replace(/^\/(?:en\/)?/, '')
  .replace(/\/$/, '')
  .replace(/[^a-z0-9]+/gi, '-')
  .replace(/^-|-$/g, '') || 'home';

const headlineHtml = Astro.slots.has('headline') ? await Astro.slots.render('headline') : title;
const ledeHtml = Astro.slots.has('lede') ? await Astro.slots.render('lede') : description;
const extraHtml = Astro.slots.has('extra') ? await Astro.slots.render('extra') : '';

const stripHtml = (html: string) =>
  html
    .replace(/<br\s*\/?>/gi, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const abstractText = stripHtml(ledeHtml || description);

const metricSource = [title, description, format, ...toc.map((item) => item.title)].join(' ');
const metricDefs = [
  {
    pattern: /(\d+)\s*crit[eè]res?/i,
    label: 'critères de contrôle',
  },
  {
    pattern: /(\d+)\s*mois/i,
    label: 'mois de feuille de route',
  },
  {
    pattern: /(\d+)\s*pages?/i,
    label: 'pages opérationnelles',
  },
  {
    pattern: /(\d+)\s*questions?/i,
    label: 'questions de cadrage',
  },
];

const keyMetrics = metricDefs
  .map((metric) => {
    const match = metricSource.match(metric.pattern);
    return match?.[1] ? { value: match[1], label: metric.label } : undefined;
  })
  .filter((metric): metric is { value: string; label: string } => Boolean(metric))
  .slice(0, 3);

const tocEvents = toc.map((item, index) => ({
  num: item.num,
  title: item.title,
  meta: index === 0 ? 'Ouverture' : `Chapitre ${item.num}`,
  body: 'Repère inclus dans le dossier téléchargeable, avec méthode et points de contrôle.',
  variant: index === 0 ? 'highlight' as const : 'default' as const,
}));
---
<Base title={title} description={description} jsonLd={jsonLd}>
  <Breadcrumb
    lang={lang}
    items={[
      { label: lang === 'fr' ? 'Accueil' : 'Home', href: lang === 'fr' ? '/' : '/en' },
      { label: lang === 'fr' ? 'Ressources' : 'Resources', href: lang === 'fr' ? '/ressources' : '/en/ressources' },
      { label: lang === 'fr' ? 'Livres blancs' : 'Whitepapers', href: lang === 'fr' ? '/ressources/livres-blancs' : '/en/ressources/livres-blancs' },
      { label: breadcrumbLabel ?? title },
    ]}
  />
  {/* HERO · titre + cover */}
  <section class="lm-hero" transition:name={`card-${pageTransitionId}`}>
    <div class="wrap-wide lm-hero-grid">
      <div class="lm-hero-text">
        <Kicker tone="accent" class="lm-kicker">{kicker}</Kicker>
        <h1 class="lm-h1 reveal-mask-up" transition:name={`hero-h1-${pageTransitionId}`} set:html={headlineHtml} />
        <p class="lm-lede reveal" set:html={ledeHtml} />
        <div class="lm-meta">
          <span>{format}</span>
          <span aria-hidden>·</span>
          <time datetime={publishedAt}>{publishedAt}</time>
          <span aria-hidden>·</span>
          <span>Gratuit</span>
        </div>
      </div>
      <aside class="lm-hero-panel reveal-stagger" aria-label="Résumé du livre blanc" transition:name={`hero-img-${pageTransitionId}`}>
        {coverUrl && (
          <div class="lm-cover" aria-hidden>
            <img src={coverUrl} alt="" loading="eager" fetchpriority="high" decoding="async" />
          </div>
        )}
        <div class="lm-download-card">
          <span class="lm-download-label">PDF gratuit · sur inscription</span>
          <Button href="#lead-magnet-form" variant="primary" size="sm">Recevoir le PDF</Button>
        </div>
      </aside>
    </div>
  </section>

  <section class="lm-abstract">
    <div class="wrap-wide lm-abstract-grid reveal-stagger">
      <div class="lm-abstract-copy">
        <Kicker tone="accent">§ 00 · Résumé exécutif</Kicker>
        <p class="lm-abstract-text">{abstractText}</p>
      </div>
      <div class="lm-metrics" aria-label="Chiffres clés du livre blanc">
        {keyMetrics.length > 0 ? (
          keyMetrics.map((metric) => (
            <KeyMetric value={metric.value} label={metric.label} size="sm" variant="accent" />
          ))
        ) : (
          <KeyMetric value={String(toc.length)} label="chapitres structurés" size="sm" variant="accent" />
        )}
      </div>
    </div>
  </section>

  {/* FORM GATED + ToC PREVIEW · 2 cols */}
  <section class="lm-body">
    <div class="wrap-wide lm-body-grid">
      {/* Form gated */}
      <form id="lead-magnet-form" class="lm-form reveal" method="POST" action={actions.leadMagnet} name="lead-magnet" data-enhanced novalidate>
        <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden">
          <label for="lead-magnet-form-hp">Ne pas remplir</label>
          <input type="text" id="lead-magnet-form-hp" name="_hp" tabindex="-1" autocomplete="off" />
        </div>
        <input type="hidden" name="slug" value={slug} />
        <input type="hidden" name="lang" value={lang} />
        <Kicker tone="accent" class="lm-form-k">§ 01 · Recevoir le PDF par email</Kicker>
        <h2 class="lm-form-h2">Trois <i>champs</i>. Le PDF dans 30 secondes.</h2>

        <div class="form-row">
          <label for="lm-email"><span>Email pro</span><span aria-hidden>*</span></label>
          <input id="lm-email" name="email" type="email" required autocomplete="email" placeholder="prénom@entreprise.com" />
        </div>
        <div class="form-row">
          <label for="lm-company"><span>Entreprise</span><span aria-hidden>*</span></label>
          <input id="lm-company" name="company" type="text" required autocomplete="organization" />
        </div>
        <div class="form-row">
          <label for="lm-role">Fonction</label>
          <input id="lm-role" name="role" type="text" autocomplete="organization-title" placeholder="CEO, COO, CTO, RevOps Lead..." />
        </div>

        <FormErrors errors={inputErrors} id="lead-magnet-errors" />
        {otherError && <p class="form-error-global" role="alert">{otherError}</p>}

        <Button as="button" type="submit" variant="primary" size="lg" mag={0.18}>
          Envoyer le PDF →
        </Button>

        <p class="lm-foot">
          Aucune relance commerciale automatique. Vous recevez le PDF, puis 3 emails sur 14 jours (1 insight, 1 cas, 1 invitation RDV facultative). Désinscription en 1 clic.
        </p>
      </form>

      {/* Preview ToC */}
      <aside class="lm-toc reveal-stagger">
        <Kicker class="lm-toc-k">§ 02 · Au programme</Kicker>
        <Timeline events={tocEvents} orientation="vertical" numbered={true} />
        <Callout variant="manifesto" size="sm">
          <p>Un document court, fait pour décider quoi auditer, quoi documenter et quoi corriger en premier — traçabilité, responsabilité humaine, données sources et preuve d’évaluation.</p>
        </Callout>
        {extraHtml && (
          <>
            <Dingbat variant="rule" size="sm" />
            <div class="lm-extra-prose reveal" set:html={extraHtml} />
          </>
        )}
      </aside>
    </div>
  </section>

  <section class="lm-footer-cta">
    <div class="wrap-wide lm-footer-grid">
      <PullQuote attribution="Waimia" variant="inline">
        Le bon moment pour documenter un système IA, c’est avant que le risque devienne une question juridique.
      </PullQuote>
      <div class="lm-footer-action">
        <Kicker>§ 03 · Prochaine étape</Kicker>
        <h2>Téléchargez le dossier, puis cadrez votre conformité.</h2>
        <Button href="#lead-magnet-form" variant="primary" size="lg" mag={0.18}>Recevoir le PDF →</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .lm-hero { padding: 140px 32px clamp(40px, 5vw, 72px); border-bottom: 1px solid var(--hairline); }
  .lm-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(280px, 4fr);
    gap: clamp(32px, 5vw, 80px);
    align-items: center;
  }
  :global(.lm-kicker) { display: block; margin-bottom: 20px; }
  .lm-h1 {
    font-family: var(--font-display);
    font-size: clamp(48px, 8vw, 120px);
    line-height: 0.94;
    letter-spacing: -0.03em;
    text-wrap: balance;
    font-weight: 400;
    margin: 0 0 24px;
  }
  .lm-h1 :global(i) { font-style: italic; color: var(--accent); }
  .lm-lede {
    font-family: var(--font-sans);
    font-style: italic;
    font-size: clamp(18px, 2vw, 24px);
    color: var(--ink-2);
    margin: 0 0 24px;
    max-width: 620px;
    line-height: 1.4;
    text-wrap: pretty;
  }
  .lm-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .lm-hero-panel {
    display: grid;
    gap: 16px;
    align-self: stretch;
  }
  .lm-cover {
    aspect-ratio: 3/4;
    border: 1px solid var(--hairline-strong);
    border-radius: 8px;
    overflow: hidden;
    background: var(--paper-2);
  }
  .lm-cover img { width: 100%; height: 100%; object-fit: cover; }
  .lm-download-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
    padding: 16px 0;
  }
  .lm-download-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .lm-abstract {
    padding: clamp(52px, 7vw, 88px) 32px;
    border-bottom: 1px solid var(--hairline);
  }
  .lm-abstract-grid {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(240px, 4fr);
    gap: clamp(32px, 6vw, 80px);
    align-items: start;
  }
  .lm-abstract-copy {
    max-width: 820px;
  }
  .lm-abstract-text {
    margin: 20px 0 0;
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 34px);
    line-height: 1.24;
    color: var(--ink);
    text-wrap: pretty;
  }
  .lm-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 16px;
    border-top: 1px solid var(--hairline-strong);
    padding-top: 8px;
  }

  .lm-body { padding: clamp(60px, 8vw, 100px) 32px; }
  .lm-body-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: clamp(40px, 6vw, 80px);
  }
  .lm-form { display: flex; flex-direction: column; gap: 22px; }
  .lm-form {
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--hairline-strong);
    padding: clamp(24px, 4vw, 40px) 0;
  }
  :global(.lm-form-k) { display: block; }
  .lm-form-h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3.6vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 0 0 12px;
    text-wrap: balance;
  }
  .lm-form-h2 :global(i) { font-style: italic; color: var(--accent); }
  .form-row { display: flex; flex-direction: column; gap: 6px; }
  .form-row label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    gap: 4px;
  }
  .form-row label span:last-child { color: var(--accent); }
  .form-row input {
    font-family: var(--font-display);
    font-size: 17px;
    padding: 14px 0;
    border: 0;
    border-bottom: 1px solid var(--hairline-strong);
    border-radius: 0;
    background: var(--paper);
    color: var(--ink);
    transition: border-color 200ms var(--ease), background 200ms var(--ease);
  }
  .form-row input:focus { outline: none; border-color: var(--accent); background: var(--paper-2); }
  .lm-foot { font-size: 12.5px; line-height: 1.5; color: var(--muted); margin: 8px 0 0; max-width: 540px; }

  .lm-toc {
    border-left: 1px solid var(--hairline);
    padding-left: clamp(24px, 3vw, 40px);
    align-self: start;
    position: sticky;
    top: 100px;
  }
  :global(.lm-toc-k) { display: block; margin-bottom: 18px; }
  .lm-toc :global(.timeline-vertical) { margin: 28px 0 40px; }
  .lm-toc :global(.timeline-title) { font-size: clamp(18px, 1.6vw, 23px); }
  .lm-toc :global(.timeline-body) { font-size: 15px; }
  .lm-toc :global(.callout) { margin-block: 24px; }
  .lm-toc :global(.callout-manifesto) { text-align: left; }
  .lm-toc :global(.callout-manifesto .callout-body) { font-size: clamp(20px, 2vw, 28px); }
  .lm-toc :global(.callout p) { margin: 0; }
  .lm-extra-prose {
    margin-top: 32px;
  }
  .lm-extra-prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    margin: 40px 0;
    padding-left: 24px;
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 34px);
    font-style: italic;
    line-height: 1.22;
    color: var(--ink);
  }

  .lm-footer-cta {
    padding: clamp(64px, 9vw, 112px) 32px;
    background: var(--ink);
    color: var(--paper);
  }
  .lm-footer-grid {
    display: grid;
    grid-template-columns: minmax(0, 6fr) minmax(280px, 4fr);
    gap: clamp(40px, 7vw, 96px);
    align-items: center;
  }
  .lm-footer-cta :global(.pull-quote-body),
  .lm-footer-cta :global(.pull-quote-attr) { color: var(--paper); }
  .lm-footer-action {
    display: grid;
    gap: 22px;
    justify-items: start;
  }
  .lm-footer-action h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 56px);
    font-weight: 400;
    line-height: 1;
    text-wrap: balance;
  }

  @media (max-width: 900px) {
    .lm-hero-grid { grid-template-columns: 1fr; }
    .lm-abstract-grid { grid-template-columns: 1fr; }
    .lm-body-grid { grid-template-columns: 1fr; }
    .lm-toc { border-left: none; padding-left: 0; border-top: 1px solid var(--hairline); padding-top: 32px; position: static; }
    .lm-footer-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import { navigate } from 'astro:transitions/client';

  document.querySelectorAll<HTMLFormElement>('form[data-enhanced]').forEach((form) => {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      const formData = new FormData(form);
      const actionPath = form.getAttribute('action');
      if (!actionPath) return;

      try {
        const res = await fetch(actionPath, { method: 'POST', body: formData, headers: { Accept: 'application/json' } });
        const json = await res.json();
        if (res.ok && json?.data?.redirect) {
          navigate(json.data.redirect);
          return;
        }
        if (submitBtn) submitBtn.disabled = false;
        form.submit();
      } catch {
        if (submitBtn) submitBtn.disabled = false;
        form.submit();
      }
    });
  });
</script>
