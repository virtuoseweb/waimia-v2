---
/**
 * OffresDetailTemplate · sub-page Offres (focus conversion service)
 *
 * Sections (6) sémantiquement différenciées de Solutions/Technologies :
 *   1. Hero · breadcrumb + tier badge + h1 + lead + CTA + meta pricing
 *   2. Problem · statement macro-typo (la tension marché en 1 phrase forte)
 *   3. Method · 4 phases numérotées 01→04 (méthode Waimia signature)
 *   4. Deliverables · 3-6 cards livrables tangibles + tag format (PDF, scripts...)
 *   5. Proof · quote client + métriques chiffrées
 *   6. CTA dark · "Prêt à déployer ?"
 *
 * Brique signature : DeliverablesGrid (livrables tangibles avec tag format).
 * Pas de Stack ici : déplacé sur Solutions/Technologies où il a + de sens.
 * Source handoff : project/pages/offres/detail.html (lignes 161-311).
 *
 * Usage minimal (props) :
 *   <OffresDetailTemplate
 *     tier="§ 02 · DÉPLOIEMENT LIGHT"
 *     tierLabel="Claude Cowork & Artifacts"
 *     meta="Palier 02 · à partir de 3 500 €"
 *     title="Contact Claude Cowork & Artifacts"
 *     description="Déploiement complet de Claude sur chaque poste."
 *   >
 *     <Fragment slot="title">Claude<br/>Cowork &amp;<br/>Artifacts</Fragment>
 *     <Fragment slot="lead">Lead html...</Fragment>
 *     <Fragment slot="problem-statement">Les équipes ont accès à l'IA. <em>Elles ne l'utilisent pas.</em></Fragment>
 *     ... etc
 *   </OffresDetailTemplate>
 */
import Base from '../../layouts/Base.astro';
import Callout from '../editorial/Callout.astro';
import DropCap from '../editorial/DropCap.astro';
import PullQuote from '../editorial/PullQuote.astro';
import Timeline from '../editorial/Timeline.astro';
import KeyMetric from '../editorial/KeyMetric.astro';
import EditorialTable from '../editorial/EditorialTable.astro';
import Dingbat from '../editorial/Dingbat.astro';
import { buildOffer, buildService } from '../../lib/seo/schema-builder';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';
import { langFromPath } from '../../lib/i18n';

interface Props {
  /** SEO meta · title de la page (browser tab) */
  title: string;
  /** SEO meta · description */
  description: string;
  /** Tier badge (kicker au-dessus du h1) ex: "§ 02 · DÉPLOIEMENT LIGHT" */
  tier: string;
  /** Label du breadcrumb second segment ex: "Claude Cowork & Artifacts" */
  tierLabel: string;
  /** Meta sous le CTA hero ex: "Palier 02 · à partir de 3 500 €" */
  meta?: string;
  /** Href du CTA hero (default /contact) */
  ctaHref?: string;
  /** Label du CTA hero (default "Parler à un expert →") */
  ctaLabel?: string;
  /** JSON-LD additionnel fourni par une page appelante. */
  additionalJsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  tier,
  tierLabel,
  meta = '',
  ctaHref = '/contact',
  ctaLabel = 'Parler à un expert →',
  additionalJsonLd,
} = Astro.props;

const lang = langFromPath(Astro.url.pathname);
const pageTransitionId = Astro.url.pathname
  .replace(/^\/(?:en\/)?/, '')
  .replace(/\/$/, '')
  .replace(/[^a-z0-9]+/gi, '-')
  .replace(/^-|-$/g, '') || 'home';
const parseMinPrice = (value: string) => {
  const normalized = value
    .replace(/\u00a0/g, ' ')
    .replace(/\s+/g, ' ')
    .toLowerCase();
  const kMatch = normalized.match(/(\d+(?:[,.]\d+)?)\s*(?:à|-|–|—)?\s*\d*(?:[,.]\d+)?\s*k\s*€/);
  if (kMatch) return Number(kMatch[1]?.replace(',', '.')) * 1000;
  const euroMatch = normalized.match(/(\d[\d\s.,]*)\s*€/);
  if (!euroMatch) return undefined;
  const amount = Number(euroMatch[1]?.replace(/\s/g, '').replace(',', '.'));
  return Number.isFinite(amount) ? amount : undefined;
};

const priceFrom = parseMinPrice(meta);
const pageJsonLd = additionalJsonLd
  ? (Array.isArray(additionalJsonLd) ? additionalJsonLd : [additionalJsonLd])
  : [];
const offreSchemas = [
  buildService({
    name: title,
    description,
    provider: { '@id': 'https://waimia.com/#organization' },
    areaServed: ['FR', 'CH', 'BE', 'LU'],
    serviceType: 'AI Integration',
  }),
  buildOffer({
    name: title,
    priceCurrency: 'EUR',
    priceSpecification: {
      '@type': 'PriceSpecification',
      priceCurrency: 'EUR',
      ...(priceFrom ? { minPrice: priceFrom } : {}),
    },
  }),
  ...pageJsonLd,
];

const methodStepsHtml = await Astro.slots.render('method-steps');
const methodAsideHtml = await Astro.slots.render('method-aside');
const deliverablesHtml = await Astro.slots.render('deliverables');
const deliverablesAsideHtml = await Astro.slots.render('deliverables-aside');
const proofQuoteHtml = await Astro.slots.render('proof-quote');
const proofAttrHtml = await Astro.slots.render('proof-attr');
const proofMetricsHtml = await Astro.slots.render('proof-metrics');

const stripHtml = (html: string) =>
  html
    .replace(/<br\s*\/?>/gi, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const extract = (html: string, selectorClass: string) => {
  const match = html.match(new RegExp(`<[^>]*class=["'][^"']*${selectorClass}[^"']*["'][^>]*>([\\s\\S]*?)<\\/[^>]+>`, 'i'));
  return match ? stripHtml(match[1] ?? '') : '';
};

const extractTag = (html: string, tag: string) => {
  const match = html.match(new RegExp(`<${tag}[^>]*>([\\s\\S]*?)<\\/${tag}>`, 'i'));
  return match ? stripHtml(match[1] ?? '') : '';
};

const methodEvents = methodStepsHtml
  .split(/<div class=["']step["'][^>]*>/)
  .slice(1)
  .map((block) => ({
    num: extract(block, 'step-n'),
    meta: extract(block, 'step-k'),
    title: extractTag(block, 'h3'),
    body: extractTag(block, 'p'),
  }))
  .filter((event) => event.title && event.body);

const deliverables = deliverablesHtml
  .split(/<div class=["']del-card["'][^>]*>/)
  .slice(1)
  .map((block) => ({
    title: extractTag(block, 'h3'),
    body: extractTag(block, 'p'),
    tag: extract(block, 'del-tag'),
  }))
  .filter((item) => item.title && item.body);

const proofMetrics = Array.from(
  proofMetricsHtml.matchAll(/<div>\s*<div class=["']metric-v["']>([\s\S]*?)<\/div>\s*<div class=["']metric-l["']>([\s\S]*?)<\/div>\s*<\/div>/g)
).map((match) => ({
  value: stripHtml(match[1] ?? ''),
  label: stripHtml(match[2] ?? ''),
}));

const deliverableClasses = [
  'deliverable',
  'deliverable',
  'deliverable',
  'deliverable',
  'deliverable',
  'deliverable',
];

const metricPlacements = [
  { class: 'col-3 start-1', size: 'lg', align: 'left', variant: 'default' },
  { class: 'col-3 start-5', size: 'lg', align: 'center', variant: 'default' },
  { class: 'col-3 start-9', size: 'hero', align: 'right', variant: 'accent' },
  { class: 'col-3 start-2', size: 'md', align: 'left', variant: 'default' },
  { class: 'col-3 start-7', size: 'md', align: 'right', variant: 'default' },
  { class: 'col-3 start-10', size: 'md', align: 'right', variant: 'default' },
] as const;

const growthToolRows = [
  ['Modèle raisonnement', 'Claude Sonnet 4.6', 'Scoring, séquences, articles'],
  ['Modèle volume', 'Claude Haiku 4.5', 'Qualification, déduplication'],
  ['Modèle créatif', 'Claude Opus 4.7', 'Articles longs, landing'],
  ['CRM', 'HubSpot / Salesforce / Pipedrive', 'Au choix client'],
  ['Email', 'Resend / Postmark / SendGrid', 'Délivrabilité'],
  ['Search', 'Google Search Console + APIs', 'Indexation'],
  ['Analytics', 'GA4 + Mixpanel', 'Conversion'],
  ['Workflow', 'LangGraph open-source', 'Orchestration'],
  ['Hébergement', 'Vercel / Cloudflare', 'Performance'],
];
---
<Base {title} {description} additionalJsonLd={offreSchemas}>
    <Breadcrumb
      lang={lang}
      items={[
        { label: lang === 'fr' ? 'Accueil' : 'Home', href: lang === 'fr' ? '/' : '/en' },
        { label: lang === 'fr' ? 'Offres' : 'Services', href: lang === 'fr' ? '/offres' : '/en/offres' },
        { label: tierLabel },
      ]}
    />
    {/* ────────── 1. HERO ────────── */}
    <section class="off-hero reveal" data-screen-label="01 Hero" transition:name={`card-${pageTransitionId}`}>
      <svg class="off-hero-geo reveal-blur-clip" viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true" transition:name={`hero-img-${pageTransitionId}`}>
        <circle cx="1200" cy="120" r="340" fill="none" stroke="currentColor" stroke-width=".6" opacity=".18"/>
        <circle cx="1200" cy="120" r="220" fill="none" stroke="var(--accent)" stroke-width=".4" opacity=".25"/>
        <line x1="0" y1="400" x2="1440" y2="280" stroke="currentColor" stroke-width=".4" opacity=".12"/>
      </svg>
      <div class="wrap g12 g12--full">
        <nav class="off-hero-bc" aria-label="Fil d'Ariane">
          <a href="/offres">Offres</a>
          <span aria-hidden="true">/</span>
          <span>{tierLabel}</span>
        </nav>
        <div class="off-hero-tier">{tier}</div>
        <h1 class="off-hero-title reveal-mask-up" transition:name={`hero-h1-${pageTransitionId}`}><slot name="title" /></h1>
        <div class="off-hero-sub">
          <p class="off-hero-lead"><slot name="lead" /></p>
          <div class="off-hero-actions">
            <a class="off-hero-cta" href={ctaHref}>{ctaLabel}</a>
            {meta && <div class="off-hero-meta">{meta}</div>}
          </div>
        </div>
      </div>
    </section>

    {/* ────────── 2. PROBLEM ────────── */}
    <section class="off-sec off-problem reveal-stagger" data-screen-label="02 Problem">
      <div class="wrap wrap-tight g12 g12--standard">
        <div class="off-problem-statement col-prose">
          <DropCap variant="mono">§</DropCap>
          <slot name="problem-statement" />
        </div>
        <div class="off-problem-annotations col-12"><slot name="problem-annotations" /></div>
      </div>
    </section>

    {/* ────────── 3. METHOD ────────── */}
    <section class="off-sec off-sec-paper off-method reveal-stagger" data-screen-label="03 Method">
      <div class="wrap g12 g12--full">
        <header class="off-sec-hd col-prose">
          <span class="eyebrow">§ Méthode</span>
          <h2><i>Méthode</i><br/>Waimia</h2>
        </header>
        {methodAsideHtml.trim() && (
          <aside class="off-aside off-aside-callout col-aside">
            <Callout variant="note" size="sm">
              <Fragment set:html={methodAsideHtml} />
            </Callout>
          </aside>
        )}
        <div class="off-steps col-prose">
          {methodEvents.length > 0 ? (
            <Timeline events={methodEvents} numbered={true} orientation="vertical" />
          ) : (
            <Fragment set:html={methodStepsHtml} />
          )}
        </div>
      </div>
    </section>

    {/* ────────── 4. DELIVERABLES ────────── */}
    <section class="off-sec off-deliverables reveal-stagger" data-screen-label="04 Deliverables">
      <div class="wrap g12 g12--full">
        <header class="off-sec-hd col-12">
          <span class="eyebrow">§ Livrables</span>
          <h2>Ce qu'on<br/><i>dépose</i> chez vous</h2>
          {deliverablesAsideHtml.trim() && (
            <p class="off-del-lead" set:html={deliverablesAsideHtml} />
          )}
        </header>
        <div class="off-del-grid col-12">
          {deliverables.length > 0 ? (
            deliverables.map((item, index) => (
              <article class={`${deliverableClasses[index % deliverableClasses.length]} reveal-zoom-in`}>
                <span class="del-tag">{item.tag}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))
          ) : (
            <Fragment set:html={deliverablesHtml} />
          )}
        </div>
      </div>
    </section>

    {/* ────────── 5. PROOF ────────── */}
    <section class="off-sec off-sec-paper off-proof reveal-stagger" data-screen-label="05 Proof">
      <div class="wrap g12 g12--full">
        <header class="off-sec-hd col-12">
          <span class="eyebrow">§ Avant / Après</span>
          <h2>Signal<br/><i>terrain</i></h2>
        </header>
        <div class="off-proof-band col-12 g12">
          <div class="off-proof-main col-5 start-1">
            <PullQuote attribution={stripHtml(proofAttrHtml)} variant="inline">
              <Fragment set:html={proofQuoteHtml} />
            </PullQuote>
          </div>
          <div class="off-proof-aside col-7 start-6">
            <div class="off-proof-metrics g12">
              {proofMetrics.length > 0 ? (
                proofMetrics.map((metric, index) => {
                  const placement = metricPlacements[index % metricPlacements.length];
                  return (
                    <>
                      {index === 3 && (
                        <div class="col-12">
                          <Dingbat variant="rule" size="lg" />
                        </div>
                      )}
                      <div class={placement.class}>
                        <KeyMetric
                          value={metric.value}
                          label={metric.label}
                          size={placement.size}
                          align={placement.align}
                          variant={placement.variant}
                        />
                      </div>
                    </>
                  );
                })
              ) : (
                <Fragment set:html={proofMetricsHtml} />
              )}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* ────────── 6. RELATED (optionnel) ────────── */}
    {tierLabel === 'Growth System IA' && (
      <section class="off-tools off-sec off-sec-paper reveal" data-screen-label="06 Tools">
        <div class="wrap g12 g12--full">
          <header class="off-sec-hd col-12">
            <span class="eyebrow">§ Stack</span>
            <h2><i>Stack</i><br/>déployée</h2>
          </header>
          <div class="col-12 off-tools-inner">
            <EditorialTable
              caption="Stack outils déployés"
              columns={['Catégorie', 'Outil', 'Rôle']}
              rows={growthToolRows}
              align="left"
              variant="editorial"
            />
            <p class="off-tools-note">Vous gardez la stack quand on part. Pas de captivité.</p>
          </div>
        </div>
      </section>
    )}
    <div class="off-related">
      <slot name="related" />
    </div>

    {/* ────────── 7. CTA ────────── */}
    <section class="off-sec off-sec-dark reveal" data-screen-label="07 CTA">
      <div class="wrap wrap-tight">
        <div class="off-cta-final">
          <h2><i><slot name="cta-title">Prêt à<br/>déployer ?</slot></i></h2>
          <div class="off-cta-body">
            <p><slot name="cta-body">Cadrage en 45 minutes. Nous auditons votre contexte et proposons un plan d'action concret — sans engagement.</slot></p>
            <div class="off-cta-btns">
              <a class="btn-accent" href="/contact">Prendre rendez-vous →</a>
              <a class="btn-light" href="/offres">Toutes les offres</a>
            </div>
          </div>
        </div>
      </div>
    </section>
    <slot name="body-end" />
</Base>

<style>
  /* ───── Hero ───── */
  .off-hero {
    position: relative;
    padding: clamp(72px, 8vw, 112px) 0 clamp(48px, 5.5vw, 88px);
    overflow: hidden;
    color: var(--ink);
  }
  .off-hero .wrap {
    position: relative;
    z-index: 1;
  }
  .off-hero-bc,
  .off-hero-tier,
  .off-hero-title,
  .off-hero-sub {
    grid-column: 1 / -1;
  }
  .off-hero-geo {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none;
  }
  .off-hero-bc {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex; gap: 8px; align-items: center;
    margin-bottom: 24px;
  }
  .off-hero-bc a { color: var(--muted); transition: color 220ms var(--ease); }
  .off-hero-bc a:hover { color: var(--accent); }
  .off-hero-tier {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .off-hero-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 148px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    font-weight: 400;
    margin: 0 0 32px;
    text-wrap: balance;
  }
  .off-hero-title :global(i) { color: var(--accent); font-style: italic; }
  .off-hero-sub {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(24px, 4vw, 64px);
    align-items: end;
    max-width: 1100px;
  }
  .off-hero-lead {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.4;
    color: var(--ink);
    font-style: italic;
    margin: 0;
  }
  .off-hero-lead :global(span) { color: var(--accent); display: block; margin-top: 8px; }
  .off-hero-actions { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .off-hero-cta {
    display: inline-block;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 2px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: transform 220ms var(--ease), box-shadow 220ms var(--ease);
  }
  .off-hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
  .off-hero-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* ───── Sec common ───── */
  .off-sec { padding: clamp(48px, 5.5vw, 76px) 0; position: relative; }
  .off-sec + .off-sec,
  .off-related + .off-sec { margin-block-start: 0; }
  .off-method,
  .off-proof { padding-block: clamp(56px, 6.5vw, 88px); }
  .off-sec-dark { margin-block-start: var(--section-grand); }
  .off-sec-paper { background: var(--paper-2, #EFEBE2); border-block: 1px solid var(--hairline); }
  .off-sec-dark { background: var(--ink); color: var(--paper); }
  .off-sec-dark :global(.kicker) { color: var(--accent); }
  .off-sec-hd {
    margin-bottom: clamp(20px, 2.5vw, 36px);
  }
  .off-sec-hd h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 72px);
    line-height: 0.96;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: 8px 0 0;
  }
  .off-sec-hd :global(i) { color: var(--accent); font-style: italic; }
  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-eyebrow);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono);
    color: var(--accent);
    margin-bottom: var(--space-3);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--accent);
  }
  .off-aside {
    font-family: var(--font-display);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.5;
    color: var(--muted);
    font-style: italic;
    max-width: 480px;
    margin: 0;
  }
  .off-aside-callout {
    align-self: end;
  }
  .off-aside-callout :global(.callout) {
    margin: 0;
  }

  /* ───── Problem ───── */
  .off-problem .wrap-tight {
    max-width: var(--col-full);
  }
  .off-problem-statement {
    font-family: var(--font-display);
    font-size: clamp(28px, 4.6vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: clamp(24px, 3vw, 40px);
    text-wrap: balance;
  }
  .off-problem-statement :global(.drop-cap) {
    margin-right: 0.16em;
  }
  .off-problem-statement :global(em) { color: var(--accent); font-style: italic; }
  .off-problem-annotations {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    margin-top: var(--space-8);
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
  }
  .off-problem-annotations :global(> div) {
    padding: var(--space-6) var(--space-5);
    border-right: 1px solid var(--hairline);
  }
  .off-problem-annotations :global(> div:last-child) { border-right: none; }
  .off-problem-annotations :global(.ann-value) {
    font-family: var(--font-display);
    font-size: clamp(40px, 4vw, 56px);
    color: var(--accent);
    line-height: 1;
    margin-bottom: 8px;
    font-weight: 400;
  }
  .off-problem-annotations :global(.ann-label) {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    line-height: 1.4;
  }

  /* ───── Steps (Method) ───── */
  .off-steps {
    margin-top: var(--space-3);
  }
  .off-steps :global(.timeline-vertical) { margin: 0; }
  .off-steps :global(.step) {
    counter-increment: step;
    padding-top: 18px;
    border-top: 1px solid currentColor;
    border-color: rgba(0,0,0,0.12);
  }
  .off-steps :global(.step-n) {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 0.85;
    color: var(--accent);
    margin-bottom: 16px;
    font-weight: 400;
  }
  .off-steps :global(.step-k) {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .off-steps :global(.step h3) {
    font-family: var(--font-display);
    font-size: clamp(20px, 1.6vw, 24px);
    line-height: 1.2;
    margin: 0 0 12px;
    font-weight: 400;
  }
  .off-steps :global(.step p) { font-size: 15px; line-height: 1.55; color: var(--ink); margin: 0; }

  /* ───── Deliverables ───── */
  .off-del-lead {
    font-family: var(--font-display);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.5;
    color: var(--muted);
    font-style: italic;
    margin: var(--space-3) 0 0;
    max-width: 520px;
  }
  .off-del-grid {
    margin-top: var(--space-4);
    counter-reset: deliverable-counter;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
