---
import Base from '../../layouts/Base.astro';
import Callout from '../editorial/Callout.astro';
import Timeline from '../editorial/Timeline.astro';
import MethodeProcessDiagram from '../svg/geometric/MethodeProcessDiagram.astro';
import PortraitSimon from '../svg/sumie/PortraitSimon.astro';
import { langFromPath, localizeHref, t } from '../../lib/i18n';

type AuthorStatus = 'active' | 'alumni' | 'guest';

interface EducationItem {
  year: string;
  institution: string;
  degree_fr: string;
  degree_en: string;
  url?: string;
}

interface ExperienceItem {
  year: string;
  role_fr: string;
  role_en: string;
  company: string;
  companyUrl?: string;
  summary_fr?: string;
  summary_en?: string;
}

interface PublicationItem {
  title: string;
  url: string;
  venue: string;
  year: string;
  type?: string;
}

interface AwardItem {
  year: string;
  label_fr: string;
  label_en: string;
}

interface AuthorSocial {
  x?: string;
  linkedin?: string;
  github?: string;
  website?: string;
  email?: string;
  bluesky?: string;
  mastodon?: string;
}

interface Author {
  title_fr: string;
  title_en: string;
  description_fr: string;
  description_en: string;
  role_fr: string;
  role_en: string;
  bio_fr: string;
  bio_en: string;
  photo?: string;
  photoAlt_fr?: string;
  photoAlt_en?: string;
  education: EducationItem[];
  experience: ExperienceItem[];
  publications: PublicationItem[];
  awards: AwardItem[];
  expertise: string[];
  social: AuthorSocial;
  status: AuthorStatus;
  featured: boolean;
  publishedAt?: Date;
  faq_fr?: Array<{ q: string; a: string }>;
  faq_en?: Array<{ q: string; a: string }>;
}

interface ContentItem {
  id: string;
  collection: string;
  data: {
    title_fr: string;
    title_en: string;
    publishedAt: Date;
    description_fr?: string;
    description_en?: string;
  };
}

interface Props {
  author: Author;
  essays: ContentItem[];
  shortPosts: ContentItem[];
  cookbooks: ContentItem[];
  livresBlancs: ContentItem[];
  veilleIA: ContentItem[];
}

const { author, essays, shortPosts, cookbooks, livresBlancs, veilleIA } = Astro.props as Props;
const lang = langFromPath(Astro.url.pathname);
const pageTransitionId = Astro.url.pathname
  .replace(/^\/(?:en\/)?/, '')
  .replace(/\/$/, '')
  .replace(/[^a-z0-9]+/gi, '-')
  .replace(/^-|-$/g, '') || 'home';
const locale = lang === 'fr' ? 'fr-FR' : 'en-US';
const displayName = lang === 'fr' ? author.title_fr : author.title_en;
const role = lang === 'fr' ? author.role_fr : author.role_en;
const description = lang === 'fr' ? author.description_fr : author.description_en;
const bio = lang === 'fr' ? author.bio_fr : author.bio_en;
const teamHref = localizeHref('/equipe', lang);
const contactHref = localizeHref('/contact', lang);
const resourcesHref = localizeHref('/ressources', lang);

const socialUrls = [
  author.social?.linkedin,
  author.social?.x,
  author.social?.github,
  author.social?.website,
  author.social?.bluesky,
  author.social?.mastodon,
].filter((url): url is string => Boolean(url));

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: displayName,
  jobTitle: role,
  description: bio.split('\n')[0]?.slice(0, 250) ?? description,
  image: author.photo ? `https://waimia.com${author.photo}` : undefined,
  sameAs: socialUrls,
  worksFor: {
    '@type': 'Organization',
    name: 'Waimia',
    url: 'https://waimia.com',
  },
};

const profilePageLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: personLd,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t({ fr: 'Accueil', en: 'Home' }, lang),
      item: lang === 'fr' ? 'https://waimia.com/' : 'https://waimia.com/en/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t({ fr: "L'équipe", en: 'The team' }, lang),
      item: `https://waimia.com${teamHref}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: displayName,
      item: Astro.url.href,
    },
  ],
};

const jsonLd = [personLd, profilePageLd, breadcrumbLd];
const bioParagraphs = bio.trim().split(/\n\s*\n/).filter(Boolean);
const lede = (bioParagraphs[0] ?? description).replace(/\*\*/g, '');

const accentLastWord = (value: string) => {
  const parts = value.trim().split(/\s+/);
  const accent = parts.pop() ?? value;
  return { lead: parts.join(' '), accent };
};

const nameParts = accentLastWord(displayName);
const formatDate = (date: Date) => new Date(date).toLocaleDateString(locale, {
  year: 'numeric',
  month: 'short',
});

const titleFor = (item: ContentItem) => lang === 'fr' ? item.data.title_fr : item.data.title_en;
const excerptFor = (item: ContentItem) => lang === 'fr'
  ? item.data.description_fr
  : (item.data.description_en ?? item.data.description_fr);
const hrefFor = (base: string, id: string) => localizeHref(`${base}/${id}`, lang);

const method = [
  {
    name: t({ fr: 'Cartographie', en: 'Mapping' }, lang),
    description: t({
      fr: 'On regarde le métier réel, les frictions, les outils, les dépendances et les décisions déjà prises hors système.',
      en: 'We inspect the real work, friction, tools, dependencies and decisions already made outside the system.',
    }, lang),
  },
  {
    name: t({ fr: 'Priorisation', en: 'Prioritisation' }, lang),
    description: t({
      fr: 'On classe les workflows par ROI, risque opérationnel, temps de retour et capacité interne à les maintenir.',
      en: 'We rank workflows by ROI, operational risk, payback time and internal ability to maintain them.',
    }, lang),
  },
  {
    name: t({ fr: 'Câblage', en: 'Wiring' }, lang),
    description: t({
      fr: "On connecte l'IA aux outils existants : CRM, inbox, tableurs, bases métier, reporting, sans théâtre technique.",
      en: 'We connect AI to the existing tools: CRM, inbox, spreadsheets, business data and reporting, without technical theatre.',
    }, lang),
  },
  {
    name: t({ fr: 'Mesure', en: 'Measurement' }, lang),
    description: t({
      fr: 'Chaque workflow a sa métrique avant/après : temps gagné, pipeline reconnecté, coûts évités, qualité produite.',
      en: 'Every workflow gets a before/after metric: time saved, pipeline reconnected, costs avoided, quality produced.',
    }, lang),
  },
  {
    name: t({ fr: 'Passation', en: 'Handover' }, lang),
    description: t({
      fr: 'Les équipes reprennent la main avec une documentation courte, des rituels de pilotage et une stack compréhensible.',
      en: 'Teams take control with short documentation, management rituals and a stack they can understand.',
    }, lang),
  },
];

const curriculumEvents = [
  ...author.experience.map((item) => ({
    num: item.year,
    title: lang === 'fr' ? item.role_fr : item.role_en,
    meta: item.company,
    body: lang === 'fr'
      ? (item.summary_fr ?? item.company)
      : (item.summary_en ?? item.company),
  })),
  ...author.education.map((item) => ({
    num: item.year,
    title: lang === 'fr' ? item.degree_fr : item.degree_en,
    meta: item.institution,
    body: item.institution,
  })),
  ...author.awards.map((item) => ({
    num: item.year,
    title: lang === 'fr' ? item.label_fr : item.label_en,
    meta: t({ fr: 'Distinction', en: 'Award' }, lang),
    body: lang === 'fr' ? item.label_fr : item.label_en,
  })),
];

const resourceGroups = [
  {
    label: t({ fr: 'Notes', en: 'Notes' }, lang),
    hrefBase: '/ressources/blog',
    items: shortPosts,
  },
  {
    label: t({ fr: 'Cookbooks', en: 'Cookbooks' }, lang),
    hrefBase: '/ressources/cookbooks',
    items: cookbooks,
  },
  {
    label: t({ fr: 'Livres blancs', en: 'White papers' }, lang),
    hrefBase: '/ressources/livres-blancs',
    items: livresBlancs,
  },
  {
    label: t({ fr: 'Veille IA', en: 'AI watch' }, lang),
    hrefBase: '/ressources/veille-ia',
    items: veilleIA,
  },
].filter((group) => group.items.length > 0);

const socialItems = [
  author.social.linkedin && { key: 'linkedin', label: 'LinkedIn', url: author.social.linkedin, external: true },
  author.social.x && { key: 'x', label: 'X', url: author.social.x, external: true },
  author.social.github && { key: 'github', label: 'GitHub', url: author.social.github, external: true },
  author.social.website && { key: 'site', label: t({ fr: 'Site', en: 'Site' }, lang), url: author.social.website, external: true },
  author.social.email && { key: 'email', label: 'Email', url: `mailto:${author.social.email}`, external: false },
  author.social.bluesky && { key: 'site', label: 'Bluesky', url: author.social.bluesky, external: true },
  author.social.mastodon && { key: 'site', label: 'Mastodon', url: author.social.mastodon, external: true },
].filter((item): item is { key: string; label: string; url: string; external: boolean } => Boolean(item));

---

<Base
  title={`${displayName} · ${role} · Waimia`}
  description={description}
  jsonLd={jsonLd}
>
  <div class="author-page">
    <section class="author-hero g12 g12--full reveal" transition:name={`card-${pageTransitionId}`}>
      <div class="author-hero-copy col-7">
        <nav class="author-breadcrumb" aria-label={t({ fr: "Fil d'Ariane", en: 'Breadcrumb' }, lang)}>
          <a href={teamHref}>{t({ fr: "L'équipe", en: 'The team' }, lang)}</a>
          <span aria-hidden="true">/</span>
          <span>{displayName}</span>
        </nav>
        <span class="eyebrow">§ {role}</span>
        <h1 class="author-h1 reveal-mask-up" transition:name={`hero-h1-${pageTransitionId}`}>
          {nameParts.lead && <>{nameParts.lead}</>}<em>{nameParts.accent}</em>
        </h1>
        <p class="author-lede col-prose">{lede}</p>
      </div>

      <figure class="author-portrait col-4 start-9 reveal-zoom-in" aria-label={t({ fr: 'Portrait signature', en: 'Signature portrait' }, lang)} transition:name={`hero-img-${pageTransitionId}`}>
        <PortraitSimon size="lg" variant="default" />
      </figure>
    </section>

    {author.expertise.length > 0 && (
      <section class="author-expertise g12 g12--full" aria-label={t({ fr: 'Expertise', en: 'Expertise' }, lang)}>
        <p class="ap-expertise col-prose">
          {author.expertise.map((item, idx) => (
            <>
              <span class="ap-expertise-item">{item}</span>
              {idx < author.expertise.length - 1 && <span class="ap-sep" aria-hidden="true">&nbsp;·&nbsp;</span>}
            </>
          ))}
        </p>
      </section>
    )}

    <section class="author-why g12 g12--full reveal">
      <header class="col-3 section-eyebrow">
        <span class="eyebrow">§ {t({ fr: 'Pourquoi Waimia', en: 'Why Waimia' }, lang)}</span>
      </header>
      <div class="author-prose col-prose">
        <slot />
      </div>
    </section>

    <section class="author-pullquote g12 g12--full">
      <blockquote class="ap-pullquote col-prose">
        <p>
          {lang === 'fr'
            ? <Fragment set:html="L&rsquo;intelligence artificielle n&rsquo;est pas un outil. C&rsquo;est une <i>nouvelle façon de travailler.</i>&nbsp;" />
            : <Fragment set:html="Artificial intelligence is not a tool. It&rsquo;s <i>a new way of working.</i>&nbsp;" />
          }
        </p>
        <cite class="ap-pullquote-cite">&mdash;&nbsp;Waimia</cite>
      </blockquote>
    </section>

    {essays.length > 0 && (
      <section class="author-essays g12 g12--full">
        <header class="col-12 section-eyebrow reveal">
          <span class="eyebrow">§ Essays · Long form</span>
          <h2 class="display-md">{t({ fr: 'Ce que je publie', en: 'What I publish' }, lang)}</h2>
        </header>
        <ul class="essays-list col-prose">
          {essays.map((essay) => (
            <li class="essay-item reveal">
              <time class="essay-date" datetime={new Date(essay.data.publishedAt).toISOString()}>
                {formatDate(essay.data.publishedAt)}
              </time>
              <div>
                <a href={hrefFor('/ressources/blog', essay.id)} class="essay-link">
                  <h3 class="essay-title">{titleFor(essay)}</h3>
                </a>
                {excerptFor(essay) && <p class="essay-excerpt">{excerptFor(essay)}</p>}
              </div>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="author-method g12 g12--full reveal">
      <header class="col-12 section-eyebrow">
        <span class="eyebrow">§ {t({ fr: 'Méthode', en: 'Method' }, lang)}</span>
        <h2 class="display-md">{t({ fr: 'Comment je travaille', en: 'How I work' }, lang)}</h2>
      </header>
      <div class="author-method-diagram col-12">
        <MethodeProcessDiagram />
      </div>
      <ul class="author-method-list col-prose reveal-stagger">
        {method.map((phase, idx) => (
          <li class="method-item">
            <span class="method-num">{String(idx + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="method-title">{phase.name}</h3>
              <p class="method-body">{phase.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>

    {curriculumEvents.length > 0 && (
      <section class="author-curriculum g12 g12--full reveal">
        <header class="col-12 section-eyebrow">
          <span class="eyebrow">§ Curriculum</span>
          <h2 class="display-md"><em>Curriculum</em></h2>
        </header>
        <div class="col-prose curriculum-wrap">
          <Timeline events={curriculumEvents} numbered={false} />
        </div>
      </section>
    )}

    <section class="author-publications g12 g12--full reveal">
      <header class="col-12 section-eyebrow">
        <span class="eyebrow">§ Publications</span>
        <h2 class="display-md">{t({ fr: 'Articles, notes, manifestes', en: 'Articles, notes, manifestos' }, lang)}</h2>
      </header>

      <div class="publication-manifesto col-prose">
        <Callout variant="manifesto" align="center">
          {t({ fr: 'Pas une stack. Un système. Pas un agent. Une équipe.', en: 'Not a stack. A system. Not an agent. A team.' }, lang)}
          <br />
          {t({ fr: 'Pas une démo. Une mise en production.', en: 'Not a demo. A production release.' }, lang)}
        </Callout>
      </div>

      {author.publications.length > 0 && (
        <ul class="publication-list col-prose">
          {author.publications.map((publication) => (
            <li class="publication-item reveal">
              <a href={publication.url} class="publication-link">
                <span class="publication-title">{publication.title}</span>
                <span class="publication-meta">{publication.venue} · {publication.year}</span>
              </a>
            </li>
          ))}
        </ul>
      )}

      {resourceGroups.length > 0 && (() => {
        const allItems = resourceGroups.flatMap(g => g.items.map(i => ({ ...i, groupLabel: g.label, hrefBase: g.hrefBase })));
        allItems.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());
        const shown = allItems.slice(0, 8);
        return (
          <ol class="ap-resource-index col-prose reveal-stagger">
            {shown.map((item) => (
              <li class="ap-resource-row">
                <time class="ap-resource-date" datetime={new Date(item.data.publishedAt).toISOString()}>
                  {new Date(item.data.publishedAt).getFullYear()}&thinsp;·&thinsp;{String(new Date(item.data.publishedAt).getMonth() + 1).padStart(2, '0')}
                </time>
                <a href={hrefFor(item.hrefBase, item.id)} class="ap-resource-link">
                  <span class="ap-resource-title">{titleFor(item)}</span>
                </a>
                <span class="ap-resource-tag">{item.groupLabel}</span>
              </li>
            ))}
          </ol>
        );
      })()}

      <a href={resourcesHref} class="resources-all col-prose link-hairline">
        {t({ fr: 'Voir toutes les ressources', en: 'See all resources' }, lang)}
      </a>
    </section>

    {socialItems.length > 0 && (
      <section class="author-social g12 g12--full reveal">
        <header class="col-12 section-eyebrow">
          <span class="eyebrow">§ {t({ fr: 'Suivre', en: 'Follow' }, lang)}</span>
        </header>
        <address class="ap-contact col-prose">
          {socialItems.map((item, idx) => (
            <>
              <a
                href={item.url}
                class="ap-contact-item"
                target={item.external ? '_blank' : undefined}
                rel={item.external ? 'noopener noreferrer' : undefined}
              >
                {item.label}
              </a>
              {idx < socialItems.length - 1 && <span class="ap-contact-sep" aria-hidden="true">&nbsp;·&nbsp;</span>}
            </>
          ))}
        </address>
      </section>
    )}

    <section class="author-cta g12 g12--full">
      <div class="col-prose author-cta-inner reveal">
        <span class="eyebrow">§ {t({ fr: 'Travailler ensemble', en: 'Work together' }, lang)}</span>
        <h2 class="display-lg">
          {t({ fr: 'Le mardi on câble.', en: 'On Tuesday we wire.' }, lang)}
          <em>{t({ fr: ' Le vendredi on mesure.', en: ' On Friday we measure.' }, lang)}</em>
        </h2>
        <a href={contactHref} class="btn btn-primary">
          {t({ fr: 'Câbler mon système →', en: 'Wire my system →' }, lang)}
        </a>
      </div>
    </section>
  </div>
</Base>

<style>
  .author-page {
    background: var(--paper);
    color: var(--ink);
  }

  .author-hero,
  .author-expertise,
  .author-why,
  .author-essays,
  .author-method,
  .author-curriculum,
  .author-publications,
  .author-social,
  .author-pullquote,
  .author-cta {
    padding-inline: clamp(20px, 4vw, 48px);
  }

  .author-hero {
    padding-top: clamp(92px, 12vw, 164px);
    padding-bottom: clamp(28px, 5vw, 72px);
    align-items: start;
  }

  .author-breadcrumb {
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: var(--space-5, 24px);
    font-family: var(--font-mono);
    font-size: var(--text-mono-md, 11px);
    letter-spacing: var(--tracking-mono, 0.12em);
    text-transform: uppercase;
    color: var(--muted);
  }

  .author-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .author-breadcrumb a:hover {
    color: var(--accent);
  }

  .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-mono-md, 11px);
    text-transform: uppercase;
    letter-spacing: var(--tracking-mono, 0.12em);
    color: var(--accent);
  }

  .author-h1 {
    font-family: var(--font-display);
    font-size: clamp(72px, 9vw, 148px);
    font-weight: 400;
    line-height: 0.92;
    letter-spacing: var(--tracking-display, -0.03em);
    margin: var(--space-3, 12px) 0 var(--space-6, 32px);
    color: var(--ink);
    text-wrap: balance;
  }

  .author-h1 em,
  .display-md em,
  .display-lg em {
    font-style: italic;
    color: var(--accent);
  }

  .author-lede {
    font-family: var(--font-display);
    font-size: var(--text-lede, clamp(21px, 2vw, 30px));
    line-height: 1.45;
    color: var(--ink-2);
    max-width: 540px;
    margin: 0;
  }

  .author-lede :global(strong) {
    color: var(--ink);
  }

  .author-portrait {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    margin: 0;
    padding-top: var(--space-7, 40px);
    color: var(--ink);
  }

  .author-portrait::before {
    content: '';
    position: absolute;
    width: min(28vw, 360px);
    aspect-ratio: 3 / 4;
    border: 1px solid var(--hairline);
    transform: translate(18px, 18px);
    pointer-events: none;
  }

  .author-portrait :global(svg) {
    position: relative;
    width: min(100%, 280px);
  }

  .author-expertise {
    padding-top: 0;
    padding-bottom: clamp(40px, 5vw, 64px);
  }

  .ap-expertise {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: var(--tracking-mono, 0.12em);
    text-transform: uppercase;
    color: var(--muted);
    margin: 0;
    line-height: 1.8;
  }

  .ap-expertise-item {
    white-space: nowrap;
  }

  .ap-sep {
    color: var(--hairline-strong);
  }

  .author-why,
  .author-pullquote,
  .author-essays,
  .author-method,
  .author-curriculum,
  .author-publications,
  .author-social,
  .author-cta {
    padding-top: clamp(76px, 9vw, 128px);
    padding-bottom: clamp(76px, 9vw, 128px);
    border-top: 1px solid var(--hairline);
  }

  .author-method,
  .author-curriculum {
    background: var(--paper-2);
  }

  .section-eyebrow {
    margin-bottom: var(--space-6, 32px);
  }

  .display-md {
    font-family: var(--font-display);
    font-size: clamp(38px, 5vw, 72px);
    font-weight: 400;
    line-height: 0.98;
    letter-spacing: var(--tracking-display, -0.03em);
    margin: var(--space-2, 8px) 0 0;
    text-wrap: balance;
  }

  .display-lg {
    font-family: var(--font-display);
    font-size: clamp(42px, 6.4vw, 96px);
    font-weight: 400;
    line-height: 0.96;
    letter-spacing: var(--tracking-display, -0.03em);
    margin: var(--space-3, 12px) 0 var(--space-6, 32px);
    text-wrap: balance;
  }

  .author-prose {
    font-family: var(--font-display);
    font-size: clamp(18px, 1.45vw, 21px);
    line-height: 1.62;
    color: var(--ink-2);
  }

  .author-prose :global(h2) {
    font-size: clamp(30px, 3.6vw, 48px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: var(--tracking-display, -0.02em);
    color: var(--ink);
    margin: 0 0 var(--space-4, 16px);
    text-wrap: balance;
  }

  .author-prose :global(h2:not(:first-child)) {
    margin-top: var(--space-8, 48px);
  }

  .author-prose :global(h3) {
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 400;
    color: var(--ink);
    margin: var(--space-6, 32px) 0 var(--space-2, 8px);
  }

  .author-prose :global(p) {
    margin: 0 0 var(--space-4, 16px);
