---
import Base from '../../layouts/Base.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import { langFromPath, localizeHref, t } from '../../lib/i18n';

type AuthorStatus = 'active' | 'alumni' | 'guest';

interface EducationItem {
  year: string;
  institution: string;
  degree_fr: string;
  degree_en: string;
  url?: string;
}

interface ExperienceItem {
  year: string;
  role_fr: string;
  role_en: string;
  company: string;
  companyUrl?: string;
  summary_fr?: string;
  summary_en?: string;
}

interface PublicationItem {
  title: string;
  url: string;
  venue: string;
  year: string;
  type?: string;
}

interface AwardItem {
  year: string;
  label_fr: string;
  label_en: string;
}

interface AuthorSocial {
  x?: string;
  linkedin?: string;
  github?: string;
  website?: string;
  email?: string;
  bluesky?: string;
  mastodon?: string;
}

interface Author {
  title_fr: string;
  title_en: string;
  description_fr: string;
  description_en: string;
  role_fr: string;
  role_en: string;
  bio_fr: string;
  bio_en: string;
  photo?: string;
  photoAlt_fr?: string;
  photoAlt_en?: string;
  education: EducationItem[];
  experience: ExperienceItem[];
  publications: PublicationItem[];
  awards: AwardItem[];
  expertise: string[];
  social: AuthorSocial;
  status: AuthorStatus;
  featured: boolean;
  publishedAt?: Date;
  faq_fr?: Array<{ q: string; a: string }>;
  faq_en?: Array<{ q: string; a: string }>;
}

interface ContentItem {
  id: string;
  collection: string;
  data: {
    title_fr: string;
    title_en: string;
    publishedAt: Date;
    description_fr?: string;
  };
}

interface Props {
  author: Author;
  essays: ContentItem[];
  shortPosts: ContentItem[];
  cookbooks: ContentItem[];
  livresBlancs: ContentItem[];
  veilleIA: ContentItem[];
}

const { author, essays, shortPosts, cookbooks, livresBlancs, veilleIA } = Astro.props as Props;
const lang = langFromPath(Astro.url.pathname);
const locale = lang === 'fr' ? 'fr-FR' : 'en-US';
const displayName = lang === 'fr' ? author.title_fr : author.title_en;
const role = lang === 'fr' ? author.role_fr : author.role_en;
const description = lang === 'fr' ? author.description_fr : author.description_en;
const bio = lang === 'fr' ? author.bio_fr : author.bio_en;
const photoAlt = lang === 'fr'
  ? (author.photoAlt_fr ?? displayName)
  : (author.photoAlt_en ?? displayName);
const teamHref = localizeHref('/equipe', lang);

const socialUrls = [
  author.social?.linkedin,
  author.social?.x,
  author.social?.github,
  author.social?.website,
  author.social?.bluesky,
  author.social?.mastodon,
].filter((url): url is string => Boolean(url));

const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: displayName,
  jobTitle: role,
  description: bio.split('\n')[0]?.slice(0, 250) ?? description,
  image: author.photo ? `https://waimia.com${author.photo}` : undefined,
  sameAs: socialUrls,
  worksFor: {
    '@type': 'Organization',
    name: 'Waimia',
    url: 'https://waimia.com',
  },
};

const profilePageLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: personLd,
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: t({ fr: 'Accueil', en: 'Home' }, lang),
      item: lang === 'fr' ? 'https://waimia.com/' : 'https://waimia.com/en/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: t({ fr: "L'équipe", en: 'The team' }, lang),
      item: `https://waimia.com${teamHref}`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: displayName,
      item: Astro.url.href,
    },
  ],
};

const jsonLd = [personLd, profilePageLd, breadcrumbLd];
const bioParagraphs = bio.trim().split(/\n\s*\n/).filter(Boolean);

const accentLastWord = (value: string) => {
  const parts = value.trim().split(/\s+/);
  const accent = parts.pop() ?? value;
  return { lead: parts.join(' '), accent };
};

const nameParts = accentLastWord(displayName);
const formatDate = (date: Date) => new Date(date).toLocaleDateString(locale, {
  year: 'numeric',
  month: 'short',
});

const titleFor = (item: ContentItem) => lang === 'fr' ? item.data.title_fr : item.data.title_en;
const hrefFor = (base: string, id: string) => localizeHref(`${base}/${id}`, lang);

const contentGroups = [
  {
    id: 'essays',
    items: essays,
    kicker: t({ fr: '§ Essays · long-form', en: '§ Essays · long-form' }, lang),
    titleParts: accentLastWord(t({ fr: 'Essays', en: 'Essays' }, lang)),
    hrefBase: '/ressources/blog',
    paper: false,
  },
  {
    id: 'short-posts',
    items: shortPosts,
    kicker: t({ fr: '§ Notes · short posts', en: '§ Notes · short posts' }, lang),
    titleParts: accentLastWord(t({ fr: 'Short posts', en: 'Short posts' }, lang)),
    hrefBase: '/ressources/blog',
    paper: false,
  },
  {
    id: 'cookbooks',
    items: cookbooks,
    kicker: t({ fr: '§ Cookbooks · guides actionnables', en: '§ Cookbooks · actionable guides' }, lang),
    titleParts: accentLastWord(t({ fr: 'Cookbooks', en: 'Cookbooks' }, lang)),
    hrefBase: '/ressources/cookbooks',
    paper: true,
  },
  {
    id: 'livres-blancs',
    items: livresBlancs,
    kicker: t({ fr: '§ Livres blancs · lead magnets', en: '§ White papers · lead magnets' }, lang),
    titleParts: accentLastWord(t({ fr: 'Livres blancs', en: 'White papers' }, lang)),
    hrefBase: '/ressources/livres-blancs',
    paper: false,
  },
  {
    id: 'veille-ia',
    items: veilleIA,
    kicker: t({ fr: '§ Veille IA · notes mensuelles', en: '§ AI watch · monthly notes' }, lang),
    titleParts: accentLastWord(t({ fr: 'Veille IA', en: 'AI watch' }, lang)),
    hrefBase: '/ressources/veille-ia',
    paper: true,
  },
] as const;
---
<Base
  title={`${displayName} · ${role} · Waimia`}
  description={description}
  jsonLd={jsonLd}
>
  {/* 1 -- HERO Author */}
  <section class="auth-hero">
    <div class="wrap auth-hero-grid">
      <div class="auth-hero-copy">
        <nav class="auth-bc" aria-label={t({ fr: "Fil d'Ariane", en: 'Breadcrumb' }, lang)}>
          <a href={teamHref}>{t({ fr: "L'équipe", en: 'The team' }, lang)}</a>
          <span aria-hidden="true">/</span>
          <span>{displayName}</span>
        </nav>

        <Kicker class="auth-kicker" tone="accent">§ {role}</Kicker>
        <h1 class="auth-name">
          {nameParts.lead && <>{nameParts.lead} </>}<i>{nameParts.accent}</i>
        </h1>

        <div class="auth-bio">
          {bioParagraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>

      {author.photo && (
        <figure class="auth-photo-frame">
          <img src={author.photo} alt={photoAlt} class="auth-photo" loading="eager" decoding="async" />
        </figure>
      )}
    </div>
  </section>

  {/* 2 -- ESSAYS, 3 -- SHORT POSTS, 4 -- COOKBOOKS, 5 -- LIVRES BLANCS, 6 -- VEILLE IA */}
  {contentGroups.map((group) => group.items.length > 0 && (
    <section class:list={['auth-list-sec', { 'auth-paper-2': group.paper }]} id={group.id}>
      <div class="wrap-tight">
        <Kicker>{group.kicker}</Kicker>
        <h2 class="auth-list-h2">
          {group.titleParts.lead && <>{group.titleParts.lead} </>}<i>{group.titleParts.accent}</i>
        </h2>
        <ul class="auth-list">
          {group.items.map((item) => (
            <li>
              <a href={hrefFor(group.hrefBase, item.id)}>
                <span class="auth-list-title">{titleFor(item)}</span>
                <time class="auth-list-date" datetime={new Date(item.data.publishedAt).toISOString()}>
                  {formatDate(item.data.publishedAt)}
                </time>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}

  {/* 7 -- BIO LONG-FORM (Content slot from MDX body) */}
  <section class="auth-content-sec">
    <div class="wrap-tight auth-prose">
      <slot />
    </div>
  </section>

  {/* 8 -- CV (Education + Experience) */}
  {(author.education.length > 0 || author.experience.length > 0 || author.awards.length > 0) && (
    <section class="auth-cv-sec auth-paper-2">
      <div class="wrap-tight">
        <Kicker>§ Curriculum</Kicker>
        <h2 class="auth-list-h2"><i>Curriculum</i></h2>

        {author.experience.length > 0 && (
          <div class="auth-cv-block">
            <h3 class="auth-cv-h3">{t({ fr: 'Expérience', en: 'Experience' }, lang)}</h3>
            <ul class="auth-cv-list">
              {author.experience.map((item) => (
                <li class="auth-cv-row">
                  <span class="auth-cv-year">{item.year}</span>
                  <div class="auth-cv-content">
                    <div class="auth-cv-role">
                      {lang === 'fr' ? item.role_fr : item.role_en}
                      {item.companyUrl ? (
                        <>{' · '}<a href={item.companyUrl}>{item.company}</a></>
                      ) : (
                        <>{' · '}{item.company}</>
                      )}
                    </div>
                    {(lang === 'fr' ? item.summary_fr : item.summary_en) && (
                      <p class="auth-cv-summary">{lang === 'fr' ? item.summary_fr : item.summary_en}</p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}

        {author.education.length > 0 && (
          <div class="auth-cv-block">
            <h3 class="auth-cv-h3">{t({ fr: 'Formation', en: 'Education' }, lang)}</h3>
            <ul class="auth-cv-list">
              {author.education.map((item) => (
                <li class="auth-cv-row">
                  <span class="auth-cv-year">{item.year}</span>
                  <div class="auth-cv-content">
                    <div class="auth-cv-role">
                      {lang === 'fr' ? item.degree_fr : item.degree_en}
                      {item.url ? (
                        <>{' · '}<a href={item.url}>{item.institution}</a></>
                      ) : (
                        <>{' · '}{item.institution}</>
                      )}
                    </div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}

        {author.awards.length > 0 && (
          <div class="auth-cv-block">
            <h3 class="auth-cv-h3">{t({ fr: 'Distinctions', en: 'Awards' }, lang)}</h3>
            <ul class="auth-cv-list">
              {author.awards.map((item) => (
                <li class="auth-cv-row">
                  <span class="auth-cv-year">{item.year}</span>
                  <div class="auth-cv-content">
                    <div class="auth-cv-role">{lang === 'fr' ? item.label_fr : item.label_en}</div>
                  </div>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>
  )}

  {/* 9 -- PUBLICATIONS EXTERNES */}
  {author.publications.length > 0 && (
    <section class="auth-list-sec">
      <div class="wrap-tight">
        <Kicker>{t({ fr: '§ Publications · papers, conférences, podcasts', en: '§ Publications · papers, talks, podcasts' }, lang)}</Kicker>
        <h2 class="auth-list-h2"><i>Publications</i></h2>
        <ul class="auth-list">
          {author.publications.map((publication) => (
            <li>
              <a href={publication.url}>
                <span class="auth-list-title">{publication.title}</span>
                <span class="auth-list-date">{publication.venue} · {publication.year}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* 10 -- EXPERTISE */}
  {author.expertise.length > 0 && (
    <section class="auth-pills-sec">
      <div class="wrap-tight">
        <Kicker>§ Expertise</Kicker>
        <div class="auth-pills">
          {author.expertise.map((item) => <span class="auth-pill">{item}</span>)}
        </div>
      </div>
    </section>
  )}

  {/* 11 -- SOCIAL ROW */}
  <section class="auth-social-sec">
    <div class="wrap-tight">
      <Kicker>{t({ fr: '§ Suivre', en: '§ Follow' }, lang)}</Kicker>
      <div class="auth-social">
        {author.social.linkedin && <a href={author.social.linkedin} class="auth-social-link">LinkedIn -></a>}
        {author.social.x && <a href={author.social.x} class="auth-social-link">X -></a>}
        {author.social.github && <a href={author.social.github} class="auth-social-link">GitHub -></a>}
        {author.social.bluesky && <a href={author.social.bluesky} class="auth-social-link">Bluesky -></a>}
        {author.social.mastodon && <a href={author.social.mastodon} class="auth-social-link">Mastodon -></a>}
        {author.social.website && <a href={author.social.website} class="auth-social-link">{t({ fr: 'Site personnel', en: 'Personal site' }, lang)} -></a>}
        {author.social.email && <a href={`mailto:${author.social.email}`} class="auth-social-link">{author.social.email}</a>}
      </div>
    </div>
  </section>
</Base>

<style>
  .auth-hero {
    padding: clamp(80px, 10vw, 140px) 0 clamp(48px, 6vw, 80px);
    color: var(--ink);
    background: var(--paper);
  }

  .wrap {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  .wrap-tight {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }

  .auth-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 880px) minmax(220px, 320px);
    gap: clamp(36px, 6vw, 96px);
    align-items: end;
  }

  .auth-hero-copy {
    min-width: 0;
  }

  .auth-bc {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    gap: 8px;
    align-items: center;
    margin-bottom: 20px;
  }

  .auth-bc a {
    color: var(--muted);
    text-decoration: none;
  }

  .auth-bc a:hover {
    color: var(--accent);
  }

  :global(.auth-kicker) {
    margin-bottom: 24px;
  }

  .auth-name {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 128px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    font-weight: 400;
    margin: 0 0 32px;
    text-wrap: balance;
  }

  .auth-name i,
  .auth-list-h2 i,
  .auth-prose :global(h2 i) {
    color: var(--accent);
    font-style: italic;
  }

  .auth-bio {
    font-family: var(--font-display);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink);
    max-width: 720px;
  }

  .auth-bio p {
    margin: 0 0 18px;
  }

  .auth-bio p:last-child {
    margin: 0;
  }

  .auth-photo-frame {
    margin: 0;
    justify-self: end;
  }

  .auth-photo {
    display: block;
    width: clamp(200px, 24vw, 320px);
    height: auto;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
  }

  .auth-list-sec {
    padding: clamp(72px, 8vw, 120px) 0;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    background: var(--paper);
  }

  .auth-paper-2 {
    background: var(--paper-2, #efebe2);
    border-top: 0;
  }

  .auth-list-h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 0.96;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: 8px 0 32px;
    text-wrap: balance;
  }

  .auth-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(0, 0, 0, 0.12);
  }

  .auth-list li {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .auth-list a {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 24px;
    padding: 18px 0;
    color: var(--ink);
    text-decoration: none;
    transition:
      padding 220ms var(--ease, cubic-bezier(0.2, 0.8, 0.2, 1)),
      color 220ms var(--ease, cubic-bezier(0.2, 0.8, 0.2, 1));
  }

  .auth-list a:hover {
    padding-left: 8px;
    color: var(--accent);
  }

  .auth-list-title {
    font-family: var(--font-display);
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.35;
  }

  .auth-list-date {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    flex-shrink: 0;
  }

  .auth-content-sec,
  .auth-cv-sec,
  .auth-pills-sec {
    padding: clamp(72px, 8vw, 120px) 0;
  }

  .auth-content-sec {
    background: var(--paper);
  }

  .auth-prose {
    font-family: var(--font-display);
    font-size: clamp(17px, 1.4vw, 19px);
    line-height: 1.65;
    color: var(--ink);
  }

  .auth-prose :global(h2) {
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.1;
    letter-spacing: -0.012em;
    margin: 48px 0 16px;
    font-weight: 400;
    text-wrap: balance;
  }

  .auth-prose :global(h3) {
    font-size: clamp(20px, 1.8vw, 24px);
    margin: 32px 0 12px;
    font-weight: 400;
  }

  .auth-prose :global(p) {
    margin: 0 0 18px;
  }

  .auth-prose :global(ul),
  .auth-prose :global(ol) {
    margin: 0 0 24px 24px;
  }

  .auth-prose :global(li) {
    margin-bottom: 8px;
  }

  .auth-prose :global(strong) {
    color: var(--accent);
  }

  .auth-prose :global(a) {
    color: var(--accent);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .auth-prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding-left: 24px;
    margin: 32px 0;
    font-style: italic;
    color: var(--muted);
  }

  .auth-cv-block {
    margin-bottom: 48px;
  }

  .auth-cv-block:last-child {
    margin-bottom: 0;
  }

  .auth-cv-h3 {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 20px;
  }

  .auth-cv-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .auth-cv-row {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 24px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    align-items: baseline;
  }

  .auth-cv-year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
  }

  .auth-cv-content {
    font-family: var(--font-display);
  }

  .auth-cv-role {
    font-size: 17px;
    line-height: 1.45;
  }

  .auth-cv-role a {
    color: var(--accent);
    text-decoration: none;
  }

  .auth-cv-role a:hover {
    text-decoration: underline;
  }

  .auth-cv-summary {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.5;
    margin: 8px 0 0;
    font-style: italic;
  }

  .auth-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 16px;
  }

  .auth-pill {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 14px;
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 999px;
    color: var(--ink);
    transition:
      border-color 220ms,
      color 220ms;
  }

  .auth-pill:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .auth-social-sec {
    padding: clamp(72px, 8vw, 120px) 0 clamp(80px, 10vw, 140px);
    background: var(--paper);
  }

  .auth-social {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    margin-top: 16px;
  }

  .auth-social-link {
    font-family: var(--font-display);
    font-size: 18px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 0, 0, 0.2);
    padding-bottom: 2px;
    transition:
      color 220ms,
      border-color 220ms;
  }

  .auth-social-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  @media (max-width: 900px) {
    .auth-hero-grid {
      grid-template-columns: 1fr;
      align-items: start;
    }

    .auth-photo-frame {
      justify-self: start;
    }
  }

  @media (max-width: 700px) {
    .auth-cv-row {
      grid-template-columns: 1fr;
      gap: 4px;
    }

    .auth-list a {
      flex-direction: column;
      gap: 4px;
      align-items: flex-start;
    }
  }
</style>
