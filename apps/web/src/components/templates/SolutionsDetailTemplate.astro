---
/**
 * SolutionsDetailTemplate · sub-page Solutions (focus département métier)
 *
 * Sections (7) sémantiquement différenciées d'OffresDetail :
 *   1. Hero Department · breadcrumb + DEPT badge + h1 + lead italique + tags row + meta + SVG rect rotated 15°
 *   2. Pain Points · 3 cards numérotées 01/02/03 (empathie métier "pourquoi ça bloque")
 *   3. Workflows Table · BRIQUE SIGNATURE 5 colonnes : numéro / kicker+h3 / model / gain / how
 *   4. ROI Band Dark · BRIQUE SIGNATURE 4 chiffres énormes 88px en background ink
 *   5. Case Study Split · split dark/light 50/50 (case dark + résultats light)
 *   6. Department Stack · 3×2 cards (kicker + h3 + body + pill type)
 *   7. CTA Dept-Augmented Dark · h2 personnalisé "Votre équipe X, augmentée."
 *
 * Briques signatures Solutions : Workflows Table + ROI Band (densité métier).
 * Géométrie hero : rectangle rotated 15° (≠ cercles d'OffresDetail) — signal visuel de différenciation.
 * Source handoff : project/pages/solutions/detail.html (lignes 157-280, dict SOLUTIONS).
 *
 * Usage minimal (props) :
 *   <SolutionsDetailTemplate
 *     dept="DÉPARTEMENT"
 *     deptLabel="Finance & Comptabilité"
 *     meta="Finance · Comptabilité · Contrôle de gestion"
 *     title="Solutions · Finance"
 *     description="Réconciliation automatisée, mémos financiers, reporting intelligent."
 *   >
 *     <Fragment slot="title"><i>Finance</i><br/>&amp; Comptabilité</Fragment>
 *     <Fragment slot="lead">Lead html...</Fragment>
 *     <Fragment slot="tags">5 pills...</Fragment>
 *     ... etc
 *   </SolutionsDetailTemplate>
 */
import Base from '../../layouts/Base.astro';
import Callout from '../editorial/Callout.astro';
import Timeline from '../editorial/Timeline.astro';
import KeyMetric from '../editorial/KeyMetric.astro';
import EditorialTable from '../editorial/EditorialTable.astro';
import Dingbat from '../editorial/Dingbat.astro';
import SecteurServicesB2B from '../svg/sumie/SecteurServicesB2B.astro';
import SecteurIndustrie from '../svg/sumie/SecteurIndustrie.astro';
import SecteurFinance from '../svg/sumie/SecteurFinance.astro';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';
import { langFromPath } from '../../lib/i18n';

interface Props {
  /** SEO meta · title de la page (browser tab) */
  title: string;
  /** SEO meta · description */
  description: string;
  /** Department badge (kicker au-dessus du h1) ex: "DÉPARTEMENT" */
  dept: string;
  /** Label du breadcrumb second segment ex: "Finance & Comptabilité" */
  deptLabel: string;
  /** Meta sous le CTA hero ex: "Finance · Comptabilité · Contrôle de gestion" */
  meta?: string;
  /** Href du CTA hero (default /contact) */
  ctaHref?: string;
  /** Label du CTA hero (default "Parler à un expert →") */
  ctaLabel?: string;
}

const {
  title,
  description,
  dept,
  deptLabel,
  meta = '',
  ctaHref = '/contact',
  ctaLabel = 'Parler à un expert →',
} = Astro.props;

const lang = langFromPath(Astro.url.pathname);
const painHtml = (await Astro.slots.render('pains')) ?? '';
const painAsideHtml = (await Astro.slots.render('pain-aside')) ?? '';
const workflowsHtml = (await Astro.slots.render('workflows')) ?? '';
const workflowsAsideHtml = (await Astro.slots.render('workflows-aside')) ?? '';
const roiHtml = (await Astro.slots.render('roi')) ?? '';
const stackHtml = (await Astro.slots.render('stack')) ?? '';
const stackAsideHtml = (await Astro.slots.render('stack-aside')) ?? '';

const stripHtml = (html: string) =>
  html
    .replace(/<br\s*\/?>/gi, ' ')
    .replace(/<[^>]+>/g, ' ')
    .replace(/\s+/g, ' ')
    .trim();

const extract = (html: string, selectorClass: string) => {
  const match = html.match(new RegExp(`<[^>]*class=["'][^"']*${selectorClass}[^"']*["'][^>]*>([\\s\\S]*?)<\\/[^>]+>`, 'i'));
  return match ? stripHtml(match[1] ?? '') : '';
};

const extractTag = (html: string, tag: string) => {
  const match = html.match(new RegExp(`<${tag}[^>]*>([\\s\\S]*?)<\\/${tag}>`, 'i'));
  return match ? stripHtml(match[1] ?? '') : '';
};

const splitCards = (html: string, className: string) =>
  html
    .split(new RegExp(`<div class=["'][^"']*${className}[^"']*["'][^>]*>`, 'i'))
    .slice(1);

const frictionPoints = splitCards(painHtml, 'pain-card')
  .map((block, index) => {
    const title = extractTag(block, 'h3');
    const meta = extract(block, 'pk');
    const body = extractTag(block, 'p') || meta || title;
    return {
      num: extract(block, 'pn') || String(index + 1).padStart(2, '0'),
      meta,
      title,
      body,
      variant: index === 0 ? ('highlight' as const) : ('default' as const),
    };
  })
  .filter((event) => event.title && event.body);

const proofMetrics = Array.from(
  roiHtml.matchAll(/<div class=["'](?:roi-cell|[^"']*\broi-cell\b[^"']*)["'][^>]*>[\s\S]*?<div class=["']roi-v["']>([\s\S]*?)<\/div>[\s\S]*?<div class=["']roi-l["']>([\s\S]*?)<\/div>[\s\S]*?<\/div>/g)
).map((match) => ({
  value: stripHtml(match[1] ?? ''),
  label: stripHtml(match[2] ?? ''),
}));

const fallbackProofMetrics = Array.from(
  roiHtml.matchAll(/<div class=["']metric-v["']>([\s\S]*?)<\/div>[\s\S]*?<div class=["']metric-l["']>([\s\S]*?)<\/div>/g)
).map((match) => ({
  value: stripHtml(match[1] ?? ''),
  label: stripHtml(match[2] ?? ''),
}));

const proofMetricRows = proofMetrics.length > 0 ? proofMetrics : fallbackProofMetrics;

const proofMetricPlacements = [
  { class: 'col-4 start-1', size: 'hero', align: 'left', variant: 'default' },
  { class: 'col-4 start-6', size: 'hero', align: 'center', variant: 'accent' },
  { class: 'col-3 start-3', size: 'md', align: 'left', variant: 'default' },
  { class: 'col-3 start-9', size: 'md', align: 'right', variant: 'default' },
  { class: 'col-3 start-2', size: 'md', align: 'left', variant: 'default' },
  { class: 'col-3 start-8', size: 'md', align: 'right', variant: 'default' },
] as const;

const stackRows = splitCards(stackHtml, 'stack-card')
  .map((block) => {
    const category = extract(block, 'stack-k') || extract(block, 'kicker');
    const tool = extractTag(block, 'h3');
    const role = extractTag(block, 'p');
    return [category, tool, role];
  })
  .filter((row) => row.every(Boolean));

const defaultToolRows = [
  ['Modèle raisonnement', 'Claude Sonnet 4.6', 'Scoring leads, séquences et synthèses métier'],
  ['Modèle volume', 'Claude Haiku 4.5', 'Qualification, tri, extraction et déduplication'],
  ['CRM', 'HubSpot / Salesforce / Pipedrive', 'Pipeline, tracking et attribution'],
  ['Email', 'Resend / Postmark', 'Délivrabilité et relances mesurées'],
  ['Analytics', 'GA4 + Mixpanel', 'Conversion et signaux comportementaux'],
  ['Orchestration', 'LangGraph open-source', 'Workflows IA durables et transférables'],
];

const toolRows = stackRows.length > 0 ? stackRows : defaultToolRows;

const signature = `${dept} ${deptLabel} ${title}`.toLowerCase();
const sectorVisual =
  signature.includes('services b2b') || signature.includes('cabinet') || signature.includes('conseil')
    ? 'services-b2b'
    : signature.includes('industrie')
      ? 'industrie'
      : signature.includes('finance') || signature.includes('compta') || signature.includes('comptabilité')
        ? 'finance'
        : '';
---
<Base {title} {description}>
    <Breadcrumb
      lang={lang}
      items={[
        { label: lang === 'fr' ? 'Accueil' : 'Home', href: lang === 'fr' ? '/' : '/en' },
        { label: lang === 'fr' ? 'Solutions' : 'Solutions', href: lang === 'fr' ? '/solutions' : '/en/solutions' },
        { label: deptLabel },
      ]}
    />
    {/* ────────── 1. HERO DEPARTMENT ────────── */}
    <section class="sol-hero" data-screen-label="01 Hero Department">
      <svg class="sol-hero-geo" viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <rect x="980" y="-40" width="420" height="420" fill="none" stroke="currentColor" stroke-width=".6" opacity=".18" transform="rotate(15 1190 170)"/>
        <rect x="1040" y="20" width="280" height="280" fill="none" stroke="var(--accent)" stroke-width=".4" opacity=".25" transform="rotate(15 1180 160)"/>
        <line x1="0" y1="420" x2="1440" y2="300" stroke="currentColor" stroke-width=".4" opacity=".12"/>
      </svg>
      <div class="wrap g12 g12--full">
        <div class="sol-hero-copy col-7 start-1">
          <nav class="sol-hero-bc" aria-label="Fil d'Ariane">
            <a href="/solutions">Solutions</a>
            <span aria-hidden="true">/</span>
            <span>{deptLabel}</span>
          </nav>
          <div class="sol-hero-dept">{dept}</div>
          <h1 class="sol-hero-title reveal"><slot name="title" /></h1>
          <div class="sol-hero-sub">
            <p class="sol-hero-lead"><slot name="lead" /></p>
            <div class="sol-hero-actions">
              <a class="sol-hero-cta" href={ctaHref}>{ctaLabel}</a>
              {meta && <div class="sol-hero-meta">{meta}</div>}
            </div>
          </div>
          <div class="sol-hero-tags reveal-stagger"><slot name="tags" /></div>
        </div>
        {sectorVisual && (
          <aside class="sol-hero-visual col-4 start-9" aria-hidden="true">
            {sectorVisual === 'services-b2b' && <SecteurServicesB2B size="lg" />}
            {sectorVisual === 'industrie' && <SecteurIndustrie size="lg" />}
            {sectorVisual === 'finance' && <SecteurFinance size="lg" />}
          </aside>
        )}
      </div>
    </section>

    {/* ────────── 2. PAIN POINTS ────────── */}
    <section class="sol-sec sol-friction reveal-stagger" data-screen-label="02 Pain Points">
      <div class="wrap g12 g12--full">
        <header class="sol-sec-hd section-eyebrow col-prose">
          <span class="eyebrow">§ Friction</span>
          <h2><i>Points</i><br/>de friction</h2>
        </header>
        <aside class="sol-aside col-aside">
          <Callout variant="note" size="sm">
            {painAsideHtml.trim() ? (
              <Fragment set:html={painAsideHtml} />
            ) : (
              <>Avant d'automatiser, comprendre où le temps se perd. Trois frictions récurrentes que nous voyons sur le terrain.</>
            )}
          </Callout>
        </aside>
        <div class="sol-pain-grid col-12">
          {frictionPoints.length > 0 ? (
            <Timeline events={frictionPoints} numbered={true} />
          ) : (
            <Fragment set:html={painHtml} />
          )}
        </div>
      </div>
    </section>

    {/* ────────── 3. WORKFLOWS TABLE ────────── */}
    <section class="sol-sec sol-sec-paper sol-workflows reveal-stagger" data-screen-label="03 Workflows">
      <div class="wrap g12 g12--full">
        <header class="sol-sec-hd section-eyebrow col-prose">
          <span class="eyebrow">§ Workflows</span>
          <h2><i>Ce qu'on</i><br/>automatise</h2>
        </header>
        <aside class="sol-aside col-aside">
          <Callout variant="info" size="sm">
            {workflowsAsideHtml.trim() ? (
              <Fragment set:html={workflowsAsideHtml} />
            ) : (
              <>Chaque workflow est nommé, mesuré, attribué à un modèle précis. Pas de boîte noire.</>
            )}
          </Callout>
        </aside>
        <div class="sol-workflow-table col-12">
          <div class="sol-workflow-head reveal-stagger">
            <div class="sol-wf-col-n">№</div>
            <div class="sol-wf-col-name">Workflow</div>
            <div class="sol-wf-col-model">Modèle</div>
            <div class="sol-wf-col-gain">Gain</div>
            <div class="sol-wf-col-how">Comment</div>
          </div>
          <div class="sol-workflow-body reveal-stagger"><Fragment set:html={workflowsHtml} /></div>
        </div>
      </div>
    </section>

    {/* ────────── 4. ROI BAND DARK ────────── */}
    <section class="sol-sec sol-sec-dark sol-proof reveal-stagger" data-screen-label="04 ROI Band">
      <div class="wrap g12 g12--full">
        <header class="sol-roi-hd section-eyebrow col-12">
          <span class="eyebrow">§ Preuve macro</span>
          <h2><i>Preuve</i> macro</h2>
        </header>
        <div class="sol-roi-grid col-12 g12">
          {proofMetricRows.length > 0 ? (
            proofMetricRows.map((metric, index) => {
              const placement = proofMetricPlacements[index % proofMetricPlacements.length];
              return (
                <div class={placement.class}>
                  <KeyMetric
                    value={metric.value}
                    label={metric.label}
                    size={placement.size}
                    align={placement.align}
                    variant={placement.variant}
                  />
                </div>
              );
            })
          ) : (
            <Fragment set:html={roiHtml} />
          )}
        </div>
      </div>
    </section>

    {/* ────────── 5. CASE STUDY SPLIT ────────── */}
    <section class="sol-case reveal-stagger" data-screen-label="05 Case Study">
      <div class="sol-case-grid">
        <div class="sol-case-dark">
          <div class="wrap-inner">
            <div class="kicker"><slot name="case-kicker">Cas client</slot></div>
            <h2 class="sol-case-title"><slot name="case-title" /></h2>
            <p class="sol-case-body"><slot name="case-body" /></p>
            <a class="sol-case-cta" href="/cas-clients"><slot name="case-cta-label">Voir le cas complet →</slot></a>
          </div>
        </div>
        <div class="sol-case-light">
          <div class="wrap-inner">
            <div class="kicker">Résultats</div>
            <div class="sol-case-results"><slot name="case-results" /></div>
          </div>
        </div>
      </div>
    </section>

    {/* ────────── 6. DEPARTMENT STACK ────────── */}
    <section class="sol-sec sol-sec-paper sol-tools reveal" data-screen-label="06 Stack">
      <div class="wrap g12 g12--full">
        <header class="sol-sec-hd section-eyebrow col-prose">
          <span class="eyebrow">§ Stack outils</span>
          <h2><i>Outils</i><br/>déployés</h2>
        </header>
        <aside class="sol-aside col-aside">
          <Callout variant="note" size="sm">
            {stackAsideHtml.trim() ? (
              <Fragment set:html={stackAsideHtml} />
            ) : (
              <>Le triptyque Anthropic primary + intégrations métier secondary + open source pour l'orchestration.</>
            )}
          </Callout>
        </aside>
        <div class="sol-stack-grid col-12">
          <EditorialTable
            caption={`Stack typique · ${deptLabel}`}
            columns={['Catégorie', 'Outil', 'Rôle']}
            rows={toolRows}
            variant="editorial"
          />
        </div>
      </div>
    </section>

    {/* ────────── 7. CTA DEPT-AUGMENTED DARK ────────── */}
    <section class="sol-sec sol-sec-dark sol-cta reveal" data-screen-label="07 CTA">
      <div class="wrap wrap-tight">
        <div class="sol-cta-final">
          <Dingbat variant="asterism" size="sm" />
          <h2><i><slot name="cta-title">Votre équipe,<br/>augmentée.</slot></i></h2>
          <div class="sol-cta-body">
            <p><slot name="cta-body">Cadrage en 45 minutes. Nous analysons votre périmètre et proposons les 3 workflows à fort ROI — sans engagement.</slot></p>
            <div class="sol-cta-btns">
              <a class="btn-accent" href="/contact">Prendre rendez-vous →</a>
              <a class="btn-light" href="/solutions">Toutes les solutions</a>
            </div>
          </div>
        </div>
      </div>
    </section>
</Base>

<style>
  /* ───── Hero Department ───── */
  .sol-hero {
    position: relative;
    padding-top: clamp(80px, 9vw, 120px);
    padding-bottom: clamp(56px, 6vw, 96px);
    overflow: hidden;
    color: var(--ink);
  }
  .start-9 { grid-column-start: 9; }
  .start-10 { grid-column-start: 10; }
  .sol-hero-geo {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none;
  }
  .sol-hero-copy,
  .sol-hero-visual {
    position: relative;
    z-index: 1;
  }
  .sol-hero-visual {
    align-self: center;
    opacity: 0.85;
    color: var(--ink);
    mix-blend-mode: multiply;
  }
  .sol-hero-visual :global(svg) {
    width: min(100%, 480px);
    height: auto;
    margin-left: auto;
  }
  .sol-hero-bc {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex; gap: 8px; align-items: center;
    margin-bottom: 24px;
  }
  .sol-hero-bc a { color: var(--muted); transition: color 220ms var(--ease); }
  .sol-hero-bc a:hover { color: var(--accent); }
  .sol-hero-dept {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 20px;
  }
  .sol-hero-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 148px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    font-weight: 400;
    margin: 0 0 32px;
    text-wrap: balance;
  }
  .sol-hero-title :global(i) { color: var(--accent); font-style: italic; }
  @keyframes mask-reveal {
    from { clip-path: inset(0 100% 0 0); }
    to { clip-path: inset(0 0% 0 0); }
  }
  @media (prefers-reduced-motion: no-preference) {
    .sol-hero-title {
      animation: mask-reveal 0.9s cubic-bezier(0.4, 0, 0.2, 1) both;
    }
  }
  .sol-hero-sub {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(24px, 4vw, 64px);
    align-items: end;
    max-width: 1100px;
    margin-bottom: clamp(28px, 3vw, 40px);
  }
  .sol-hero-lead {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.4;
    color: var(--ink);
    font-style: italic;
    margin: 0;
  }
  .sol-hero-lead :global(span) { color: var(--accent); display: block; margin-top: 8px; }
  .sol-hero-actions { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .sol-hero-cta {
    display: inline-block;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 2px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: transform 220ms var(--ease), box-shadow 220ms var(--ease);
  }
  .sol-hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
  .sol-hero-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .sol-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }
  .sol-hero-tags :global(.sol-tag) {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink);
    padding: 8px 14px;
    background: rgba(0,0,0,0.04);
    border: 1px solid var(--hairline);
    border-radius: 2px;
    transition: border-color 220ms var(--ease), color 220ms var(--ease);
  }
  .sol-hero-tags :global(.sol-tag:hover) {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ───── Sec common ───── */
  .sol-sec { padding: clamp(48px, 6vw, 80px) 0; position: relative; }
  .sol-friction { margin-top: var(--section-base); }
  .sol-workflows { margin-top: var(--section-base); }
  .sol-proof { margin-top: clamp(48px, 5vw, 80px); }
  .sol-tools { margin-top: var(--section-base); }
  .sol-cta { margin-top: clamp(48px, 5vw, 80px); }
  .sol-sec-paper {
    padding-block: clamp(64px, 7vw, 96px);
    background: var(--paper-2, #EFEBE2);
    border-block: 1px solid var(--hairline);
  }
  .sol-sec-dark { background: var(--ink); color: var(--paper); }
  .sol-sec-dark :global(.kicker) { color: var(--accent); }
  .sol-sec-hd {
    margin-bottom: clamp(28px, 4vw, 48px);
  }
  .section-eyebrow .eyebrow {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .sol-sec-hd h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 72px);
    line-height: 0.96;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: 8px 0 0;
  }
  .sol-sec-hd :global(i) { color: var(--accent); font-style: italic; }
  .sol-aside {
    font-family: var(--font-display);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.5;
    color: var(--muted);
    font-style: italic;
    max-width: 480px;
    margin: 0;
  }
  .sol-aside :global(.callout) {
    margin: 0;
  }

  /* ───── Pain Points ───── */
  .sol-pain-grid {
    display: block;
  }
  .sol-pain-grid :global(.pain-card) {
    padding-top: 32px;
    border-top: 1px solid var(--hairline);
  }
  .sol-pain-grid :global(.pn) {
    font-family: var(--font-display);
    font-size: 96px;
    line-height: 0.85;
    color: var(--accent);
    margin-bottom: 16px;
    font-weight: 400;
  }
  .sol-pain-grid :global(.pk) {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: 10px;
  }
  .sol-pain-grid :global(.pain-card h3) {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.8vw, 26px);
    line-height: 1.2;
    margin: 0 0 12px;
    font-weight: 400;
  }
  .sol-pain-grid :global(.pain-card p) {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0;
  }

  /* ───── Workflows Table (BRIQUE SIGNATURE) ───── */
  .sol-workflow-table {
    border-top: 1px solid var(--hairline);
  }
  .sol-workflow-head {
    display: grid;
    grid-template-columns: 60px 2fr 1.2fr 1fr 2.4fr;
    gap: 24px;
