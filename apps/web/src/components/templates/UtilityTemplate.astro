---
// Template · UtilityTemplate · pages utilitaires (contact, careers, about, academy)
//
// Mapping handoff2 :
//  - contact.html             → /contact
//  - careers.html             → /agence/careers
//  - about.html               → /agence/about
//  - academy-diagnostic.html  → /ressources/academy
//
// Squelette flexible · Masthead (centered ou left) + slot `body` libre + slot `cta` optionnel
//
// Décision · un seul template "utility" car ces pages partagent la structure
// (h1 + lede + body + CTA optionnel). Prop `align` (centered / left) pour les
// variations visuelles. Le slot `body` accepte n'importe quel JSX riche.
//
// Composé de · Bi (atom) · Kicker (atom) · CtaFinal (section · optionnelle)

import Base from '../../layouts/Base.astro';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import CtaFinal from '../sections/CtaFinal.astro';
import type { SectionByType } from '../../schemas/sections';
import { langFromPath, localizeHref } from '../../lib/i18n';

interface Crumb {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description: string;
  /** Kicker section (Contact, Careers, À propos…) */
  kicker?: string;
  /** Alignement masthead · `left` (défaut, narrative) ou `centered` (action focus) */
  align?: 'left' | 'centered';
  /** Afficher le CTA final en fin de page · défaut true */
  showCta?: boolean;
  /** Breadcrumb items (optionnel) · si absent, deduit du pathname */
  breadcrumb?: Crumb[];
  /** JSON-LD spécifique à la page (forwarded to Base) */
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}
const { title, description, kicker, align = 'left', showCta = true, breadcrumb, jsonLd } = Astro.props as Props;

const lang = langFromPath(Astro.url.pathname);
const isContactPage = Astro.url.pathname === '/contact' || Astro.url.pathname === '/en/contact';
const utilityLabel = title.split(' · ')[0];
const ctaData: SectionByType<'cta-final'> = isContactPage
  ? {
      type: 'cta-final',
      h2_fr: "Besoin d'un <i>cadre</i> avant de réserver ?",
      h2_en: 'Need a <i>framework</i> before booking?',
      body_fr: 'Commencez par le périmètre, la méthode et les formats d\'intervention. Ensuite seulement, on ouvre un créneau utile.',
      body_en: 'Start with scope, method, and engagement formats. Then, and only then, we open a useful slot.',
      cta_primary: {
        label_fr: 'Voir les offres →',
        label_en: 'See services →',
        href: localizeHref('/offres', lang),
        variant: 'primary',
      },
      cta_secondary: {
        label_fr: 'Voir la méthode →',
        label_en: 'See the method →',
        href: localizeHref('/agence/methode', lang),
        variant: 'ghost',
      },
      background: 'paper',
    }
  : {
      type: 'cta-final',
      h2_fr: 'Prêt à passer du <i>texte</i> au terrain ?',
      h2_en: 'Ready to move from <i>text</i> to the field?',
      body_fr: `${utilityLabel} clarifié. Reste à cadrer le chantier, le bon niveau d'engagement et le premier livrable utile.`,
      body_en: `${utilityLabel} clarified. Now it is about framing the engagement, the right level of involvement, and the first useful deliverable.`,
      cta_primary: {
        label_fr: 'Réserver un audit →',
        label_en: 'Book an audit →',
        href: localizeHref('/contact', lang),
        variant: 'primary',
      },
      cta_secondary: {
        label_fr: 'Voir les offres →',
        label_en: 'See services →',
        href: localizeHref('/offres', lang),
        variant: 'ghost',
      },
      background: 'paper',
    };

// Auto-deduction breadcrumb si non fourni (segments URL → labels capitalises)
const autoCrumbs: Crumb[] = breadcrumb ?? (() => {
  const segments = Astro.url.pathname.split('/').filter(s => s && s !== 'en');
  if (segments.length === 0) return [];
  const home: Crumb = { label: lang === 'fr' ? 'Accueil' : 'Home', href: lang === 'fr' ? '/' : '/en' };
  const intermediate = segments.slice(0, -1).map((s, i) => ({
    label: s.charAt(0).toUpperCase() + s.slice(1).replace(/-/g, ' '),
    href: (lang === 'fr' ? '/' : '/en/') + segments.slice(0, i + 1).join('/'),
  }));
  const last: Crumb = { label: title.split(' · ')[0] };
  return [home, ...intermediate, last];
})();
---
<Base title={title} description={description} jsonLd={jsonLd}>
  {autoCrumbs.length > 0 && <Breadcrumb lang={lang} items={autoCrumbs} />}
  {/* MASTHEAD */}
  <section class:list={['util-hd', `util-hd-${align}`]}>
    <div class="wrap-wide">
      {kicker && <Kicker class="util-kicker reveal">{kicker}</Kicker>}
      <h1 class="util-h1 reveal"><slot name="headline" /></h1>
      <p class="util-lede reveal"><slot name="lede" /></p>
    </div>
  </section>

  {/* BODY · slot libre (form, story, jobs list…) */}
  <section class="util-body reveal">
    <div class="wrap-wide">
      <slot name="body" />
    </div>
  </section>

  {/* CTA optionnel en bas */}
  {showCta && <CtaFinal data={ctaData} lang={lang} />}
</Base>

<style>
  .util-hd {
    padding: 140px 32px clamp(40px, 5vw, 72px);
    border-bottom: 1px solid var(--hairline);
  }
  .util-hd-centered { text-align: center; }
  :global(.util-kicker) { display: block; margin-bottom: 24px; }
  .util-hd-centered :global(.util-kicker) { display: inline-block; }

  .util-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    font-weight: 400;
    text-wrap: balance;
    margin: 0;
  }
  .util-h1 :global(i) { font-style: italic; color: var(--accent); }

  .util-lede {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(20px, 2.2vw, 32px);
    color: var(--ink-2);
    margin: 32px 0 0;
    max-width: 760px;
    line-height: 1.4;
    text-wrap: pretty;
  }
  .util-hd-centered .util-lede {
    margin-left: auto;
    margin-right: auto;
  }

  .util-body { padding: clamp(60px, 8vw, 100px) 32px; }
</style>
