---
// Template · CaseStudyTemplate · cas client (long-form)
//
// Mapping handoff2 :
//  - case-plateau.html → /ressources/cas/plateau
//  - (autres cas seront stubs jusqu'à contenu validé)
//
// Squelette : Masthead + Spec bar + Context + Approach (steps) + Proof band
//             + Tech stack + Related + CTABand
//
// Composé de · Bi, Kicker, ChapterLabel atoms · ProcessSteps, ProofBand,
//              TechPillRow, RelatedCards molecules · CtaBand organism.

import Base from '../../layouts/Base.astro';
import Bi from '../ui/atoms/Bi.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import { langFromPath } from '../../lib/i18n';
import ChapterLabel from '../ui/atoms/ChapterLabel.astro';
import ProcessSteps from '../ui/molecules/ProcessSteps.astro';
import ProofBand from '../ui/molecules/ProofBand.astro';
import TechPillRow from '../ui/molecules/TechPillRow.astro';
import CtaBand from '../ui/organisms/CtaBand.astro';
import KeyMetric from '../editorial/KeyMetric.astro';
import Breadcrumb from '../ui/molecules/Breadcrumb.astro';

interface SpecItem {
  label_fr: string;
  label_en: string;
  value: string;
}
interface Step {
  sn: string;
  kicker_fr: string;
  kicker_en: string;
  title_fr: string;
  title_en: string;
  body_fr: string;
  body_en: string;
}
interface Pill {
  label: string;
  kind?: 'primary' | 'open' | 'neutral';
}
interface Metric {
  k: string;
  label_fr: string;
  label_en: string;
}
interface RelatedCard {
  kicker: string;
  title_fr: string;
  title_en: string;
  lead_fr: string;
  lead_en: string;
  href: string;
}
interface Props {
  title: string;
  description: string;
  /** Label personnalisé pour le breadcrumb. */
  caseTitle?: string;
  /** Numéro éditorial (Case 04, Case 07…) */
  caseNum: string;
  /** Spec bar (5 items typiquement : Client, Sector, Duration, Stack, Services) */
  specs: SpecItem[];
  /** Steps process (4 typiquement) */
  steps: Step[];
  /** Proof quote + metrics */
  proofQuoteFr: string;
  proofQuoteEn: string;
  proofAttrFr: string;
  proofAttrEn: string;
  proofMetrics: Metric[];
  /** Tech stack pills */
  techPills: Pill[];
  /** Related cards (3 cas connexes) */
  relatedCards: RelatedCard[];
  /** Offres liées (cross-collection) */
  relatedOffresLinks?: Array<{ title: string; href: string }>;
  /** Slug pour ViewTransition (ex: "cas-plateau") */
  transitionSlug?: string;
}
const {
  title, description, caseTitle, caseNum, specs, steps,
  proofQuoteFr, proofQuoteEn, proofAttrFr, proofAttrEn, proofMetrics,
  techPills, relatedCards, relatedOffresLinks, transitionSlug,
} = Astro.props;
const lang = langFromPath(Astro.url.pathname);
const pageTransitionId = Astro.url.pathname
  .replace(/^\/(?:en\/)?/, '')
  .replace(/\/$/, '')
  .replace(/[^a-z0-9]+/gi, '-')
  .replace(/^-|-$/g, '') || 'home';
const cardTransitionId = transitionSlug ?? pageTransitionId;
---
<Base title={title} description={description}>
  <Breadcrumb
    lang={lang}
    items={[
      { label: lang === 'fr' ? 'Accueil' : 'Home', href: lang === 'fr' ? '/' : '/en' },
      { label: lang === 'fr' ? 'Cas clients' : 'Case studies', href: lang === 'fr' ? '/cas' : '/en/cas' },
      { label: caseTitle ?? title },
    ]}
  />
  {/* MASTHEAD */}
  <section class="case-masthead" transition:name={`card-${cardTransitionId}`}>
    <svg class="case-hero-decoration reveal-blur-clip" viewBox="0 0 600 500" aria-hidden="true" focusable="false" transition:name={`hero-img-${pageTransitionId}`}>
      <circle cx="480" cy="80" r="220" fill="none" stroke="currentColor" stroke-width=".5" opacity=".12"/>
      <circle cx="460" cy="60" r="140" fill="none" stroke="var(--accent)" stroke-width=".4" opacity=".18"/>
      <line x1="0" y1="400" x2="600" y2="280" stroke="currentColor" stroke-width=".4" opacity=".1"/>
    </svg>
    <div class="wrap-wide">
      <span class="eyebrow">§ Cas client</span>
      <Kicker class="case-num">§ Case {caseNum}</Kicker>
      <h1 class="case-h1 reveal-mask-up" transition:name={`hero-h1-${pageTransitionId}`}>
        <slot name="headline" />
      </h1>
    </div>
  </section>

  {/* SPEC BAR (Client · Sector · Duration · Stack · Services) */}
  <section class="case-specs">
    <div class="wrap-wide case-specs-grid" style={`--spec-cols:${specs.length}`}>
      {specs.map((s, i) => (
        <div class="case-spec" data-last={i === specs.length - 1 ? 'true' : 'false'}>
          <Kicker class="case-spec-l"><Bi fr={s.label_fr} en={s.label_en} /></Kicker>
          <div class="case-spec-v">{s.value}</div>
        </div>
      ))}
    </div>
  </section>

  {Astro.slots.has('hero-image') && <div class="case-hero-image"><slot name="hero-image" /></div>}

  {/* CONTEXT (slot ouvert pour storytelling) */}
  <section class="case-context reveal">
    <div class="wrap-wide case-context-grid">
      <div>
        <ChapterLabel num="§ 01" title="Context" class="case-sticky" />
      </div>
      <div>
        <Kicker tone="accent" class="case-context-k"><Bi fr="Le brief" en="The brief" /></Kicker>
        <slot name="context" />
      </div>
    </div>
  </section>

  {/* APPROACH · steps */}
  <section class="case-approach reveal-stagger">
    <div class="wrap-wide">
      <header class="case-section-hd">
        <Kicker tone="accent">§ 02 · <Bi fr="L'approche" en="The approach" /></Kicker>
        <h2 class="case-section-h2"><slot name="approach-headline" /></h2>
        <p class="case-section-aside"><slot name="approach-aside" /></p>
      </header>
      <ProcessSteps steps={steps} />
    </div>
  </section>

  {/* PROOF TESTIMONIAL */}
  <section class="case-proof reveal">
    <div class="wrap-wide">
      <span class="eyebrow">§ 03 · Témoignage</span>
      <blockquote class="case-proof-quote">
        <Bi fr={`« ${proofQuoteFr} »`} en={`"${proofQuoteEn}"`} />
      </blockquote>
      <cite class="case-proof-attr">
        <Bi fr={proofAttrFr} en={proofAttrEn} />
      </cite>
    </div>
  </section>

  {/* KEY METRICS */}
  {proofMetrics.length > 0 && (
    <section class="case-key-metrics reveal-stagger">
      <div class="wrap-wide">
        <span class="eyebrow">§ Résultats mesurés</span>
        <div class="case-km-row">
          {proofMetrics.map((m, idx) => (
            <KeyMetric
              value={m.k}
              label={m.label_fr}
              size={idx === 0 ? 'hero' : 'lg'}
              align={idx === 0 ? 'left' : idx === 1 ? 'center' : 'right'}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  {/* STACK */}
  <section class="case-stack reveal">
    <div class="wrap-wide">
      <Kicker tone="accent" class="case-stack-k">§ 04 · <Bi fr="La stack" en="The stack" /></Kicker>
      <p class="case-stack-lead">
        <slot name="stack-lead" />
      </p>
      <TechPillRow pills={techPills} />
    </div>
  </section>

  {relatedOffresLinks && relatedOffresLinks.length > 0 && (
    <section class="case-related-offres">
      <p class="case-related-offres__label">
        {lang === 'en' ? 'Service used' : 'Offre utilisée'}
      </p>
      <div class="case-related-offres__links">
        {relatedOffresLinks.map(off => (
          <a href={off.href} class="case-offre-link">
            <span>{off.title}</span>
            <span aria-hidden>→</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* RELATED */}
  <section class="case-related reveal-stagger">
    <div class="wrap-wide">
      <span class="eyebrow">§ Autres cas</span>
      <div class="case-related-grid">
        {relatedCards.map((c) => (
          <a class="related-case-card" href={c.href}>
            <span class="related-case-kicker">{c.kicker}</span>
            <h3 class="related-case-title">{lang === 'en' ? c.title_en : c.title_fr}</h3>
            <p class="related-case-lead">{lang === 'en' ? c.lead_en : c.lead_fr}</p>
            <span class="related-case-go" aria-hidden>→</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand />
  <slot name="body-end" />
</Base>

<style>
  .case-masthead { padding: clamp(80px, 10vw, 120px) 32px 40px; }
  :global(.case-num) { display: block; margin-bottom: var(--space-5); }
  .case-h1 {
    font-family: var(--font-display);
    font-size: clamp(56px, 11vw, 180px);
    line-height: 0.88;
    letter-spacing: -0.035em;
    text-wrap: balance;
    font-weight: 400;
    margin: 0 0 48px;
  }
  .case-h1 :global(i) { font-style: italic; color: var(--accent); }

  .case-specs { padding: 0 32px 40px; border-bottom: 1px solid var(--hairline); }
  .case-specs-grid {
    display: grid;
    grid-template-columns: repeat(var(--spec-cols, 5), 1fr);
    border-top: 1px solid var(--hairline);
  }
  .case-spec {
    padding: 22px 20px;
    border-right: 1px solid var(--hairline);
  }
  .case-spec[data-last='true'] { border-right: none; }
  :global(.case-spec-l) { display: block; margin-bottom: 6px; }
  .case-spec-v {
    font-family: var(--font-display);
    font-size: 22px;
    letter-spacing: -0.01em;
  }

  .case-context { padding: clamp(56px, 7vw, 80px) 32px; }
  .case-context-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 64px;
  }
  :global(.case-sticky) { position: sticky; top: 100px; }
  :global(.case-context-k) { display: block; margin-bottom: 24px; }

  .case-approach { padding: clamp(56px, 7vw, 80px) 32px; background: var(--paper-2); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  .case-section-hd {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(24px, 4vw, 60px);
    margin-bottom: clamp(36px, 5vw, 70px);
    align-items: end;
  }
  .case-section-h2 {
    font-family: var(--font-display);
    font-size: clamp(34px, 5.5vw, 88px);
    line-height: 0.95;
    letter-spacing: -0.024em;
    text-wrap: balance;
    font-weight: 400;
    margin: 14px 0 0;
  }
  .case-section-h2 :global(i) { font-style: italic; color: var(--accent); }
  .case-section-aside {
    font-size: clamp(13px, 1.3vw, 15px);
    line-height: 1.55;
    color: var(--muted);
    text-wrap: pretty;
    max-width: 400px;
    margin: 0;
  }

  .case-proof { padding: clamp(56px, 7vw, 80px) 32px; }
  .case-proof-quote {
    font-family: var(--font-display);
    font-size: clamp(24px, 3.5vw, 52px);
    line-height: 1.1;
    letter-spacing: -0.018em;
    font-weight: 400;
    font-style: italic;
    text-wrap: pretty;
    max-width: 860px;
    margin: 0 0 24px;
  }
  .case-proof-attr {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.06em;
    font-style: normal;
  }
  .case-key-metrics {
    padding: clamp(40px, 5vw, 72px) 32px;
    background: var(--ink);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
  }
  .case-key-metrics .eyebrow { color: var(--accent); margin-bottom: 40px; }
  .case-km-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: clamp(24px, 4vw, 60px);
    align-items: end;
  }
  .case-key-metrics :global(.key-metric-value) { color: var(--paper); }
  .case-key-metrics :global(.key-metric-label) { color: rgba(246,241,232,0.55); }
  .case-stack { padding: clamp(56px, 7vw, 80px) 32px; background: var(--paper-2); border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
  :global(.case-stack-k) { display: block; margin-bottom: 16px; }
  .case-stack-lead {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 30px);
    line-height: 1.3;
    color: var(--muted);
    max-width: 760px;
    text-wrap: balance;
    margin: 0 0 clamp(28px, 3vw, 44px);
  }

  .case-related { padding: clamp(56px, 6vw, 80px) 32px; }
  :global(.case-related-k) { display: block; margin-bottom: var(--space-6); }
  .case-related-offres {
    margin: var(--space-6, 2rem) 0;
    padding: var(--space-4, 1.5rem);
    border: 1px solid var(--hairline-strong);
    border-left: 3px solid var(--accent-offre, #f59e0b);
  }
  .case-related-offres__label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-2, 0.75rem);
  }
  .case-offre-link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-2, 0.75rem) 0;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--hairline-strong);
    transition: color 200ms var(--ease);
  }
  .case-offre-link:last-child { border-bottom: none; }
  .case-offre-link:hover { color: var(--accent); }

  @media (max-width: 900px) {
    .case-context-grid,
    .case-section-hd { grid-template-columns: 1fr; }
    .case-specs-grid { grid-template-columns: repeat(2, 1fr); }
  }

  /* Hero decoration SVG */
  .case-hero-decoration {
    position: absolute;
    top: 0;
    right: 0;
    width: 500px;
    height: 400px;
    pointer-events: none;
    z-index: 0;
    color: var(--ink);
    opacity: 0.08;
    mix-blend-mode: multiply;
  }
  .case-masthead { position: relative; overflow: hidden; }
  .case-masthead .wrap-wide { position: relative; z-index: 1; }
  .case-hero-image { aspect-ratio: 16/9; margin: clamp(48px, 6vw, 80px) 32px; overflow: hidden; }
  .case-hero-image :global(img) { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Eyebrow */
  .eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent);
    margin-bottom: 16px;
  }

  /* Related cases with GSAP target class */
  .case-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--hairline-strong);
    gap: 0;
  }
  .related-case-card {
    padding: clamp(22px, 2.5vw, 36px) clamp(18px, 2vw, 28px);
    border-right: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: 8px;
    color: inherit;
    text-decoration: none;
    transition: background 240ms ease;
  }
  .related-case-card:last-child { border-right: none; }
  .related-case-card:hover { background: var(--paper-2); }
  .related-case-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.14em;
  }
  .related-case-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 32px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 8px 0 4px;
  }
  .related-case-lead {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.5;
    flex: 1;
  }
  .related-case-go {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
  }
  @media (max-width: 800px) {
    .case-related-grid { grid-template-columns: 1fr; }
    .related-case-card { border-right: none; border-bottom: 1px solid var(--hairline); }
    .related-case-card:last-child { border-bottom: none; }
    .case-hero-decoration { width: 280px; height: 240px; opacity: 0.6; }
  }

  @keyframes mask-reveal {
    from { clip-path: inset(0 100% 0 0); }
    to   { clip-path: inset(0 0 0 0); }
  }
  .case-h1 {
    animation: mask-reveal 1s cubic-bezier(0.16, 1, 0.30, 1) both;
  }
  @media (prefers-reduced-motion: reduce) {
    .case-h1 { animation: none; }
  }
</style>
