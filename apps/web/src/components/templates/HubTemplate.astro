---
// Template · HubTemplate · « Pillar page » d'un hub d'offres / pilier marketing
//
// Mapping handoff2 :
//  - hub-consulting.html → /offres/conseil
//  - virtuoseos.html      → /technologies/virtuoseos
//  - hub-development.html (à venir)
//
// Squelette : Masthead + Manifesto pull + Service catalog list + Fit columns
//             + Related cases + CTABand
//
// Mode Slots (Astro recommande) — chaque slot ouvre un point d'extension.
// Les pages utilisatrices peuvent :
//   - passer du contenu HTML riche (italic, br) sans sérialisation JSON
//   - omettre un slot pour cacher la section (ex: pas de manifesto)
//
// Composé de · Kicker, Bi, ChapterLabel (atoms) · KeyMetric, Callout,
//              DropCap, PullQuote (editorial) · FitColumns, RelatedCards
//              (molecules) · CtaBand (organism).

import Base from '../../layouts/Base.astro';
import Bi from '../ui/atoms/Bi.astro';
import Kicker from '../ui/atoms/Kicker.astro';
import ChapterLabel from '../ui/atoms/ChapterLabel.astro';
import FitColumns from '../ui/molecules/FitColumns.astro';
import RelatedCards from '../ui/molecules/RelatedCards.astro';
import CtaBand from '../ui/organisms/CtaBand.astro';
import Callout from '../editorial/Callout.astro';
import KeyMetric from '../editorial/KeyMetric.astro';
import DropCap from '../editorial/DropCap.astro';
import PullQuote from '../editorial/PullQuote.astro';
import { langFromPath } from '../../lib/i18n';

interface Stat {
  k: string;
  label_fr: string;
  label_en: string;
}
interface RelatedCard {
  kicker: string;
  title_fr: string;
  title_en: string;
  lead_fr: string;
  lead_en: string;
  href: string;
}
interface Props {
  /** SEO · titre HTML de la page */
  title: string;
  /** SEO · meta description */
  description: string;
  /** Numéro éditorial (FIG · 02 / § 02 · ...) */
  hubNum: string;
  /** Kicker label (Hub · §02, Pillar · ...) */
  metaKickerFr: string;
  metaKickerEn: string;
  /** Stats pour la masthead */
  stats: Stat[];
  /** Fit columns */
  fitYesTitleFr: string;
  fitYesTitleEn: string;
  fitYesItems: string[];
  fitNoTitleFr: string;
  fitNoTitleEn: string;
  fitNoItems: string[];
  /** Related cases */
  relatedKickerFr: string;
  relatedKickerEn: string;
  relatedCards: RelatedCard[];
}
const {
  title, description, hubNum, metaKickerFr, metaKickerEn, stats,
  fitYesTitleFr, fitYesTitleEn, fitYesItems,
  fitNoTitleFr, fitNoTitleEn, fitNoItems,
  relatedKickerFr, relatedKickerEn, relatedCards,
} = Astro.props;

const lang = langFromPath(Astro.url.pathname);
const isFr = lang === 'fr';
---
<Base title={title} description={description}>
  {/* MASTHEAD */}
  <section class="hub-masthead">
    <div class="wrap-wide">
      <Kicker class="hub-meta">
        <Bi fr={metaKickerFr} en={metaKickerEn} />
      </Kicker>
      <Kicker tone="accent" class="hub-num">§ {hubNum}</Kicker>
      <h1 class="hub-h1 reveal">
        <slot name="headline" />
      </h1>
      <div class="hub-lede reveal">
        <p>
          <DropCap variant="mono">§</DropCap>
          <slot name="lede" />
        </p>
      </div>

      {stats && stats.length > 0 && (
        <div class="hub-stats reveal-stagger">
          {stats.map((stat, index) => (
            <KeyMetric
              value={stat.k}
              label={isFr ? stat.label_fr : stat.label_en}
              size={index === 0 ? 'lg' : 'md'}
              variant={index === 1 ? 'accent' : 'default'}
            />
          ))}
        </div>
      )}
    </div>
  </section>

  {/* MANIFESTO PULL (optionnel) */}
  {Astro.slots.has('manifesto') && (
    <section class="hub-manifesto">
      <div class="wrap-wide hub-manifesto-grid reveal-stagger">
        <ChapterLabel num={`§ ${hubNum}.0`} title="Stance" />
        <div class="hub-manifesto-text">
          <Callout variant="manifesto" size="lg">
            <slot name="manifesto" />
          </Callout>
        </div>
      </div>
    </section>
  )}

  {/* SERVICE CATALOG (slot ouvert pour ServiceCatalogRow × N) */}
  <section class="hub-catalog">
    <div class="wrap-wide">
      <header class="hub-catalog-hd">
        <ChapterLabel num={`FIG ${hubNum}.S`} title="Catalogue" />
        <Kicker><slot name="catalog-meta" /></Kicker>
      </header>
      <div class="hub-catalog-list reveal-stagger">
        <slot name="catalog" />
      </div>
    </div>
  </section>

  {/* FIT / NO FIT */}
  <section class="hub-fit">
    <div class="wrap-wide">
      <Kicker tone="dim" class="hub-fit-kicker">§ {hubNum}.F · <Bi fr="Fit" en="Fit" /></Kicker>
      <h2 class="hub-fit-h2">
        <slot name="fit-headline" />
      </h2>
      <div class="hub-fit-callout reveal">
        <Callout variant="info" size="sm">
          <Bi>
            <Fragment slot="fr">Le bon engagement tient en deux colonnes&nbsp;: ce que l'on peut rendre opérable, et ce que l'on doit refuser avant de diluer la mission.</Fragment>
            <Fragment slot="en">A good engagement fits in two columns: what can become operational, and what must be refused before the mission gets diluted.</Fragment>
          </Bi>
        </Callout>
      </div>
      <FitColumns
        class="hub-fit-cols reveal-stagger"
        yesTitleFr={fitYesTitleFr} yesTitleEn={fitYesTitleEn} yesItems={fitYesItems}
        noTitleFr={fitNoTitleFr} noTitleEn={fitNoTitleEn} noItems={fitNoItems}
      />
    </div>
  </section>

  {/* RELATED CASES */}
  <section class="hub-related">
    <div class="wrap-wide">
      <Kicker class="hub-related-kicker">§ {hubNum}.C · <Bi fr={relatedKickerFr} en={relatedKickerEn} /></Kicker>
      <RelatedCards cards={relatedCards} class="hub-related-grid reveal-stagger" />
    </div>
  </section>

  <section class="hub-closing">
    <div class="wrap-wide">
      <PullQuote variant="centered" attribution="Waimia">
        <Bi>
          <Fragment slot="fr">Le livrable final n'est pas un effet d'annonce. C'est une couche que vos équipes peuvent relire, reprendre et exploiter.</Fragment>
          <Fragment slot="en">The final deliverable is not theatre. It is an operating layer your teams can read, own, and use.</Fragment>
        </Bi>
      </PullQuote>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .hub-masthead { padding: 140px 32px 0; }
  /* :global parce que les Kicker sont rendus par sous-composants */
  :global(.hub-meta) { display: inline-flex; gap: 8px; margin-bottom: var(--space-5); }
  :global(.hub-num) { display: block; margin-bottom: var(--space-5); }
  .hub-h1 {
    font-family: var(--font-display);
    font-size: clamp(64px, 13vw, 200px);
    line-height: 0.88;
    letter-spacing: -0.035em;
    text-wrap: balance;
    font-weight: 400;
    margin: 0;
  }
  .hub-h1 :global(i) { font-style: italic; color: var(--accent); }
  .hub-lede {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.4vw, 30px);
    line-height: 1.3;
    margin-top: 32px;
    max-width: 980px;
    color: var(--muted);
    text-wrap: balance;
  }
  .hub-lede p { margin: 0; }
  .hub-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 70px;
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
  }
  .hub-stats :global(.key-metric) {
    min-height: 100%;
    padding: clamp(24px, 3vw, 36px) clamp(14px, 2vw, 22px);
    border-right: 1px solid var(--hairline);
  }
  .hub-stats :global(.key-metric:last-child) { border-right: none; }
  .hub-stats :global(.key-metric-value) { font-style: normal; }

  .hub-manifesto {
    padding: clamp(80px, 10vw, 100px) 32px;
    background: var(--paper-2);
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    margin-top: clamp(60px, 8vw, 80px);
  }
  .hub-manifesto-grid {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: clamp(32px, 5vw, 64px);
  }
  .hub-manifesto-text {
    font-family: var(--font-display);
    font-size: clamp(36px, 5.5vw, 76px);
    line-height: 1.08;
    letter-spacing: -0.022em;
    text-wrap: balance;
  }
  .hub-manifesto-text :global(i) { font-style: italic; color: var(--accent); }
  .hub-manifesto-text :global(.callout) { margin: 0; }
  .hub-manifesto-text :global(.callout-manifesto) {
    border-color: var(--hairline-strong);
    padding-block: clamp(24px, 4vw, 48px);
  }
  .hub-manifesto-text :global(.callout-body) {
    font-size: inherit;
    line-height: inherit;
  }

  .hub-catalog { padding: clamp(80px, 10vw, 120px) 32px; }
  .hub-catalog-hd {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--space-6);
    padding-bottom: 14px;
    border-bottom: 1px solid var(--ink);
    flex-wrap: wrap;
    gap: 14px;
  }
  .hub-catalog-list {
    border-top: 1px solid var(--hairline-strong);
  }
  .hub-catalog-list :global(.svc-row) {
    border-top: 1px solid var(--hairline-strong);
    transition:
      background 240ms var(--ease),
      padding-left 320ms var(--ease),
      padding-right 320ms var(--ease),
      transform 320ms var(--ease);
  }
  .hub-catalog-list :global(.svc-row:first-child) { border-top: none; }
  .hub-catalog-list :global(.svc-row:hover) {
    background: var(--paper-2);
    transform: translateY(-2px);
  }

  .hub-fit {
    padding: clamp(80px, 10vw, 120px) 32px;
    background: var(--ink);
    color: var(--paper);
  }
  :global(.hub-fit-kicker) { display: block; margin-bottom: var(--space-6); }
  .hub-fit-h2 {
    font-family: var(--font-display);
    font-size: clamp(48px, 7vw, 112px);
    line-height: 0.94;
    letter-spacing: -0.028em;
    color: var(--paper);
    margin: 0 0 60px;
    text-wrap: balance;
    font-weight: 400;
  }
  .hub-fit-h2 :global(i) { font-style: italic; }
  .hub-fit-callout {
    max-width: 760px;
    margin-bottom: clamp(36px, 5vw, 56px);
  }
  .hub-fit-callout :global(.callout) {
    color: rgba(246, 241, 232, 0.72);
    border-left-color: rgba(246, 241, 232, 0.28);
    margin: 0;
  }
  .hub-fit-callout :global(.callout-body) { font-family: var(--font-sans); }
  :global(.hub-fit-cols) {
    border-top: 1px solid rgba(246, 241, 232, 0.18);
  }
  :global(.hub-fit-cols .fit-col) {
    border-top: 1px solid rgba(246, 241, 232, 0.18);
    transition: background 240ms var(--ease), transform 320ms var(--ease);
  }
  :global(.hub-fit-cols .fit-col:hover) {
    background: rgba(246, 241, 232, 0.04);
    transform: translateY(-2px);
  }

  .hub-related { padding: clamp(80px, 10vw, 120px) 32px; }
  :global(.hub-related-kicker) { display: block; margin-bottom: var(--space-6); }
  :global(.hub-related-grid .related-card) {
    border-top: 1px solid var(--hairline-strong);
    transition: background 240ms var(--ease), transform 320ms var(--ease);
  }
  :global(.hub-related-grid .related-card:hover) {
    background: var(--paper-2);
    transform: translateY(-2px);
  }

  .hub-closing {
    padding: clamp(24px, 5vw, 56px) 32px clamp(80px, 10vw, 120px);
    border-top: 1px solid var(--hairline);
  }
  .hub-closing :global(.pull-quote) { margin-block: 0; }

  @media (max-width: 900px) {
    .hub-masthead { padding-top: 100px; }
    .hub-manifesto-grid { grid-template-columns: 1fr; }
    .hub-stats { grid-template-columns: repeat(2, 1fr); }
    .hub-stats :global(.key-metric:nth-child(2n)) { border-right: none; }
  }

  @media (max-width: 640px) {
    .hub-stats { grid-template-columns: 1fr; }
    .hub-stats :global(.key-metric) {
      border-right: none;
      border-bottom: 1px solid var(--hairline);
    }
    .hub-stats :global(.key-metric:last-child) { border-bottom: none; }
  }
</style>
