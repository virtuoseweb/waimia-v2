---
import type { CollectionEntry } from 'astro:content';
import Kicker from '../ui/atoms/Kicker.astro';

interface Props {
  data: CollectionEntry<'formations'>['data'];
  lang: "fr" | "en";
}

const { data, lang } = Astro.props;

const title = lang === 'fr' ? data.title_fr : data.title_en;
const description = lang === 'fr' ? data.description_fr : data.description_en;
const objectives = lang === 'fr' ? data.learning_objectives_fr : data.learning_objectives_en;
const prerequisites = lang === 'fr' ? data.prerequisites_fr : data.prerequisites_en;

const levelLabels: Record<string, string> = {
  debutant: lang === 'fr' ? 'Débutant' : 'Beginner',
  intermediaire: lang === 'fr' ? 'Intermédiaire' : 'Intermediate',
  avance: lang === 'fr' ? 'Avancé' : 'Advanced',
  expert: lang === 'fr' ? 'Expert' : 'Expert',
};
const levelLabel = levelLabels[data.level] ?? data.level;
const formatLabel = data.format.charAt(0).toUpperCase() + data.format.slice(1);

const price = data.pricing?.one_time_eur;
const stripeLink = data.pricing?.stripe_payment_link;
const isPlaceholder = stripeLink?.includes('PLACEHOLDER') ?? true;

const priceStr = price === 0
  ? (lang === 'fr' ? 'Gratuit' : 'Free')
  : price != null
    ? `${price} €`
    : null;

const typeLabels: Record<string, Record<string, string>> = {
  fr: { lecture: 'Cours', exercice: 'Exercice', projet: 'Projet', evaluation: 'Évaluation' },
  en: { lecture: 'Lecture', exercice: 'Exercise', projet: 'Project', evaluation: 'Assessment' },
};

const objectivesTitle = lang === 'fr' ? "Ce que vous allez apprendre" : "What you'll learn";
const programmeTitle = lang === 'fr' ? "Programme détaillé" : "Full program";
const prereqTitle = lang === 'fr' ? "Prérequis" : "Prerequisites";
const rightColTitle = lang === 'fr' ? "Programme" : "Program";
const ctaEnroll = lang === 'fr'
  ? `S'inscrire${priceStr ? ` — ${priceStr}` : ''}`
  : `Enroll${priceStr ? ` — ${priceStr}` : ''}`;
const ctaSoon = lang === 'fr' ? "Inscriptions bientôt disponibles" : "Enrollment coming soon";
const ctaSeeProgram = lang === 'fr' ? "Voir le programme" : "See the program";
const ctaContact = lang === 'fr'
  ? "Disponible prochainement — nous contacter"
  : "Coming soon — contact us";
---

<article class="formation-detail">
  <!-- HERO 2-COLS -->
  <div class="hero">
    <div class="hero-left">
      <Kicker as="p">{`${lang === 'fr' ? 'Cours' : 'Course'} · ${levelLabel} · ${data.duration_hours}h · ${formatLabel}`}</Kicker>
      <h1 class="heading">{title}</h1>
      <p class="lede">{description}</p>
      <div class="cta-group">
        {stripeLink && !isPlaceholder ? (
          <a class="btn-primary" href={stripeLink} target="_blank" rel="noopener noreferrer">
            {ctaEnroll}
          </a>
        ) : (
          <span class="btn-primary btn-disabled">{ctaSoon}</span>
        )}
        <a class="btn-secondary" href="#programme">{ctaSeeProgram} ↓</a>
      </div>
    </div>
    <div class="hero-right">
      <p class="right-label">{rightColTitle}</p>
      <div class="modules-preview">
        {data.modules.map((mod, i) => {
          const modTitle = lang === 'fr' ? mod.title_fr : mod.title_en;
          const typeLabel = typeLabels[lang][mod.type] ?? mod.type;
          return (
            <div class="module-preview-item">
              <div class="module-meta">
                <span class="mono muted">{mod.num}</span>
                <span class="mono muted">{mod.duration_minutes}min</span>
                <span class="type-pill">{typeLabel}</span>
              </div>
              <p class="module-title-text">{modTitle}</p>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- OBJECTIFS -->
  <section class="section" id="programme">
    <h2 class="section-heading">{objectivesTitle}</h2>
    <ol class="objectives-list">
      {objectives.map((obj) => (
        <li class="objective-item">{obj}</li>
      ))}
    </ol>
  </section>

  <!-- PROGRAMME COMPLET -->
  <section class="section">
    <h2 class="section-heading">{programmeTitle}</h2>
    <div class="modules-table">
      {data.modules.map((mod) => {
        const modTitle = lang === 'fr' ? mod.title_fr : mod.title_en;
        const typeLabel = typeLabels[lang][mod.type] ?? mod.type;
        return (
          <div class="module-row">
            <span class="mod-num mono">{mod.num}</span>
            <span class="mod-title">{modTitle}</span>
            <span class="mod-duration mono muted">{mod.duration_minutes}min</span>
            <span class={`type-pill type-pill--${mod.type}`}>{typeLabel}</span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- PREREQUISITES -->
  {prerequisites && prerequisites.length > 0 && (
    <section class="section">
      <h2 class="section-heading">{prereqTitle}</h2>
      <ul class="prereq-list">
        {prerequisites.map((p) => (
          <li class="prereq-item">{p}</li>
        ))}
      </ul>
    </section>
  )}

  <!-- BODY MDX -->
  <section class="section mdx-body">
    <slot />
  </section>

  <!-- CTA FINALE -->
  <div class="cta-finale">
    {stripeLink && !isPlaceholder ? (
      <div class="cta-row">
        <a class="btn-primary" href={stripeLink} target="_blank" rel="noopener noreferrer">
          {ctaEnroll}
        </a>
        <a class="cta-secondary-link" href="/contact">
          {lang === 'fr' ? 'Une question ?' : 'Have a question?'} →
        </a>
      </div>
    ) : (
      <div class="cta-row">
        <a class="cta-secondary-link cta-accent" href="/contact">{ctaContact} →</a>
      </div>
    )}
  </div>
</article>

<style>
  .formation-detail {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 var(--space-page-x, 24px);
    background: var(--paper);
  }

  /* HERO */
  .hero {
    display: grid;
    grid-template-columns: 58% 42%;
    gap: 64px;
    padding: 72px 0 56px;
    border-bottom: 1px solid var(--hairline);
    align-items: start;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 24px;
  }

  .heading {
    font-size: var(--text-h1-hero);
    font-family: var(--font-display);
    font-weight: 400;
    line-height: 1.05;
    margin: 0 0 24px;
  }

  .lede {
    font-size: var(--text-lede);
    font-family: var(--font-sans);
    line-height: 1.5;
    margin: 0 0 32px;
    color: var(--text-secondary, #444);
  }

  .cta-group {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-start;
  }

  .btn-primary {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    padding: 12px 24px;
    background: var(--text-primary, #111);
    color: var(--paper);
    text-decoration: none;
    border: 1px solid var(--text-primary, #111);
    transition: background 0.15s, color 0.15s;
  }

  .btn-primary:hover {
    background: var(--accent);
    border-color: var(--accent);
  }

  .btn-disabled {
    opacity: 0.5;
    cursor: not-allowed;
    pointer-events: none;
  }

  .btn-secondary {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    color: var(--text-secondary, #444);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .btn-secondary:hover {
    color: var(--accent);
  }

  /* RIGHT COL */
  .hero-right {
    padding-top: 8px;
  }

  .right-label {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted, #888);
    margin: 0 0 16px;
  }

  .modules-preview {
    border-top: 1px solid var(--hairline);
  }

  .module-preview-item {
    padding: 14px 0;
    border-bottom: 1px solid var(--hairline);
  }

  .module-meta {
    display: flex;
    gap: 12px;
    align-items: center;
    margin-bottom: 4px;
  }

  .module-title-text {
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 500;
    margin: 0;
    line-height: 1.4;
  }

  .mono {
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .muted {
    color: var(--text-muted, #888);
  }

  .type-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 2px 6px;
    border: 1px solid var(--hairline);
    border-radius: 2px;
    color: var(--text-muted, #888);
  }

  /* SECTIONS */
  .section {
    padding: 48px 0 0;
  }

  .section-heading {
    font-family: var(--font-display);
    font-size: clamp(22px, 3vw, 28px);
    font-weight: 400;
    margin: 0 0 24px;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 16px;
  }

  /* OBJECTIVES */
  .objectives-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
    counter-reset: obj;
  }

  .objective-item {
    counter-increment: obj;
    padding: 16px 0;
    border-bottom: 1px solid var(--hairline);
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.5;
    display: grid;
    grid-template-columns: 32px 1fr;
    align-items: start;
    gap: 12px;
  }

  .objective-item::before {
    content: counter(obj, decimal-leading-zero);
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--accent);
    margin-top: 2px;
  }

  /* MODULES TABLE */
  .modules-table {
    border-top: 1px solid var(--hairline);
  }

  .module-row {
    display: grid;
    grid-template-columns: 40px 1fr 70px 100px;
    gap: 0 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--hairline);
    align-items: center;
  }

  .mod-num {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted, #888);
  }

  .mod-title {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.4;
  }

  .mod-duration {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-muted, #888);
    text-align: right;
  }

  .type-pill--lecture { border-color: #3a7d44; color: #3a7d44; }
  .type-pill--exercice { border-color: var(--accent); color: var(--accent); }
  .type-pill--projet { border-color: #7b4ea6; color: #7b4ea6; }
  .type-pill--evaluation { border-color: #111; color: #111; }

  /* PREREQS */
  .prereq-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid var(--hairline);
  }

  .prereq-item {
    padding: 14px 0;
    border-bottom: 1px solid var(--hairline);
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }

  .prereq-item::before {
    content: '—';
    position: absolute;
    left: 0;
    font-family: var(--font-mono);
    color: var(--text-muted, #888);
  }

  /* MDX BODY */
  .mdx-body {
    border-top: 1px solid var(--hairline);
    margin-top: 48px;
    padding-top: 48px;
  }

  .mdx-body :global(h2) {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 24px);
    font-weight: 400;
    margin-top: 40px;
    margin-bottom: 16px;
  }

  .mdx-body :global(p) {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-secondary, #444);
    margin-bottom: 20px;
  }

  /* CTA FINALE */
  .cta-finale {
    padding: 56px 0 72px;
    border-top: 1px solid var(--hairline);
    margin-top: 48px;
  }

  .cta-row {
    display: flex;
    gap: 24px;
    align-items: center;
    flex-wrap: wrap;
  }

  .cta-secondary-link {
    font-family: var(--font-sans);
    font-size: 14px;
    color: var(--text-secondary, #444);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .cta-accent {
    color: var(--accent);
  }

  .cta-secondary-link:hover {
    color: var(--accent);
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .hero {
      grid-template-columns: 1fr;
      gap: 40px;
      padding: 40px 0 32px;
    }

    .module-row {
      grid-template-columns: 32px 1fr 70px;
    }

    .type-pill { display: none; }
  }
</style>
