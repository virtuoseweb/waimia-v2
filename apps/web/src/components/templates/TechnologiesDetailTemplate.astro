---
/**
 * TechnologiesDetailTemplate · sub-page Technologies (focus stack architecture)
 *
 * Sections (6 fixes + 2 conditionnelles) sémantiquement différenciées de Offres/Solutions :
 *   1. Hero Layer · breadcrumb + badge COUCHE coloré (claude/os/orch) + h1 + lead italique + meta + SVG triangles
 *   2. Positioning Split · "Pourquoi X" — split 50/50 statement éditorial + 3 facts mono kv
 *   3. Capabilities Grid · 3×2 cards (kicker + h3 + p + value signature)
 *   4. Models Comparison Table (CONDITIONNEL showModels) · 5 colonnes (modèle / profil / coût / contexte / usages)
 *   5. When To Use Dual · split "Utiliser quand" / "Considérer autre chose quand"
 *   6. Integration Flow · 5 nœuds horizontaux avec 1 actif
 *   7. Ecosystem Grid (CONDITIONNEL showEcosystem) · 4 cards éditeurs open-source (uniquement layerType=os)
 *   8. CTA dark · "Quelle stack pour votre contexte ?"
 *
 * Briques signature : Positioning Split (prise de position), When To Use Dual (aide décision rare), Integration Flow.
 * Géométrie hero : triangles SVG (Offres=cercles, Solutions=rect-rotated, Technologies=triangles).
 * Source handoff : project/pages/technologies/detail.html (lignes 162-298, dict TECHNOLOGIES).
 *
 * Usage minimal (props) :
 *   <TechnologiesDetailTemplate
 *     layer="COUCHE MODÈLES"
 *     layerLabel="Claude Models"
 *     layerType="claude"
 *     showModels={true}
 *     meta="Anthropic · Claude-first"
 *     title="Claude Models · Waimia"
 *     description="Haiku, Sonnet, Opus, Code — un modèle par profil de tâche."
 *   >
 *     <Fragment slot="title"><i>Claude</i><br/>Models</Fragment>
 *     <Fragment slot="lead">Lead html...</Fragment>
 *     ... etc
 *   </TechnologiesDetailTemplate>
 */
import Base from '../../layouts/Base.astro';


interface Props {
  /** SEO meta · title de la page */
  title: string;
  /** SEO meta · description */
  description: string;
  /** Badge couche (kicker au-dessus du h1) ex: "COUCHE MODÈLES" */
  layer: string;
  /** Label du breadcrumb second segment ex: "Claude Models" */
  layerLabel: string;
  /** Type de couche — détermine la couleur du badge : claude (orange) / os (vert) / orch (bleu) */
  layerType?: 'claude' | 'os' | 'orch';
  /** Affiche la table de comparaison des modèles (default false, généralement true pour layerType=claude) */
  showModels?: boolean;
  /** Affiche la grille écosystème (default false, généralement true pour layerType=os) */
  showEcosystem?: boolean;
  /** Meta sous le CTA hero ex: "Anthropic · Claude-first" */
  meta?: string;
  /** Href du CTA hero (default /contact) */
  ctaHref?: string;
  /** Label du CTA hero (default "Parler architecture →") */
  ctaLabel?: string;
}

const {
  title,
  description,
  layer,
  layerLabel,
  layerType = 'claude',
  showModels = false,
  showEcosystem = false,
  meta = '',
  ctaHref = '/contact',
  ctaLabel = 'Parler architecture →',
} = Astro.props;
---
<Base {title} {description}>
    {/* ────────── 1. HERO LAYER ────────── */}
    <section class={`tech-hero tech-hero--${layerType}`} data-screen-label="01 Hero Layer">
      <svg class="tech-hero-geo" viewBox="0 0 1440 700" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        {/* Triangles superposés — signature géométrique Technologies */}
        <polygon points="1100,80 1340,80 1220,300" fill="none" stroke="currentColor" stroke-width=".6" opacity=".18"/>
        <polygon points="1160,140 1320,140 1240,280" fill="none" stroke="var(--accent)" stroke-width=".4" opacity=".25"/>
        <polygon points="60,420 280,420 170,580" fill="none" stroke="currentColor" stroke-width=".4" opacity=".12"/>
        <line x1="0" y1="500" x2="1440" y2="380" stroke="currentColor" stroke-width=".3" opacity=".1"/>
      </svg>
      <div class="wrap">
        <nav class="tech-hero-bc" aria-label="Fil d'Ariane">
          <a href="/technologies">Technologies</a>
          <span aria-hidden="true">/</span>
          <span>{layerLabel}</span>
        </nav>
        <div class={`tech-hero-layer tech-hero-layer--${layerType}`}>{layer}</div>
        <h1 class="tech-hero-title"><slot name="title" /></h1>
        <div class="tech-hero-sub">
          <p class="tech-hero-lead"><slot name="lead" /></p>
          <div class="tech-hero-actions">
            <a class="tech-hero-cta" href={ctaHref}>{ctaLabel}</a>
            {meta && <div class="tech-hero-meta">{meta}</div>}
          </div>
        </div>
      </div>
    </section>

    {/* ────────── 2. POSITIONING SPLIT (signature) ────────── */}
    <section class="tech-sec tech-sec-paper" data-screen-label="02 Positioning">
      <div class="wrap">
        <div class="tech-pos-split">
          <div class="tech-pos-left">
            <div class="kicker">Position Waimia</div>
            <h2 class="tech-pos-title"><slot name="positioning-title" /></h2>
            <p class="tech-aside"><slot name="positioning-aside" /></p>
          </div>
          <div class="tech-pos-right">
            <div class="tech-pos-statement"><slot name="positioning-statement" /></div>
            <div class="tech-pos-facts"><slot name="positioning-facts" /></div>
          </div>
        </div>
      </div>
    </section>

    {/* ────────── 3. CAPABILITIES GRID ────────── */}
    <section class="tech-sec" data-screen-label="03 Capabilities">
      <div class="wrap">
        <div class="tech-sec-hd">
          <div>
            <div class="kicker">Capacités</div>
            <h2><slot name="capabilities-title"><i>Inventaire</i><br/>technique</slot></h2>
          </div>
          <p class="tech-aside"><slot name="capabilities-aside" /></p>
        </div>
        <div class="tech-cap-grid"><slot name="capabilities" /></div>
      </div>
    </section>

    {/* ────────── 4. MODELS COMPARISON TABLE (conditionnel) ────────── */}
    {showModels && (
      <section class="tech-sec tech-sec-paper" data-screen-label="04 Models">
        <div class="wrap">
          <div class="tech-sec-hd">
            <div>
              <div class="kicker">Choisir le bon modèle</div>
              <h2><slot name="models-title"><i>Modèles</i><br/>disponibles</slot></h2>
            </div>
            <p class="tech-aside"><slot name="models-aside" /></p>
          </div>
          <div class="tech-models-table-wrap">
            <table class="tech-models-table">
              <thead>
                <tr>
                  <th scope="col">Modèle</th>
                  <th scope="col">Profil</th>
                  <th scope="col">Coût</th>
                  <th scope="col">Contexte</th>
                  <th scope="col">Usages</th>
                </tr>
              </thead>
              <tbody>
                <slot name="models-rows" />
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}

    {/* ────────── 5. WHEN TO USE DUAL (signature) ────────── */}
    <section class="tech-sec" data-screen-label="05 When To Use">
      <div class="wrap">
        <div class="tech-sec-hd">
          <div>
            <div class="kicker">Aide décision</div>
            <h2><slot name="when-title"><i>Quand</i><br/>l'utiliser ?</slot></h2>
          </div>
          <p class="tech-aside"><slot name="when-aside" /></p>
        </div>
        <div class="tech-when-dual">
          <div class="tech-when-col tech-when-col--use">
            <div class="kicker tech-when-kicker">Utiliser quand</div>
            <ul class="tech-when-list tech-when-list--use">
              <slot name="when-use" />
            </ul>
          </div>
          <div class="tech-when-col tech-when-col--avoid">
            <div class="kicker tech-when-kicker">Considérer autre chose quand</div>
            <ul class="tech-when-list tech-when-list--avoid">
              <slot name="when-avoid" />
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* ────────── 6. INTEGRATION FLOW (signature) ────────── */}
    <section class="tech-sec tech-sec-paper" data-screen-label="06 Integration">
      <div class="wrap">
        <div class="tech-sec-hd">
          <div>
            <div class="kicker">Position dans la stack</div>
            <h2><slot name="integration-title"><i>Intégration</i></slot></h2>
          </div>
          <p class="tech-aside"><slot name="integration-aside" /></p>
        </div>
        <div class="tech-int-flow"><slot name="integration-nodes" /></div>
      </div>
    </section>

    {/* ────────── 7. ECOSYSTEM GRID (conditionnel layerType=os) ────────── */}
    {showEcosystem && (
      <section class="tech-sec" data-screen-label="07 Ecosystem">
        <div class="wrap">
          <div class="tech-sec-hd">
            <div>
              <div class="kicker">Écosystème open-source</div>
              <h2><slot name="ecosystem-title"><i>Éditeurs</i><br/>compatibles</slot></h2>
            </div>
            <p class="tech-aside"><slot name="ecosystem-aside" /></p>
          </div>
          <div class="tech-eco-grid"><slot name="ecosystem" /></div>
        </div>
      </section>
    )}

    {/* ────────── 8. RELATED (optionnel) ────────── */}
    <slot name="related" />

    {/* ────────── 9. CTA ARCHITECTURE DARK ────────── */}
    <section class="tech-sec tech-sec-dark" data-screen-label="09 CTA">
      <div class="wrap wrap-tight">
        <div class="tech-cta-final">
          <h2><i><slot name="cta-title">Quelle stack<br/>pour votre<br/>contexte ?</slot></i></h2>
          <div class="tech-cta-body">
            <p><slot name="cta-body">Chaque déploiement Waimia commence par un choix technologique rigoureux — adapté à vos contraintes, pas à nos préférences.</slot></p>
            <div class="tech-cta-btns">
              <a class="btn-accent" href="/contact">Parler architecture →</a>
              <a class="btn-light" href="/technologies">Voir la stack complète</a>
            </div>
          </div>
        </div>
      </div>
    </section>
</Base>

<style>
  /* ───── Hero ───── */
  .tech-hero {
    position: relative;
    padding: clamp(80px, 10vw, 140px) 0 clamp(64px, 8vw, 120px);
    overflow: hidden;
    color: var(--ink);
  }
  .tech-hero-geo {
    position: absolute; inset: 0; width: 100%; height: 100%;
    pointer-events: none;
  }
  .tech-hero-bc {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex; gap: 8px; align-items: center;
    margin-bottom: 24px;
  }
  .tech-hero-bc a { color: var(--muted); transition: color 220ms var(--ease); }
  .tech-hero-bc a:hover { color: var(--accent); }
  .tech-hero-layer {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 20px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .tech-hero-layer::before {
    content: '';
    width: 8px; height: 8px;
    border-radius: 999px;
    background: currentColor;
  }
  .tech-hero-layer--claude { color: var(--accent); }
  .tech-hero-layer--os { color: #2AA876; }
  .tech-hero-layer--orch { color: #3321FF; }
  .tech-hero-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 148px);
    line-height: 0.92;
    letter-spacing: -0.028em;
    font-weight: 400;
    margin: 0 0 32px;
    text-wrap: balance;
  }
  .tech-hero-title :global(i) { color: var(--accent); font-style: italic; }
  .tech-hero--os .tech-hero-title :global(i) { color: #2AA876; }
  .tech-hero--orch .tech-hero-title :global(i) { color: #3321FF; }
  .tech-hero-sub {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(24px, 4vw, 64px);
    align-items: end;
    max-width: 1100px;
  }
  .tech-hero-lead {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.4;
    color: var(--ink);
    font-style: italic;
    margin: 0;
  }
  .tech-hero-lead :global(span) { color: var(--accent); display: block; margin-top: 8px; }
  .tech-hero--os .tech-hero-lead :global(span) { color: #2AA876; }
  .tech-hero--orch .tech-hero-lead :global(span) { color: #3321FF; }
  .tech-hero-actions { display: flex; flex-direction: column; gap: 12px; align-items: flex-start; }
  .tech-hero-cta {
    display: inline-block;
    padding: 14px 24px;
    background: var(--ink);
    color: var(--paper);
    border-radius: 999px;
    font-size: 14px;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.005em;
    transition: transform 220ms var(--ease), box-shadow 220ms var(--ease);
  }
  .tech-hero-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
  .tech-hero-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* ───── Sec common ───── */
  .tech-sec { padding: clamp(72px, 8vw, 120px) 0; position: relative; }
  .tech-sec-paper { background: var(--paper-2, #EFEBE2); }
  .tech-sec-dark { background: var(--ink); color: var(--paper); }
  .tech-sec-dark :global(.kicker) { color: var(--accent); }
  .tech-sec-hd {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(24px, 4vw, 80px);
    margin-bottom: clamp(40px, 5vw, 64px);
    align-items: end;
  }
  .tech-sec-hd h2 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 72px);
    line-height: 0.96;
    letter-spacing: -0.018em;
    font-weight: 400;
    margin: 8px 0 0;
  }
  .tech-sec-hd :global(i) { color: var(--accent); font-style: italic; }
  .tech-aside {
    font-family: var(--font-display);
    font-size: clamp(15px, 1.3vw, 17px);
    line-height: 1.5;
    color: var(--muted);
    font-style: italic;
    max-width: 480px;
    margin: 0;
  }

  /* ───── Positioning Split (signature) ───── */
  .tech-pos-split {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(32px, 5vw, 80px);
    align-items: start;
  }
  .tech-pos-title {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    font-weight: 400;
    margin: 8px 0 24px;
  }
  .tech-pos-title :global(i) { color: var(--accent); font-style: italic; }
  .tech-pos-statement {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 32px);
    line-height: 1.32;
    letter-spacing: -0.012em;
    color: var(--ink);
    font-style: italic;
    margin-bottom: clamp(28px, 4vw, 48px);
    text-wrap: balance;
  }
  .tech-pos-statement :global(em) { color: var(--accent); font-style: italic; }
  .tech-pos-facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    border-top: 1px solid rgba(0,0,0,0.1);
  }
  .tech-pos-facts :global(.fact) {
    display: grid;
    grid-template-columns: minmax(140px, 1fr) auto 2fr;
    gap: 16px 24px;
    padding: 18px 0;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    align-items: baseline;
  }
  .tech-pos-facts :global(.fact-k) {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
  }
  .tech-pos-facts :global(.fact-v) {
    font-family: var(--font-display);
    font-size: clamp(18px, 1.8vw, 22px);
    color: var(--accent);
    line-height: 1;
    font-weight: 400;
    white-space: nowrap;
  }
  .tech-pos-facts :global(.fact-l) {
    font-family: var(--font-display);
    font-size: 14.5px;
    line-height: 1.45;
    color: var(--ink);
    font-style: italic;
  }

  /* ───── Capabilities Grid ───── */
  .tech-cap-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: clamp(20px, 2.5vw, 32px);
  }
  .tech-cap-grid :global(.cap-card) {
    padding: 32px 28px;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    background: var(--paper);
    transition: border-color 220ms var(--ease), transform 220ms var(--ease);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tech-cap-grid :global(.cap-card:hover) { border-color: var(--accent); transform: translateY(-2px); }
  .tech-cap-grid :global(.cap-ck) {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .tech-cap-grid :global(.cap-card h3) {
    font-family: var(--font-display);
    font-size: clamp(20px, 1.7vw, 24px);
    line-height: 1.2;
    margin: 0;
    font-weight: 400;
  }
  .tech-cap-grid :global(.cap-card p) {
    font-size: 14.5px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 8px;
    flex: 1;
  }
  .tech-cap-grid :global(.cap-v) {
    font-family: var(--font-display);
    font-size: clamp(28px, 2.6vw, 36px);
    color: var(--accent);
    line-height: 1;
    font-weight: 400;
    margin-top: auto;
  }

  /* ───── Models Comparison Table ───── */
  .tech-models-table-wrap {
    overflow-x: auto;
    border: 1px solid rgba(0,0,0,0.1);
    border-radius: 12px;
    background: var(--paper);
  }
  .tech-models-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 14.5px;
  }
  .tech-models-table thead th {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: left;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    font-weight: 500;
  }
  .tech-models-table tbody :global(td) {
    padding: 18px 20px;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    line-height: 1.5;
    vertical-align: top;
  }
  .tech-models-table tbody :global(tr:last-child td) { border-bottom: none; }
  .tech-models-table tbody :global(.mdl-name) {
    font-family: var(--font-display);
    font-size: 17px;
    color: var(--ink);
    font-weight: 400;
    white-space: nowrap;
  }
  .tech-models-table tbody :global(.mdl-badge) {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 5px 10px;
    border-radius: 4px;
    display: inline-block;
    background: rgba(201,79,46,0.08);
    color: var(--accent);
    white-space: nowrap;
  }
  .tech-models-table tbody :global(.mdl-badge--speed) { background: rgba(42,168,118,0.1); color: #2AA876; }
  .tech-models-table tbody :global(.mdl-badge--balance) { background: rgba(201,79,46,0.08); color: var(--accent); }
  .tech-models-table tbody :global(.mdl-badge--power) { background: rgba(51,33,255,0.08); color: #3321FF; }
  .tech-models-table tbody :global(.mdl-badge--code) { background: rgba(0,0,0,0.06); color: var(--ink); }
  .tech-models-table tbody :global(.mdl-cost),
  .tech-models-table tbody :global(.mdl-ctx) {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink);
    white-space: nowrap;
  }
  .tech-models-table tbody :global(.mdl-uses) {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.5;
  }

  /* ───── When To Use Dual (signature) ───── */
  .tech-when-dual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 4vw, 64px);
    align-items: start;
  }
  .tech-when-kicker { margin-bottom: 20px; }
  .tech-when-col--use .tech-when-kicker { color: var(--accent); }
  .tech-when-col--avoid .tech-when-kicker { color: var(--muted); }
  .tech-when-list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid rgba(0,0,0,0.1);
  }
  .tech-when-list :global(li) {
    padding: 18px 0 18px 28px;
    border-bottom: 1px solid rgba(0,0,0,0.08);
    font-family: var(--font-display);
    font-size: clamp(16px, 1.4vw, 18.5px);
    line-height: 1.45;
    color: var(--ink);
    position: relative;
  }
  .tech-when-list--use :global(li::before) {
    content: '+';
    position: absolute;
    left: 0; top: 18px;
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--accent);
    font-weight: 500;
    line-height: 1;
  }
  .tech-when-list--avoid :global(li) { color: var(--muted); }
  .tech-when-list--avoid :global(li::before) {
    content: '−';
    position: absolute;
    left: 0; top: 18px;
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--muted);
    line-height: 1;
  }

  /* ───── Integration Flow (signature) ───── */
  .tech-int-flow {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(12px, 1.5vw, 24px);
    counter-reset: flow;
    position: relative;
  }
  .tech-int-flow::before {
    content: '';
    position: absolute;
    top: 14px; left: 5%; right: 5%;
    height: 1px;
    background: rgba(0,0,0,0.12);
    z-index: 0;
  }
  .tech-int-flow :global(.flow-node) {
    position: relative;
    padding: 32px 16px 20px;
    text-align: left;
    z-index: 1;
  }
  .tech-int-flow :global(.flow-node::before) {
    content: '';
    position: absolute;
    top: 8px; left: 16px;
    width: 12px; height: 12px;
    border-radius: 999px;
    background: var(--paper-2, #EFEBE2);
    border: 1px solid rgba(0,0,0,0.2);
    z-index: 2;
  }
