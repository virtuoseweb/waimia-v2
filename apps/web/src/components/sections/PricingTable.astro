---
import type { SectionByType } from '../../schemas/sections';
import Kicker from '../ui/atoms/Kicker.astro';
import Button from '../ui/atoms/Button.astro';

interface Props {
  data: SectionByType<'pricing-table'>;
  lang: 'fr' | 'en';
}
const { data, lang } = Astro.props;
const isFr = lang === 'fr';
---

<section class="pricing-table">
  <div class="wrap-wide">
  <div class="pricing-table__header">
    {(isFr ? data.kicker_fr : data.kicker_en) && (
      <Kicker tone="muted">{isFr ? data.kicker_fr : data.kicker_en}</Kicker>
    )}
    <h2 set:html={isFr ? data.h2_fr : data.h2_en} />
  </div>
  <div class="pricing-table__grid" style={`--col-count: ${data.tiers.length}`}>
    {data.tiers.map((tier: (typeof data.tiers)[number]) => (
      <div class:list={['pricing-table__tier', tier.featured && 'pricing-table__tier--featured']}>
        <div class="pricing-table__tier-header">
          <strong class="pricing-table__tier-name">{isFr ? tier.name_fr : tier.name_en}</strong>
          <span class="pricing-table__price">{tier.price}</span>
        </div>
        <ul class="pricing-table__features">
          {(isFr ? tier.features_fr : tier.features_en).map((f: string) => (
            <li>
              <span class="pricing-table__check">▸</span>
              {f}
            </li>
          ))}
        </ul>
        <div class="pricing-table__cta">
          <Button
            href={tier.cta.href}
            variant={tier.featured ? 'accent' : (tier.cta.variant as any)}
            size="md"
            class="pricing-table__btn"
          >
            {isFr ? tier.cta.label_fr : tier.cta.label_en}
          </Button>
        </div>
      </div>
    ))}
  </div>
  </div>
</section>

<style>
  .pricing-table {
    padding-block: var(--spacing-section);
    border-bottom: 1px solid var(--hairline);
  }
  .pricing-table__header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: var(--spacing-block);
  }
  h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2-section);
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
  }
  h2 :global(i) { font-style: italic; }
  .pricing-table__grid {
    display: grid;
    grid-template-columns: repeat(var(--col-count, 3), 1fr);
    border-top: 1px solid var(--hairline);
    border-left: 1px solid var(--hairline);
  }
  .pricing-table__tier {
    border-right: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .pricing-table__tier--featured {
    background: rgba(181,71,42,.04);
    position: relative;
  }
  .pricing-table__tier--featured::before {
    content: '';
    display: block;
    height: 2px;
    background: var(--accent);
    position: absolute;
    top: -1px;
    left: -1px;
    right: -1px;
  }
  .pricing-table__tier-header {
    padding: 24px 24px 16px;
    border-bottom: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pricing-table__tier-name {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 400;
  }
  .pricing-table__tier--featured .pricing-table__tier-name { color: var(--accent); }
  .pricing-table__price {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.5vw, 36px);
    line-height: 1;
    color: var(--ink);
  }
  .pricing-table__features {
    list-style: none;
    margin: 0;
    padding: 16px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .pricing-table__features li {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    color: var(--ink);
    display: flex;
    gap: 10px;
    align-items: baseline;
    line-height: 1.5;
    border-bottom: 1px solid var(--hairline);
    padding-bottom: 10px;
  }
  .pricing-table__features li:last-child { border-bottom: none; padding-bottom: 0; }
  .pricing-table__check {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 10px;
    flex-shrink: 0;
  }
  .pricing-table__cta { padding: 16px 24px 24px; }
  .pricing-table__btn { width: 100%; }
  @media (max-width: 768px) {
    .pricing-table__grid { grid-template-columns: 1fr; --col-count: 1; }
  }
</style>
