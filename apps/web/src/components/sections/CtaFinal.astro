---
import type { SectionByType } from '../../schemas/sections';
import Button from '../ui/atoms/Button.astro';

interface Props {
  data: SectionByType<'cta-final'>;
  lang: 'fr' | 'en';
}
const { data, lang } = Astro.props;
const isFr = lang === 'fr';
---

<section class="cta-final" data-bg={data.background}>
  <div class="wrap-wide">
  <div class="cta-final__inner">
    <h2 class="reveal-mask-up" set:html={isFr ? data.h2_fr : data.h2_en} />
    {(isFr ? data.body_fr : data.body_en) && (
      <p class="reveal reveal-fade">{isFr ? data.body_fr : data.body_en}</p>
    )}
    <div class="cta-final__ctas">
      <Button href={data.cta_primary.href} variant={data.cta_primary.variant as any} size="lg" mag={data.cta_primary.mag ?? 0.18}>
        {isFr ? data.cta_primary.label_fr : data.cta_primary.label_en}
      </Button>
      {data.cta_secondary && (
        <Button href={data.cta_secondary.href} variant={data.cta_secondary.variant as any} size="md">
          {isFr ? data.cta_secondary.label_fr : data.cta_secondary.label_en}
        </Button>
      )}
    </div>
  </div>
  </div>
</section>

<style>
  .cta-final { padding-block: var(--spacing-section); }
  .cta-final[data-bg="paper"] { background: var(--paper); border-block: 1px solid var(--hairline); }
  .cta-final[data-bg="paper-2"] { background: var(--paper-2); border-block: 1px solid var(--hairline); }
  .cta-final[data-bg="ink"] { background: var(--ink); }
  .cta-final[data-bg="accent"] { background: var(--accent); }
  .cta-final[data-bg="ink"] h2,
  .cta-final[data-bg="ink"] p { color: var(--paper); }
  .cta-final[data-bg="accent"] h2,
  .cta-final[data-bg="accent"] p { color: var(--paper); }
  .cta-final__inner {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-block);
    max-width: 72ch;
  }
  h2 {
    font-family: var(--font-serif);
    font-size: var(--text-h1);
    line-height: 1.05;
    color: var(--ink);
    margin: 0;
  }
  h2 :global(i) { font-style: italic; }
  p {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.4vw, 20px);
    line-height: 1.6;
    color: var(--muted);
    margin: 0;
    max-width: 56ch;
  }
  .cta-final__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
</style>
