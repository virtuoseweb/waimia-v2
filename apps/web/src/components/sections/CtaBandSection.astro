---
import type { SectionByType } from '../../schemas/sections';
import Button from '../ui/atoms/Button.astro';

interface Props {
  data: SectionByType<'cta-band'>;
  lang: 'fr' | 'en';
}
const { data, lang } = Astro.props;
const isFr = lang === 'fr';
---

<div class="cta-band" data-bg={data.background}>
  <div class="wrap-wide cta-band__inner">
    <p class="cta-band__text">{isFr ? data.text_fr : data.text_en}</p>
    <Button href={data.cta.href} variant={data.cta.variant as any} size="md" mag={data.cta.mag ?? 0.12}>
      {isFr ? data.cta.label_fr : data.cta.label_en}
    </Button>
  </div>
</div>

<style>
  .cta-band {
    padding-block: 20px;
    border-block: 1px solid var(--hairline);
  }
  .cta-band__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .cta-band[data-bg="paper-2"] { background: var(--paper-2); }
  .cta-band[data-bg="ink"] { background: var(--ink); }
  .cta-band[data-bg="accent"] { background: var(--accent); }
  .cta-band[data-bg="ink"] .cta-band__text { color: var(--paper); }
  .cta-band[data-bg="accent"] .cta-band__text { color: var(--paper); }
  .cta-band__text {
    font-family: var(--font-sans);
    font-size: var(--text-body-md);
    color: var(--ink);
    margin: 0;
    max-width: 60ch;
    line-height: 1.5;
  }
</style>
