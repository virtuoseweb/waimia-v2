---
// FaqAccordion · section W6 · accordéon canonique FAQ
// Pivot du dispositif GEO/AIO. Cf docs/02-geo-aio-strategy.md
//
// Deux modes d'usage :
//   1. CMS  : <FaqAccordion data={section} lang="fr" />
//   2. Direct: <FaqAccordion items={[{q,a}]} heading="..." intro="..." />
//
// Génère JSON-LD FAQPage dans les deux modes (dispositif GEO/AIO).
import type { SectionByType } from '../../schemas/sections';
import Kicker from '../ui/atoms/Kicker.astro';
import JsonLd from '../seo/JsonLd.astro';
import { faqPage } from '../../lib/seo';

interface SimpleItem { q: string; a: string }

interface DirectProps {
  items: SimpleItem[];
  heading?: string;
  intro?: string;
}

interface CmsProps {
  data: SectionByType<'faq-accordion'>;
  lang: 'fr' | 'en';
}

type Props = DirectProps | CmsProps;

let normalizedItems: SimpleItem[];
let heading: string;
let kicker: string | undefined;
let intro: string | undefined;

if ('data' in Astro.props) {
  const { data, lang } = Astro.props as CmsProps;
  const isFr = lang === 'fr';
  normalizedItems = data.items.map((it: (typeof data.items)[number]) => ({
    q: isFr ? it.q_fr : it.q_en,
    a: isFr ? it.a_fr : it.a_en,
  }));
  heading = isFr ? data.h2_fr : data.h2_en;
  kicker = isFr ? data.kicker_fr : data.kicker_en;
  intro = undefined;
} else {
  const { items, heading: h, intro: i } = Astro.props as DirectProps;
  normalizedItems = items;
  heading = h ?? 'Questions fréquentes';
  kicker = undefined;
  intro = i;
}
---

<section class="faq-accordion">
  <div class="wrap-wide">
  <div class="faq-accordion__header">
    {kicker && (
      <Kicker tone="muted">{kicker}</Kicker>
    )}
    <h2 set:html={heading} />
    {intro && <p class="faq-accordion__intro">{intro}</p>}
  </div>
  <div class="faq-accordion__list">
    {normalizedItems.map((item, i) => (
      <details class="faq-accordion__item" name="faq">
        <summary class="faq-accordion__q">
          <Kicker as="span" tone="accent" size={10} class="faq-accordion__q-label">
            Q.{String(i + 1).padStart(2, '0')}
          </Kicker>
          <span>{item.q}</span>
          <span class="faq-accordion__arrow" aria-hidden="true">↓</span>
        </summary>
        <div class="faq-accordion__a">
          <p>{item.a}</p>
        </div>
      </details>
    ))}
  </div>
  </div>
</section>

<JsonLd data={faqPage(normalizedItems)} />

<style>
  .faq-accordion {
    padding-block: var(--spacing-section);
    border-bottom: 1px solid var(--hairline);
  }
  .faq-accordion__header {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: var(--spacing-block);
  }
  h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2-section);
    line-height: 1.1;
    color: var(--ink);
    margin: 0;
  }
  h2 :global(i) { font-style: italic; }
  .faq-accordion__intro {
    font-family: var(--font-sans);
    font-size: var(--text-body-md);
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    max-width: 64ch;
    text-wrap: pretty;
  }
  .faq-accordion__item { border-top: 1px solid var(--hairline); }
  .faq-accordion__item:last-child { border-bottom: 1px solid var(--hairline); }
  .faq-accordion__q {
    list-style: none;
    display: flex;
    gap: 16px;
    align-items: baseline;
    padding-block: 20px;
    cursor: pointer;
    user-select: none;
  }
  .faq-accordion__q::-webkit-details-marker { display: none; }
  .faq-accordion__q-label { flex-shrink: 0; padding-top: 2px; line-height: 1; }
  .faq-accordion__q span:not(.faq-accordion__q-label):not(.faq-accordion__arrow) {
    font-family: var(--font-display);
    font-size: clamp(16px, 1.6vw, 22px);
    color: var(--ink);
    line-height: 1.3;
    flex: 1;
  }
  .faq-accordion__arrow {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--muted);
    transition: transform .2s;
    flex-shrink: 0;
  }
  details[open] .faq-accordion__arrow { transform: rotate(180deg); }
  .faq-accordion__a { padding: 0 0 24px 56px; }
  .faq-accordion__a p {
    font-family: var(--font-sans);
    font-size: var(--text-body-md);
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
    max-width: 64ch;
  }
</style>
