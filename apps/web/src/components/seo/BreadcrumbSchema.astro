---
interface BreadcrumbItem {
  name: string;
  item?: string;
}
interface Props {
  items: BreadcrumbItem[];
  showVisual?: boolean;
  lang?: 'fr' | 'en';
}
const { items, showVisual = false, lang = 'fr' } = Astro.props;

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    ...(crumb.item ? { item: crumb.item } : {}),
  })),
};
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(schemaData)}></script>

{showVisual && (
  <nav class="bc-schema" aria-label={lang === 'fr' ? "Fil d'Ariane" : 'Breadcrumb'}>
    <ol>
      {items.map((c, i) => (
        <li>
          {c.item
            ? <a href={c.item}>{c.name}</a>
            : <span aria-current="page">{c.name}</span>}
          {i < items.length - 1 && <span class="bc-schema__sep" aria-hidden>/</span>}
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .bc-schema {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-4);
  }
  .bc-schema ol {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }
  .bc-schema a {
    color: var(--muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color 200ms var(--ease), border-color 200ms var(--ease);
  }
  .bc-schema a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  .bc-schema__sep {
    color: var(--hairline-strong);
  }
</style>
