---
// FAQ · accordéon signature <details>/<summary> + ornement +/− · JSON-LD FAQPage
// Pivot du dispositif GEO/AIO. Cf docs/02-geo-aio-strategy.md
import JsonLd from './JsonLd.astro';
import { faqPage } from '../../lib/seo';

interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
  heading?: string;
  intro?: string;
}
const { items, heading = 'Questions fréquentes', intro } = Astro.props;
---
<section class="sec wrap-tight" aria-labelledby="faq-heading">
  <header class="sec-hd">
    <div>
      <div class="n">
        <span class="roman">§</span>
        <span>FAQ</span>
      </div>
      <h2 id="faq-heading" class="faq-h2">{heading}</h2>
    </div>
    {intro && <p class="aside">{intro}</p>}
  </header>

  <div class="faq-list reveal-stagger">
    {items.map((item) => (
      <details class="faq-item">
        <summary class="faq-q">
          <span class="faq-q-label">{item.q}</span>
        </summary>
        <div class="faq-body">
          <p class="faq-ans">{item.a}</p>
        </div>
      </details>
    ))}
  </div>
</section>

<JsonLd data={faqPage(items)} />

<style>
  /* V6 densification · padding section scoped */
  .sec[aria-labelledby="faq-heading"] {
    padding: clamp(56px, 7vw, 88px) 0;
  }

  /* V6 cap "titres pas trop gros" + densification one-viewport */
  .faq-h2 {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 42px);
    line-height: 1.15;
    letter-spacing: -0.02em;
    margin-bottom: clamp(20px, 2.5vw, 36px);
    text-wrap: balance;
    color: var(--ink);
  }

  .faq-list {
    border-top: 1px solid var(--hairline-strong);
  }

  .faq-item {
    border-bottom: 1px solid var(--hairline);
  }

  /* V6 densification · padding réduit · taille modérée */
  .faq-q {
    list-style: none;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    padding: clamp(14px, 1.8vw, 22px) 0;
    cursor: pointer;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(16px, 1.5vw, 20px);
    line-height: 1.3;
    color: var(--ink);
    transition: color 200ms var(--ease);
  }

  .faq-q::-webkit-details-marker {
    display: none;
  }

  .faq-q::after {
    content: '+';
    font-family: var(--font-mono);
    font-size: 20px;
    color: var(--accent);
    flex-shrink: 0;
    line-height: 1;
    transition: opacity 200ms var(--ease);
  }

  details[open] > .faq-q::after {
    content: '\2212';
  }

  .faq-q:hover,
  details[open] > .faq-q {
    color: var(--accent);
  }

  .faq-q-label {
    flex: 1;
    text-wrap: balance;
  }

  .faq-item {
    overflow: hidden;
  }

  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 380ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .faq-item[open] .faq-body {
    grid-template-rows: 1fr;
  }

  .faq-body > * {
    min-height: 0;
    overflow: hidden;
  }

  .faq-ans {
    font-family: var(--font-sans);
    font-style: normal;
    font-size: clamp(14px, 1.4vw, 16px);
    line-height: 1.62;
    color: var(--muted);
    max-width: 820px;
    padding-bottom: clamp(20px, 2.5vw, 32px);
    text-wrap: pretty;
    margin: 0;
  }
</style>
