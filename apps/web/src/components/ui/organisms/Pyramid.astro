---
// Section · Pyramide 4 tiers · pyra des offres
// Variant : ec-grid cols-4 d'editorial-cell + .scale-in
// Motion : .scale-in stagger sur cards + .lift hover
// Mémorable : « Quatre paliers, lus comme un escalier vers la souveraineté. »
//
// Composé de · SectionHeader (refactor atomic-components 2026-04-26)

import SectionHeader from '../molecules/SectionHeader.astro';
import { PYRAMID_TIERS } from '../../../data/sitemap';
import { langFromPath, t } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section class="sec sec-paper" aria-labelledby="pyramid-h2">
  <div class="wrap-wide">
    <SectionHeader
      roman="II"
      label={lang === 'fr' ? "Acte II — La pyramide d'engagements" : 'Act II — The engagement pyramid'}
      id="pyramid-h2"
    >
      <Fragment slot="heading">
        {lang === 'fr' ? (
          <>Quatre <i>paliers</i>, une seule architecture continue.</>
        ) : (
          <>Four <i>tiers</i>, one continuous architecture.</>
        )}
      </Fragment>
      <Fragment slot="aside">
        {lang === 'fr'
          ? "Du diagnostic process à l'infrastructure souveraine — chaque palier prépare le suivant. Vous montez quand vous êtes prêt."
          : "From process diagnostic to sovereign infrastructure — each tier sets up the next. You climb when you're ready."}
      </Fragment>
    </SectionHeader>

    <div class="pyramid-svg reveal-blur-clip">
      <svg viewBox="0 0 800 140" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
        <!-- Palier I - sommet accent -->
        <rect x="0" y="10" width="60" height="120" fill="var(--accent)" fill-opacity="0.12" stroke="var(--accent)" stroke-width="1"/>
        <!-- Séparateur accent -->
        <line x1="64" y1="10" x2="64" y2="130" stroke="var(--accent)" stroke-width="1" opacity="0.4"/>
        <!-- Palier II -->
        <rect x="64" y="10" width="116" height="120" fill="transparent" stroke="var(--hairline)" stroke-width="1"/>
        <!-- Palier III -->
        <rect x="184" y="10" width="196" height="120" fill="transparent" stroke="var(--hairline)" stroke-width="1"/>
        <!-- Palier IV -->
        <rect x="384" y="10" width="416" height="120" fill="transparent" stroke="var(--hairline)" stroke-width="1"/>
      </svg>
    </div>

    <div class="ec-grid cols-4 pyramid-asym reveal-stagger">
      {PYRAMID_TIERS.map((tier) => (
        <a class="editorial-cell lift" href={tier.href}>
          <span class="e-num">{tier.n}</span>
          <span class="e-tag">{t(tier.tag, lang)}</span>
          <h3 class="e-title">{t(tier.label, lang)}</h3>
          <p class="e-body">{t(tier.lead, lang)}</p>
          <ul class="e-list">
            {tier.items.map((it) => <li>{it}</li>)}
          </ul>
          <span class="e-go">{lang === 'fr' ? 'Voir le palier →' : 'Open tier →'}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .pyramid-svg {
    margin: clamp(40px, 5vw, 64px) 0;
    overflow: visible;
  }
  .pyramid-svg svg {
    width: 100%;
    height: auto;
    max-height: 140px;
  }

  .pyramid-asym {
    grid-template-columns: 7fr 5fr 4fr 8fr;
  }

  .editorial-cell {
    transition: transform 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1)), border-color 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .editorial-cell:hover {
    border-color: var(--accent);
  }

  .editorial-cell:hover .e-num {
    color: var(--accent);
    transition: color 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  @media (max-width: 900px) {
    .pyramid-asym {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .pyramid-asym {
      grid-template-columns: 1fr;
    }
  }
</style>
