---
// Section · Pyramide 4 tiers · pyra des offres
// Variant : ec-grid cols-4 d'editorial-cell + .scale-in
// Motion : .scale-in stagger sur cards + .lift hover
// Mémorable : « Quatre paliers, lus comme un escalier vers la souveraineté. »
//
// Composé de · SectionHeader (refactor atomic-components 2026-04-26)

import SectionHeader from '../molecules/SectionHeader.astro';
import { PYRAMID_TIERS } from '../../../data/sitemap';
import { langFromPath, t } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);

const ACTION_LABELS = [
  { fr: 'Cartographier', en: 'Map' },
  { fr: 'Câbler', en: 'Wire' },
  { fr: 'Orchestrer', en: 'Orchestrate' },
  { fr: 'Industrialiser', en: 'Industrialize' },
];
---
<section class="sec sec-paper" aria-labelledby="pyramid-h2">
  <div class="wrap-wide">
    <SectionHeader
      roman="II"
      label={lang === 'fr' ? "Acte II — La pyramide d'engagements" : 'Act II — The engagement pyramid'}
      id="pyramid-h2"
    >
      <Fragment slot="heading">
        {lang === 'fr' ? (
          <><i>Cartographier.</i> Câbler.<br/>Orchestrer. <i>Industrialiser.</i></>
        ) : (
          <><i>Map.</i> Wire.<br/>Orchestrate. <i>Industrialize.</i></>
        )}
      </Fragment>
      <Fragment slot="aside">
        {lang === 'fr'
          ? "Du diagnostic process à l'infrastructure souveraine — chaque palier prépare le suivant. Vous montez quand vous êtes prêt."
          : "From process diagnostic to sovereign infrastructure — each tier sets up the next. You climb when you're ready."}
      </Fragment>
    </SectionHeader>

    {/* Timeline maturité V7 · 4 étapes Audit → Workflow → System → Infrastructure */}
    <ol class="pyramid-timeline reveal reveal-fade" aria-label={lang === 'fr' ? "Progression de maturité IA" : 'AI maturity path'}>
      <li class="pyramid-step">
        <span class="pyramid-step-roman">I</span>
        <span class="pyramid-step-verb">{lang === 'fr' ? ACTION_LABELS[0].fr : ACTION_LABELS[0].en}</span>
        <span class="pyramid-step-stage">{lang === 'fr' ? 'Audit' : 'Audit'}</span>
      </li>
      <li class="pyramid-step">
        <span class="pyramid-step-roman">II</span>
        <span class="pyramid-step-verb">{lang === 'fr' ? ACTION_LABELS[1].fr : ACTION_LABELS[1].en}</span>
        <span class="pyramid-step-stage">{lang === 'fr' ? 'Workflow' : 'Workflow'}</span>
      </li>
      <li class="pyramid-step">
        <span class="pyramid-step-roman">III</span>
        <span class="pyramid-step-verb">{lang === 'fr' ? ACTION_LABELS[2].fr : ACTION_LABELS[2].en}</span>
        <span class="pyramid-step-stage">{lang === 'fr' ? 'Système' : 'System'}</span>
      </li>
      <li class="pyramid-step">
        <span class="pyramid-step-roman">IV</span>
        <span class="pyramid-step-verb">{lang === 'fr' ? ACTION_LABELS[3].fr : ACTION_LABELS[3].en}</span>
        <span class="pyramid-step-stage">{lang === 'fr' ? 'Infrastructure' : 'Infrastructure'}</span>
      </li>
    </ol>

    <div class="pyramid-svg reveal-blur-clip">
      <svg viewBox="0 0 800 160" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" role="presentation">
        {/* Palier I · accent solide · investment minimal mais signal max */}
        <rect x="0" y="20" width="60" height="120" fill="var(--accent)" fill-opacity="0.22" stroke="var(--accent)" stroke-width="1.2"/>
        <text x="30" y="84" text-anchor="middle" font-family="var(--font-display)" font-size="22" fill="var(--accent)" font-style="italic">I</text>
        <text x="30" y="156" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--accent)" letter-spacing="0.14em">{t(PYRAMID_TIERS[0].tag, lang)}</text>

        {/* Palier II · accent tinté */}
        <rect x="64" y="20" width="116" height="120" fill="var(--accent)" fill-opacity="0.10" stroke="var(--accent)" stroke-width="1" stroke-opacity="0.6"/>
        <text x="122" y="84" text-anchor="middle" font-family="var(--font-display)" font-size="22" fill="var(--ink)" font-style="italic">II</text>
        <text x="122" y="156" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--ink-2)" letter-spacing="0.14em">{t(PYRAMID_TIERS[1].tag, lang)}</text>

        {/* Palier III · ink-2 */}
        <rect x="184" y="20" width="196" height="120" fill="var(--accent)" fill-opacity="0.05" stroke="var(--ink-2)" stroke-width="1" stroke-opacity="0.6"/>
        <text x="282" y="84" text-anchor="middle" font-family="var(--font-display)" font-size="22" fill="var(--ink)" font-style="italic">III</text>
        <text x="282" y="156" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--ink-2)" letter-spacing="0.14em">{t(PYRAMID_TIERS[2].tag, lang)}</text>

        {/* Palier IV · hairline */}
        <rect x="384" y="20" width="416" height="120" fill="transparent" stroke="var(--hairline-strong)" stroke-width="1"/>
        <text x="592" y="84" text-anchor="middle" font-family="var(--font-display)" font-size="22" fill="var(--ink)" font-style="italic">IV</text>
        <text x="592" y="156" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--ink-2)" letter-spacing="0.14em">{t(PYRAMID_TIERS[3].tag, lang)}</text>
      </svg>
    </div>

    <div class="ec-grid cols-4 pyramid-asym reveal-stagger">
      {PYRAMID_TIERS.map((tier, idx) => (
        <a class="editorial-cell lift" href={tier.href}>
          <span class="e-action">{lang === 'fr' ? ACTION_LABELS[idx].fr : ACTION_LABELS[idx].en}</span>
          <span class="e-num">{tier.n}</span>
          <span class="e-tag">{t(tier.tag, lang)}</span>
          <h3 class="e-title">{t(tier.label, lang)}</h3>
          <p class="e-body">{t(tier.lead, lang)}</p>
          <ul class="e-list">
            {tier.items.map((it) => <li>{it}</li>)}
          </ul>
          <span class="e-go">{lang === 'fr' ? 'Voir le palier →' : 'Open tier →'}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* V6 densification "1 viewport par section majeure" */
  .sec[aria-labelledby="pyramid-h2"] {
    padding: clamp(56px, 7vw, 88px) 0;
  }
  .pyramid-svg {
    margin: clamp(20px, 2.5vw, 36px) 0 clamp(28px, 3vw, 44px);
    overflow: visible;
  }
  .pyramid-svg svg {
    width: 100%;
    height: auto;
    max-height: 140px;
  }

  .pyramid-asym {
    grid-template-columns: 7fr 5fr 4fr 8fr;
  }

  /* V6 densification · override editorial-cell pour cards plus compactes (Pyramid only) */
  .pyramid-asym .editorial-cell {
    padding: clamp(16px, 1.8vw, 24px) clamp(14px, 1.4vw, 20px);
    gap: 8px;
  }
  .pyramid-asym .editorial-cell .e-num {
    font-size: clamp(28px, 3.2vw, 44px);
    line-height: 1;
  }
  .pyramid-asym .editorial-cell .e-title {
    font-size: clamp(18px, 1.5vw, 24px);
    line-height: 1.05;
    margin-top: 4px;
  }
  .pyramid-asym .editorial-cell .e-body {
    font-size: 12.5px;
    line-height: 1.45;
  }
  .pyramid-asym .editorial-cell .e-list {
    font-size: 11px;
    gap: 3px;
  }
  .pyramid-asym .editorial-cell .e-list li {
    line-height: 1.4;
  }

  /* Tier I · primary visual weight · border accent + e-num accent par défaut */
  .pyramid-asym .editorial-cell:first-child {
    border-color: var(--accent);
    background: rgba(201, 79, 46, 0.025);
  }
  .pyramid-asym .editorial-cell:first-child .e-num {
    color: var(--accent);
  }
  .pyramid-asym .editorial-cell:first-child .e-tag {
    color: var(--accent);
  }

  .editorial-cell {
    transition: transform 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1)), border-color 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1)), background 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .editorial-cell:hover {
    border-color: var(--accent);
    background: rgba(201, 79, 46, 0.04);
  }

  .editorial-cell:hover .e-num {
    color: var(--accent);
    transition: color 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  @media (max-width: 900px) {
    .pyramid-asym {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .pyramid-asym {
      grid-template-columns: 1fr;
    }
  }

  /* V7 · Timeline maturité Audit → Workflow → System → Infrastructure */
  .pyramid-timeline {
    list-style: none;
    padding: 0;
    margin: 0 0 clamp(28px, 3vw, 44px);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--hairline-strong);
    border-bottom: 1px solid var(--hairline);
    position: relative;
  }

  .pyramid-step {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: clamp(20px, 2.2vw, 28px) clamp(16px, 1.8vw, 24px);
    border-right: 1px solid var(--hairline);
    position: relative;
  }
  .pyramid-step:last-child { border-right: none; }

  .pyramid-step::before {
    content: '';
    position: absolute;
    top: -3px;
    left: clamp(16px, 1.8vw, 24px);
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
  }

  .pyramid-step-roman {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    color: var(--muted);
  }

  .pyramid-step-verb {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-h3-row);
    line-height: var(--leading-h3);
    letter-spacing: -0.02em;
    color: var(--ink);
  }

  .pyramid-step-stage {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  /* Action verb override dans les cards */
  .pyramid-asym .editorial-cell .e-action {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(14px, 1.2vw, 17px);
    color: var(--accent);
    margin-bottom: 4px;
    letter-spacing: -0.01em;
  }

  @media (max-width: 900px) {
    .pyramid-timeline { grid-template-columns: repeat(2, 1fr); }
    .pyramid-step:nth-child(2n) { border-right: none; }
    .pyramid-step:nth-child(odd) { border-right: 1px solid var(--hairline); }
  }
  @media (max-width: 560px) {
    .pyramid-timeline { grid-template-columns: 1fr; }
    .pyramid-step, .pyramid-step:nth-child(n) { border-right: none; border-bottom: 1px solid var(--hairline); }
    .pyramid-step:last-child { border-bottom: none; }
  }
</style>
