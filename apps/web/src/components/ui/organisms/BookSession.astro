---
/**
 * Section · CTA diagnostic
 *
 * M4 remplace le ton « working session » par un cadrage business-first :
 * diagnostic de 45 minutes, plan d'action concret, sans engagement.
 */

import ChapterLabel from '../atoms/ChapterLabel.astro';
import Button from '../atoms/Button.astro';
import { langFromPath, localizeHref } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
const ctaHref = localizeHref('/contact', lang);
const email = lang === 'fr' ? 'bonjour@waimia.fr' : 'hello@waimia.fr';
---
<section id="act-5" class="book-session scale-in" aria-labelledby="book-h2">
  <div class="wrap-wide" style="text-align:center;position:relative;z-index:1">
    <div style="display:flex;justify-content:center">
      <ChapterLabel
        num="FIG V · 5.0"
        title={lang === 'fr' ? "Acte V — Passer à l'action" : 'Act V — Act'}
      />
    </div>

    <h2 id="book-h2" class="book-h2 reveal-mask-up">
      {lang === 'fr' ? (
        <>Stop le <i>théâtre</i>. <br />Câbler.</>
      ) : (
        <>Stop the <i>theatre</i>. <br />Wire it.</>
      )}
    </h2>

    <p class="book-lede">
      {lang === 'fr'
        ? "45 minutes. On regarde. On audite. On chiffre. Si on n'a rien à vous proposer, on le dit. On ne relance pas."
        : "45 minutes. We look. We audit. We price. If we have nothing to offer, we say so. No follow-up."}
    </p>

    <p class="book-avail">
      {lang === 'fr'
        ? '● DISPONIBLE · RÉPONSE SOUS 24H'
        : '● AVAILABLE · RESPONSE IN 24H'}
    </p>

    <div class="book-ctas reveal-snap">
      <Button href={ctaHref} variant="primary" size="lg" mag={0.22}>
        {lang === 'fr' ? 'Câbler →' : 'Wire it →'}
      </Button>
      <Button href={`mailto:${email}`} variant="ghost" size="lg">
        {email}
      </Button>
    </div>
  </div>
</section>

<style>
  .book-session{padding:clamp(140px,18vw,260px) 0 clamp(100px,12vw,200px);background:var(--paper);border-top:1px solid var(--hairline);border-radius:0;transition:border-radius 1200ms var(--ease)}
  .book-session.in{border-radius:32px 32px 0 0}
  .book-h2{font-family:var(--font-display);font-style:italic;font-size:clamp(64px,12vw,184px);line-height:.92;letter-spacing:-0.03em;margin:32px 0 28px;text-wrap:balance;font-weight:400}
  .book-h2 i{font-style:italic;color:var(--accent)}
  .book-lede{font-size:clamp(16px,1.8vw,19px);color:var(--muted);max-width:620px;margin:0 auto 36px;font-family:var(--font-display);line-height:1.45}
  .book-avail{font-family:var(--font-mono);font-size:11px;font-style:normal;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin:0 0 32px;line-height:1}
  .book-ctas{display:inline-flex;gap:12px;flex-wrap:wrap;justify-content:center}
</style>
