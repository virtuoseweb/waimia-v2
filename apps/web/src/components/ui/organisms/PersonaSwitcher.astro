---
/**
 * Section · PersonaSwitcher · 3 personas pour entrée auto-sélectionnée
 *
 * M4 recadre les chemins visibles en langage PME : acquisition, CRM,
 * productivité et gouvernance, sans jargon technique en surface.
 * T4.1c : consomme la collection `personas` en build-time.
 */

import { getCollection } from 'astro:content';
import { langFromPath, localizeHref } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);

type PathItem = { fr: string; en: string; href: string };
type PersonaItem = {
  k: string;
  label_fr: string;
  label_en: string;
  role_fr?: string;
  role_en?: string;
  pitch_fr: string;
  pitch_en: string;
  paths: PathItem[];
};

// Liens de navigation par slug — non stockés en collection (appartiennent au site, pas au persona)
const PATHS_BY_SLUG: Record<string, PathItem[]> = {
  'ceo-pme-b2b': [
    { fr: 'Activation IA · 1 semaine', en: 'AI Activation · 1 week', href: '/offres/activation-ia' },
    { fr: 'Growth System IA · acquisition + CRM', en: 'AI Growth System · acquisition + CRM', href: '/offres/growth-system-ia' },
    { fr: 'Cas client · ROI mesurés', en: 'Customer cases · measured ROI', href: '/cas' },
  ],
  'cto-scale-up': [
    { fr: 'Infrastructure IA · architecture', en: 'AI Infrastructure · architecture', href: '/offres/infrastructure-ia' },
    { fr: 'Productivité Opérationnelle IA', en: 'Operational AI Productivity', href: '/offres/productivite-operationnelle-ia' },
    { fr: 'Cookbooks & tutoriels', en: 'Cookbooks & tutorials', href: '/ressources/cookbooks' },
  ],
  'cmo-mid-market': [
    { fr: 'Acquisition IA · contenu & SEO', en: 'AI Acquisition · content & SEO', href: '/solutions/acquisition-ia' },
    { fr: 'CRM & relances IA', en: 'CRM & AI follow-ups', href: '/solutions/crm-relances-ia' },
    { fr: 'Growth Intelligence · données', en: 'Growth Intelligence · data', href: '/offres/growth-intelligence' },
  ],
};

// Fallback si la collection personas est vide (backward compat)
const FALLBACK_PERSONAS: PersonaItem[] = [
  {
    k: 'ceo',
    label_fr: 'CEO PME',
    label_en: 'SMB CEO',
    pitch_fr: "Vous voulez un ROI mesuré en 6 semaines, pas une roadmap de 18 mois.",
    pitch_en: 'You want a measured ROI in 6 weeks, not an 18-month roadmap.',
    paths: [
      { fr: 'Activation IA · 1 semaine', en: 'AI Activation · 1 week', href: '/offres/activation-ia' },
      { fr: 'Growth System IA · acquisition + CRM', en: 'AI Growth System · acquisition + CRM', href: '/offres/growth-system-ia' },
      { fr: 'Cas client · ROI mesurés', en: 'Customer cases · measured ROI', href: '/cas' },
    ],
  },
  {
    k: 'dsi',
    label_fr: 'DSI / RSSI',
    label_en: 'CIO / CISO',
    pitch_fr: "Vous voulez la trace, la souveraineté, la conformité — avant le sprint MVP.",
    pitch_en: 'You want the audit trail, sovereignty, compliance — before the MVP sprint.',
    paths: [
      { fr: 'Infrastructure IA · ETI', en: 'AI Infrastructure · enterprise', href: '/offres/infrastructure-ia' },
      { fr: 'Gouvernance données · sécurité', en: 'Data governance · security', href: '/offres/infrastructure-ia' },
      { fr: 'Trust Center · contrôles', en: 'Trust Center · controls', href: '/trust' },
    ],
  },
  {
    k: 'cto',
    label_fr: 'CTO / Tech lead',
    label_en: 'CTO / Tech lead',
    pitch_fr: "Vous voulez connecter les outils, fiabiliser les workflows et garder la main sur l'exploitation.",
    pitch_en: 'You want to connect tools, harden workflows, and keep control of operations.',
    paths: [
      { fr: 'Productivité Opérationnelle IA', en: 'Operational AI', href: '/offres/productivite-operationnelle-ia' },
      { fr: 'CRM & relances IA', en: 'CRM & AI follow-ups', href: '/solutions/crm-relances-ia' },
      { fr: 'Cookbooks & tutoriels', en: 'Cookbooks & tutorials', href: '/ressources/cookbooks' },
    ],
  },
];

const collectionEntries = await getCollection('personas');

const personas: PersonaItem[] = collectionEntries.length > 0
  ? collectionEntries
      .sort((a, b) => {
        const dateDiff = a.data.publishedAt.getTime() - b.data.publishedAt.getTime();
        return dateDiff !== 0 ? dateDiff : a.data.slug.localeCompare(b.data.slug);
      })
      .map((entry) => ({
        k: entry.data.slug,
        label_fr: entry.data.title_fr,
        label_en: entry.data.title_en,
        role_fr: entry.data.role_fr,
        role_en: entry.data.role_en,
        pitch_fr: entry.data.description_fr,
        pitch_en: entry.data.description_en,
        paths: PATHS_BY_SLUG[entry.data.slug] ?? [],
      }))
  : FALLBACK_PERSONAS;
---
<section class="sec sec-paper" aria-labelledby="persona-h2">
  <div class="wrap-wide">
    <header class="sec-hd">
      <div>
        <div class="n">
          <span class="roman">§</span>
          <span>{lang === 'fr' ? 'Sélecteur — où commences-tu ?' : 'Selector — where do you start?'}</span>
        </div>
        <h2 id="persona-h2">
          {lang === 'fr' ? (
            <>Trois <i>portes d'entrée</i>. La même équipe derrière.</>
          ) : (
            <>Three <i>entry doors</i>. Same team behind.</>
          )}
        </h2>
      </div>
      <p class="aside">
        {lang === 'fr'
          ? 'Cliquez sur la porte qui vous correspond. La page filtre les chemins, mais l\'engagement reste cousu main.'
          : 'Click the door that matches you. The page filters paths, but engagement stays bespoke.'}
      </p>
    </header>

    <div class="persona-tabs" role="tablist">
      {personas.map((p, i) => (
        <button class={'persona-tab' + (i === 0 ? ' is-active' : '')} role="tab" data-persona={p.k} aria-selected={i === 0 ? 'true' : 'false'}>
          <span class="k">{String(i + 1).padStart(2, '0')}</span>
          <span class="t">{lang === 'fr' ? p.label_fr : p.label_en}</span>
        </button>
      ))}
    </div>

    <div class="persona-stage">
      {personas.map((p, i) => (
        <article class={'persona-panel' + (i === 0 ? ' is-active' : '')} data-panel={p.k}>
          {(p.role_fr || p.role_en) && (
            <p class="persona-role">{lang === 'fr' ? p.role_fr : p.role_en}</p>
          )}
          <p class="persona-pitch">{lang === 'fr' ? p.pitch_fr : p.pitch_en}</p>
          <ul class="persona-paths">
            {p.paths.map((path, idx) => (
              <li>
                <a href={localizeHref(path.href, lang)}>
                  <span class="i">§ {String(idx + 1).padStart(2, '0')}</span>
                  <span class="t">{lang === 'fr' ? path.fr : path.en}</span>
                  <span class="g">→</span>
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const tabs = document.querySelectorAll('.persona-tab');
    const panels = document.querySelectorAll('.persona-panel');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const k = tab.getAttribute('data-persona');
        tabs.forEach((t) => {
          const active = t.getAttribute('data-persona') === k;
          t.classList.toggle('is-active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        panels.forEach((p) => p.classList.toggle('is-active', p.getAttribute('data-panel') === k));
      });
    });
  })();
</script>

<style>
  .persona-tabs{display:flex;gap:4px;margin-bottom:clamp(40px,5vw,72px);border-bottom:1px solid var(--hairline-strong);padding-bottom:0}
  .persona-tab{padding:18px 28px;font-family:var(--font-mono);font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);transition:color 280ms var(--ease),border-color 280ms var(--ease);border-bottom:2px solid transparent;display:flex;gap:10px;align-items:baseline;cursor:pointer}
  .persona-tab:hover{color:var(--ink)}
  .persona-tab.is-active{color:var(--accent);border-bottom-color:var(--accent)}
  .persona-tab .k{opacity:.5}
  .persona-stage{position:relative;min-height:300px}
  .persona-panel{position:absolute;inset:0;opacity:0;transform:translateY(8px);transition:opacity 540ms var(--ease),transform 540ms var(--ease);pointer-events:none;clip-path:inset(0 0 100% 0)}
  .persona-panel.is-active{opacity:1;transform:none;pointer-events:auto;clip-path:inset(0 0 0 0);transition:opacity 720ms var(--ease),transform 720ms var(--ease),clip-path 800ms var(--ease)}
  .persona-role{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.12em;text-transform:uppercase;margin-bottom:16px}
  .persona-pitch{font-family:var(--font-display);font-style:italic;font-size:clamp(22px,2.6vw,40px);line-height:1.25;color:var(--ink-2);max-width:900px;margin-bottom:clamp(32px,4vw,56px);text-wrap:balance}
  .persona-paths{list-style:none;display:flex;flex-direction:column;gap:0;border-top:1px solid var(--hairline)}
  .persona-paths li{border-bottom:1px solid var(--hairline)}
  .persona-paths a{display:grid;grid-template-columns:80px 1fr 40px;align-items:baseline;gap:24px;padding:24px 0;color:inherit;transition:padding 360ms var(--ease),background 280ms var(--ease)}
  .persona-paths a:hover{padding-left:16px;padding-right:16px;background:var(--paper)}
  .persona-paths .i{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.12em}
  .persona-paths .t{font-family:var(--font-display);font-size:clamp(20px,2.2vw,32px);letter-spacing:-0.015em;line-height:1.1}
  .persona-paths .g{color:var(--accent);font-family:var(--font-mono);font-size:18px;justify-self:end}

  @media (max-width:700px){
    .persona-tabs{flex-wrap:wrap}
    .persona-tab{padding:14px 18px;font-size:10.5px}
    .persona-paths a{grid-template-columns:1fr;gap:6px}
    .persona-paths .g{display:none}
  }
</style>
