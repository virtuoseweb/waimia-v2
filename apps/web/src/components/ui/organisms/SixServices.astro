---
// Section · Acte II — Six services taught by doing / Six services appris en faisant
// Variant : grille 3×2 sur fond paper-2 + hover terracotta tint
// Motion : .reveal-stagger sur cells + .lift hover
// Mémorable : « Six services nommés par l'acte de livrer, pas par le buzzword. »
//
// Composé de · ChapterLabel (refactor atomic-components)

import ChapterLabel from '../atoms/ChapterLabel.astro';
import { langFromPath, t } from '../../../lib/i18n';
import { SIX_SERVICES } from '../../../data/sitemap';

const lang = langFromPath(Astro.url.pathname);
---
<section id="act-2" class="sec sec-paper" aria-labelledby="six-h2">
  <div class="wrap-wide">
    <header class="six-hd">
      <ChapterLabel
        num="FIG II · 2.0"
        title={lang === 'fr' ? "Acte II — La méthode" : 'Act II — The method'}
      />
      <span class="six-spec">
        {lang === 'fr' ? '6 SERVICES · UNE COUCHE CONTINUE' : '6 SERVICES · ONE CONTINUOUS LAYER'}
      </span>
    </header>

    <h2 id="six-h2" class="six-h2 reveal">
      {lang === 'fr' ? (
        <>Six services, appris en <i>livrant</i> — pas en PowerPoint.</>
      ) : (
        <>Six services, taught by <i>doing</i> — not by slides.</>
      )}
    </h2>

    <div class="six-grid reveal-stagger">
      {SIX_SERVICES.map((s) => (
        <article class="six-cell">
          <header class="six-cell-head">
            <span class="six-cell-fig">FIG 2.{s.k}</span>
            <span class="six-cell-metric">{t(s.metric, lang)}</span>
          </header>
          <h3 class="six-cell-title">{t(s.label, lang)}</h3>
          <span class="six-cell-rule" aria-hidden="true"></span>
          <p class="six-cell-body">{t(s.body, lang)}</p>
          <footer class="six-cell-foot">
            <span class="six-cell-foot-key">{lang === 'fr' ? 'Connecteurs' : 'Connectors'}</span>
            <span class="six-cell-foot-val">{t(s.connectors, lang)}</span>
          </footer>
          <span class="six-cell-arr" aria-hidden>→</span>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  #act-2{padding:clamp(100px,12vw,160px) 0;border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline)}
  .six-hd{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:clamp(40px,4vw,56px);padding-bottom:20px;border-bottom:1px solid var(--hairline);flex-wrap:wrap;gap:14px}
  .six-spec{font-family:var(--font-mono);font-size:11px;color:var(--muted);letter-spacing:.1em}
  .six-h2{font-family:var(--font-display);font-size:clamp(40px,7vw,104px);line-height:.98;letter-spacing:-0.025em;max-width:1100px;margin-bottom:clamp(56px,6vw,80px);font-weight:400;text-wrap:balance}
  .six-h2 i{font-style:italic;color:var(--accent)}

  .six-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid var(--hairline-strong)}
  .six-cell{padding:clamp(28px,3vw,40px) clamp(22px,2.6vw,32px) clamp(40px,4.5vw,52px);border-right:1px solid var(--hairline);border-bottom:1px solid var(--hairline);min-height:300px;position:relative;transition:background 320ms var(--ease), border-color 300ms var(--ease), transform 300ms var(--ease)}
  .six-cell:hover{background:rgba(201,79,46,0.04);border-color:var(--accent);transform:translateY(-1px)}
  .six-cell:nth-child(3n){border-right:none}
  .six-cell:nth-child(n+4){border-bottom:none}

  /* Header row · FIG kicker (mono ink) + metric (mono accent terracotta) */
  .six-cell-head{display:flex;justify-content:space-between;align-items:baseline;gap:12px}
  .six-cell-fig{font-family:var(--font-mono);font-size:11px;letter-spacing:.12em;color:var(--ink);text-transform:uppercase}
  .six-cell-metric{font-family:var(--font-mono);font-size:11px;letter-spacing:.08em;color:var(--accent);text-transform:uppercase;text-align:right;text-wrap:nowrap}

  .six-cell-title{font-family:var(--font-display);font-size:clamp(28px,3vw,40px);line-height:1.02;letter-spacing:-0.02em;margin:20px 0 0;font-weight:400;text-wrap:balance;color:var(--ink)}

  /* Hairline accent · structurant sous le titre · expands on hover */
  .six-cell-rule{display:block;width:32px;height:1px;background:var(--accent);margin:16px 0 0;transition:width 320ms var(--ease)}
  .six-cell:hover .six-cell-rule{width:60px}

  .six-cell-body{margin-top:14px;font-family:var(--font-sans);font-size:14px;line-height:1.55;color:var(--muted);max-width:380px;text-wrap:pretty}

  /* Footer connecteurs · mono micro · key ink · val ink-2 · hairline top discrète */
  .six-cell-foot{margin-top:auto;padding-top:18px;display:flex;flex-direction:column;gap:4px;border-top:1px dashed var(--hairline)}
  .six-cell-foot-key{font-family:var(--font-mono);font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:var(--ink-2)}
  .six-cell-foot-val{font-family:var(--font-mono);font-size:11px;letter-spacing:.04em;color:var(--ink);line-height:1.5}

  .six-cell{display:flex;flex-direction:column}
  .six-cell-arr{position:absolute;bottom:18px;right:22px;font-family:var(--font-mono);font-size:13px;color:var(--accent);transition:transform 320ms var(--ease)}
  .six-cell:hover .six-cell-arr{transform:translateX(4px)}

  @media (max-width:900px){
    .six-grid{grid-template-columns:repeat(2,1fr)}
    .six-cell{border-right:none;border-bottom:1px solid var(--hairline)!important}
    .six-cell:nth-child(2n){border-right:none}
    .six-cell:nth-child(odd){border-right:1px solid var(--hairline)}
  }
  @media (max-width:600px){
    .six-grid{grid-template-columns:1fr}
    .six-cell{border-right:none!important}
  }
</style>
