---
/**
 * Section · cas d'usage horizontaux PME
 *
 * M4 remplace la grille « six métiers » par 5 cas d'usage business
 * alignés sur /solutions/* : acquisition, CRM, contenu, productivité, support.
 */

import SectionHeader from '../molecules/SectionHeader.astro';
import { DEPARTMENTS_GRID } from '../../../data/sitemap';
import { langFromPath, t, localizeHref } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section class="sec" aria-labelledby="dept-h2">
  <div class="wrap-wide">
    <SectionHeader
      roman="III"
      label={lang === 'fr' ? "§ 05 — Cas d'usage horizontaux" : '§ 05 — Horizontal use cases'}
      id="dept-h2"
    >
      <Fragment slot="heading">
        {lang === 'fr' ? (<>Cinq <i>cas d'usage</i>. Une seule méthode.</>) : (<>Five <i>use cases</i>. One method.</>)}
      </Fragment>
      <Fragment slot="aside">
        {lang === 'fr'
          ? "Acquisition, CRM, contenu, productivité, support — les douleurs récurrentes des PME. Mêmes systèmes, vocabulaire adapté à votre métier."
          : 'Acquisition, CRM, content, productivity, support — recurring SMB pain points. Same systems, wording adapted to your sector.'}
      </Fragment>
    </SectionHeader>

    <ul class="dept-index reveal-stagger">
      {DEPARTMENTS_GRID.map((d, i) => (
        <li>
          <a class="dept-row" href={localizeHref(`/solutions/${d.slug}`, lang)}>
            <span class="dept-row-num"><span class="dept-row-num-prefix">USE CASE </span>{`0${i + 1}`}</span>
            <span class="dept-row-label">{t(d.label, lang)}</span>
            <span class="dept-row-tag">{t(d.tag, lang)}</span>
            <span class="dept-row-arr" aria-hidden>→</span>
          </a>
        </li>
      ))}
    </ul>

    <a class="dept-sector lift" href={localizeHref('/secteurs', lang)}>
      <span>{lang === 'fr' ? 'Adapté à votre secteur →' : 'Adapted to your sector →'}</span>
    </a>
  </div>
</section>

<style>
  /* V6 densification scoped · réduit padding section sans toucher global .sec */
  .sec[aria-labelledby="dept-h2"] {
    padding: clamp(56px, 7vw, 88px) 0;
  }

  .dept-index {
    list-style: none;
    padding: 0;
    margin: 0;
    margin-top: clamp(20px, 2.5vw, 32px);
    border-top: 1px solid var(--hairline-strong);
  }

  .dept-index li {
    display: contents;
  }

  .dept-row {
    display: grid;
    grid-template-columns: 70px 1.4fr 1fr 32px;
    gap: clamp(20px, 2vw, 32px);
    padding: clamp(16px, 1.8vw, 24px) 0;
    border-bottom: 1px solid var(--hairline);
    align-items: baseline;
    color: inherit;
    text-decoration: none;
    transition: background 220ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1)), padding-left 320ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1)), padding-right 320ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .dept-row:hover {
    background: rgba(201, 79, 46, 0.04);
    padding-left: 14px;
    padding-right: 14px;
  }

  .dept-row:hover .dept-row-label {
    color: var(--accent);
  }

  .dept-row:hover .dept-row-arr {
    color: var(--accent);
    transform: translateX(4px);
  }

  .dept-row-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    color: var(--muted);
    text-transform: uppercase;
    white-space: nowrap;
  }

  .dept-row-label {
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 28px);
    font-style: italic;
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
    transition: color 200ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
  }

  .dept-row-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--ink-2);
    align-self: center;
  }

  .dept-row-arr {
    font-family: var(--font-mono);
    font-size: 16px;
    color: var(--muted);
    text-align: right;
    transition: color 240ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1)), transform 320ms var(--ease, cubic-bezier(0.22, 1, 0.36, 1));
    align-self: center;
  }

  @media (max-width: 900px) {
    .dept-row {
      grid-template-columns: 1fr;
      row-gap: 6px;
      padding: clamp(18px, 2vw, 28px) 0;
    }

    .dept-row-num {
      grid-column: 1 / -1;
    }

    .dept-row-label {
      grid-column: 1 / -1;
      font-size: clamp(22px, 5vw, 28px);
    }

    .dept-row-tag {
      grid-column: 1 / -1;
    }

    .dept-row-arr {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .dept-row-num-prefix {
      display: none;
    }

    .dept-row {
      padding: 16px 0;
    }
  }

  .dept-sector {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: min(100%, 360px);
    min-height: 96px;
    margin-top: clamp(24px, 3vw, 40px);
    padding: 24px 28px;
    border: 1px solid var(--hairline-strong);
    color: inherit;
    background: var(--paper);
  }

  .dept-sector span {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--accent);
  }
</style>
