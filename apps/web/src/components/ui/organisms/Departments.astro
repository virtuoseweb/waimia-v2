---
// Section · Departments grid · 6 métiers en cells
// Variant : ec-grid cols-3 + .reveal-stagger
// Motion : stagger fade-up + .lift hover
// Mémorable : « La grille des métiers comme un index notarié. »
//
// Composé de · SectionHeader (refactor atomic-components)

import SectionHeader from '../molecules/SectionHeader.astro';
import { DEPARTMENTS_GRID } from '../../../data/sitemap';
import { langFromPath, t, localizeHref } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section class="sec" aria-labelledby="dept-h2">
  <div class="wrap-wide">
    <SectionHeader
      roman="III"
      label={lang === 'fr' ? 'Acte III — Solutions par métier' : 'Act III — Department solutions'}
      id="dept-h2"
    >
      <Fragment slot="heading">
        {lang === 'fr' ? (<>Six métiers. Six <i>terrains</i>. Une méthode.</>) : (<>Six departments. Six <i>fields</i>. One method.</>)}
      </Fragment>
      <Fragment slot="aside">
        {lang === 'fr'
          ? "Chaque département a ses contraintes — réglementation, données, culture interne. Notre méthode reste la même : process, agent, audit, mesure."
          : 'Each department has its own constraints — regulation, data, internal culture. Our method stays the same: process, agent, audit, measure.'}
      </Fragment>
    </SectionHeader>

    <div class="ec-grid cols-3 reveal-stagger">
      {DEPARTMENTS_GRID.map((d) => (
        <a class="editorial-cell lift" href={localizeHref(`/solutions/${d.slug}`, lang)}>
          <span class="e-tag">{t(d.tag, lang)}</span>
          <h3 class="e-title">{t(d.label, lang)}</h3>
          <span class="e-go">{lang === 'fr' ? "Voir le métier →" : 'Open department →'}</span>
        </a>
      ))}
    </div>
  </div>
</section>
