---
/**
 * Section · CapabilityStrip · 8 piliers du scope Waimia complet
 *
 * Conçu pour exposer en 5 secondes que Waimia couvre acquisition, contenu, web,
 * CRM, data, automation, brand system et gouvernance — pas seulement Excel/HubSpot/Outlook.
 *
 * Lit · CAPABILITY_MAP (sitemap.ts) · chaque item pointe vers une page existante
 * Layout · grille 4×2 desktop, 2×4 tablet, stack mobile · hairlines 1px
 * DA · Editorial Tech × Swiss × Premium Minimalism · zéro icon library externe
 */
import ChapterLabel from '../atoms/ChapterLabel.astro';
import { CAPABILITY_MAP } from '../../../data/sitemap';
import { langFromPath, t, localizeHref } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section id="capability-strip" class="capstrip" aria-labelledby="capstrip-h2">
  <div class="wrap-wide">
    <header class="capstrip-hd">
      <ChapterLabel
        num="FIG I · 1.5"
        title={lang === 'fr' ? "Ce qu'on câble" : 'What we wire'}
      />
      <span class="capstrip-spec">
        {lang === 'fr' ? '8 PILIERS · UN SEUL SYSTÈME' : '8 PILLARS · ONE SYSTEM'}
      </span>
    </header>

    <h2 id="capstrip-h2" class="capstrip-h2 reveal">
      {lang === 'fr' ? (
        <>Du <i>canal</i> à <i>l'action</i>.<br/>Marketing, sales, contenu, web — alignés.</>
      ) : (
        <>From <i>channel</i> to <i>action</i>.<br/>Marketing, sales, content, web — aligned.</>
      )}
    </h2>

    <p class="capstrip-lede reveal reveal-fade">
      {lang === 'fr'
        ? "On ne branche pas seulement des outils. On relie acquisition, contenu, site, CRM, analytics et marque dans un système qui apprend et s'améliore."
        : 'We do not connect tools in isolation. We wire acquisition, content, site, CRM, analytics and brand into one system that learns and improves.'}
    </p>

    <div class="capstrip-groups reveal-stagger">
      {[0, 2, 4, 6].map((startIdx) => {
        const GROUP_META = [
          { fr: 'Canaux', en: 'Channels' },
          { fr: 'Systèmes', en: 'Systems' },
          { fr: 'Intelligence', en: 'Intelligence' },
          { fr: 'Marque & Trust', en: 'Brand & Trust' },
        ];
        const groupIdx = startIdx / 2;
        const groupNum = ['I', 'II', 'III', 'IV'][groupIdx];
        const groupKicker = GROUP_META[groupIdx];
        const pair = [CAPABILITY_MAP[startIdx], CAPABILITY_MAP[startIdx + 1]];
        return (
          <article class="capstrip-group">
            <header class="capstrip-group-hd">
              <span class="capstrip-group-roman">{groupNum}</span>
              <span class="capstrip-group-kicker">
                {lang === 'fr' ? groupKicker.fr : groupKicker.en}
              </span>
            </header>
            <div class="capstrip-group-pair">
              {pair.map((cat) => (
                <a class="capstrip-cell" href={localizeHref(cat.href, lang)}>
                  <header class="capstrip-cell-head">
                    <span class="capstrip-cell-num">{cat.k}</span>
                    <span class="capstrip-cell-kicker">{t(cat.kicker, lang)}</span>
                  </header>
                  <h3 class="capstrip-cell-title">{t(cat.label, lang)}</h3>
                  <span class="capstrip-cell-rule" aria-hidden="true"></span>
                  <p class="capstrip-cell-lead">{t(cat.lead, lang)}</p>
                  <ul class="capstrip-cell-items">
                    {cat.items.map((item) => (
                      <li>{t(item, lang)}</li>
                    ))}
                  </ul>
                  <span class="capstrip-cell-go" aria-hidden>
                    {lang === 'fr' ? 'Ouvrir →' : 'Open →'}
                  </span>
                </a>
              ))}
            </div>
          </article>
        );
      })}
    </div>

    <p class="capstrip-foot reveal reveal-fade">
      {lang === 'fr'
        ? <>Chaque pilier vit avec les autres. <i>Les agents communiquent.</i> Les données circulent. La marque reste cohérente.</>
        : <>Every pillar lives with the others. <i>Agents communicate.</i> Data flows. Brand stays consistent.</>}
    </p>
  </div>
</section>

<style>
  .capstrip {
    padding: clamp(100px, 12vw, 160px) 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    background: var(--paper);
  }

  .capstrip-hd {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: clamp(36px, 4vw, 52px);
    padding-bottom: 20px;
    border-bottom: 1px solid var(--hairline);
    flex-wrap: wrap;
    gap: 14px;
  }
  .capstrip-spec {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.1em;
  }

  .capstrip-h2 {
    font-family: var(--font-display);
    font-size: clamp(40px, 6.6vw, 96px);
    line-height: 0.98;
    letter-spacing: -0.025em;
    max-width: 1100px;
    margin: 0 0 clamp(24px, 2.5vw, 36px);
    font-weight: 400;
    text-wrap: balance;
    color: var(--ink);
  }
  .capstrip-h2 i { font-style: italic; color: var(--accent); }

  .capstrip-lede {
    font-family: var(--font-sans);
    font-size: var(--text-lede, clamp(18px, 1.5vw, 21px));
    line-height: var(--leading-body, 1.5);
    color: var(--ink-2);
    max-width: 720px;
    margin: 0 0 clamp(48px, 5vw, 72px);
    text-wrap: pretty;
    transition-delay: 200ms;
  }

  .capstrip-groups {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(32px, 4vw, 64px);
    row-gap: clamp(48px, 5vw, 72px);
    position: relative;
  }

  .capstrip-groups::before {
    content: "";
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: 50%;
    transform: translateX(-0.5px);
    width: 1px;
    background: linear-gradient(to bottom, transparent, var(--accent), transparent);
    opacity: 0.4;
    pointer-events: none;
  }

  .capstrip-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .capstrip-group-hd {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--hairline-strong);
  }

  .capstrip-group-roman {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(22px, 2vw, 32px);
    color: var(--accent);
    font-weight: 400;
    letter-spacing: -0.02em;
  }

  .capstrip-group-kicker {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .capstrip-group-pair {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .capstrip-cell {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: clamp(20px, 2vw, 28px) clamp(18px, 1.6vw, 24px) clamp(44px, 3.5vw, 56px);
    border: 1px solid var(--hairline);
    position: relative;
    color: inherit;
    text-decoration: none;
    transition:
      background 320ms var(--ease),
      border-color 280ms var(--ease),
      transform 280ms var(--ease);
  }
  .capstrip-cell:hover {
    background: rgba(201, 79, 46, 0.04);
    border-color: var(--accent);
    transform: translateY(-1px);
  }

  .capstrip-cell-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .capstrip-cell-num {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    color: var(--accent);
  }
  .capstrip-cell-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-2);
  }

  .capstrip-cell-title {
    font-family: var(--font-display);
    font-size: clamp(22px, 1.8vw, 28px);
    line-height: 1.08;
    letter-spacing: -0.015em;
    font-weight: 400;
    margin: var(--space-2) 0 0;
    color: var(--ink);
    font-style: italic;
    text-wrap: balance;
  }

  .capstrip-cell-rule {
    display: block;
    width: 28px;
    height: 1px;
    background: var(--accent);
    margin: var(--space-2) 0 var(--space-3);
    transition: width 320ms var(--ease);
  }
  .capstrip-cell:hover .capstrip-cell-rule { width: 56px; }

  .capstrip-cell-lead {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.55;
    color: var(--muted);
    margin: 0 0 var(--space-3);
    text-wrap: pretty;
  }

  .capstrip-cell-items {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .capstrip-cell-items li {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.5;
    color: var(--ink-2);
    letter-spacing: 0.02em;
  }
  .capstrip-cell-items li::before {
    content: '· ';
    color: var(--accent);
  }

  .capstrip-cell-go {
    position: absolute;
    bottom: 18px;
    right: 22px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    transition: transform 320ms var(--ease);
  }
  .capstrip-cell:hover .capstrip-cell-go { transform: translateX(4px); }

  .capstrip-foot {
    margin: clamp(40px, 4vw, 60px) 0 0;
    font-family: var(--font-display);
    font-size: clamp(20px, 2vw, 28px);
    line-height: 1.3;
    color: var(--ink);
    max-width: 800px;
    text-wrap: balance;
    text-align: center;
    margin-left: auto;
    margin-right: auto;
    transition-delay: 280ms;
  }
  .capstrip-foot i { font-style: italic; color: var(--accent); }

  @media (max-width: 900px) {
    .capstrip-groups::before { display: none; }
  }
  @media (max-width: 600px) {
    .capstrip-groups { grid-template-columns: 1fr; }
  }
</style>
