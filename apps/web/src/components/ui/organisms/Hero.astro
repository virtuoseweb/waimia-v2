---
/**
 * Section · Hero · business-first PME/ETI · FR/EN
 *
 * M4 recadre la home : promesse lisible en 5 secondes, CTA vers contact
 * et offre Growth System IA, métriques de ROI conservées.
 */

import { langFromPath, t, localizeHref } from '../../../lib/i18n';
import { HERO_METRICS } from '../../../data/sitemap';

import MastheadRow from '../molecules/MastheadRow.astro';
import Kicker from '../atoms/Kicker.astro';
import Button from '../atoms/Button.astro';
import MetricStrip from '../molecules/MetricStrip.astro';

const lang = langFromPath(Astro.url.pathname);
const ctaHref = localizeHref('/contact', lang);
const offerHref = localizeHref('/offres/growth-system-ia', lang);
const pageTransitionId = Astro.url.pathname
  .replace(/^\/(?:en\/)?/, '')
  .replace(/\/$/, '')
  .replace(/[^a-z0-9]+/gi, '-')
  .replace(/^-|-$/g, '') || 'home';

// Le MetricStrip prend des `label: string` · on résout les BiText ici
const metrics = HERO_METRICS.map((m) => ({ k: m.k, n: m.n, label: t(m.label, lang) }));
---
<section class="hero-a home-hero" aria-labelledby="hero-heading">
  <div class="signature-grid" transition:name={`hero-img-${pageTransitionId}`}></div>

  {/* SVG signature géométrique · overlay v9 · wrapper div pour scope CSS Astro propre */}
  <div class="hero-sig-mark" aria-hidden="true">
    <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="60" cy="60" r="58" stroke="currentColor" stroke-width="0.5"/>
      <text x="60" y="67" text-anchor="middle" font-family="var(--font-mono)" font-size="13" fill="currentColor" letter-spacing="0.14em">V · 9</text>
    </svg>
  </div>

  <div class="wrap-wide">
    {/* Masthead newspaper · atome MastheadRow · margin compactée V6 (24px vs 48px) */}
    <div class="par hero-masthead" data-par="-0.04">
      <MastheadRow />
    </div>

    {/* Headline · mask-up reveal · Instrument Serif · 2 lignes orienté résultat */}
    <h1 id="hero-heading" class="hero-headline reveal-mask-up" transition:name={`hero-h1-${pageTransitionId}`}>
      {lang === 'fr' ? (
        <>
          L'<i class="acc">IA</i> dans vos outils.<br />
          <i>Des résultats</i> dans vos chiffres.
        </>
      ) : (
        <>
          <i class="acc">AI</i> in your tools.<br />
          <i>Results</i> in your numbers.
        </>
      )}
    </h1>

    {/* Sub-block · 2 colonnes · promesse + contexte */}
    <div class="hero-sub">
      <div>
        <Kicker class="hero-fig">§ 01 · {lang === 'fr' ? 'Promesse' : 'Promise'}</Kicker>
        <p class="hero-lede reveal reveal-fade">
          {lang === 'fr' ? (
            <>On câble l'<i>IA</i> dans vos outils marketing, sales, contenu et web — acquisition, CRM, site, analytics, marque — <i>sans changer</i> vos process.</>
          ) : (
            <>We wire <i>AI</i> into your marketing, sales, content and web stack — acquisition, CRM, site, analytics, brand — <i>without changing</i> your process.</>
          )}
        </p>

        {/* Scope strip · 6 groupes éditoriaux représentant le périmètre Waimia complet
            (les noms d'outils figurent dans la section CapabilityStrip plus bas) */}
        <ul class="hero-scope reveal reveal-fade" aria-label={lang === 'fr' ? 'Périmètre opérationnel' : 'Operational scope'}>
          <li class="hero-scope-item">{lang === 'fr' ? 'Acquisition' : 'Acquisition'}</li>
          <li class="hero-scope-item">{lang === 'fr' ? 'Contenu' : 'Content'}</li>
          <li class="hero-scope-item">{lang === 'fr' ? 'Site & CMS' : 'Site & CMS'}</li>
          <li class="hero-scope-item">{lang === 'fr' ? 'CRM & Sales' : 'CRM & Sales'}</li>
          <li class="hero-scope-item">{lang === 'fr' ? 'Data & Insights' : 'Data & Insights'}</li>
          <li class="hero-scope-item">{lang === 'fr' ? 'Brand System' : 'Brand System'}</li>
        </ul>

        <div class="hero-ctas reveal reveal-snap">
          <Button href={ctaHref} variant="primary" size="lg" mag={0.18}>
            {lang === 'fr' ? 'Réserver un audit →' : 'Book an audit →'}
          </Button>
          <Button href={offerHref} variant="ghost" size="lg">
            {lang === 'fr' ? 'Voir Growth System IA' : 'See AI Growth System'}
          </Button>
        </div>
        <p class="hero-cta-sub reveal reveal-fade">
          {lang === 'fr'
            ? <>Audit IA opérationnel · 30 min · on identifie <i>3 automatisations rentables</i>.</>
            : <>AI operational audit · 30 min · we identify <i>3 high-ROI automations</i>.</>}
        </p>
      </div>

      <div>
        <Kicker class="hero-fig">§ 02 · {lang === 'fr' ? 'Résultats concrets' : 'Concrete results'}</Kicker>

        {/* 3 preuves verticales · format "n · label" éditorial · hairline 1px entre */}
        <ul class="hero-proofs reveal reveal-fade" aria-label={lang === 'fr' ? 'Preuves de résultats' : 'Result proofs'}>
          <li class="hero-proof">
            <span class="hero-proof-num">+12h</span>
            <span class="hero-proof-label">
              {lang === 'fr'
                ? <>économisées <i>par équipe</i> · semaine</>
                : <>saved <i>per team</i> · week</>}
            </span>
          </li>
          <li class="hero-proof">
            <span class="hero-proof-num">5 j</span>
            <span class="hero-proof-label">
              {lang === 'fr'
                ? <>jusqu'au <i>premier système</i> livré</>
                : <>to the <i>first system</i> shipped</>}
            </span>
          </li>
          <li class="hero-proof">
            <span class="hero-proof-num">100%</span>
            <span class="hero-proof-label">
              {lang === 'fr'
                ? <>intégré · <i>sans changer</i> vos outils</>
                : <>integrated · <i>no migration</i></>}
            </span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

{/* Metrics strip · reveal-zoom-in · molécule MetricStrip */}
<div class="metrics-reveal reveal reveal-zoom-in">
  <MetricStrip metrics={metrics} />
</div>

<style>
  .hero-a {
    position: relative;
    /* Sticky-aware · header fixed 79px + respiration éditoriale densifiée
       (V6 brief Simon : faire passer plus de contenu dans la section) */
    padding: clamp(72px, 5.5vw, 92px) 0 0;
    border-bottom: 1px solid var(--hairline);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .hero-a > *:not(.signature-grid):not(.hero-sig-mark) { position: relative; z-index: 1; }
  .hero-a .signature-grid { z-index: 0; }

  /* Wrapper hero · max-width hard cap pour grands écrans · contrainte de
     lisibilité éditoriale (V6 : éviter casse design sur ultra-wide) */
  .hero-a .wrap-wide {
    max-width: 1560px;
    margin-inline: auto;
  }

  /* SVG signature v9 · wrapper div (scope Astro propre) · overlay décoratif */
  .hero-sig-mark {
    position: absolute;
    right: calc(var(--gut) * 2);
    top: calc(var(--section-loose) * 0.55);
    width: 88px;
    height: 88px;
    pointer-events: none;
    user-select: none;
    z-index: 0;
    color: var(--ink);
    opacity: 0.18;
  }
  .hero-sig-mark svg { width: 100%; height: 100%; display: block; }

  /* H1 · token sémantique unifié --text-h1-hero · cf tokens.css */
  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-h1-hero);
    line-height: var(--leading-h1, .96);
    letter-spacing: var(--tracking-display, -0.025em);
    font-weight: 400;
    max-width: 980px;
    margin: 0 0 var(--space-5);
  }
  .hero-headline i { font-style: italic; }
  .hero-headline i.acc { color: var(--accent); }

  .hero-masthead { margin-bottom: var(--space-5); }

  .hero-sub {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    gap: clamp(40px, 5vw, 80px);
    margin-top: var(--space-6);
    padding: var(--space-5) 0 var(--space-8);
    border-top: 1px solid var(--hairline);
    align-items: start;
  }
  .hero-fig { margin-bottom: var(--space-4); }

  /* Lede · Inter Tight (pas Serif) · reveal-fade delay 200ms */
  .hero-lede {
    font-family: var(--font-sans);
    font-size: var(--text-lede, clamp(20px, 1.7vw, 24px));
    line-height: var(--leading-body, 1.5);
    color: var(--ink-2);
    max-width: 520px;
    text-wrap: pretty;
    transition-delay: 200ms;
  }
  .hero-lede i { font-style: italic; color: var(--accent); }

  /* Scope strip · 6 piliers éditoriaux du périmètre Waimia · hairline 1px par item
     mono caps · separator middot terracotta · responsive wrap propre */
  .hero-scope {
    list-style: none;
    padding: 0;
    margin: var(--space-5) 0 0;
    display: flex;
    align-items: center;
    gap: clamp(10px, 1vw, 14px);
    flex-wrap: wrap;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-2);
    transition-delay: 280ms;
  }
  .hero-scope-item {
    position: relative;
    padding: 5px 10px 5px 0;
  }
  .hero-scope-item::after {
    content: '·';
    color: var(--accent);
    margin-left: clamp(10px, 1vw, 14px);
    opacity: 0.6;
  }
  .hero-scope-item:last-child::after { content: ''; margin: 0; }
  .hero-scope-item:hover { color: var(--accent); cursor: default; }

  /* CTAs · reveal-snap delay 400ms */
  .hero-ctas {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-6);
    transition-delay: 400ms;
  }

  /* Sub-CTA · précise format audit · serif italique terracotta */
  .hero-cta-sub {
    margin: var(--space-3) 0 0;
    font-family: var(--font-sans);
    font-size: clamp(13px, 1vw, 14px);
    line-height: 1.5;
    color: var(--ink-2);
    letter-spacing: 0.005em;
    transition-delay: 520ms;
  }
  .hero-cta-sub i { font-style: italic; color: var(--accent); }

  /* Right rail · preuves verticales orientées conversion · hairline entre */
  .hero-proofs {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    transition-delay: 320ms;
  }
  .hero-proof {
    display: grid;
    grid-template-columns: minmax(110px, 0.4fr) 1fr;
    gap: clamp(16px, 1.8vw, 28px);
    align-items: baseline;
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--hairline);
  }
  .hero-proof:first-child { padding-top: 0; }
  .hero-proof:last-child { border-bottom: 0; }
  .hero-proof-num {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.6vw, 64px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--accent);
    font-weight: 400;
  }
  .hero-proof-label {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.4;
    color: var(--ink);
    text-wrap: balance;
  }
  .hero-proof-label i { font-style: italic; color: var(--ink-2); }

  /* Trust bar retirée du Hero v6-densify · les 4 piliers vivront dans
     une zone "principles" dédiée plus tard (cf BookSession ou nouveau organism) */

  /* Metrics wrapper · préserve le layout MetricStrip */
  .metrics-reveal { display: block; }

  @media (max-width: 900px) {
    .hero-sub { grid-template-columns: 1fr; gap: var(--space-9); }
    .hero-sig-mark { display: none; }
    .hero-proof { grid-template-columns: 90px 1fr; gap: var(--space-4); }
  }
  @media (max-width: 560px) {
    .hero-proof { grid-template-columns: 1fr; gap: 4px; padding: var(--space-3) 0; }
  }
  /* Low-height desktop · 1280×720 / 1366×768 / 1440×800 avec cookie banner visible
     → on resserre les rythmes verticaux sans toucher à l'identité typographique */
  @media (max-height: 850px) and (min-width: 900px) {
    .hero-a { padding-top: clamp(64px, 5vw, 80px); }
    .hero-sub { margin-top: var(--space-5); padding: var(--space-4) 0 var(--space-7); }
    .hero-headline { font-size: clamp(44px, 7vw, 92px); }
  }
</style>
