---
/**
 * Section · Hero · business-first PME/ETI · FR/EN
 *
 * M4 recadre la home : promesse lisible en 5 secondes, CTA vers contact
 * et offre Growth System IA, métriques de ROI conservées.
 */

import { langFromPath, t, localizeHref } from '../../../lib/i18n';
import { HERO_METRICS } from '../../../data/sitemap';

import MastheadRow from '../molecules/MastheadRow.astro';
import Kicker from '../atoms/Kicker.astro';
import Button from '../atoms/Button.astro';
import MetricStrip from '../molecules/MetricStrip.astro';

const lang = langFromPath(Astro.url.pathname);
const ctaHref = localizeHref('/contact', lang);
const offerHref = localizeHref('/offres/growth-system-ia', lang);

// Le MetricStrip prend des `label: string` · on résout les BiText ici
const metrics = HERO_METRICS.map((m) => ({ k: m.k, n: m.n, label: t(m.label, lang) }));
---
<section class="hero-a" aria-labelledby="hero-heading">
  <div class="signature-grid"></div>

  <div class="wrap-wide">
    {/* Masthead newspaper · atome MastheadRow */}
    <div class="par" data-par="-0.04" style="margin-bottom:42px">
      <MastheadRow />
    </div>

    {/* Headline · ancré, statique */}
    <h1 id="hero-heading" class="hero-headline">
      {lang === 'fr' ? (
        <>
          L'<i class="acc">IA</i>, <i>connectée</i><br />
          à vos outils,<br />
          à vos opérations.
        </>
      ) : (
        <>
          <i class="acc">AI</i>, <i>connected</i><br />
          to your tools,<br />
          to your operations.
        </>
      )}
    </h1>

    {/* Sub-block · 2 colonnes · promesse + contexte */}
    <div class="hero-sub">
      <div>
        <Kicker class="hero-fig">§ 01 · {lang === 'fr' ? 'Promesse' : 'Promise'}</Kicker>
        <p class="hero-lede">
          {lang === 'fr' ? (
            <>Nous aidons les PME à <i>piloter</i> leur acquisition et leurs opérations grâce à des systèmes IA connectés à leurs données.</>
          ) : (
            <>We help SMBs <i>manage</i> acquisition and operations with AI systems connected to their data.</>
          )}
        </p>
        <div class="hero-ctas">
          <Button href={ctaHref} variant="primary" size="lg" mag={0.18}>
            {lang === 'fr' ? 'Réserver mon diagnostic →' : 'Book a diagnostic →'}
          </Button>
          <Button href={offerHref} variant="ghost" size="lg">
            {lang === 'fr' ? 'Voir Growth System IA' : 'See AI Growth System'}
          </Button>
        </div>
      </div>

      <div>
        <Kicker class="hero-fig">§ 02 · {lang === 'fr' ? 'En clair' : 'In short'}</Kicker>
        <p class="hero-context">
          {lang === 'fr'
            ? "Acquisition. CRM. Relances. Productivité. Des workflows qui tournent, des données lisibles, des heures récupérées chaque semaine."
            : 'Acquisition. CRM. Follow-ups. Productivity. Workflows that run, readable data, hours reclaimed every week.'}
        </p>
      </div>
    </div>
  </div>
</section>

{/* Metrics strip · molécule MetricStrip */}
<MetricStrip metrics={metrics} />

<style>
  .hero-a { position:relative; padding:calc(140px + var(--gut)) 0 0; border-bottom:1px solid var(--hairline); overflow:hidden; display:flex; flex-direction:column; }
  .hero-a > *:not(.signature-grid) { position:relative; z-index:1; }
  .hero-a .signature-grid { z-index:0; }

  .hero-headline { font-family:var(--font-display); font-size:clamp(48px,9vw,148px); line-height:.96; letter-spacing:-0.025em; font-weight:400; margin:0 0 32px; }
  .hero-headline i { font-style:italic; }
  /* Mot relevé en accent (mot-clé central : IA / AI) */
  .hero-headline i.acc { color: var(--accent); }

  .hero-sub { display:grid; grid-template-columns:1.05fr 1fr; gap:clamp(40px,5vw,80px); margin-top:clamp(40px,4vw,56px); padding:clamp(28px,3vw,40px) 0 clamp(48px,5vw,80px); border-top:1px solid var(--hairline); align-items:start; }
  .hero-fig { margin-bottom:16px; }

  .hero-lede { font-family:var(--font-display); font-size:clamp(18px,1.6vw,21px); line-height:1.42; color:var(--ink-2); max-width:520px; text-wrap:pretty; }
  .hero-lede i { font-style:italic; color:var(--accent); }

  .hero-ctas { display:flex; gap:12px; flex-wrap:wrap; margin-top:clamp(24px,2.5vw,36px); }

  .hero-context { font-family:var(--font-display); font-size:clamp(22px,2.3vw,34px); line-height:1.18; color:var(--ink); max-width:560px; text-wrap:balance; margin:0; }

  @media (max-width:900px) {
    .hero-sub { grid-template-columns:1fr; gap:48px; }
  }
</style>
