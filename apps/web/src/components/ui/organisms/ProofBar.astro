---
import { HERO_METRICS } from '../../../data/sitemap';
import { langFromPath, t } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---

<section id="proof-bar" class="proofbar" aria-labelledby="proofbar-h2">
  <div class="wrap-wide">
    <header class="proofbar-hd">
      <span class="proofbar-eyebrow">{lang === 'fr' ? '§ 02 · PREUVES' : '§ 02 · PROOFS'}</span>
      <h2 id="proofbar-h2" class="proofbar-h2 reveal">
        {lang === 'fr' ? (
          <>Chiffres mesurés.<br/><i>Pas projections marketing.</i></>
        ) : (
          <>Measured numbers.<br/><i>Not marketing projections.</i></>
        )}
      </h2>
    </header>

    <ul class="proofbar-grid reveal-stagger">
      {HERO_METRICS.map((m, i) => (
        <li class="proofbar-cell">
          <span class="proofbar-cell-idx">N°{m.k}</span>
          <span class="proofbar-cell-num">{m.n}</span>
          <span class="proofbar-cell-label">{t(m.label, lang)}</span>
        </li>
      ))}
    </ul>

    <p class="proofbar-note">
      {lang === 'fr'
        ? <>Données anonymisées · résultats observés selon <i>périmètre, stack et maturité d'équipe</i>.</>
        : <>Anonymized data · results observed depending on <i>scope, stack and team maturity</i>.</>}
    </p>
  </div>
</section>

<style>
  .proofbar {
    padding: clamp(48px, 6vw, 80px) 0;
    border-top: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    background: var(--paper);
  }

  .proofbar-hd {
    margin-bottom: clamp(28px, 3vw, 44px);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--hairline);
  }

  .proofbar-eyebrow {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-3);
  }

  .proofbar-h2 {
    font-family: var(--font-display);
    font-size: var(--text-h2-tight);
    line-height: var(--leading-h2);
    letter-spacing: -0.02em;
    max-width: 720px;
    margin: 0;
    font-weight: 400;
    color: var(--ink);
  }
  .proofbar-h2 i { font-style: italic; color: var(--accent); }

  .proofbar-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--hairline-strong);
  }

  .proofbar-cell {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: clamp(24px, 2.8vw, 36px) clamp(16px, 1.8vw, 24px);
    border-right: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    position: relative;
  }
  .proofbar-cell:nth-child(4n) { border-right: none; }

  .proofbar-cell-idx {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.16em;
    color: var(--muted);
    text-transform: uppercase;
  }

  .proofbar-cell-num {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 72px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--accent);
    font-weight: 400;
  }

  .proofbar-cell-label {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.5;
    color: var(--ink-2);
    text-wrap: pretty;
  }

  .proofbar-note {
    margin: clamp(20px, 2.4vw, 32px) 0 0;
    font-family: var(--font-sans);
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--muted);
    max-width: 720px;
    text-wrap: pretty;
  }
  .proofbar-note i { font-style: italic; color: var(--ink-2); }

  @media (max-width: 900px) {
    .proofbar-grid { grid-template-columns: repeat(2, 1fr); }
    .proofbar-cell:nth-child(4n) { border-right: 1px solid var(--hairline); }
    .proofbar-cell:nth-child(2n) { border-right: none; }
  }
  @media (max-width: 560px) {
    .proofbar-grid { grid-template-columns: 1fr; }
    .proofbar-cell,
    .proofbar-cell:nth-child(n) { border-right: none; }
  }
</style>
