---
// Section · TrustMarquee · ruban infini de noms clients
// Variant : Marquee infini (slow 95s, italique Instrument Serif)
// Motion : @keyframes slide infinite + reduced-motion fallback
// Mémorable : « Une rivière de noms qui jamais ne s'arrête. »

import { CLIENT_LOGOS } from '../../../data/sitemap';
import { langFromPath } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
// Triplé pour qu'il n'y ait jamais de rupture visible quand la track translate -50%
const tripled = [...CLIENT_LOGOS, ...CLIENT_LOGOS, ...CLIENT_LOGOS];
---
<section class="marquee" aria-label={lang === 'fr' ? 'Clients ayant fait confiance à Waimia' : 'Clients who trusted Waimia'}>
  <div class="track" aria-hidden>
    {tripled.map((name, i) => (
      <>
        <span class="item">{name}</span>
        {i < tripled.length - 1 && <span class="sep">·</span>}
      </>
    ))}
  </div>
</section>
