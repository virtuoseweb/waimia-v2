---
// Atome · ProgressBar · barre de progression scroll terracotta
// Indivisible : un seul rôle (scroll progress feedback), aucune composition.
//
// Comportement :
//   - 1.5px de hauteur fixée en haut de page
//   - Width animée = scrollY / (scrollHeight - innerHeight)
//   - Utilise rAF throttle pour 60fps
//
// Usage : inclure une fois dans Base.astro (template layer).
---
<div class="u-progress" aria-hidden="true"><i data-progress-fill></i></div>

<script>
  // rAF throttle pour update width (Pattern 2 · Astro + script)
  const fill = document.querySelector<HTMLElement>('[data-progress-fill]');
  if (fill) {
    let raf = 0;
    const update = () => {
      raf = 0;
      const h = document.documentElement.scrollHeight - window.innerHeight;
      const p = h > 0 ? Math.max(0, Math.min(1, window.scrollY / h)) : 0;
      fill.style.width = (p * 100).toFixed(2) + '%';
    };
    const onScroll = () => {
      if (raf) return;
      raf = requestAnimationFrame(update);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    update();
  }
</script>

<style is:global>
  .u-progress {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 1.5px;
    z-index: 65;
    pointer-events: none;
  }
  .u-progress > i {
    display: block;
    height: 100%;
    background: var(--accent);
    width: 0%;
    transform-origin: left;
  }
</style>
