---
interface Props {
  errors?: Record<string, string[]>;
  id?: string;
  className?: string;
}
const { errors, id, className } = Astro.props as Props;
const hasErrors = errors && Object.keys(errors).length > 0;
---
{hasErrors && (
  <div role="alert" aria-live="polite" aria-atomic="true" id={id} class:list={['form-errors', className]}>
    <ul>
      {Object.entries(errors).map(([field, msgs]) => (
        <li><strong>{field}</strong>{' : '}{msgs.join(', ')}</li>
      ))}
    </ul>
  </div>
)}

<style>
  .form-errors {
    margin: 12px 0;
    padding: 12px 16px;
    border-left: 2px solid var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink);
  }
  .form-errors ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 4px; }
  .form-errors strong { font-family: var(--font-mono); font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.08em; color: var(--accent); margin-right: 6px; }
</style>
