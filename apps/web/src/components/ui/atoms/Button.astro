---
// Atome · Button
// Wrapper sur les classes legacy `.btn .btn-primary|ghost|accent` du global.css
// Centralise les variantes + magnetic + accessibility · 9 fichiers utilisaient
// inline `<a class="btn btn-primary">` avant ce refactor.
//
// Usage :
//   <Button href="/contact" variant="primary" size="lg" mag={0.18}>Réserver →</Button>
//   <Button href="mailto:hello@x" variant="ghost">hello@x</Button>
//   <Button as="button" type="submit" variant="accent">Envoyer</Button>

interface Props {
  /** Cible href si link (défaut). Si `as="button"` est passé, ignoré. */
  href?: string;
  /** Variante visuelle · primary (ink) / ghost (border) / accent (terracotta) / link (souligné) */
  variant?: 'primary' | 'ghost' | 'accent' | 'link';
  /** Taille · `md` (défaut) ou `lg` (CTA principaux) */
  size?: 'md' | 'lg';
  /** Force magnétique au survol (0 = désactivé). Cf Base.astro inline script. */
  mag?: number;
  /** Forcer un <button> au lieu d'un <a> · pour les forms ou actions JS */
  as?: 'a' | 'button';
  /** Type pour `<button>` */
  type?: 'button' | 'submit' | 'reset';
  /** Désactive l'action native. */
  disabled?: boolean;
  /** Aria-label si l'enfant est ambigu (icône seule) */
  'aria-label'?: string;
  /** Classes additionnelles */
  class?: string;
  /** Etat de chargement, avec spinner inline pour submit. */
  loading?: boolean;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  mag,
  as = 'a',
  type = 'button',
  disabled = false,
  class: extraClass = '',
  loading = false,
  ...rest
} = Astro.props;

const showSpinner = loading && as === 'button' && type === 'submit';
const classes = [
  'btn',
  `btn-${variant}`,
  size === 'lg' && 'btn-lg',
  loading && 'btn--loading',
  extraClass,
].filter(Boolean).join(' ');

const dataMag = mag !== undefined ? String(mag) : undefined;
const ariaBusy = loading ? 'true' : undefined;
const ariaDisabled = loading ? 'true' : undefined;
---
{as === 'button' ? (
  <button type={type} class={classes} data-mag={dataMag} disabled={disabled || loading} aria-busy={ariaBusy} {...rest}>
    {showSpinner && (
      <svg class="btn-spinner" viewBox="0 0 16 16" aria-hidden="true" focusable="false">
        <circle cx="8" cy="8" r="5.5" fill="none" stroke-width="2" />
      </svg>
    )}
    <span class="btn-label"><slot /></span>
  </button>
) : (
  <a href={href} class={classes} data-mag={dataMag} aria-busy={ariaBusy} aria-disabled={ariaDisabled} {...rest}>
    <span class="btn-label"><slot /></span>
  </a>
)}
