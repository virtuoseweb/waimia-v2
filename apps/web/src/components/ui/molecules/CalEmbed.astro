---
// Molécule · CalEmbed · Cal.com booking widget (SaaS via @calcom/embed-react)
//
// Bascule 2026-05-08 :
//   AVANT · script vanilla pointant sur cal.waimia.com (self-host)
//   APRÈS · island React via @calcom/embed-react, calendrier cal.com SaaS
//
// Calendrier source : https://cal.com/simonberos/audit
// Documentation : https://cal.com/docs/embed
//
// Réutilisable sur :
//  - /contact (inline) · plein widget de booking
//  - toute page nécessitant un embed direct Cal.com
//
// L'app self-host `apps/cal` (cal.waimia.com) reste déployée pour back-up,
// mais le site (waimia.com) pointe désormais sur cal.com SaaS pour réduire
// la dépendance opérationnelle (pas de runtime à maintenir côté Waimia).

import CalEmbedReact from './CalEmbedReact.tsx';

interface Props {
  /** Slug Cal.com (default: env PUBLIC_CAL_USERNAME) */
  username?: string;
  /** Event type slug (default: env PUBLIC_CAL_EVENT_TYPE) */
  eventType?: string;
  /** Namespace Cal isolant l'instance (default: env PUBLIC_CAL_NAMESPACE) */
  namespace?: string;
  /** Theme · auto/light/dark */
  theme?: 'auto' | 'light' | 'dark';
  /** Layout · seul `inline` est supporté avec @calcom/embed-react ici */
  layout?: 'inline';
  /** ID élément container (default 'cal-embed') · conservé pour compat ascendante */
  id?: string;
}

// `.trim()` défensif : `vercel env add` via `echo 'value' |` stocke parfois
// la valeur avec un \n trailing qui casse le slug Cal.com (404 en prod).
const {
  username = (import.meta.env.PUBLIC_CAL_USERNAME ?? 'simonberos').trim(),
  eventType = (import.meta.env.PUBLIC_CAL_EVENT_TYPE ?? 'audit').trim(),
  namespace = (import.meta.env.PUBLIC_CAL_NAMESPACE ?? 'audit').trim(),
  theme = 'light',
  id = 'cal-embed',
} = Astro.props as Props;

const calLink = `${username}/${eventType}`;
---
<div id={id} class="cal-inline">
  <CalEmbedReact
    client:only="react"
    namespace={namespace}
    calLink={calLink}
    theme={theme}
  />
</div>

<style>
  /* Intégration éditoriale : pas de cadre wrapper.
   * Le widget Cal.com fournit son propre conteneur visuel (carte profil + grid).
   * On laisse l'embed flotter dans le flow `<UtilityTemplate>` — la séparation
   * hiérarchique vient déjà du `.contact-cal { border-top }` côté page.
   * `min-height` stabilise le layout pendant l'hydratation `client:only="react"`.
   */
  .cal-inline {
    width: 100%;
    min-height: 600px;
  }
</style>
