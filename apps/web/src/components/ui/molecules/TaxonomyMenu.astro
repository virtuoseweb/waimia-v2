---
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../../data/taxonomies';

const [blog, cookbooks, livresBlancs, veilleIA, cases] = await Promise.all([
  getCollection('blog'),
  getCollection('cookbooks'),
  getCollection('livresBlancs'),
  getCollection('veilleIA'),
  getCollection('cases'),
]);

const all = [...blog, ...cookbooks, ...livresBlancs, ...veilleIA, ...cases];

const counts: Record<string, number> = {};
for (const cat of Object.keys(CATEGORIES)) {
  counts[cat] = all.filter((entry) => entry.data.category === cat).length;
}
---

<nav class="tax-menu" aria-label="Catégories de ressources">
  <div class="tax-menu-kicker">§ Explorer par catégorie</div>
  <ul>
    {
      Object.entries(CATEGORIES).map(([slug, cat]) => (
        <li>
          <a href={`/ressources/categorie/${slug}`}>
            <span class="tax-menu-label">{cat.label.fr}</span>
            {counts[slug] > 0 && (
              <span class="tax-menu-count">{counts[slug]}</span>
            )}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .tax-menu { padding: 24px 0; }
  .tax-menu-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .tax-menu ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 8px;
  }
  .tax-menu a {
    display: flex;
    justify-content: space-between;
    padding: 12px 16px;
    color: var(--ink);
    text-decoration: none;
    border: 1px solid rgba(0,0,0,.08);
    border-radius: 8px;
    transition: border-color 220ms, color 220ms;
  }
  .tax-menu a:hover { border-color: var(--accent); color: var(--accent); }
  .tax-menu-label { font-family: var(--font-display); font-size: 15px; }
  .tax-menu-count {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
</style>
