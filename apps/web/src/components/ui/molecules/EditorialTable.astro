---
// Molécule · EditorialTable
// Frame de table éditoriale terminal-style · header (mono uppercase) + slot pour rows.
// Border 1px solid ink + radius 10px + head bg paper-2.
//
// Unifie les 2 tables de /console : `c-services-tbl` (4 cols) et `c-cases-tbl` (7 cols).
// Le pattern grid est paramétré via `cols` pour réutilisation.
//
// Composition rigoureuse Atomic Design : chaque header est rendu via Kicker atom.
//
// Usage :
//   <EditorialTable cols="60px 180px 1fr 120px" headers={['id','service','description','status']}>
//     <EditorialTableRow ...>...
//   </EditorialTable>

import Kicker from '../atoms/Kicker.astro';

interface Props {
  /** Grid template columns · ex: "60px 180px 1fr 120px" */
  cols: string;
  /** Headers de la table (1 par colonne) */
  headers: string[];
  /** Tone fond head · `paper` (défaut) ou `ink` (réservé futur) */
  tone?: 'paper' | 'ink';
  /** Classes additionnelles */
  class?: string;
}

const { cols, headers, tone = 'paper', class: extraClass = '' } = Astro.props;
---
<div
  class={`u-edit-tbl ${extraClass}`.trim()}
  style={`--u-edit-tbl-cols:${cols}`}
  data-tone={tone}
>
  <div class="u-edit-tbl-head">
    {headers.map((h) => <Kicker as="span" size={10.5} letterSpacing=".12em">{h}</Kicker>)}
  </div>
  <slot />
</div>

<style>
  .u-edit-tbl{border:1px solid var(--ink);border-radius:10px;overflow:hidden;background:var(--paper)}
  .u-edit-tbl-head{
    display:grid;
    grid-template-columns:var(--u-edit-tbl-cols);
    padding:14px 20px;
    gap:14px;
    background:var(--paper-2);
    border-bottom:1px solid var(--hairline);
  }
  /* Les rows sont injectées en slot · elles doivent utiliser .u-edit-tbl-row */
  :global(.u-edit-tbl-row){
    display:grid;
    grid-template-columns:var(--u-edit-tbl-cols);
    padding:22px 20px;
    gap:14px;
    border-bottom:1px solid var(--hairline);
    align-items:baseline;
    color:inherit;
    transition:background 180ms var(--ease);
  }
  :global(.u-edit-tbl-row:last-child){border-bottom:none}
  :global(.u-edit-tbl-row:hover){background:var(--paper-2)}

  @media (max-width:900px){
    .u-edit-tbl-head{display:none}
    :global(.u-edit-tbl-row){grid-template-columns:1fr;gap:6px;padding:18px 16px}
  }
</style>
