---
// Molécule · Footnotes · « ¹ NDA · ² Claude · ³ règles typo »
// Bande de notes éditoriales en bas du Hero · réutilisable sur toute page hub
//
// Composition rigoureuse Atomic Design : utilise Kicker atom (variante non-uppercase).
//
// Usage :
//   <Footnotes
//     items={[
//       { mark: '¹', text: 'Tous les chiffres re-mesurables sous NDA.' },
//       { mark: '²', text: 'Claude Opus · Sonnet · Haiku.' },
//     ]}
//   />

import Kicker from '../atoms/Kicker.astro';

interface Note {
  /** Marqueur · ex: "¹", "²", "★" */
  mark: string;
  /** Contenu de la note · texte simple */
  text: string;
}

interface Props {
  items: Note[];
  /** Tone · `paper` (clair) ou `ink` (dark) */
  tone?: 'paper' | 'ink';
  /** Classes additionnelles */
  class?: string;
}

const { items, tone = 'paper', class: extraClass = '' } = Astro.props;
const isInk = tone === 'ink';
const ink = isInk ? 'var(--paper)' : 'var(--ink)';
const border = isInk ? 'rgba(246,241,232,.12)' : 'var(--hairline)';
const kickerTone = isInk ? 'dim' : 'muted';
---
<div
  class={`u-footnotes ${extraClass}`.trim()}
  style={`padding:18px 0;border-top:1px solid ${border};display:flex;gap:48px;flex-wrap:wrap`}
>
  {items.map((n) => (
    <Kicker as="span" tone={kickerTone} size={10.5} letterSpacing=".06em" textTransform="none">
      <span style={`color:${ink};margin-right:4px`}>{n.mark}</span>
      {n.text}
    </Kicker>
  ))}
</div>
