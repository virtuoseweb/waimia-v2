---
import { getCollection } from 'astro:content';

interface Props {
  cluster?: string;
  excludeId?: string;
  limit?: number;
}

interface RelatedData {
  cluster?: string;
  publishedAt: Date | string;
  title_fr: string;
}

interface Item {
  id: string;
  type: string;
  data: RelatedData;
  href: string;
}

const { cluster, excludeId, limit = 3 } = Astro.props;

if (!cluster) return null;

const [blog, cookbooks, livresBlancs] = await Promise.all([
  getCollection('blog'),
  getCollection('cookbooks'),
  getCollection('livresBlancs'),
]);

const all: Item[] = [
  ...blog
    .filter((entry) => entry.data.cluster === cluster && entry.id !== excludeId)
    .map((entry) => ({
      id: entry.id,
      type: 'blog',
      data: entry.data,
      href: `/ressources/blog/${entry.id}`,
    })),
  ...cookbooks
    .filter((entry) => entry.data.cluster === cluster && entry.id !== excludeId)
    .map((entry) => ({
      id: entry.id,
      type: 'cookbook',
      data: entry.data,
      href: `/ressources/cookbooks/${entry.id}`,
    })),
  ...livresBlancs
    .filter((entry) => entry.data.cluster === cluster && entry.id !== excludeId)
    .map((entry) => ({
      id: entry.id,
      type: 'livre-blanc',
      data: entry.data,
      href: `/ressources/livres-blancs/${entry.id}`,
    })),
]
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() -
      new Date(a.data.publishedAt).getTime(),
  )
  .slice(0, limit);

if (all.length === 0) return null;
---

<aside class="rel-cluster">
  <div class="rel-kicker">§ Continuer dans ce cluster</div>
  <ul>
    {
      all.map((it) => (
        <li>
          <a href={it.href}>
            <span class="rel-type">{it.type}</span>
            <span class="rel-title">{it.data.title_fr}</span>
          </a>
        </li>
      ))
    }
  </ul>
  <a href={`/ressources/silo/${cluster}`} class="rel-cta"
    >Voir le silo complet →</a
  >
</aside>

<style>
  .rel-cluster {
    padding: 32px;
    background: var(--paper-2, #EFEBE2);
    border-radius: 16px;
    margin: 48px 0;
  }
  .rel-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 16px;
  }
  .rel-cluster ul { list-style: none; padding: 0; margin: 0 0 20px; }
  .rel-cluster li { border-bottom: 1px solid rgba(0,0,0,.08); }
  .rel-cluster li:last-child { border-bottom: 0; }
  .rel-cluster a {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 16px;
    padding: 14px 0;
    color: var(--ink);
    text-decoration: none;
    align-items: baseline;
  }
  .rel-cluster a:hover { color: var(--accent); }
  .rel-type {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .rel-title { font-family: var(--font-display); font-size: 15px; line-height: 1.4; }
  .rel-cta {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--accent);
    text-decoration: none;
  }
</style>
