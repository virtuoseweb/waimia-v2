---
// RelatedByCluster · data-loader par cluster · délègue le rendu à RelatedCards
// Logique : getCollection(blog + cookbooks + livresBlancs) filtré par cluster,
// tri par date desc, slice(limit), puis mappage vers RelatedCards.Card.
import { getCollection } from 'astro:content';
import RelatedCards from './RelatedCards.astro';

interface Props {
  cluster?: string;
  excludeId?: string;
  limit?: number;
}

interface RelatedData {
  cluster?: string;
  publishedAt: Date | string;
  title_fr: string;
}

interface Item {
  id: string;
  type: string;
  data: RelatedData;
  href: string;
}

const { cluster, excludeId, limit = 3 } = Astro.props;

if (!cluster) return null;

const [blog, cookbooks, livresBlancs] = await Promise.all([
  getCollection('blog'),
  getCollection('cookbooks'),
  getCollection('livresBlancs'),
]);

const all: Item[] = [
  ...blog
    .filter((entry) => entry.data.cluster === cluster && entry.id !== excludeId)
    .map((entry) => ({
      id: entry.id,
      type: 'blog',
      data: entry.data,
      href: `/ressources/blog/${entry.id}`,
    })),
  ...cookbooks
    .filter((entry) => entry.data.cluster === cluster && entry.id !== excludeId)
    .map((entry) => ({
      id: entry.id,
      type: 'cookbook',
      data: entry.data,
      href: `/ressources/cookbooks/${entry.id}`,
    })),
  ...livresBlancs
    .filter((entry) => entry.data.cluster === cluster && entry.id !== excludeId)
    .map((entry) => ({
      id: entry.id,
      type: 'livre-blanc',
      data: entry.data,
      href: `/ressources/livres-blancs/${entry.id}`,
    })),
]
  .sort(
    (a, b) =>
      new Date(b.data.publishedAt).getTime() -
      new Date(a.data.publishedAt).getTime(),
  )
  .slice(0, limit);

if (all.length === 0) return null;

const cards = all.map((it) => ({
  kicker: it.type.toUpperCase(),
  title_fr: it.data.title_fr,
  title_en: it.data.title_fr,
  lead_fr: '',
  lead_en: '',
  href: it.href,
}));
---

<div class="rel-cluster-wrap">
  <p class="rel-cluster-label">§ Continuer dans ce cluster</p>
  <RelatedCards {cards} />
  <a href={`/ressources/silo/${cluster}`} class="rel-cluster-cta">Voir le silo complet →</a>
</div>

<style>
  .rel-cluster-wrap { margin: 48px 0; }
  .rel-cluster-label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 16px;
  }
  .rel-cluster-cta {
    display: inline-block;
    margin-top: 20px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--accent);
    text-decoration: none;
  }
  .rel-cluster-cta:hover { text-decoration: underline; }
</style>
