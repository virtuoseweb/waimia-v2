---
// Base layout · head SEO/GEO/AIO + Header + Footer + JSON-LD baseline
// Toute page Astro hérite de ce layout. Frontmatter passe via Astro.props.

import '../styles/global.css';
import '../styles/grid.css';
import '../styles/scroll-reveal.css';
import Header from '../components/header/Header.astro';
import Footer from '../components/footer/Footer.astro';
import PagePill from '../components/ui/molecules/PagePill.astro';
import CursorDot from '../components/ui/atoms/CursorDot.astro';
import ProgressBar from '../components/ui/atoms/ProgressBar.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { organization, website } from '../lib/seo';
import { langFromPath, alternateHref, HREFLANG } from '../lib/i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  /** Bloc(s) JSON-LD spécifiques à la page (Service / Article / FAQ…). Organization+WebSite sont auto-injectés. */
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** Bloc(s) JSON-LD additionnels injectés par un template parent sans écraser jsonLd. */
  additionalJsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** OG image absolue */
  ogImage?: string;
  /** Pas d'index (pages WIP) */
  noindex?: boolean;
  /** Override canonical (sinon dérivé du chemin) */
  canonical?: string;
  /** Couleur thème navigateur */
  themeColor?: string;
}

const {
  title,
  description,
  jsonLd,
  additionalJsonLd,
  ogImage = 'https://waimia.com/og/default.png',
  noindex = false,
  canonical,
  themeColor = '#F6F1E8',
} = Astro.props;

const lang = langFromPath(Astro.url.pathname);
const altPath = alternateHref(Astro.url.pathname, lang);
const siteUrl = 'https://waimia.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const altUrl = `${siteUrl}${altPath}`;

const baseLd = [organization(), website(lang)];
const pageLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const additionalLd = additionalJsonLd
  ? (Array.isArray(additionalJsonLd) ? additionalJsonLd : [additionalJsonLd])
  : [];
---
<!doctype html>
<html lang={HREFLANG[lang]} data-lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Hreflang · pivot SEO bilingue */}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={HREFLANG[lang]} href={canonicalUrl} />
    <link rel="alternate" hreflang={HREFLANG[lang === 'fr' ? 'en' : 'fr']} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    {/* Open Graph + Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={HREFLANG[lang]} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Waimia" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />

    {/* Favicons */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    {/* Preconnect Google Fonts (gain LCP 200-500ms — fonts chargees via
        @import dans tokens.css). DNS lookup + TLS handshake termine
        avant que le CSS soit parse. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    {/* JSON-LD baseline (Organization + WebSite) + custom blocks */}
    <JsonLd data={[...baseLd, ...pageLd, ...additionalLd]} />

    {/* Sitemap & RSS */}
    <link rel="sitemap" href="/sitemap-index.xml" />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    {/* Skip-to-content · WCAG 2.4.1 — apparaît au focus, masqué sinon */}
    <a href="#main" class="skip-link">
      {lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}
    </a>
    <ProgressBar />
    <CursorDot />
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <PagePill />

    <script>
      import { initScrollReveal } from '../lib/animations/scroll-reveal';
      import { initSplitLetterReveal } from '../lib/animations/split-letter';

      initScrollReveal();
      initSplitLetterReveal();
    </script>

    {/* IntersectionObserver léger pour activer les classes .reveal/.in */}
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        const reduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
        if (reduced) {
          document.querySelectorAll('.reveal,.reveal-up,.reveal-fade,.reveal-slide,.reveal-snap,.reveal-stagger,.scale-in,.blur-in,.clip-up,.hair-draw,.row-lines,.reveal-mask-up,.reveal-zoom-in,.reveal-blur-clip,.reveal-curtain,.reveal-split-letter').forEach((el) => el.classList.add('in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '0px 0px -10% 0px', threshold: 0.08 },
        );
        const sels = '.reveal,.reveal-up,.reveal-fade,.reveal-slide,.reveal-snap,.reveal-stagger,.scale-in,.blur-in,.clip-up,.hair-draw,.row-lines,.reveal-mask-up,.reveal-zoom-in,.reveal-blur-clip,.reveal-curtain,.reveal-split-letter';
        document.querySelectorAll(sels).forEach((el) => io.observe(el));
      })();
    </script>

    {/* Magnetic hover sur [data-mag] */}
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        if (!window.matchMedia('(pointer:fine)').matches) return;
        const reduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
        if (reduced) return;
        document.querySelectorAll('[data-mag]').forEach((el) => {
          const strength = parseFloat(el.getAttribute('data-mag') || '0.18');
          el.addEventListener('mousemove', (e) => {
            const r = el.getBoundingClientRect();
            const x = (e.clientX - r.left - r.width / 2) * strength;
            const y = (e.clientY - r.top - r.height / 2) * strength;
            el.style.transform = `translate(${x}px,${y}px)`;
          });
          el.addEventListener('mouseleave', () => { el.style.transform = ''; });
        });
      })();
    </script>
  </body>
</html>
