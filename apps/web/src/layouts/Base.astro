---
// Base layout · head SEO/GEO/AIO + Header + Footer + JSON-LD baseline
// Toute page Astro hérite de ce layout. Frontmatter passe via Astro.props.

import '../styles/global.css';
import '../styles/grid.css';
import '../styles/scroll-reveal.css';
import Header from '../components/header/Header.astro';
import Footer from '../components/footer/Footer.astro';
import PagePill from '../components/ui/molecules/PagePill.astro';
import CookiesBanner from '../components/ui/organisms/CookiesBanner.astro';
import CursorDot from '../components/ui/atoms/CursorDot.astro';
import ProgressBar from '../components/ui/atoms/ProgressBar.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import { organization, website } from '../lib/seo';
import { langFromPath, alternateHref, HREFLANG } from '../lib/i18n';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  /** Bloc(s) JSON-LD spécifiques à la page (Service / Article / FAQ…). Organization+WebSite sont auto-injectés. */
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** Bloc(s) JSON-LD additionnels injectés par un template parent sans écraser jsonLd. */
  additionalJsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
  /** OG image absolue */
  ogImage?: string;
  /** Pas d'index (pages WIP) */
  noindex?: boolean;
  /** Override canonical (sinon dérivé du chemin) */
  canonical?: string;
  /** Couleur thème navigateur */
  themeColor?: string;
}

const {
  title,
  description,
  jsonLd,
  additionalJsonLd,
  ogImage,
  noindex = false,
  canonical,
  themeColor = '#F6F1E8',
} = Astro.props;

const lang = langFromPath(Astro.url.pathname);
const altPath = alternateHref(Astro.url.pathname, lang);
const siteUrl = 'https://waimia.com';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;

// T1.6b · OG image dynamique via /api/og.png si pas d'image fournie
// Utilise title + kicker dérivé de la description (first sentence) pour le rendu SVG
const ogTitle = encodeURIComponent(title.split('·')[0].trim().substring(0, 80));
const ogKicker = encodeURIComponent(lang === 'fr' ? '§ Waimia' : '§ Waimia');
const dynamicOgUrl = `${siteUrl}/api/og.png?title=${ogTitle}&kicker=${ogKicker}`;
const finalOgImage = ogImage ?? dynamicOgUrl;
const altUrl = `${siteUrl}${altPath}`;

const baseLd = [organization(), website(lang)];
const pageLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const additionalLd = additionalJsonLd
  ? (Array.isArray(additionalJsonLd) ? additionalJsonLd : [additionalJsonLd])
  : [];
---
<!doctype html>
<html lang={HREFLANG[lang]} data-lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content={themeColor} />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    {/* Hreflang · pivot SEO bilingue */}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={HREFLANG[lang]} href={canonicalUrl} />
    <link rel="alternate" hreflang={HREFLANG[lang === 'fr' ? 'en' : 'fr']} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/`} />

    {/* Open Graph + Twitter */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={HREFLANG[lang]} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Waimia" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={finalOgImage} />

    {/* Favicons + PWA manifest */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <link rel="manifest" href="/manifest.json" />

    {/* Google Fonts · stratégie 3 couches pour LCP optimal :
        1. preconnect : DNS + TLS anticipés sur les 2 origines
        2. preload as="style" : browser démarre le fetch dès le parse HTML
           avant de voir le <link rel="stylesheet"> (découverte ~200-400ms plus tôt)
        3. stylesheet : chargement standard, parallèle au CSS bundle Astro
        L'@import url() a été retiré de tokens.css — chaîne CSS → découverte tardive éliminée. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&display=swap" />

    {/* JSON-LD baseline (Organization + WebSite) + custom blocks */}
    <JsonLd data={[...baseLd, ...pageLd, ...additionalLd]} />

    {/* Sitemap & RSS */}
    <link rel="sitemap" href="/sitemap-index.xml" />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    {/* Skip-to-content · WCAG 2.4.1 — apparaît au focus, masqué sinon */}
    <a href="#main" class="skip-link">
      {lang === 'fr' ? 'Aller au contenu' : 'Skip to content'}
    </a>
    <ProgressBar />
    <CursorDot />
    <Header />
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <Footer />
    {import.meta.env.DEV && <PagePill />}
    <CookiesBanner lang={lang} />

    <script>
      import { initScrollReveal } from '../lib/animations/scroll-reveal';
      import { initSplitLetterReveal } from '../lib/animations/split-letter';

      initScrollReveal();
      initSplitLetterReveal();
    </script>

    {/* IntersectionObserver léger pour activer les classes .reveal/.in — réexécuté après View Transitions */}
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        function initRevealObserver() {
          const reduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
          const sels = '.reveal,.reveal-up,.reveal-fade,.reveal-slide,.reveal-snap,.reveal-stagger,.scale-in,.blur-in,.clip-up,.hair-draw,.row-lines,.reveal-mask-up,.reveal-zoom-in,.reveal-blur-clip,.reveal-curtain,.reveal-split-letter';
          if (reduced) {
            document.querySelectorAll(sels).forEach((el) => el.classList.add('in'));
            return;
          }
          const io = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                if (e.isIntersecting) {
                  e.target.classList.add('in');
                  io.unobserve(e.target);
                }
              }
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.08 },
          );
          document.querySelectorAll(sels).forEach((el) => {
            if (!el.classList.contains('in')) io.observe(el);
          });
          // Fallback pour les éléments above-the-fold masqués par BootSplash overlay
          // (~1100ms) : l'IO ne déclenche pas pendant que l'overlay z-index:200 couvre tout.
          setTimeout(() => {
            document.querySelectorAll(sels).forEach((el) => {
              if (el.classList.contains('in')) return;
              const r = el.getBoundingClientRect();
              if (r.top < window.innerHeight * 0.95 && r.bottom > 0) {
                el.classList.add('in');
              }
            });
          }, 1300);
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initRevealObserver);
        } else {
          initRevealObserver();
        }
        document.addEventListener('astro:page-load', initRevealObserver);
      })();
    </script>

    {/* Magnetic hover sur [data-mag] — réexécuté après View Transitions */}
    <script is:inline>
      (() => {
        if (typeof window === 'undefined') return;
        function initMagnetic() {
          if (!window.matchMedia('(pointer:fine)').matches) return;
          const reduced = window.matchMedia('(prefers-reduced-motion:reduce)').matches;
          if (reduced) return;
          document.querySelectorAll('[data-mag]').forEach((el) => {
            if (el.dataset.magBound === '1') return;
            el.dataset.magBound = '1';
            const strength = parseFloat(el.getAttribute('data-mag') || '0.18');
            el.addEventListener('mousemove', (e) => {
              const r = el.getBoundingClientRect();
              const x = (e.clientX - r.left - r.width / 2) * strength;
              const y = (e.clientY - r.top - r.height / 2) * strength;
              el.style.transform = `translate(${x}px,${y}px)`;
            });
            el.addEventListener('mouseleave', () => { el.style.transform = ''; });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initMagnetic);
        } else {
          initMagnetic();
        }
        document.addEventListener('astro:page-load', initMagnetic);
      })();
    </script>
  </body>
</html>

<style>
  main[id="main"]:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
  }
</style>
