# pnpm config racine · dev-friendly pour agents IA
#
# Politique lockfile :
#   - Dev local : pnpm install non-strict, agents peuvent ajouter des deps sans
#     que le lockfile out-of-sync bloque l'install.
#   - CI / Vercel prod : passer --frozen-lockfile en flag CLI explicite pour
#     garantir builds reproductibles. Pas activé par défaut ici.

# Lockfile non-strict en local (agents peuvent itérer sans blocage)
prefer-frozen-lockfile=false

# Auto-install peer dependencies (évite les warnings React/Astro pénibles)
auto-install-peers=true

# Pas de strict peer dependencies (compromis : warnings au lieu d'erreurs)
strict-peer-dependencies=false

# Hoisting pnpm standard (isolation forte par package, pas de pollution)
shamefully-hoist=false

# Pour les workspaces : préférer linker entre packages internes plutôt que
# télécharger npm registry quand le nom matche (@waimia/*)
link-workspace-packages=true
prefer-workspace-packages=true

# Engine strict (warning si Node version diverge de package.json engines)
engine-strict=true
