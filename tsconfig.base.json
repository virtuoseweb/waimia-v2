{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Waimia Monorepo Base",
  "_comment": "Config TypeScript partagée — chaque app/package étend ce fichier via 'extends'. Modifier ici impacte toutes les apps après prochain build.",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,

    "skipLibCheck": true,
    "incremental": true
  },
  "exclude": ["node_modules", "dist", ".turbo", ".next", ".astro", ".vercel"]
}
