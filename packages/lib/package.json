{
  "name": "@waimia/lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Utils communs Waimia (Resend client, types Bi/Lead, helpers i18n)",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./resend": {
      "types": "./src/resend.ts",
      "import": "./src/resend.ts"
    },
    "./i18n": {
      "types": "./src/i18n.ts",
      "import": "./src/i18n.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"@waimia/lib: lint TBD\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
