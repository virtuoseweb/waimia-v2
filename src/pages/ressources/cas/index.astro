---
// Page · /ressources/cas · Index des cas clients
// Source : waimia-handoff2 / cases-index.html
//
// Composé de · ListIndexTemplate (squelette) + EditorialCaseCard (molecule)
// Rend la liste depuis CASE_FEED (data/sitemap.ts) — pas de duplication.

import ListIndexTemplate from '../../../components/templates/ListIndexTemplate.astro';
import EditorialCaseCard from '../../../components/ui/molecules/EditorialCaseCard.astro';
import { CASE_FEED } from '../../../data/sitemap';
import { langFromPath, t } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<ListIndexTemplate
  title="Cas clients · Waimia"
  description="Quatre dossiers livrés. Secteur · durée · stack · impact mesurable. Les cas qui ont inspiré nos services."
  kicker="§ Cas clients · 4 dossiers"
>
  <Fragment slot="headline">
    Quatre <i>dossiers</i>. Pas une démo.
  </Fragment>
  <Fragment slot="lede">
    Chaque cas reflète un chantier réel — réconciliation données, déploiement d'agents, FinOps. Mesures vérifiables sous NDA.
  </Fragment>

  <Fragment slot="list">
    <div class="cases-grid">
      {CASE_FEED.map((c, i) => (
        <EditorialCaseCard
          idx={i + 1}
          client={c.client}
          sector={t(c.sector, lang)}
          stack={c.stack}
          impact={t(c.impact, lang)}
          duration={c.duration}
          href={`/ressources/cas/${c.slug}`}
          offset={i % 2 === 1 ? 60 : 0}
        />
      ))}
    </div>
  </Fragment>
</ListIndexTemplate>

<style>
  .cases-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  @media (max-width: 800px) {
    .cases-grid { grid-template-columns: 1fr; gap: 16px; }
    .cases-grid > * { margin-top: 0 !important; }
  }
</style>
