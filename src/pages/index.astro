---
// Homepage · Direction 1 · refonte enrichie · FR
// Pacing : 5 actes + 4 intercalaires .5 qui amplifient chaque acte sans le diluer.
//   1   Hero (statique, ancré)
//   2   TrustMarquee (intercalaire · social proof)
//   3   ACTE I — Why AI stalls (4 FIG)
//   3.5 HowWeShip (intercalaire · comment on adresse le problème, sticky pin signature)
//   4   ACTE II — Six services taught by doing (3×2)
//   4.5 Pyramid (intercalaire · l'architecture 4 paliers Claude-native)
//   5   ¶ Manifeste (anti-théâtre IA)
//   6   ACTE III — Operating layer DARK (console VirtuoseOS)
//   6.5 Departments (intercalaire · qui ça sert, dans quel métier)
//   7   ACTE IV — Four files (cases)
//   8   § Writing — Slow notes from the floor
//   8.5 Offices (intercalaire · ancrage Paris-Genève)
//   9   § FAQ (GEO/AIO)
//   10  ACTE V — Book a working session
//   11  Sig band
// Cf docs/04-motion-system.md pour le mapping motion par section.

import Base from '../layouts/Base.astro';
import BootSplash from '../components/motion/BootSplash.tsx';

import Hero            from '../components/sections/Hero.astro';
import TrustMarquee    from '../components/sections/TrustMarquee.astro';
import WhyAIStalls     from '../components/sections/WhyAIStalls.astro';
import HowWeShip       from '../components/sections/HowWeShip.astro';
import SixServices     from '../components/sections/SixServices.astro';
import Pyramid         from '../components/sections/Pyramid.astro';
import Manifesto       from '../components/sections/Manifesto.astro';
import OperatingLayer  from '../components/sections/OperatingLayer.astro';
import Departments     from '../components/sections/Departments.astro';
import Cases           from '../components/sections/Cases.astro';
import WritingNotes    from '../components/sections/WritingNotes.astro';
import Offices         from '../components/sections/Offices.astro';
import FAQ             from '../components/seo/FAQ.astro';
import BookSession     from '../components/sections/BookSession.astro';
import SigBand         from '../components/sections/SigBand.astro';

import { faqPage } from '../lib/seo';

// FAQ visible + JSON-LD pour GEO/AIO (cf docs/02-geo-aio-strategy.md)
const faqItems = [
  {
    q: "Qu'est-ce qu'une « agence IA experte Claude » et en quoi ça diffère d'une agence IA généraliste ?",
    a: "Nous concentrons 100 % de notre R&D sur l'écosystème Anthropic — Opus 4.7, Sonnet 4.6, Haiku 4.5, Skills, MCP, Managed Agents — et sur les frameworks open-source compatibles. Cela se voit en time-to-production : 6 semaines médian pour un agent en prod, contre 14+ pour des équipes généralistes. Nous écrivons en français, lisons la documentation Stripe, livrons du code le mardi et mesurons le pipeline le vendredi.",
  },
  {
    q: "Quelle est la différence entre Claude Skills et MCP ?",
    a: "Une Claude Skill est un comportement défini — un workflow précis (ex : « générer un mémo finance »), avec ses étapes, contraintes, formats de sortie. MCP (Model Context Protocol) est le standard ouvert qui connecte un modèle à des sources de données et des outils externes (Notion, Drive, Slack, HubSpot). Skills = comportement réutilisable. MCP = connectivité standardisée. Les deux se complètent dans chaque agent Waimia.",
  },
  {
    q: "Pouvez-vous déployer en self-hosted, sans dépendance Anthropic ?",
    a: "Oui. Nous déployons des modèles open-source (Llama 4, DeepSeek V3.2, Qwen 3.5, GLM-5) sur infrastructure cliente via vLLM ou Ollama, orchestrés avec LangGraph ou CrewAI. Cette voie est recommandée quand les contraintes RGPD, ACPR, SecNumCloud ou HIPAA imposent que la donnée ne quitte jamais votre périmètre. Nous documentons toujours le coût total et la trajectoire de migration éventuelle.",
  },
  {
    q: "Combien coûte un premier engagement ?",
    a: "Un audit Process Intelligence démarre à 12 000 € HT sur 5 jours. Un sprint MVP de 4 semaines (1 agent en production, audit trail complet, métriques avant/après) démarre à 24 000 € HT. Pour une enveloppe précise, utilisez notre calculateur TCO ou réservez 45 minutes d'échange — on revient avec un problème diagnostiqué, ou on ne relance pas.",
  },
  {
    q: "Êtes-vous une agence Anthropic certifiée ?",
    a: "Notre dossier de partenariat Anthropic est en cours d'instruction (T3 2026). Nos architectes sont Claude Certified et nous sommes Activateur Francenum (expert IA reconnu par l'État français). Tous les chiffres et certifications sont sur notre Trust Center.",
  },
  {
    q: "Comment garantissez-vous la conformité AI Act et RGPD ?",
    a: "Chaque agent inclut par défaut : log signé de toutes les actions (AI Act Art. 12), export CSV/JSON, possibilité de rollback, classification automatique du niveau de risque. Pour la conformité RGPD/LPD, nous menons un PIA (Privacy Impact Assessment) avant le sprint MVP. Notre Trust Center détaille la liste complète des contrôles.",
  },
  {
    q: "Qu'est-ce que VirtuoseOS et faut-il l'acheter pour travailler avec vous ?",
    a: "VirtuoseOS est notre plateforme interne — le kernel multi-workspace qui se trouve sous chaque mission Waimia. Vous n'avez pas à l'acheter pour travailler avec nous. Pour les engagements Enterprise, nous le proposons en self-hosted sur votre infra ou en SaaS managé avec parité française.",
  },
];
---
<Base
  title="Waimia · Architectes de systèmes agentiques · Claude-native · Paris · Genève"
  description="Agence IA experte Claude (Opus, Sonnet, Haiku) pour les opérations revenue. On déploie stratégie, opérations et VirtuoseOS comme une seule couche continue. Sans le théâtre."
  jsonLd={faqPage(faqItems)}
>
  {/* Splash · respiration cinématique 1.1s */}
  <BootSplash client:only="react" lang="fr" />

  <Hero />
  <TrustMarquee />
  <WhyAIStalls />
  <HowWeShip />          {/* 3.5 — comment on adresse le problème · sticky pin signature */}
  <SixServices />
  <Pyramid />            {/* 4.5 — l'architecture 4 paliers qui sous-tend les 6 services */}
  <Manifesto />
  <OperatingLayer />
  <Departments />        {/* 6.5 — pour qui, dans quel métier · 6 cells */}
  <Cases />
  <WritingNotes />
  <Offices />            {/* 8.5 — ancrage géographique Paris-Genève */}
  <FAQ
    items={faqItems}
    heading="Questions qu'on nous pose"
    intro="Sept réponses honnêtes — celles qu'on donne par mail avant le premier rendez-vous."
  />
  <BookSession />
  <SigBand />
</Base>
