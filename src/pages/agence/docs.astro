---
// Page · /agence/docs · Documentation technique publique
// Source : waimia-handoff2 / docs.html
//
// Composé de · TrustLegalTemplate (variant docs technique · sections par domaine)

import TrustLegalTemplate from '../../components/templates/TrustLegalTemplate.astro';
import Bi from '../../components/ui/atoms/Bi.astro';

const sections = [
  { id: 'getting-started', title_fr: 'Démarrage rapide',          title_en: 'Quick start' },
  { id: 'architecture',    title_fr: 'Architecture VirtuoseOS',   title_en: 'VirtuoseOS architecture' },
  { id: 'agents',          title_fr: 'Construire un agent',       title_en: 'Building an agent' },
  { id: 'mcp',             title_fr: 'Connecteurs MCP',           title_en: 'MCP connectors' },
  { id: 'audit',           title_fr: 'Trail audit & re-rejouage', title_en: 'Audit trail & replay' },
  { id: 'self-hosted',     title_fr: 'Self-hosting',              title_en: 'Self-hosting' },
];
---
<TrustLegalTemplate
  title="Documentation technique VirtuoseOS · Waimia"
  description="Documentation publique VirtuoseOS — démarrage, architecture, construction d'agents, MCP, audit trail, self-hosting."
  kickerFr="Documentation · VirtuoseOS v2.4"
  kickerEn="Documentation · VirtuoseOS v2.4"
  revisedAt="2026-04-22"
  version="v2.4.1"
  sections={sections}
>
  <Fragment slot="headline">
    <i>Documentation</i><br />technique.
  </Fragment>
  <Fragment slot="lede">
    La documentation publique de VirtuoseOS. Pour les architectures plus profondes (Annexe IV AI Act, runbooks ops, guidelines équipe), demandez l'accès via votre référent.
  </Fragment>

  <Fragment slot="sections">
    <section id="getting-started">
      <h2><Bi fr={"Démarrage"} en={"Quick"} /> <i><Bi fr="rapide" en="start" /></i></h2>
      <p><Bi fr="VirtuoseOS s'installe en deux modes : managé (Anthropic + zone EU choisie) ou self-hosted (vLLM/Ollama sur votre infra). Le mode managé démarre en 30 minutes avec un agreement DPA signé. Le self-hosted nécessite un cluster Kubernetes 1.28+ et 4 GPU minimum." en="VirtuoseOS installs in two modes: managed (Anthropic + chosen EU zone) or self-hosted (vLLM/Ollama on your infra). Managed mode starts in 30 minutes with a signed DPA. Self-hosted needs a Kubernetes 1.28+ cluster and 4 GPU minimum." /></p>
      <h3><Bi fr={"Pré-requis"} en={"Prerequisites"} /></h3>
      <ul>
        <li><Bi fr="Compte cloud (AWS, GCP, OVH, Scaleway, ou bare-metal)" en="Cloud account (AWS, GCP, OVH, Scaleway, or bare-metal)" /></li>
        <li><Bi fr="Accès admin à votre CRM (HubSpot, Salesforce)" en="Admin access to your CRM (HubSpot, Salesforce)" /></li>
        <li><Bi fr="Entrepôt SQL (dbt + Snowflake/BigQuery/Postgres)" en="SQL warehouse (dbt + Snowflake/BigQuery/Postgres)" /></li>
        <li><Bi fr="Email DPO + référent technique nommés" en="DPO email + named tech lead" /></li>
      </ul>
    </section>

    <section id="architecture">
      <h2><Bi fr={"Architecture"} en={"VirtuoseOS"} /> <i><Bi fr="VirtuoseOS" en="architecture" /></i></h2>
      <p><Bi fr="Kernel multi-workspace · runtime agents · couche données · trail audit · garde-fous · FinOps · locale FR-first. Chaque module est documenté individuellement." en="Multi-workspace kernel · agents runtime · data layer · audit trail · guardrails · FinOps · FR-first locale. Each module is documented individually." /></p>
      <p><a href="/technologies/virtuoseos">Voir la pillar page VirtuoseOS →</a></p>
    </section>

    <section id="agents">
      <h2><Bi fr={"Construire"} en={"Building"} /> <i><Bi fr="un agent" en="an agent" /></i></h2>
      <p><Bi fr="Un agent VirtuoseOS = un descriptor JSON qui déclare : modèle Claude (Opus/Sonnet/Haiku), outils disponibles (MCP), guardrails appliqués, politique de validation humaine, périmètre de données. Le descripteur est généré par notre Module Builder UI ou écrit à la main." en="A VirtuoseOS agent = a JSON descriptor declaring: Claude model (Opus/Sonnet/Haiku), available tools (MCP), applied guardrails, human validation policy, data scope. The descriptor is generated by our Module Builder UI or written by hand." /></p>
    </section>

    <section id="mcp">
      <h2><i><Bi fr={"Connecteurs"} en={"MCP"} /></i> <Bi fr="MCP" en="connectors" /></h2>
      <p><Bi fr="MCP (Model Context Protocol) est le standard ouvert qui connecte un agent à des sources externes. VirtuoseOS supporte les MCP officiels (Stripe, GitHub, Linear, Notion, Slack) et les MCP customs. Tous sont audités côté trail et soumis aux mêmes garde-fous." en="MCP (Model Context Protocol) is the open standard that connects an agent to external sources. VirtuoseOS supports official MCPs (Stripe, GitHub, Linear, Notion, Slack) and custom MCPs. All are audited via the trail and subject to the same guardrails." /></p>
    </section>

    <section id="audit">
      <h2><i><Bi fr={"Trail audit"} en={"Audit trail"} /></i> <Bi fr="& re-rejouage" en="& replay" /></h2>
      <p><Bi fr="Chaque action agent est loggée avec : timestamp, agent ID, prompt input, output, outils invoqués, latence, coût LLM. Le trail est exportable en CSV/JSONL/SIEM. Re-rejouage possible sur n'importe quelle décision passée — utile pour audits ACPR/AI Act." en="Every agent action is logged with: timestamp, agent ID, prompt input, output, invoked tools, latency, LLM cost. The trail is exportable to CSV/JSONL/SIEM. Replay possible on any past decision — useful for ACPR/AI Act audits." /></p>
    </section>

    <section id="self-hosted">
      <h2><i><Bi fr={"Self-hosting"} en={"Self-hosting"} /></i></h2>
      <p><Bi fr="Pour les contraintes ACPR / SecNumCloud / HIPAA, VirtuoseOS s'auto-héberge avec vLLM (modèles open-source : Llama 4, DeepSeek R1, Qwen 3) ou Ollama (dev). Toute la stack reste dans votre datacenter. Aucune donnée sortante. Performances : 80-90 % de Claude Sonnet sur la plupart des cas RevOps." en="For ACPR / SecNumCloud / HIPAA constraints, VirtuoseOS self-hosts with vLLM (open-source models: Llama 4, DeepSeek R1, Qwen 3) or Ollama (dev). The entire stack stays in your datacenter. No outgoing data. Performance: 80-90% of Claude Sonnet on most RevOps cases." /></p>
    </section>
  </Fragment>
</TrustLegalTemplate>
