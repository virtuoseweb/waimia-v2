---
// Section · Silence · une seule citation manifeste, énorme, centrée
// Variant : Typographic breath (padding XL + bold display italic)
// Motion : .reveal-fade
// Mémorable : « Une page entière pour respirer une seule phrase. »

import { langFromPath } from '../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section class="silence reveal-fade" aria-labelledby="silence-quote">
  <blockquote id="silence-quote">
    {lang === 'fr' ? (
      <>
        Nous ne livrons pas <em>des slides</em>.<br />
        Nous livrons des <em>agents qui exécutent</em>.
      </>
    ) : (
      <>
        We don't ship <em>decks</em>.<br />
        We ship <em>agents that execute</em>.
      </>
    )}
  </blockquote>
  <cite>
    {lang === 'fr' ? '— Waimia · Manifeste 2026' : '— Waimia · 2026 Manifesto'}
  </cite>
</section>

<style>
  .silence{padding:clamp(110px,18vw,260px) var(--gut);text-align:center;background:var(--paper);border-bottom:1px solid var(--hairline)}
  .silence blockquote{font-family:var(--font-display);font-style:italic;font-size:clamp(36px,5.5vw,84px);line-height:1.12;letter-spacing:-0.02em;color:var(--ink);max-width:1100px;margin:0 auto;text-wrap:balance;font-weight:400}
  .silence blockquote em{color:var(--accent);font-style:italic}
  .silence cite{display:block;margin-top:32px;font-family:var(--font-mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);font-style:normal}
</style>
