---
// Section · Thesis dark · respiration éditoriale fond ink
// Variant : .clip-up sur h2 + .row-lines sur grille 3 col
// Motion : clip-path reveal sur h2 (1×/page max), staggered row-lines sur la grille
// Mémorable : « Le moment où le manifeste s'imprime en blanc sur noir. »

import { langFromPath } from '../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section class="thesis on-dark" aria-labelledby="thesis-h2">
  <div class="signature-grid on-dark"></div>
  <div class="frame">
    <div class="mono">
      {lang === 'fr' ? '§ Acte I — Notre thèse' : '§ Act I — Our thesis'}
    </div>

    <h2 id="thesis-h2" class="clip-up">
      {lang === 'fr' ? (
        <>
          Une bonne agence Claude n'est pas un consultant.<br />
          C'est un <em>opérateur</em> qui livre, mesure, gouverne.
        </>
      ) : (
        <>
          A good Claude agency is not a consultant.<br />
          It's an <em>operator</em> that ships, measures, governs.
        </>
      )}
    </h2>

    <div class="thesis-grid row-lines">
      <div>
        <div class="fig">§ 01</div>
        <h4>{lang === 'fr' ? 'Process avant modèle' : 'Process before model'}</h4>
        <p class="drop-cap">
          {lang === 'fr'
            ? 'On cartographie vos SOPs avant de choisir Opus, Sonnet ou Haiku. Le modèle suit le besoin. Pas l\'inverse.'
            : "We map your SOPs before picking Opus, Sonnet or Haiku. The model serves the workflow — not the other way around."}
        </p>
      </div>
      <div>
        <div class="fig">§ 02</div>
        <h4>{lang === 'fr' ? 'Trace auditable' : 'Audit trail by default'}</h4>
        <p>
          {lang === 'fr'
            ? 'Chaque action d\'agent est signée, exportable, réversible. AI Act Art. 12. RGPD. LPD. Compliance n\'est pas une option.'
            : 'Every agent action is signed, exportable, reversible. AI Act Art. 12. GDPR. LPD. Compliance is not optional.'}
        </p>
      </div>
      <div>
        <div class="fig">§ 03</div>
        <h4>{lang === 'fr' ? 'Souveraineté quand il faut' : 'Sovereignty on demand'}</h4>
        <p>
          {lang === 'fr'
            ? 'Claude managé par défaut. Self-hosted (vLLM, Ollama, modèles open-source) quand la donnée l\'exige. Le choix vient de votre contrainte, pas de notre catalogue.'
            : 'Managed Claude by default. Self-hosted (vLLM, Ollama, open-source models) when data demands it. Your constraint drives the choice — not our catalogue.'}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .thesis{padding:clamp(120px,16vw,280px) var(--gut);background:var(--ink);color:var(--paper);position:relative;overflow:hidden}
  .thesis .frame{max-width:var(--wrap-wide);margin:0 auto;position:relative;z-index:1}
  .thesis .mono{font-family:var(--font-mono);font-size:11px;letter-spacing:.2em;color:rgba(246,241,232,.42);text-transform:uppercase;margin-bottom:clamp(20px,2.5vw,40px);display:flex;align-items:center;gap:14px}
  .thesis .mono::before{content:"";width:40px;height:1px;background:var(--accent);display:inline-block;flex-shrink:0}
  .thesis h2{font-family:var(--font-display);font-size:clamp(38px,8vw,140px);line-height:.98;letter-spacing:-0.028em;text-wrap:balance;font-weight:400;max-width:min(1200px,100%)}
  .thesis h2 em{font-style:italic;color:var(--accent)}
  .thesis-grid{margin-top:clamp(56px,7vw,112px);display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-top:1px solid rgba(246,241,232,.12)}
  .thesis-grid > div{padding:clamp(28px,3.5vw,48px) clamp(22px,2.8vw,38px);border-right:1px solid rgba(246,241,232,.10)}
  .thesis-grid > div:last-child{border-right:none}
  .thesis-grid .fig{color:rgba(246,241,232,.38)}
  .thesis-grid h4{font-family:var(--font-display);font-size:clamp(20px,2.2vw,30px);line-height:1.15;letter-spacing:-0.014em;margin-top:16px;text-wrap:balance;font-weight:400;color:var(--paper)}
  .thesis-grid p{font-size:clamp(13px,1.22vw,15px);line-height:1.65;color:rgba(246,241,232,.78);margin-top:14px;text-wrap:pretty}
  .thesis-grid p.drop-cap::first-letter{color:var(--accent);opacity:1;font-family:var(--font-display);font-size:2.4em;line-height:1;float:left;padding:.04em .1em 0 0;font-weight:400}

  @media (max-width:900px){
    .thesis-grid{grid-template-columns:1fr}
    .thesis-grid > div{border-right:none;border-bottom:1px solid rgba(246,241,232,.12)}
  }
</style>
