---
// Section · SigBand · vibration finale du wordmark
// Variant : Wordmark XL clip-up
// Motion : .clip-up (1×/page max sur les sections où on veut un climax visuel)
// Note : on garde le clip-up uniquement ici car c'est le moment final de la page
// Mémorable : « La marque vibre une dernière fois avant qu'on parte. »
---
<section class="sig-band">
  <div class="wm clip-up">
    Waim<i>i</i>a<span class="dot">.</span>
  </div>
</section>

<style>
  .sig-band{padding:clamp(28px,4vw,60px) var(--gut) clamp(72px,9vw,140px);overflow:hidden;position:relative}
  .sig-band .wm{font-family:var(--font-display);font-size:clamp(80px,22vw,380px);line-height:.82;letter-spacing:-0.036em;font-weight:400;position:relative;text-align:center}
  .sig-band .wm i{font-style:italic}
  .sig-band .wm .dot{color:var(--accent)}
</style>
