---
// Atome · Bi · primitive bilingue côté serveur
// Choisit la chaîne EN/FR selon la langue de la page Astro courante.
// Indivisible : un seul rôle (text en/fr) sans composition d'autres atomes.
import { langFromPath } from '../../../lib/i18n';

interface Props {
  en: string;
  fr: string;
}
const { en, fr } = Astro.props;
const lang = langFromPath(Astro.url.pathname);
---
{lang === 'en' ? en : fr}
