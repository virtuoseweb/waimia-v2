---
// Molécule · ProcessSteps · grille N steps numérotés
//
// Pattern récurrent (≥ 4 occurrences) :
// - offres/detail.html : 4 étapes process (sn + sk + h3 + p)
// - hub-consulting.html : 7 services rows (variante ServiceCatalogRow)
// - service-revops.html : 4 phases
// - case-plateau.html : 4 steps approach
//
// Composé de · Bi (atom) pour bilingue.
//
// API :
//   <ProcessSteps steps={[
//     { sn: '01', kicker_fr: 'Constat', kicker_en: 'Diagnose',
//       title_fr: '...', title_en: '...',
//       body_fr: '...', body_en: '...' },
//   ]} />

import Bi from '../atoms/Bi.astro';

interface Step {
  sn: string;
  kicker_fr: string;
  kicker_en: string;
  title_fr: string;
  title_en: string;
  body_fr: string;
  body_en: string;
}
interface Props {
  steps: Step[];
  class?: string;
}
const { steps, class: extraClass = '' } = Astro.props;
---
<div class={`steps ${extraClass}`.trim()}>
  {steps.map((s) => (
    <article class="step">
      <div class="step-sn">{s.sn}</div>
      <div class="step-sk"><Bi fr={s.kicker_fr} en={s.kicker_en} /></div>
      <h3 class="step-title"><Bi fr={s.title_fr} en={s.title_en} /></h3>
      <p class="step-body"><Bi fr={s.body_fr} en={s.body_en} /></p>
    </article>
  ))}
</div>

<style>
  .steps {
    display: grid;
    grid-template-columns: repeat(var(--cols, 4), 1fr);
    border: 1px solid var(--hairline-strong);
  }
  .step {
    padding: clamp(24px, 3vw, 40px) clamp(20px, 2.5vw, 32px);
    border-right: 1px solid var(--hairline);
    display: flex;
    flex-direction: column;
    min-height: clamp(260px, 22vw, 360px);
    transition: background 220ms var(--ease);
  }
  .step:last-child {
    border-right: none;
  }
  .step:hover {
    background: var(--paper-2);
  }
  .step-sn {
    font-family: var(--font-display);
    font-size: clamp(52px, 7vw, 96px);
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: var(--accent);
    font-weight: 400;
    opacity: 0.25;
  }
  .step-sk {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 12px;
  }
  .step-title {
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 26px);
    line-height: 1.1;
    letter-spacing: -0.013em;
    font-weight: 400;
    margin-top: 6px;
    text-wrap: balance;
  }
  .step-body {
    font-size: 12.5px;
    color: var(--muted);
    line-height: 1.55;
    text-wrap: pretty;
    margin-top: 10px;
    flex: 1;
  }
  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
    }
    .step:nth-child(2n) {
      border-right: none;
    }
    .step:nth-child(-n + 2) {
      border-bottom: 1px solid var(--hairline);
    }
  }
  @media (max-width: 600px) {
    .steps {
      grid-template-columns: 1fr;
    }
    .step {
      border-right: none;
      border-bottom: 1px solid var(--hairline);
    }
    .step:last-child {
      border-bottom: none;
    }
  }
</style>
