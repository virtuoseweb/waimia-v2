---
// Molécule · CalEmbed · Cal.com booking widget
//
// 3 layouts officiels Cal.com :
//  - inline       · iframe pleine largeur intégrée dans la page
//  - floating-popup · bouton flottant ancré (bottom-right)
//  - element-click  · transforme un lien existant en trigger popup
//
// Réutilisable sur :
//  - /contact (inline) · plein widget de booking
//  - /offres/conseil et hubs (floating-popup) · CTA permanent
//  - liens textuels « Prendre RDV » (element-click) · partout
//
// Documentation : https://cal.com/docs/embed
//
// Note · Cal.com SaaS recommandé pour démarrer (slug `waimia/45min` actif).
// Cal.diy MIT self-hosted possible plus tard pour souveraineté.

interface Props {
  /** Slug Cal.com (default: env PUBLIC_CAL_USERNAME) */
  username?: string;
  /** Event type slug (default: env PUBLIC_CAL_EVENT_TYPE) */
  eventType?: string;
  /** Layout · inline (défaut) / floating-popup / element-click */
  layout?: 'inline' | 'floating-popup' | 'element-click';
  /** Pour element-click : sélecteur CSS du lien à transformer (ex: '[data-cal]') */
  trigger?: string;
  /** Pour floating-popup : label du bouton flottant */
  buttonText?: string;
  /** Theme · auto/light/dark */
  theme?: 'auto' | 'light' | 'dark';
  /** ID élément container (default 'cal-embed') */
  id?: string;
}

const {
  username = import.meta.env.PUBLIC_CAL_USERNAME ?? 'waimia',
  eventType = import.meta.env.PUBLIC_CAL_EVENT_TYPE ?? '45min',
  layout = 'inline',
  trigger = '[data-cal]',
  buttonText = 'Réserver 45 min',
  theme = 'light',
  id = 'cal-embed',
} = Astro.props as Props;

const calLink = `${username}/${eventType}`;
---
{layout === 'inline' && (
  <div id={id} class="cal-inline" style="min-height:600px;width:100%"></div>
)}

{/* Le script Cal embed officiel · injecté une seule fois par page */}
<script
  is:inline
  define:vars={{ calLink, layout, trigger, buttonText, theme, id }}
>
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement('script')).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === 'string') {
          cal.ns[namespace] = cal.ns[namespace] || api;
          p(cal.ns[namespace], ar);
          p(cal, ['initNamespace', namespace]);
        } else p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window, 'https://app.cal.com/embed/embed.js', 'init');

  Cal('init', { origin: 'https://app.cal.com' });

  if (layout === 'inline') {
    Cal('inline', {
      elementOrSelector: '#' + id,
      calLink,
      layout: 'month_view',
      config: { theme },
    });
  } else if (layout === 'floating-popup') {
    Cal('floatingButton', {
      calLink,
      config: { theme },
      buttonText,
      buttonColor: '#C94F2E',
      buttonTextColor: '#F6F1E8',
    });
  } else if (layout === 'element-click') {
    Cal('on', {
      action: 'linkReady',
      callback: () => {
        document.querySelectorAll(trigger).forEach((el) => {
          el.setAttribute('data-cal-link', calLink);
          el.setAttribute('data-cal-config', JSON.stringify({ theme }));
        });
      },
    });
    Cal('ui', { theme, hideEventTypeDetails: false });
  }
</script>

<style>
  .cal-inline {
    border: 1px solid var(--hairline-strong);
    border-radius: 12px;
    overflow: hidden;
    background: var(--paper);
  }
</style>
