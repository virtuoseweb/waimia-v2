---
// Stub · placeholder éditorial pour pages en cours de rédaction
// Garde le DS, la dignité, et permet de naviguer le site sans 404 jaloux.

import { langFromPath, localizeHref } from '../../../lib/i18n';

interface Props {
  kicker_fr: string;
  kicker_en: string;
  title_fr: string;
  title_en: string;
  body_fr: string;
  body_en: string;
}

const { kicker_fr, kicker_en, title_fr, title_en, body_fr, body_en } = Astro.props;
const lang = langFromPath(Astro.url.pathname);
---
<section class="sec" style="min-height:80vh;display:flex;align-items:center">
  <div class="signature-grid"></div>
  <div class="wrap" style="position:relative;z-index:1">
    <div class="kicker" style="margin-bottom:24px">
      {lang === 'fr' ? kicker_fr : kicker_en}
    </div>
    <h1 style="font-family:var(--font-display);font-size:clamp(48px,9vw,140px);line-height:.94;letter-spacing:-0.028em;font-weight:400;text-wrap:balance">
      {lang === 'fr' ? title_fr : title_en}
    </h1>
    <p style="font-family:var(--font-display);font-style:italic;font-size:clamp(20px,2.2vw,32px);color:var(--muted);margin-top:32px;max-width:780px;line-height:1.4;text-wrap:pretty">
      {lang === 'fr' ? body_fr : body_en}
    </p>
    <div style="margin-top:48px;display:flex;gap:12px;flex-wrap:wrap">
      <a href={localizeHref('/contact', lang)} class="btn btn-primary btn-lg" data-mag="0.18">
        {lang === 'fr' ? 'Réserver un audit' : 'Book an audit'} <span aria-hidden>→</span>
      </a>
      <a href={localizeHref('/', lang)} class="btn btn-ghost btn-lg">
        {lang === 'fr' ? "← Retour à l'accueil" : '← Back to home'}
      </a>
    </div>
    <div style="margin-top:80px;padding:18px 22px;border:1px dashed var(--hairline-strong);border-radius:8px;background:var(--paper-2);font-family:var(--font-mono);font-size:11px;letter-spacing:.06em;color:var(--muted);max-width:640px">
      <span style="color:var(--accent)">◉</span> {lang === 'fr' ? "Page en cours de rédaction. Le contenu sera publié via le CMS Pages CMS — pas de redéploiement nécessaire." : 'Page is being written. Content will be published via Pages CMS — no redeployment needed.'}
    </div>
  </div>
</section>
