---
// Section · Pyramide 4 tiers · pyra des offres
// Variant : ec-grid cols-4 d'editorial-cell + .scale-in
// Motion : .scale-in stagger sur cards + .lift hover
// Mémorable : « Quatre paliers, lus comme un escalier vers la souveraineté. »
//
// Composé de · SectionHeader (refactor atomic-components 2026-04-26)

import SectionHeader from '../molecules/SectionHeader.astro';
import { PYRAMID_TIERS } from '../../../data/sitemap';
import { langFromPath, t } from '../../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
---
<section class="sec sec-paper" aria-labelledby="pyramid-h2">
  <div class="wrap-wide">
    <SectionHeader
      roman="II"
      label={lang === 'fr' ? "Acte II — La pyramide d'engagements" : 'Act II — The engagement pyramid'}
      id="pyramid-h2"
    >
      <Fragment slot="heading">
        {lang === 'fr' ? (
          <>Quatre <i>paliers</i>, une seule architecture continue.</>
        ) : (
          <>Four <i>tiers</i>, one continuous architecture.</>
        )}
      </Fragment>
      <Fragment slot="aside">
        {lang === 'fr'
          ? "Du diagnostic process à l'infrastructure souveraine — chaque palier prépare le suivant. Vous montez quand vous êtes prêt."
          : "From process diagnostic to sovereign infrastructure — each tier sets up the next. You climb when you're ready."}
      </Fragment>
    </SectionHeader>

    <div class="ec-grid cols-4 reveal-stagger">
      {PYRAMID_TIERS.map((tier) => (
        <a class="editorial-cell lift" href={tier.href}>
          <span class="e-num">{tier.n}</span>
          <span class="e-tag">{t(tier.tag, lang)}</span>
          <h3 class="e-title">{t(tier.label, lang)}</h3>
          <p class="e-body">{t(tier.lead, lang)}</p>
          <ul class="e-list">
            {tier.items.map((it) => <li>{it}</li>)}
          </ul>
          <span class="e-go">{lang === 'fr' ? 'Voir le palier →' : 'Open tier →'}</span>
        </a>
      ))}
    </div>
  </div>
</section>
