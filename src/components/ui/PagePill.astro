---
// PagePill · tab flottant bottom-left · point d'ancrage éditorial + lien vers /atlas
// Refonte v2 · pattern Slots Astro :
//   — Astro rend tout le contenu visible (Vol. 03 · Manifeste · lien /atlas) en HTML pur
//     → indexable instantanément par GPTBot, ClaudeBot, Google-Extended sans exécution JS
//   — PagePillIsland (React, client:visible) ne gère que les états .is-visible
//     (apparition après 220 px de scroll · masquage proche du footer)
//
// Cf docs/04-motion-system.md

import PagePillIsland from './PagePillIsland.tsx';
import { langFromPath, localizeHref } from '../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
const isAtlas = Astro.url.pathname.includes('/atlas');
const target = isAtlas ? localizeHref('/', lang) : localizeHref('/atlas', lang);
const targetLabel = isAtlas
  ? (lang === 'fr' ? "Voir l'accueil" : 'See the home')
  : (lang === 'fr' ? "Voir l'atlas" : 'See the atlas');
---
{/* Tout le contenu ci-dessous est rendu par Astro côté serveur · React ne wrap que les états. */}
<PagePillIsland client:visible>
  <span>Vol. 03</span>
  <span style="opacity:.4">·</span>
  <span>{lang === 'fr' ? 'Manifeste 2026' : '2026 Manifesto'}</span>
  <span style="opacity:.4">·</span>
  <a href={target} aria-label={targetLabel}>{targetLabel} →</a>
</PagePillIsland>

{/* Styles dans src/styles/global.css (.page-pill · .page-pill.is-visible)
    pour éviter le scoping Astro qui empêche le React island de matcher .is-visible. */}
