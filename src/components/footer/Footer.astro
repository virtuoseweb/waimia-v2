---
// Footer · 5 colonnes éditoriales · pur Astro (pas d'interactivité)
import { FOOTER_COLS, TRUST_BADGES } from '../../data/sitemap';
import { langFromPath, t } from '../../lib/i18n';

const lang = langFromPath(Astro.url.pathname);
// `year` est résolu au build (SSG). En cas de site non rebuilt en début d'année,
// le copyright reste figé. Atténuation : Vercel cron annuel ou simplement push
// d'un commit start-of-year. À défaut, accepter le glissement (faible criticité).
const year = new Date().getFullYear();
---
<footer class="ft" aria-labelledby="ft-heading">
  <h2 id="ft-heading" class="sr-only">
    {lang === 'fr' ? 'Pied de page' : 'Footer'}
  </h2>

  {/* Top — wordmark vibration */}
  <div class="wrap" style="padding-top:clamp(80px,10vw,160px);padding-bottom:clamp(40px,5vw,80px)">
    <div style="font-family:var(--font-display);font-size:clamp(60px,12vw,200px);line-height:.88;letter-spacing:-0.03em;font-weight:400;color:var(--ink)">
      Waim<i style="font-style:italic;color:var(--accent)">i</i>a<span style="color:var(--accent)">.</span>
    </div>
    <p style="font-family:var(--font-display);font-style:italic;font-size:clamp(20px,2vw,28px);color:var(--muted);max-width:640px;margin-top:clamp(16px,2vw,32px);line-height:1.4;text-wrap:balance">
      {lang === 'fr'
        ? 'Architectes de systèmes agentiques. Experts Claude. Paris · Genève.'
        : 'Architects of agentic systems. Claude experts. Paris · Geneva.'}
    </p>
  </div>

  {/* Trust badges row */}
  <div class="wrap" style="padding-bottom:clamp(40px,4vw,60px)">
    <div class="trust-row">
      {TRUST_BADGES.map((b) => (
        <span class={`trust-pill ${b.kind}`}>
          <span class="dot"></span>
          {t(b.label, lang)}
        </span>
      ))}
    </div>
  </div>

  {/* Tier 1 — 5 colonnes */}
  <div class="wrap hline" style="padding-top:clamp(40px,4vw,60px);padding-bottom:clamp(60px,6vw,100px)">
    <div class="ft-tier1-grid" style="display:grid;grid-template-columns:repeat(5,1fr);gap:clamp(24px,3vw,48px)">
      {FOOTER_COLS.map((col) => (
        <div>
          <h3 style="font-family:var(--font-mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);margin-bottom:18px;font-weight:500">
            {t(col.heading, lang)}
          </h3>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:10px">
            {col.items.map((it) => (
              <li>
                <a href={it.href} style="font-size:13.5px;color:var(--ink-2);transition:color 220ms var(--ease);display:inline-block;line-height:1.4" class="ft-link">
                  {t(it.label, lang)}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  {/* Bottom — copyright + socials */}
  <div class="wrap hline" style="padding:24px 0;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;font-family:var(--font-mono);font-size:11px;letter-spacing:.08em;color:var(--muted)">
    <span>© {year} Waimia · {lang === 'fr' ? 'Partenaire Intégrateur IA' : 'AI Integration Partner'}</span>
    <div style="display:flex;gap:18px">
      <a href="https://www.linkedin.com/company/waimia" target="_blank" rel="noopener" class="ft-link">LinkedIn</a>
      <a href="https://x.com/waimia_ai" target="_blank" rel="noopener" class="ft-link">X</a>
      <a href="https://www.youtube.com/@waimia" target="_blank" rel="noopener" class="ft-link">YouTube</a>
    </div>
  </div>
</footer>

<style>
  .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
  .ft-link{transition:color 220ms var(--ease)}
  .ft-link:hover{color:var(--accent)}
  @media (max-width:900px){
    .ft-tier1-grid{grid-template-columns:repeat(2,1fr)!important}
  }
  @media (max-width:640px){
    .ft-tier1-grid{grid-template-columns:1fr!important;gap:32px!important}
  }
</style>
